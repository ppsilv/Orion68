04:00001460 4841            	  1334: 	SWAP	D1		D1 is finally high/low
04:00001462 4840            	  1335: TOASCII SWAP	D0		get remainder
04:00001464 1F00            	  1336: 	MOVE.B	D0,-(SP)	stack it as a digit
04:00001466 4840            	  1337: 	SWAP	D0
04:00001468 5344            	  1338: 	SUBQ	#1,D4		decrement width count
04:0000146A 4A81            	  1339: 	TST.L	D1		if quotient is zero, we're done
04:0000146C 66CA            	  1340: 	BNE	PN1
