                            	    27: REG_13         equ $FF8025        ;;Endereço real 37 0x25  o pico enxerga 0x12
                            	    28: SET_MODE       equ $FF8027        ;;Endereço real 39 0x27  o pico enxerga 0x13 (0=Texto+Scroll, 1=Texto Fixo, 2=320x20
                            	    29: SET_TXT_COLOR  equ $FF8029        ;;Endereço real 41 0x29  o pico enxerga 0x14
