                            	     6: ; -----------------------------------------------------------------------------
                            	     7: ; O SEU CÓDIGO DO PDS317 (Agora rodando na RAM)
                            	     8: ; -----------------------------------------------------------------------------
                            	     9: 
                            	    10: ; --------------------------------
                            	    11: ; TRAP_CCONIN - Ler caractere do console
                            	    12: ; Saída: D0.L - Caractere lido
                            	    13: ; --------------------------------
                            	    14: trap_cconin:
04:000002E4 2F0A            	    15:     MOVE.L A2,-(SP)
04:000002E6 247900080418    	    16:     MOVE.L  (cconin),A2
04:000002EC 4E92            	    17:     JSR     (A2)
04:000002EE 245F            	    18:     MOVE.L (SP)+,A2
04:000002F0 0280000000FF    	    19:     ANDI.L  #$FF,D0       ; Mantém apenas o byte inferior
04:000002F6 4E73            	    20:     RTE                   ; Retorna da exceção
                            	    21: 
                            	    22: ; --------------------------------
                            	    23: ; TRAP_CCONOUT - Escrever caractere no console
                            	    24: ; Entrada: D1.L - Caractere a escrever
                            	    25: ; --------------------------------
                            	    26: trap_cconout:
04:000002F8 2F0A            	    27:     MOVE.L A2,-(SP)
04:000002FA 1001            	    28:     MOVE.B  D1,D0
04:000002FC 247900080414    	    29:     MOVE.L  (cconout),A2        ; Busca o endereço da rotina física da UART
04:00000302 4E92            	    30:     JSR     (A2)
04:00000304 245F            	    31:     MOVE.L (SP)+,A2
04:00000306 4E73            	    32:     RTE      
                            	    33:                 
                            	    34: 
                            	    35: trap_strout:
04:00000308 2049            	    36:     MOVE.L  A1,A0
04:0000030A 4EB9000001F8    	    37:     JSR     WriteStringConout
04:00000310 4E73            	    38:     RTE
                            	    39: 
                            	    40: 
                            	    41: ; --------------------------------
                            	    42: ; TRAP_PTERM0 - Terminar programa
                            	    43: ; --------------------------------
                            	    44: trap_pterm0:
04:00000312 303C0000        	    45:     move.w  #0,d0         ; Código de saída 0
04:00000316 6102            	    46:     bsr     hardware_exit ; Chama rotina de término
04:00000318 4E73            	    47:     RTE     
                            	    48: 
                            	    49: ; --------------------------------
                            	    50: ; hardware_exit - Terminar execução
                            	    51: ; Entrada: D0.W - Código de saída
                            	    52: ; --------------------------------
                            	    53: hardware_exit:
                            	    54:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    55:     ; Exemplo: parar o processador
                            	    56:     ; stop    #$2700
                            	    57: 
                            	    58:     ; Exemplo simples: loop infinito
04:0000031A 60FE            	    59:     BRA     hardware_exit
04:0000031C 4E75            	    60:     RTS
                            	    61: 
                            	    62: InitTrap1:
                            	    63:     ; -------------------------------------------------------------------------
                            	    64:     ; COMO INSTALAR NA RAM:
                            	    65:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	    66:     ; -------------------------------------------------------------------------
                            	    67:     ;LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
                            	    68:     ;MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
04:0000031E 4E75            	    69:     RTS
                            	    70:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    71: 

