04:000014B8 225F            	  1376: 	MOVE.L	(SP)+,A1	get the return address
04:000014BA 1219            	  1377: 	MOVE.B	(A1)+,D1	get the byte to compare
04:000014BC B210            	  1378: 	CMP.B	(A0),D1 	is it = to what A0 points to?
04:000014BE 6708            	  1379: 	BEQ	TC1		if so
04:000014C0 7200            	  1380: 	CLR.L	D1		If not, add the second
04:000014C2 1211            	  1381: 	MOVE.B	(A1),D1 	byte following the call to
04:000014C4 D3C1            	  1382: 	ADD.L	D1,A1		the return address.
04:000014C6 4ED1            	  1383: 	JMP	(A1)		jump to the routine
04:000014C8 5288            	  1384: TC1	ADDQ.L	#1,A0		if equal, bump text pointer
04:000014CA 5289            	  1385: 	ADDQ.L	#1,A1		Skip the 2 bytes following
