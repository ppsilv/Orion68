Source: "cmd/xmodem.asm"
                            	     1: 
                            	     2: ;=== Uart receiver ================= CONSTANTES =================
                            	     3: SOH         EQU     $01        ; Start Of Header
                            	     4: EOT         EQU     $04        ; End Of Transmission
                            	     5: ACK         EQU     $06        ; Acknowledge
                            	     6: NACK        EQU     $15        ; Negative Acknowledge
                            	     7: CAN         EQU     $18        ; Cancel
                            	     8: 
                            	     9: XmodemRec:
                            	    10:         RESET_FLAG    PROGRAM_LOADED,flg_system
04:0000092C 0279000000080A5A	     1M             and.w   #PROGRAM_LOADED,flg_system
04:00000934 47F900082000    	    11:         LEA     buf_pgm,A3
04:0000093A 7A00            	    12:         clr.l     D5
04:0000093C 4EB900000300    	    13:         JSR     UartFlush
04:00000942 103C0015        	    14:         MOVE.B  #NACK,D0
04:00000946 4EB9000002D0    	    15:         JSR     UartWriteChar
                            	    16:         ;MOVE.B  #13,D0
                            	    17:         ;JSR     WriteConout      
                            	    18:         ;MOVE.B  #10,D0
                            	    19:         ;JSR     WriteConout      
                            	    20: .receivePacote:
04:0000094C 4EB9000001CE    	    21:         JSR     ReadConin
04:00000952 B03C0004        	    22:         CMP.B   #EOT,D0
04:00000956 675A            	    23:         BEQ     .Transfer_Complete   ; Fim da transmissão          
                            	    24:         ;JSR     PrintByteHexConout      
04:00000958 4EB9000001CE    	    25:         JSR     ReadConin
                            	    26:         ;JSR     PrintByteHexConout      
04:0000095E 4EB9000001CE    	    27:         JSR     ReadConin
                            	    28:         ;JSR     PrintByteHexConout         
04:00000964 323C007F        	    29:         MOVE.W  #$7F,D1
04:00000968 43F900080448    	    30:         LEA     buf_xmodem,A1
                            	    31: .centoEvinteOito:
04:0000096E 4EB9000001CE    	    32:         JSR     ReadConin
04:00000974 DA40            	    33:         add     D0,D5
04:00000976 12C0            	    34:         MOVE.B  D0,(A1)+                
                            	    35:         ;JSR     PrintByteHexConout      
04:00000978 51C9FFF4        	    36:         dbra    d1,.centoEvinteOito
                            	    37:         ;Aguardando check sum
04:0000097C 4EB9000001CE    	    38:         JSR     ReadConin
                            	    39: 
