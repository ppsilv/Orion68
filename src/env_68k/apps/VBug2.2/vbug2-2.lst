                            	   251: *
                            	   252: *******************************************************************
                            	   253: *
                            	   254: * What follows is the code to execute direct and statement
                            	   255: * commands. Control is transferred to these points via the command
                            	   256: * table lookup code of 'DIRECT' and 'EXEC' in the last section.
                            	   257: * After the command is executed, control is transferred to other
                            	   258: * sections as follows:
                            	   259: *
                            	   260: * For 'LIST', 'NEW', and 'STOP': go back to the warm start point.
                            	   261: * For 'RUN': go execute the first stored line if any; else go
                            	   262: * back to the warm start point.
                            	   263: * For 'GOTO' and 'GOSUB': go execute the target line.
                            	   264: * For 'RETURN' and 'NEXT'; go back to saved return line.
                            	   265: * For all others: if 'CURRNT' is 0, go to warm start; else go
                            	   266: * execute next command. (This is done in 'FINISH'.)
                            	   267: *
                            	   268: *******************************************************************
                            	   269: *
                            	   270: * *** NEW *** STOP *** RUN (& friends) *** GOTO ***
                            	   271: *
                            	   272: * 'NEW<CR>' sets TXTUNF to point to TXTBGN
                            	   273: *
                            	   274: * 'STOP<CR>' goes back to WSTART
                            	   275: *
                            	   276: * 'RUN<CR>' finds the first stored line, stores its address
                            	   277: * in CURRNT, and starts executing it. Note that only those
                            	   278: * commands in TAB2 are legal for a stored program.
                            	   279: *
                            	   280: * There are 3 more entries in 'RUN':
                            	   281: * 'RUNNXL' finds next line, stores it's address and executes it.
                            	   282: * 'RUNTSL' stores the address of this line and executes it.
                            	   283: * 'RUNSML' continues the execution on same line.
                            	   284: *
                            	   285: * 'GOTO expr<CR>' evaluates the expression, finds the target
                            	   286: * line, and jumps to 'RUNTSL' to do it.
                            	   287: *
04:00000BFA 6100062E        	   288: NEW	JSR	ENDCHK
04:00000BFE 23FAFE1600080AC6	   289: 	MOVE.L	TXTBGN,TXTUNF	set the end pointer
                            	   290: 
04:00000C06 61000622        	   291: STOP	JSR	ENDCHK
04:00000C0A 6000FE44        	   292: 	BRA	WSTART
                            	   293: 
04:00000C0E 6100061A        	   294: RUN	JSR	ENDCHK
04:00000C12 207AFE02        	   295: 	MOVE.L	TXTBGN,A0	set pointer to beginning
04:00000C16 23C800080AA6    	   296: 	MOVE.L	A0,CURRNT
                            	   297: 
04:00000C1C 4AB900080AA6    	   298: RUNNXL	TST.L	CURRNT		executing a program?
04:00000C22 6700FE2C        	   299: 	BEQ.W	WSTART		if not, we've finished a direct stat.
04:00000C26 7200            	   300: 	CLR.L	D1		else find the next line number
04:00000C28 2248            	   301: 	MOVE.L	A0,A1
04:00000C2A 61000716        	   302: 	JSR	FNDLNP
04:00000C2E 6500FE20        	   303: 	BCS	WSTART		if we've fallen off the end, stop
                            	   304: 
04:00000C32 23C900080AA6    	   305: RUNTSL	MOVE.L	A1,CURRNT	set CURRNT to point to the line no.
04:00000C38 2049            	   306: 	MOVE.L	A1,A0		set the text pointer to
04:00000C3A 5488            	   307: 	ADDQ.L	#2,A0		the start of the line text
                            	   308: 
04:00000C3C 6100091E        	   309: RUNSML	JSR	CHKIO		see if a control-C was pressed
04:00000C40 43FAFED2        	   310: 	LEA	TAB2,A1 	find command in TAB2
04:00000C44 45FAFF32        	   311: 	LEA	TAB2_1,A2
04:00000C48 6000FF74        	   312: 	BRA	EXEC		and execute it
                            	   313: 
04:00000C4C 61000390        	   314: GOTO	JSR	EXPR		evaluate the following expression
04:00000C50 610005D8        	   315: 	JSR	ENDCHK		must find end of line
04:00000C54 2200            	   316: 	MOVE.L	D0,D1
04:00000C56 610006DC        	   317: 	JSR	FNDLN		find the target line
04:00000C5A 6600062A        	   318: 	BNE.W	QHOW		no such line no.
04:00000C5E 60D2            	   319: 	BRA	RUNTSL		go do it
                            	   320: 
                            	   321: *
                            	   322: *******************************************************************
                            	   323: *
                            	   324: * *** LIST *** PRINT ***
                            	   325: *
                            	   326: * LIST has two forms:
                            	   327: * 'LIST<CR>' lists all saved lines
                            	   328: * 'LIST #<CR>' starts listing at the line #
                            	   329: * Control-S pauses the listing, control-C stops it.
                            	   330: *
                            	   331: * PRINT command is 'PRINT ....:' or 'PRINT ....<CR>'
                            	   332: * where '....' is a list of expressions, formats, back-arrows,
                            	   333: * and strings.	These items a separated by commas.
                            	   334: *
                            	   335: * A format is a pound sign followed by a number.  It controls
                            	   336: * the number of spaces the value of an expression is going to
                            	   337: * be printed in.  It stays effective for the rest of the print
                            	   338: * command unless changed by another format.  If no format is
                            	   339: * specified, 11 positions will be used.
                            	   340: *
                            	   341: * A string is quoted in a pair of single- or double-quotes.
                            	   342: *
                            	   343: * An underline (back-arrow) means generate a <CR> without a <LF>
                            	   344: *
                            	   345: * A <CR LF> is generated after the entire list has been printed
                            	   346: * or if the list is empty.  If the list ends with a semicolon,
                            	   347: * however, no <CR LF> is generated.
                            	   348: *
                            	   349: 
04:00000C60 6100086C        	   350: LIST	JSR	TSTNUM		see if there's a line no.
04:00000C64 610005C4        	   351: 	JSR	ENDCHK		if not, we get a zero
04:00000C68 610006CA        	   352: 	JSR	FNDLN		find this or next line
04:00000C6C 6500FDE2        	   353: LS1	BCS	WSTART		warm start if we passed the end
04:00000C70 6100082A        	   354: 	JSR	PRTLN		print the line
04:00000C74 610008E6        	   355: 	JSR	CHKIO		check for listing halt request
04:00000C78 670C            	   356: 	BEQ	LS3
04:00000C7A B03C0013        	   357: 	CMP.B	#CTRLS,D0	pause the listing?
04:00000C7E 6606            	   358: 	BNE	LS3
04:00000C80 610008DA        	   359: LS2	JSR	CHKIO		if so, wait for another keypress
04:00000C84 67FA            	   360: 	BEQ	LS2
04:00000C86 610006BA        	   361: LS3	JSR	FNDLNP		find the next line
04:00000C8A 60E0            	   362: 	BRA	LS1
                            	   363: 
04:00000C8C 383C000B        	   364: PRINT	MOVE	#11,D4		D4 = number of print spaces
04:00000C90 61000824        	   365: 	JSR	TSTC		if null list and ":"
04:00000C94 3A              	   366: 	DC.B	':',PR2-*
04:00000C95 07
04:00000C96 610008D6        	   367: 	JSR	CRLF		give CR-LF and continue
04:00000C9A 60A0            	   368: 	BRA	RUNSML		execution on the same line
04:00000C9C 61000818        	   369: PR2	JSR	TSTC		if null list and <CR>
04:00000CA0 0D              	   370: 	DC.B	CR,PR0-*
04:00000CA1 09
04:00000CA2 610008CA        	   371: 	JSR	CRLF		also give CR-LF and
04:00000CA6 6000FF74        	   372: 	BRA	RUNNXL		execute the next line
04:00000CAA 6100080A        	   373: PR0	JSR	TSTC		else is it a format?
04:00000CAE 23              	   374: 	DC.B	'#',PR1-*
04:00000CAF 09
04:00000CB0 6100032C        	   375: 	JSR	EXPR		yes, evaluate expression
04:00000CB4 3800            	   376: 	MOVE	D0,D4		and save it as print width
04:00000CB6 6016            	   377: 	BRA	PR3		look for more to print
04:00000CB8 610007FC        	   378: PR1	JSR	TSTC		is character expression? (MRL)
04:00000CBC 24              	   379: 	DC.B	'$',PR4-*
04:00000CBD 0B
04:00000CBE 6100031E        	   380: 	JSR	EXPR		yep. Evaluate expression (MRL)
04:00000CC2 6100FD3E        	   381: 	BSR	GOOUT		print low byte (MRL)
04:00000CC6 6006            	   382: 	BRA	PR3		look for more. (MRL)
04:00000CC8 61000720        	   383: PR4	JSR	QTSTG		is it a string?
04:00000CCC 6012            	   384: 	BRA.S	PR8		if not, must be an expression
04:00000CCE 610007E6        	   385: PR3	JSR	TSTC		if ",", go find next
04:00000CD2 2C              	   386: 	DC.B	',',PR6-*
04:00000CD3 07
04:00000CD4 6100053A        	   387: 	JSR	FIN		in the list.
04:00000CD8 60D0            	   388: 	BRA	PR0
04:00000CDA 61000892        	   389: PR6	JSR	CRLF		list ends here
04:00000CDE 6010            	   390: 	BRA	FINISH
04:00000CE0 3F04            	   391: PR8	MOVE	D4,-(SP)	save the width value
04:00000CE2 610002FA        	   392: 	JSR	EXPR		evaluate the expression
04:00000CE6 381F            	   393: 	MOVE	(SP)+,D4	restore the width
04:00000CE8 2200            	   394: 	MOVE.L	D0,D1
04:00000CEA 6100073C        	   395: 	JSR	PRTNUM		print its value
04:00000CEE 60DE            	   396: 	BRA	PR3		more to print?
                            	   397: 
04:00000CF0 6100051E        	   398: FINISH	JSR	FIN		Check end of command
04:00000CF4 60000540        	   399: 	JMP	QWHAT		print "What?" if wrong
                            	   400: 
                            	   401: *
                            	   402: *******************************************************************
                            	   403: *
                            	   404: * *** GOSUB *** & RETURN ***
                            	   405: *
                            	   406: * 'GOSUB expr:' or 'GOSUB expr<CR>' is like the 'GOTO' command,
                            	   407: * except that the current text pointer, stack pointer, etc. are
                            	   408: * saved so that execution can be continued after the subroutine
                            	   409: * 'RETURN's.  In order that 'GOSUB' can be nested (and even
                            	   410: * recursive), the save area must be stacked.  The stack pointer
                            	   411: * is saved in 'STKGOS'.  The old 'STKGOS' is saved on the stack.
                            	   412: * If we are in the main routine, 'STKGOS' is zero (this was done
                            	   413: * in the initialization section of the interpreter), but we still
                            	   414: * save it as a flag for no further 'RETURN's.
                            	   415: *
                            	   416: * 'RETURN<CR>' undoes everything that 'GOSUB' did, and thus
                            	   417: * returns the execution to the command after the most recent
                            	   418: * 'GOSUB'.  If 'STKGOS' is zero, it indicates that we never had
                            	   419: * a 'GOSUB' and is thus an error.
                            	   420: *
04:00000CF8 610006A2        	   421: GOSUB	JSR	PUSHA		save the current 'FOR' parameters
04:00000CFC 610002E0        	   422: 	JSR	EXPR		get line number
04:00000D00 2F08            	   423: 	MOVE.L	A0,-(SP)	save text pointer
04:00000D02 2200            	   424: 	MOVE.L	D0,D1
04:00000D04 6100062E        	   425: 	JSR	FNDLN		find the target line
04:00000D08 6600057E        	   426: 	BNE.W	AHOW		if not there, say "How?"
04:00000D0C 2F3900080AA6    	   427: 	MOVE.L	CURRNT,-(SP)	found it, save old 'CURRNT'...
04:00000D12 2F3900080AAA    	   428: 	MOVE.L	STKGOS,-(SP)	and 'STKGOS'
04:00000D18 42B900080AB2    	   429: 	CLR.L	LOPVAR		load new values
04:00000D1E 23CF00080AAA    	   430: 	MOVE.L	SP,STKGOS
04:00000D24 6000FF0C        	   431: 	BRA	RUNTSL
                            	   432: 
04:00000D28 61000500        	   433: RETURN	JSR	ENDCHK		there should be just a <CR>
04:00000D2C 223900080AAA    	   434: 	MOVE.L	STKGOS,D1	get old stack pointer
04:00000D32 67000502        	   435: 	BEQ.W	QWHAT		if zero, it doesn't exist
04:00000D36 2E41            	   436: 	MOVE.L	D1,SP		else restore it
04:00000D38 23DF00080AAA    	   437: 	MOVE.L	(SP)+,STKGOS	and the old 'STKGOS'
04:00000D3E 23DF00080AA6    	   438: 	MOVE.L	(SP)+,CURRNT	and the old 'CURRNT'
04:00000D44 205F            	   439: 	MOVE.L	(SP)+,A0	and the old text pointer
04:00000D46 61000630        	   440: 	JSR	POPA		and the old 'FOR' parameters
04:00000D4A 60A4            	   441: 	BRA	FINISH		and we are back home
                            	   442: 
                            	   443: *
                            	   444: *******************************************************************
                            	   445: *
                            	   446: * *** FOR *** & NEXT ***
                            	   447: *
                            	   448: * 'FOR' has two forms:
                            	   449: * 'FOR var=exp1 TO exp2 STEP exp1' and 'FOR var=exp1 TO exp2'
                            	   450: * The second form means the same thing as the first form with a
                            	   451: * STEP of positive 1.  The interpreter will find the variable 'var'
                            	   452: * and set its value to the current value of 'exp1'.  It also
                            	   453: * evaluates 'exp2' and 'exp1' and saves all these together with
                            	   454: * the text pointer, etc. in the 'FOR' save area, which consisits of
                            	   455: * 'LOPVAR', 'LOPINC', 'LOPLMT', 'LOPLN', and 'LOPPT'.  If there is
                            	   456: * already something in the save area (indicated by a non-zero
                            	   457: * 'LOPVAR'), then the old save area is saved on the stack before
                            	   458: * the new values are stored.  The interpreter will then dig in the
                            	   459: * stack and find out if this same variable was used in another
                            	   460: * currently active 'FOR' loop.  If that is the case, then the old
                            	   461: * 'FOR' loop is deactivated. (i.e. purged from the stack)
                            	   462: *
                            	   463: * 'NEXT var' serves as the logical (not necessarily physical) end
                            	   464: * of the 'FOR' loop.  The control variable 'var' is checked with
                            	   465: * the 'LOPVAR'.  If they are not the same, the interpreter digs in
                            	   466: * the stack to find the right one and purges all those that didn't
                            	   467: * match.  Either way, it then adds the 'STEP' to that variable and
                            	   468: * checks the result with against the limit value.  If it is within
                            	   469: * the limit, control loops back to the command following the
                            	   470: * 'FOR'.  If it's outside the limit, the save area is purged and
                            	   471: * execution continues.
                            	   472: *
04:00000D4C 6100064E        	   473: FOR	JSR	PUSHA		save the old 'FOR' save area
04:00000D50 610004A4        	   474: 	JSR	SETVAL		set the control variable
04:00000D54 23CE00080AB2    	   475: 	MOVE.L	A6,LOPVAR	save its address
04:00000D5A 43FAFDFF        	   476: 	LEA	TAB5,A1 	use 'EXEC' to test for 'TO'
04:00000D5E 45FAFE40        	   477: 	LEA	TAB5_1,A2
04:00000D62 6000FE5A        	   478: 	BRA	EXEC
04:00000D66 61000276        	   479: FR1	JSR	EXPR		evaluate the limit
04:00000D6A 23C000080ABA    	   480: 	MOVE.L	D0,LOPLMT	save that
04:00000D70 43FAFDEC        	   481: 	LEA	TAB6,A1 	use 'EXEC' to look for the
04:00000D74 45FAFE2E        	   482: 	LEA	TAB6_1,A2	word 'STEP'
04:00000D78 6000FE44        	   483: 	BRA	EXEC
04:00000D7C 61000260        	   484: FR2	JSR	EXPR		found it, get the step value
04:00000D80 6002            	   485: 	BRA	FR4
04:00000D82 7001            	   486: FR3	MOVEQ	#1,D0		not found, step defaults to 1
04:00000D84 23C000080AB6    	   487: FR4	MOVE.L	D0,LOPINC	save that too
04:00000D8A 23F900080AA60008	   488: FR5	MOVE.L	CURRNT,LOPLN	save address of current line number
04:00000D92 0ABE
04:00000D94 23C800080AC2    	   489: 	MOVE.L	A0,LOPPT	and text pointer
04:00000D9A 2C4F            	   490: 	MOVE.L	SP,A6		dig into the stack to find 'LOPVAR'
04:00000D9C 6004            	   491: 	BRA	FR7
04:00000D9E 4DEE0014        	   492: FR6	ADD.L	#20,A6		look at next stack frame
04:00000DA2 2016            	   493: FR7	MOVE.L	(A6),D0 	is it zero?
04:00000DA4 6718            	   494: 	BEQ	FR8		if so, we're done
04:00000DA6 B0B900080AB2    	   495: 	CMP.L	LOPVAR,D0	same as current LOPVAR?
04:00000DAC 66F0            	   496: 	BNE	FR6		nope, look some more
04:00000DAE 244F            	   497: 	MOVE.L	SP,A2		Else remove 5 long words from...
04:00000DB0 224E            	   498: 	MOVE.L	A6,A1		inside the stack.
04:00000DB2 47F80014        	   499: 	LEA	20,A3
04:00000DB6 D7C9            	   500: 	ADD.L	A1,A3
04:00000DB8 610005B6        	   501: 	JSR	MVDOWN
04:00000DBC 2E4B            	   502: 	MOVE.L	A3,SP		set the SP 5 long words up
04:00000DBE 6000FF30        	   503: FR8	BRA	FINISH		and continue execution
                            	   504: 
04:00000DC2 61000302        	   505: NEXT	JSR	TSTV		get address of variable
04:00000DC6 6500046E        	   506: 	BCS.W	QWHAT		if no variable, say "What?"
04:00000DCA 2240            	   507: 	MOVE.L	D0,A1		save variable's address
04:00000DCC 203900080AB2    	   508: NX0	MOVE.L	LOPVAR,D0	If 'LOPVAR' is zero, we never...
04:00000DD2 67000462        	   509: 	BEQ.W	QWHAT		had a FOR loop, so say "What?"
04:00000DD6 B3C0            	   510: 	CMP.L	D0,A1		else we check them
04:00000DD8 6706            	   511: 	BEQ	NX3		OK, they agree
04:00000DDA 6100059C        	   512: 	JSR	POPA		nope, let's see the next frame
04:00000DDE 60EC            	   513: 	BRA	NX0
04:00000DE0 2011            	   514: NX3	MOVE.L	(A1),D0 	get control variable's value
04:00000DE2 D0B900080AB6    	   515: 	ADD.L	LOPINC,D0	add in loop increment
04:00000DE8 6900049C        	   516: 	BVS.W	QHOW		say "How?" for 32-bit overflow
04:00000DEC 2280            	   517: 	MOVE.L	D0,(A1) 	save control variable's new value
04:00000DEE 223900080ABA    	   518: 	MOVE.L	LOPLMT,D1	get loop's limit value
04:00000DF4 4AB900080AB6    	   519: 	TST.L	LOPINC
04:00000DFA 6A02            	   520: 	BPL	NX1		branch if loop increment is positive
04:00000DFC C141            	   521: 	EXG	D0,D1
04:00000DFE B280            	   522: NX1	CMP.L	D0,D1		test against limit
04:00000E00 6D14            	   523: 	BLT	NX2		branch if outside limit
04:00000E02 23F900080ABE0008	   524: 	MOVE.L	LOPLN,CURRNT	Within limit, go back to the...
04:00000E0A 0AA6
04:00000E0C 207900080AC2    	   525: 	MOVE.L	LOPPT,A0	saved 'CURRNT' and text pointer.
04:00000E12 6000FEDC        	   526: 	BRA	FINISH
04:00000E16 61000560        	   527: NX2	JSR	POPA		purge this loop
04:00000E1A 6000FED4        	   528: 	BRA	FINISH
