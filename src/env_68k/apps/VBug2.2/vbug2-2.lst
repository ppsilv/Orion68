04:00000986 303C001F        	    48:         MOVE.W  #32-1,D0          ; Contador para 32 Longs (128 bytes)Subtraímos 1 porque o DBRA para no -1
04:0000098A 43F900080448    	    49:         LEA     buf_xmodem,A1
                            	    50: .CopyLoop:
04:00000990 26D9            	    51:         MOVE.L  (A1)+,(A3)+       ; Copia 4 bytes de (A1) para (A3) e avança ambos
04:00000992 51C8FFFC        	    52:         DBRA    D0,.CopyLoop      ; Decrementa D0 e pula para .CopyLoop se D0 >= 0
04:00000996 103C0006        	    53:         MOVE.B  #ACK,D0
