                            	   492:         INCLUDE "cmd/mem_dump.asm"

Source: "cmd/mem_dump.asm"
                            	     1: ; ----------------------------------------------------------------------
                            	     2: ; MemDump - Imprime dump de memória formatado
                            	     3: ; Entrada:
                            	     4: ;   A0 = Endereço inicial (ex: $80000)
                            	     5: ;   D0 = Quantidade de bytes (ex: 256)
                            	     6: ; ----------------------------------------------------------------------
                            	     7: MemDump:
04:00000320 4EB900000548    	     8:         JSR     PicoClearScreen
                            	     9: 
04:00000326 41F900000000    	    10:         LEA     MsgDumpHeader,A0
04:0000032C 4EB9000001F0    	    11:         JSR     WriteStringConout
04:00000332 207900080424    	    12:         MOVE.L  (addressInHex),A0
04:00000338 2008            	    13:         MOVE.L  A0,D0
04:0000033A 61000674        	    14:         JSR     Print32bitsHex
04:0000033E 4EB811F4        	    15:         JSR     NewLine
                            	    16: 
04:00000342 41F900000018    	    17:         LEA     MsgDumpHeader1,A0
04:00000348 4EB9000001F0    	    18:         JSR     WriteStringConout
                            	    19: 
04:0000034E 207900080424    	    20:         MOVE.L  (addressInHex),A0
                            	    21:         ; Calcula endereço final
                            	    22: 
                            	    23: DUMPLOOPMASTER:
04:00000354 303C0000        	    24:         MOVE.W  #$0,D0
04:00000358 4840            	    25:         SWAP    D0
04:0000035A 303C0005        	    26:         MOVE.W  #$5,D0
04:0000035E 4EB9000004E4    	    27:         JSR     PicoSetCursor
                            	    28:         
04:00000364 7200            	    29:         CLR.L   D1
04:00000366 2208            	    30:         MOVE.L  A0,D1
04:00000368 0681000000FF    	    31:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    32: 
                            	    33: DumpLoop:
                            	    34:         ; Nova linha a cada 16 bytes
04:0000036E 2008            	    35:         MOVE.L  A0,D0
04:00000370 02800000000F    	    36:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
04:00000376 661A            	    37:         BNE     NoNewLine
                            	    38: 
                            	    39:         ; Imprime endereço
04:00000378 2008            	    40:         MOVE.L  A0,D0
04:0000037A 61000634        	    41:         JSR     Print32bitsHex    ; Imprime 8 dígitos hex
                            	    42: 
04:0000037E 103C003A        	    43:         MOVE.B  #':',D0
04:00000382 4EB9000001E6    	    44:         JSR     WriteConout
04:00000388 103C0020        	    45:         MOVE.B  #' ',D0
04:0000038C 4EB9000001E6    	    46:         JSR     WriteConout
                            	    47: 
                            	    48: NoNewLine:
                            	    49:         ; Imprime byte em hex
04:00000392 1018            	    50:         MOVE.B  (A0)+,D0
04:00000394 61000636        	    51:         JSR     PrintByteHex
                            	    52: 
04:00000398 103C0020        	    53:         MOVE.B  #' ',D0
04:0000039C 4EB9000001E6    	    54:         JSR     WriteConout
                            	    55: 
                            	    56:         ; Verifica fim da linha (16 bytes)
04:000003A2 2008            	    57:         MOVE.L  A0,D0
04:000003A4 02800000000F    	    58:         ANDI.L  #$0000000F,D0
04:000003AA 665C            	    59:         BNE     NoEndLine
                            	    60: 
                            	    61:         ; Imprime caracteres ASCII
04:000003AC 103C0020        	    62:         MOVE.B  #' ',D0
04:000003B0 4EB9000001E6    	    63:         JSR     WriteConout
04:000003B6 103C007C        	    64:         MOVE.B  #'|',D0
04:000003BA 4EB9000001E6    	    65:         JSR     WriteConout
                            	    66: 
04:000003C0 43E8FFF0        	    67:         LEA     -16(A0),A1        ; Volta ao início da linha
04:000003C4 740F            	    68:         MOVEQ   #15,D2            ; 16 caracteres
                            	    69: 
                            	    70: AsciiLoop:
04:000003C6 1019            	    71:         MOVE.B  (A1)+,D0
04:000003C8 B03C0020        	    72:         CMP.B   #32,D0            ; Verifica se é imprimível
04:000003CC 6D0E            	    73:         BLT     NonPrintable
04:000003CE B03C007E        	    74:         CMP.B   #$7E,D0
04:000003D2 6E08            	    75:         BGT     NonPrintable
                            	    76: 
04:000003D4 4EB9000001E6    	    77:         JSR     WriteConout
04:000003DA 600A            	    78:         BRA     NextAscii
                            	    79: 
                            	    80: NonPrintable:
04:000003DC 103C002E        	    81:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
04:000003E0 4EB9000001E6    	    82:         JSR     WriteConout
                            	    83: 
                            	    84: NextAscii:
04:000003E6 51CAFFDE        	    85:         DBRA    D2,AsciiLoop
                            	    86: 
04:000003EA 103C007C        	    87:         MOVE.B  #'|',D0
04:000003EE 4EB9000001E6    	    88:         JSR     WriteConout
04:000003F4 103C000D        	    89:         MOVE.B  #13,D0            ; CR
04:000003F8 4EB9000001E6    	    90:         JSR     WriteConout
04:000003FE 103C000A        	    91:         MOVE.B  #10,D0            ; LF
04:00000402 4EB9000001E6    	    92:         JSR     WriteConout
                            	    93: 
                            	    94: NoEndLine:
                            	    95:         ; Verifica fim do dump
04:00000408 B1C1            	    96:         CMP.L   D1,A0
04:0000040A 6300FF62        	    97:         BLS     DumpLoop
                            	    98: 
                            	    99:         ;JSR     PrintAx
                            	   100:         ;JSR     PrintDx
                            	   101: 
04:0000040E 2F08            	   102:         MOVE.L  A0,-(SP)          ; Salva endereço atual
04:00000410 41F900000371    	   103:         LEA     MsgHitAnyKey,A0
04:00000416 4EB9000001F0    	   104:         JSR     WriteStringConout
04:0000041C 4EB9000001C6    	   105:         JSR     ReadConin
04:00000422 B03C001B        	   106:         CMP.B   #$1B,D0
04:00000426 6706            	   107:         BEQ     .fim
                            	   108: 
04:00000428 205F            	   109:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
04:0000042A 6000FF28        	   110:         BRA     DUMPLOOPMASTER
                            	   111: .fim
04:0000042E 205F            	   112:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
04:00000430 4E75            	   113:         RTS
                            	   114: 
