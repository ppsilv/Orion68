                            	    10: InitUartb:
03:00000412 227C00FF4100    	    11:         move.l  #UARTB_BASE,A1
03:00000418 203900080A58    	    12:         move.l  currentBaudRate,D0
03:0000041E 137C00830007    	    13:         move.b  #%10000011,LCR(A1) ;DLAB=1
03:00000424 137C00080001    	    14:         move.b  #$08,DLL(A1)       ; set divisor latch low byte
03:0000042A 137C00000003    	    15:         move.b  #$00,DLM(A1)       ; set divisor latch high byte
03:00000430 137C00030007    	    16:         move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
03:00000436 137C000D0005    	    17:         move.b  #%00001101,FCR(A1) ; enable FIFO
03:0000043C 4229000F        	    18:         clr.b   SCR(A1)            ; clear the scratch register
03:00000440 4E75            	    19:         RTS
                            	    20: InitUartb1:
03:00000442 227C00FF4100    	    21:         move.l  #UARTB_BASE,A1
03:00000448 203900080A58    	    22:         move.l  currentBaudRate,D0
03:0000044E 137C000D0005    	    23:         move.b  #%00001101,FCR(a1)      ; enable FIFO
03:00000454 137C00830007    	    24:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
03:0000045A 13400001        	    25:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
03:0000045E E088            	    26:         lsr.l   #8,D0                   ; Shift right 8 bits
03:00000460 13400003        	    27:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
03:00000464 08A900070007    	    28:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
03:0000046A 4229000F        	    29:         clr.b   SCR(a1)                 ; clear the scratch register
03:0000046E 4E75            	    30:         RTS
