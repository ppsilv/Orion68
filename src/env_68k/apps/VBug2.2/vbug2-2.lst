04:00001434 4481            	  1317: 	NEG.L	D1		else make it positive
04:00001436 5344            	  1318: 	SUBQ	#1,D4		one less for width count
04:00001438 82FC000A        	  1319: PN1	DIVU	#10,D1		get the next digit
04:0000143C 690A            	  1320: 	BVS	PNOV		overflow flag set?
04:0000143E 2001            	  1321: 	MOVE.L	D1,D0		if not, save remainder
04:00001440 C2BC0000FFFF    	  1322: 	AND.L	#$FFFF,D1	strip the remainder
04:00001446 601A            	  1323: 	BRA	TOASCII 	skip the overflow stuff
04:00001448 3001            	  1324: PNOV	MOVE	D1,D0		prepare for long word division
04:0000144A 4241            	  1325: 	CLR.W	D1		zero out low word
04:0000144C 4841            	  1326: 	SWAP	D1		high word into low
04:0000144E 82FC000A        	  1327: 	DIVU	#10,D1		divide high word
