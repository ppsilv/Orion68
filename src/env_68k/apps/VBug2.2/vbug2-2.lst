                            	    17: REG_0A         equ $FF8013        ;;Endereço real 19 0x13  o pico enxerga 0x09
                            	    18: REG_0B         equ $FF8015        ;;Endereço real 21 0x15  o pico enxerga 0x0A
                            	    19: REG_0C         equ $FF8017        ;;Endereço real 23 0x17  o pico enxerga 0x0B
                            	    20: REG_0D         equ $FF8019        ;;Endereço real 25 0x19  o pico enxerga 0x0C
                            	    21: REG_0E         equ $FF801B        ;;Endereço real 27 0x1b  o pico enxerga 0x0D
                            	    22: REG_0F         equ $FF801D        ;;Endereço real 29 0x1d  o pico enxerga 0x0E
                            	    23: REG_10         equ $FF801F        ;;Endereço real 31 0x1f  o pico enxerga 0x0F
                            	    24: ;End
