Source: "rot_print_hex_num.asm"
                            	     1: 
                            	     2: ; ----------------------------------------------------------------------
                            	     3: ; Print32bitsHex - Imprime endereço de 32 bits
                            	     4: ; Entrada: D0 = endereço
                            	     5: ; ----------------------------------------------------------------------
                            	     6: Print32bitsHex:
04:000009B0 2F01            	     7:         MOVE.L  D1,-(SP)
04:000009B2 4840            	     8:         SWAP    D0                ; Imprime parte alta primeiro
04:000009B4 610A            	     9:         JSR     PrintWordHex
04:000009B6 2001            	    10:         MOVE.L  D1,D0
04:000009B8 4840            	    11:         SWAP    D0                ; Parte baixa
04:000009BA 6104            	    12:         JSR     PrintWordHex
04:000009BC 221F            	    13:         MOVE.L (SP)+,D1
04:000009BE 4E75            	    14:         RTS
                            	    15:         
                            	    16: PrintWordHex:
04:000009C0 2200            	    17:         MOVE.L  D0,D1
04:000009C2 E058            	    18:         ROR     #8,D0             ; Byte mais significativo primeiro
04:000009C4 6106            	    19:         JSR     PrintByteHex
04:000009C6 2001            	    20:         MOVE.L  D1,D0             ; Byte menos significativo
04:000009C8 6102            	    21:         JSR     PrintByteHex
04:000009CA 4E75            	    22:         RTS
                            	    23: 
                            	    24: PrintByteHex:
04:000009CC 1F00            	    25:         MOVE.B  D0,-(SP)          ; 1. Guarda o byte original na pilha
                            	    26:         ; --- PROCESSA O PRIMEIRO NIBBLE (ALTO) ---
04:000009CE E808            	    27:         LSR.B   #4,D0             ; Isola o nibble alto (ex: $A4 -> $0A)
04:000009D0 610A            	    28:         BSR     .PrintNibble      ; Executa a subrotina para o primeiro dígito
                            	    29:         ; --- PROCESSA O SEGUNDO NIBBLE (BAIXO) ---
04:000009D2 101F            	    30:         MOVE.B  (SP)+,D0          ; 2. Recupera o byte original da pilha
04:000009D4 0200000F        	    31:         ANDI.B  #$0F,D0           ; Isola o nibble baixo (ex: $A4 -> $04)
04:000009D8 6102            	    32:         BSR     .PrintNibble      ; Executa a subrotina para o segundo dígito
04:000009DA 4E75            	    33:         RTS
                            	    34: 
                            	    35: .PrintNibble:
04:000009DC 1F00            	    36:         MOVE.B  D0,-(SP)          ; Salva D0 para não destruir o valor na conversão        
04:000009DE B03C0009        	    37:         CMP.B   #9,D0
04:000009E2 6302            	    38:         BLS     .Decimal          ; Se for menor ou igual a 9, vai direto
04:000009E4 5E00            	    39:         ADD.B   #7,D0             ; Ajuste para letras 'A' até 'F'
                            	    40: .Decimal:
04:000009E6 D03C0030        	    41:         ADD.B   #'0',D0           ; Converte o valor bruto em caractere ASCII
04:000009EA 4EB9000001E6    	    42:         JSR     WriteConout       ; Chama a sua rotina de exibição na tela/serial
04:000009F0 101F            	    43:         MOVE.B  (SP)+,D0          ; Restaura o D0 original deste nibble
04:000009F2 4E75            	    44:         RTS
                            	    45: 

