03:00000004 4FF9000FFFF0    	   300:         LEA     $FFFF0,SP ; Garante o Stack Pointer (se o hardware não carregou)
                            	   301: 
                            	   302: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   303: ;This gives hardware time to get up
                            	   304: ;
03:0000000A 223C0003FFFF    	   305:         MOVE.L  #$003FFFF,D1 ; Contador para o delay (ajuste se precisar de mais)
                            	   306: .DELAY01:
03:00000010 5381            	   307:         SUBQ.L  #1,D1         ; Subtrai 1 de D1 (4 ciclos)
03:00000012 66FC            	   308:         BNE.S   .DELAY01     ; Pula se não for zero (10 ciclos se pular, 8 se não)
