04:000013FA 225F            	  1295: 	MOVE.L	(SP)+,A1	pop return address
04:000013FC B03C000A        	  1296: 	CMP.B	#LF,D0		was last one a CR?
04:00001400 6700F81A        	  1297: 	BEQ	RUNNXL		if so, run next line
04:00001404 5489            	  1298: QT2	ADDQ.L	#2,A1		skip 2 bytes on return
04:00001406 4ED1            	  1299: 	JMP	(A1)		return
04:00001408 610000AC        	  1300: QT3	JSR	TSTC		is it a single quote?
04:0000140C 27              	  1301: 	DC.B	'''',QT4-*
04:0000140D 07
04:0000140E 103C0027        	  1302: 	MOVE.B	#'''',D0        if so, do same as above
04:00001412 60E0            	  1303: 	BRA	QT1
04:00001414 610000A0        	  1304: QT4	JSR	TSTC		is it an underline?
04:00001418 5F              	  1305: 	DC.B	'_',QT5-*
04:00001419 0D
04:0000141A 103C000D        	  1306: 	MOVE.B	#CR,D0		if so, output a CR without LF
04:0000141E 6100F5E2        	  1307: 	JSR	GOOUT
04:00001422 225F            	  1308: 	MOVE.L	(SP)+,A1	pop return address
04:00001424 60DE            	  1309: 	BRA	QT2
