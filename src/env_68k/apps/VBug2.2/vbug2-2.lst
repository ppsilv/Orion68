                            	   104: ; ----------------------------------------------------------------------
                            	   105: ; UART_WriteString - Envia string terminada em null para UART
                            	   106: ; Entrada:
                            	   107: ;   A0 = Ponteiro para a string (endereço da string)
                            	   108: ; ----------------------------------------------------------------------
                            	   109: DelUartWriteString:
03:00000358 2F08            	   110:         MOVE.L  A0,-(SP)      ; Preserva D0
03:0000035A 2F00            	   111:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   112: .WriteLoop:
03:0000035C 1018            	   113:         MOVE.B  (A0)+,D0      ; Pega caractere
03:0000035E 6706            	   114:         BEQ     .Done
03:00000360 6100FE8C        	   115:         JSR     WriteConout ; Use sua rotine existente
03:00000364 60F6            	   116:         BRA     .WriteLoop
                            	   117: .Done:
03:00000366 201F            	   118:         MOVE.L  (SP)+,D0
03:00000368 205F            	   119:         MOVE.L  (SP)+,A0
03:0000036A 4E75            	   120:         RTS
                            	   121: 
                            	   122: ; Lê número hexadecimal (retorna em D0)
                            	   123: DelUartReadHex:
03:0000036C 2F01            	   124:         MOVE.L  D1,-(SP)
03:0000036E 2F02            	   125:         MOVE.L  D2,-(SP)
                            	   126: 
03:00000370 7000            	   127:         MOVEQ   #0,D0
03:00000372 721C            	   128:         MOVEQ   #28,D1            ; Máximo 8 dígitos
03:00000374 7400            	   129:         MOVEQ   #0,D2            ; Resultado em D2
                            	   130: .Loop:
03:00000376 7000            	   131:         CLR.L   D0
03:00000378 6100FE54        	   132:         JSR     ReadConin
03:0000037C B03C000D        	   133:         CMP.B   #13,D0
03:00000380 674C            	   134:         BEQ     .Done
03:00000382 B03C000A        	   135:         CMP.B   #10,D0
03:00000386 6746            	   136:         BEQ     .Done
                            	   137:         ;Tratando os numeros
03:00000388 B03C0030        	   138:         CMP.B   #'0',D0
03:0000038C 6C02            	   139:         BGE     .maiorQueZero
03:0000038E 60E6            	   140:         BRA     .Loop
                            	   141: .maiorQueZero:
03:00000390 B03C0039        	   142:         CMP.B   #'9',D0
03:00000394 6F10            	   143:         BLE     .isdigit
                            	   144:         ;Tratando as letras
03:00000396 B03C0041        	   145:         CMP.B   #'A',D0
03:0000039A 6C02            	   146:         BGE     .maiorQueA
03:0000039C 60D8            	   147:         BRA     .Loop
                            	   148: .maiorQueA:
03:0000039E B03C0046        	   149:         CMP.B   #'F',D0
03:000003A2 6F16            	   150:         BLE     .isletter
03:000003A4 60D0            	   151:         BRA     .Loop
                            	   152: .isdigit:
03:000003A6 903C0030        	   153:         SUB.B   #'0',D0
03:000003AA E3A8            	   154:         LSL.L   D1,D0
03:000003AC 5901            	   155:         SUB.B   #4,D1
03:000003AE 8480            	   156:         OR.L    D0,D2
03:000003B0 41F900080424    	   157:         LEA     addressInHex,A0
03:000003B6 2082            	   158:         MOVE.L  D2,(A0)
03:000003B8 60BC            	   159:         BRA     .Loop
                            	   160: .isletter:
03:000003BA 903C0037        	   161:         SUB.B   #$37,D0
03:000003BE E3A8            	   162:         LSL.L   D1,D0
03:000003C0 5901            	   163:         SUB.B   #4,D1
03:000003C2 8480            	   164:         OR.L    D0,D2
03:000003C4 41F900080424    	   165:         LEA     addressInHex,A0
03:000003CA 2082            	   166:         MOVE.L  D2,(A0)
03:000003CC 60A8            	   167:         BRA     .Loop
                            	   168: .Done:
03:000003CE 4EB811E4        	   169:         JSR     NewLine
03:000003D2 41F900080424    	   170:         LEA     addressInHex,A0
03:000003D8 2010            	   171:         MOVE.L  (A0),D0
03:000003DA 610001B2        	   172:         JSR     PicoPrint32bitsHex
03:000003DE 4EB811E4        	   173:         JSR     NewLine
03:000003E2 241F            	   174:         MOVE.L  (SP)+,D2
03:000003E4 221F            	   175:         MOVE.L  (SP)+,D1
03:000003E6 4E75            	   176:         RTS
