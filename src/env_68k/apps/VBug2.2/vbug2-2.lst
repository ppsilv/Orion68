04:00000B4F CB
04:00000B50 524E            	   167: 	DC.B	'RN',('D'+$80)
04:00000B52 C4
04:00000B53 4142            	   168: 	DC.B	'AB',('S'+$80)
04:00000B55 D3
04:00000B56 53495A          	   169: 	DC.B	'SIZ',('E'+$80)
04:00000B59 C5
04:00000B5A 00              	   170: 	DC.B	0
