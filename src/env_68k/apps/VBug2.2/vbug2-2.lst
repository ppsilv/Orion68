                            	   122: ; Lê número hexadecimal (retorna em D0)
                            	   123: DelUartReadHex:
03:00000364 2F01            	   124:         MOVE.L  D1,-(SP)
03:00000366 2F02            	   125:         MOVE.L  D2,-(SP)
                            	   126: 
03:00000368 7000            	   127:         MOVEQ   #0,D0
03:0000036A 721C            	   128:         MOVEQ   #28,D1            ; Máximo 8 dígitos
03:0000036C 7400            	   129:         MOVEQ   #0,D2            ; Resultado em D2
                            	   130: .Loop:
03:0000036E 7000            	   131:         CLR.L   D0
03:00000370 6100FE54        	   132:         JSR     ReadConin
03:00000374 B03C000D        	   133:         CMP.B   #13,D0
03:00000378 674C            	   134:         BEQ     .Done
03:0000037A B03C000A        	   135:         CMP.B   #10,D0
03:0000037E 6746            	   136:         BEQ     .Done
                            	   137:         ;Tratando os numeros
03:00000380 B03C0030        	   138:         CMP.B   #'0',D0
03:00000384 6C02            	   139:         BGE     .maiorQueZero
03:00000386 60E6            	   140:         BRA     .Loop
                            	   141: .maiorQueZero:
03:00000388 B03C0039        	   142:         CMP.B   #'9',D0
03:0000038C 6F10            	   143:         BLE     .isdigit
                            	   144:         ;Tratando as letras
03:0000038E B03C0041        	   145:         CMP.B   #'A',D0
03:00000392 6C02            	   146:         BGE     .maiorQueA
03:00000394 60D8            	   147:         BRA     .Loop
                            	   148: .maiorQueA:
03:00000396 B03C0046        	   149:         CMP.B   #'F',D0
03:0000039A 6F16            	   150:         BLE     .isletter
03:0000039C 60D0            	   151:         BRA     .Loop
                            	   152: .isdigit:
03:0000039E 903C0030        	   153:         SUB.B   #'0',D0
03:000003A2 E3A8            	   154:         LSL.L   D1,D0
03:000003A4 5901            	   155:         SUB.B   #4,D1
03:000003A6 8480            	   156:         OR.L    D0,D2
03:000003A8 41F900080424    	   157:         LEA     addressInHex,A0
03:000003AE 2082            	   158:         MOVE.L  D2,(A0)
03:000003B0 60BC            	   159:         BRA     .Loop
                            	   160: .isletter:
03:000003B2 903C0037        	   161:         SUB.B   #$37,D0
03:000003B6 E3A8            	   162:         LSL.L   D1,D0
03:000003B8 5901            	   163:         SUB.B   #4,D1
03:000003BA 8480            	   164:         OR.L    D0,D2
03:000003BC 41F900080424    	   165:         LEA     addressInHex,A0
03:000003C2 2082            	   166:         MOVE.L  D2,(A0)
03:000003C4 60A8            	   167:         BRA     .Loop
                            	   168: .Done:
03:000003C6 4EB811F4        	   169:         JSR     NewLine
03:000003CA 41F900080424    	   170:         LEA     addressInHex,A0
03:000003D0 2010            	   171:         MOVE.L  (A0),D0
03:000003D2 610001B2        	   172:         JSR     PicoPrint32bitsHex
03:000003D6 4EB811F4        	   173:         JSR     NewLine
03:000003DA 241F            	   174:         MOVE.L  (SP)+,D2
03:000003DC 221F            	   175:         MOVE.L  (SP)+,D1
03:000003DE 4E75            	   176:         RTS
