                            	   530: *
                            	   531: *******************************************************************
                            	   532: *
                            	   533: * *** REM *** IF *** INPUT *** LET (& DEFLT) ***
                            	   534: *
                            	   535: * 'REM' can be followed by anything and is ignored by the
                            	   536: * interpreter.
                            	   537: *
                            	   538: * 'IF' is followed by an expression, as a condition and one or
                            	   539: * more commands (including other 'IF's) separated by colons.
                            	   540: * Note that the word 'THEN' is not used.  The interpreter evaluates
                            	   541: * the expression.  If it is non-zero, execution continues.  If it
                            	   542: * is zero, the commands that follow are ignored and execution
                            	   543: * continues on the next line.
                            	   544: *
                            	   545: * 'INPUT' is like the 'PRINT' command, and is followed by a list
                            	   546: * of items.  If the item is a string in single or double quotes,
                            	   547: * or is an underline (back arrow), it has the same effect as in
                            	   548: * 'PRINT'.  If an item is a variable, this variable name is
                            	   549: * printed out followed by a colon, then the interpreter waits for
                            	   550: * an expression to be typed in.  The variable is then set to the
                            	   551: * value of this expression.  If the variable is preceeded by a
                            	   552: * string (again in single or double quotes), the string will be
                            	   553: * displayed followed by a colon.  The interpreter the waits for an
                            	   554: * expression to be entered and sets the variable equal to the
                            	   555: * expression's value.  If the input expression is invalid, the
                            	   556: * interpreter will print "What?", "How?", or "Sorry" and reprint
                            	   557: * the prompt and redo the input.  The execution will not terminate
                            	   558: * unless you press control-C.  This is handled in 'INPERR'.
                            	   559: *
                            	   560: * 'LET' is followed by a list of items separated by commas.
                            	   561: * Each item consists of a variable, an equals sign, and an
                            	   562: * expression.  The interpreter evaluates the expression and sets
                            	   563: * the variable to that value.  The interpreter will also handle
                            	   564: * 'LET' commands without the word 'LET'.  This is done by 'DEFLT'.
                            	   565: *
04:00000E1E 600A            	   566: REM	BRA	IF2		skip the rest of the line
                            	   567: 
04:00000E20 610001BC        	   568: IF	JSR	EXPR		evaluate the expression
04:00000E24 4A80            	   569: IF1	TST.L	D0		is it zero?
04:00000E26 6600FE14        	   570: 	BNE	RUNSML		if not, continue
04:00000E2A 2248            	   571: IF2	MOVE.L	A0,A1
04:00000E2C 7200            	   572: 	CLR.L	D1
04:00000E2E 6100052E        	   573: 	JSR	FNDSKP		if so, skip the rest of the line
04:00000E32 6400FDFE        	   574: 	BCC	RUNTSL		and run the next line
04:00000E36 6000FC18        	   575: 	JMP	WSTART		if no next line, do a warm start
                            	   576: 
04:00000E3A 2E7900080AAE    	   577: INPERR	MOVE.L	STKINP,SP	restore the old stack pointer
04:00000E40 23DF00080AA6    	   578: 	MOVE.L	(SP)+,CURRNT	and old 'CURRNT'
04:00000E46 588F            	   579: 	ADDQ.L	#4,SP
04:00000E48 205F            	   580: 	MOVE.L	(SP)+,A0	and old text pointer
                            	   581: 
04:00000E4A 2F08            	   582: INPUT	MOVE.L	A0,-(SP)	save in case of error
04:00000E4C 6100059C        	   583: 	JSR	QTSTG		is next item a string?
04:00000E50 600A            	   584: 	BRA.S	IP2		nope
04:00000E52 61000272        	   585: 	JSR	TSTV		yes, but is it followed by a variable?
04:00000E56 6556            	   586: 	BCS	IP4		if not, branch
04:00000E58 2440            	   587: 	MOVE.L	D0,A2		put away the variable's address
04:00000E5A 601A            	   588: 	BRA	IP3		if so, input to variable
04:00000E5C 2F08            	   589: IP2	MOVE.L	A0,-(SP)	save for 'PRTSTG'
04:00000E5E 61000266        	   590: 	JSR	TSTV		must be a variable now
04:00000E62 650003D2        	   591: 	BCS.W	QWHAT		"What?" it isn't?
04:00000E66 2440            	   592: 	MOVE.L	D0,A2		put away the variable's address
04:00000E68 1410            	   593: 	MOVE.B	(A0),D2 	get ready for 'PRTSTG'
04:00000E6A 4200            	   594: 	CLR.B	D0
04:00000E6C 1080            	   595: 	MOVE.B	D0,(A0)
04:00000E6E 225F            	   596: 	MOVE.L	(SP)+,A1
04:00000E70 6100055C        	   597: 	JSR	PRTSTG		print string as prompt
04:00000E74 1082            	   598: 	MOVE.B	D2,(A0) 	restore text
04:00000E76 2F08            	   599: IP3	MOVE.L	A0,-(SP)	save in case of error
04:00000E78 2F3900080AA6    	   600: 	MOVE.L	CURRNT,-(SP)	also save 'CURRNT'
04:00000E7E 23FCFFFFFFFF0008	   601: 	MOVE.L	#-1,CURRNT	flag that we are in INPUT
04:00000E86 0AA6
04:00000E88 23CF00080AAE    	   602: 	MOVE.L	SP,STKINP	save the stack pointer too
04:00000E8E 2F0A            	   603: 	MOVE.L	A2,-(SP)	save the variable address
04:00000E90 103C003A        	   604: 	MOVE.B	#':',D0         print a colon first
04:00000E94 610003FA        	   605: 	JSR	GETLN		then get an input line
04:00000E98 41F900080AD2    	   606: 	LEA	BUFFER,A0	point to the buffer
04:00000E9E 6100013E        	   607: 	JSR	EXPR		evaluate the input
04:00000EA2 245F            	   608: 	MOVE.L	(SP)+,A2	restore the variable address
04:00000EA4 2480            	   609: 	MOVE.L	D0,(A2) 	save value in variable
04:00000EA6 23DF00080AA6    	   610: 	MOVE.L	(SP)+,CURRNT	restore old 'CURRNT'
04:00000EAC 205F            	   611: 	MOVE.L	(SP)+,A0	and the old text pointer
04:00000EAE 588F            	   612: IP4	ADDQ.L	#4,SP		clean up the stack
04:00000EB0 61000604        	   613: 	JSR	TSTC		is the next thing a comma?
04:00000EB4 2C              	   614: 	DC.B	',',IP5-*
04:00000EB5 03
04:00000EB6 6092            	   615: 	BRA	INPUT		yes, more items
04:00000EB8 6000FE36        	   616: IP5	BRA	FINISH
                            	   617: 
04:00000EBC 0C10000D        	   618: DEFLT	CMP.B	#CR,(A0)	empty line is OK
04:00000EC0 670C            	   619: 	BEQ	LT1		else it is 'LET'
                            	   620: 
04:00000EC2 61000332        	   621: LET	JSR	SETVAL		do the assignment
04:00000EC6 610005EE        	   622: 	JSR	TSTC		check for more 'LET' items
04:00000ECA 2C              	   623: 	DC.B	',',LT1-*
04:00000ECB 03
04:00000ECC 60F4            	   624: 	BRA	LET
04:00000ECE 6000FE20        	   625: LT1	BRA	FINISH		until we are finished.
                            	   626: 
                            	   627: *
                            	   628: *******************************************************************
                            	   629: *
                            	   630: * *** LOAD *** & SAVE ***
                            	   631: *
                            	   632: * These two commands transfer a program to/from an auxiliary
                            	   633: * device such as a cassette, another computer, etc.  The program
                            	   634: * is converted to an easily-stored format: each line starts with
                            	   635: * a colon, the line no. as 4 hex digits, and the rest of the line.
                            	   636: * At the end, a line starting with an '@' sign is sent.  This
                            	   637: * format can be read back with a minimum of processing time by
                            	   638: * the 68000.
                            	   639: *
04:00000ED2 207AFB42        	   640: LOAD	MOVE.L	TXTBGN,A0	set pointer to start of prog. area
04:00000ED6 103C000D        	   641: 	MOVE.B	#CR,D0		For a CP/M host, tell it we're ready...
04:00000EDA 6100FB2E        	   642: 	BSR	GOAUXO		by sending a CR to finish PIP command.
04:00000EDE 6100FB2E        	   643: LOD1	BSR	GOAUXI		look for start of line
04:00000EE2 67FA            	   644: 	BEQ	LOD1
04:00000EE4 B03C0040        	   645: 	CMP.B	#'@',D0         end of program?
04:00000EE8 671E            	   646: 	BEQ	LODEND
04:00000EEA B03C003A        	   647: 	CMP.B	#':',D0         if not, is it start of line?
04:00000EEE 66EE            	   648: 	BNE	LOD1		if not, wait for it
04:00000EF0 6120            	   649: 	BSR	GBYTE		get first byte of line no.
04:00000EF2 10C1            	   650: 	MOVE.B	D1,(A0)+	store it
04:00000EF4 611C            	   651: 	BSR	GBYTE		get 2nd bye of line no.
04:00000EF6 10C1            	   652: 	MOVE.B	D1,(A0)+	store that, too
04:00000EF8 6100FB14        	   653: LOD2	BSR	GOAUXI		get another text char.
04:00000EFC 67FA            	   654: 	BEQ	LOD2
04:00000EFE 10C0            	   655: 	MOVE.B	D0,(A0)+	store it
04:00000F00 B03C000D        	   656: 	CMP.B	#CR,D0		is it the end of the line?
04:00000F04 66F2            	   657: 	BNE	LOD2		if not, go back for more
04:00000F06 60D6            	   658: 	BRA	LOD1		if so, start a new line
04:00000F08 23C800080AC6    	   659: LODEND	MOVE.L	A0,TXTUNF	set end-of program pointer
04:00000F0E 6000FB40        	   660: 	BRA	WSTART		back to direct mode
                            	   661: 
04:00000F12 7401            	   662: GBYTE	MOVEQ	#1,D2		get two hex characters from auxiliary
04:00000F14 4241            	   663: 	CLR	D1		and store them as a byte in D1
04:00000F16 6100FAF6        	   664: GBYTE1	BSR	GOAUXI		get a char.
04:00000F1A 67FA            	   665: 	BEQ	GBYTE1
04:00000F1C B03C0041        	   666: 	CMP.B	#'A',D0
04:00000F20 6502            	   667: 	BCS	GBYTE2
04:00000F22 5F00            	   668: 	SUBQ.B	#7,D0		if greater than 9, adjust
04:00000F24 C03C000F        	   669: GBYTE2	AND.B	#$F,D0		strip ASCII
04:00000F28 E909            	   670: 	LSL.B	#4,D1		put nybble into the result
04:00000F2A 8200            	   671: 	OR.B	D0,D1
04:00000F2C 51CAFFE8        	   672: 	DBRA	D2,GBYTE1	get another char.
04:00000F30 4E75            	   673: 	RTS
                            	   674: 
04:00000F32 207AFAE2        	   675: SAVE	MOVE.L	TXTBGN,A0	set pointer to start of prog. area
04:00000F36 227900080AC6    	   676: 	MOVE.L	TXTUNF,A1	set pointer to end of prog. area
04:00000F3C 103C000D        	   677: SAVE1	MOVE.B	#CR,D0		send out a CR & LF (CP/M likes this)
04:00000F40 6100FAC8        	   678: 	BSR	GOAUXO
04:00000F44 103C000A        	   679: 	MOVE.B	#LF,D0
04:00000F48 6100FAC0        	   680: 	BSR	GOAUXO
04:00000F4C B3C8            	   681: 	CMP.L	A0,A1		are we finished?
04:00000F4E 631E            	   682: 	BLS	SAVEND
04:00000F50 103C003A        	   683: 	MOVE.B	#':',D0         if not, start a line
04:00000F54 6100FAB4        	   684: 	BSR	GOAUXO
04:00000F58 1218            	   685: 	MOVE.B	(A0)+,D1	send first half of line no.
04:00000F5A 6136            	   686: 	BSR	PBYTE
04:00000F5C 1218            	   687: 	MOVE.B	(A0)+,D1	and send 2nd half
04:00000F5E 6132            	   688: 	BSR	PBYTE
04:00000F60 1018            	   689: SAVE2	MOVE.B	(A0)+,D0	get a text char.
04:00000F62 B03C000D        	   690: 	CMP.B	#CR,D0		is it the end of the line?
04:00000F66 67D4            	   691: 	BEQ	SAVE1		if so, send CR & LF and start new line
04:00000F68 6100FAA0        	   692: 	BSR	GOAUXO		send it out
04:00000F6C 60F2            	   693: 	BRA	SAVE2		go back for more text
04:00000F6E 103C0040        	   694: SAVEND	MOVE.B	#'@',D0         send end-of-program indicator
04:00000F72 6100FA96        	   695: 	BSR	GOAUXO
04:00000F76 103C000D        	   696: 	MOVE.B	#CR,D0		followed by a CR & LF
04:00000F7A 6100FA8E        	   697: 	BSR	GOAUXO
04:00000F7E 103C000A        	   698: 	MOVE.B	#LF,D0
04:00000F82 6100FA86        	   699: 	BSR	GOAUXO
04:00000F86 103C001A        	   700: 	MOVE.B	#$1A,D0 	and a control-Z to end the CP/M file
04:00000F8A 6100FA7E        	   701: 	BSR	GOAUXO
04:00000F8E 6000FAC0        	   702: 	BRA	WSTART		then go do a warm start
                            	   703: 
04:00000F92 7401            	   704: PBYTE	MOVEQ	#1,D2		send two hex characters from D1's low byte
04:00000F94 E919            	   705: PBYTE1	ROL.B	#4,D1		get the next nybble
04:00000F96 1001            	   706: 	MOVE.B	D1,D0
04:00000F98 C03C000F        	   707: 	AND.B	#$F,D0		strip off garbage
04:00000F9C D03C0030        	   708: 	ADD.B	#'0',D0         make it into ASCII
04:00000FA0 B03C0039        	   709: 	CMP.B	#'9',D0
04:00000FA4 6302            	   710: 	BLS	PBYTE2
04:00000FA6 5E00            	   711: 	ADDQ.B	#7,D0		adjust if greater than 9
04:00000FA8 6100FA60        	   712: PBYTE2	BSR	GOAUXO		send it out
04:00000FAC 51CAFFE6        	   713: 	DBRA	D2,PBYTE1	then send the next nybble
04:00000FB0 4E75            	   714: 	RTS
