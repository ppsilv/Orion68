                            	  1025: *
                            	  1026: *******************************************************************
                            	  1027: *
                            	  1028: * *** SETVAL *** FIN *** ENDCHK *** ERROR (& friends) ***
                            	  1029: *
                            	  1030: * 'SETVAL' expects a variable, followed by an equal sign and then
                            	  1031: * an expression.  It evaluates the expression and sets the variable
                            	  1032: * to that value.
                            	  1033: *
                            	  1034: * 'FIN' checks the end of a command.  If it ended with ":",
                            	  1035: * execution continues.	If it ended with a CR, it finds the
                            	  1036: * the next line and continues from there.
                            	  1037: *
                            	  1038: * 'ENDCHK' checks if a command is ended with a CR. This is
                            	  1039: * required in certain commands, such as GOTO, RETURN, STOP, etc.
                            	  1040: *
                            	  1041: * 'ERROR' prints the string pointed to by A0. It then prints the
                            	  1042: * line pointed to by CURRNT with a "?" inserted at where the
                            	  1043: * old text pointer (should be on top of the stack) points to.
                            	  1044: * Execution of Tiny BASIC is stopped and a warm start is done.
                            	  1045: * If CURRNT is zero (indicating a direct command), the direct
                            	  1046: * command is not printed. If CURRNT is -1 (indicating
                            	  1047: * 'INPUT' command in progress), the input line is not printed
                            	  1048: * and execution is not terminated but continues at 'INPERR'.
                            	  1049: *
                            	  1050: * Related to 'ERROR' are the following:
                            	  1051: * 'QWHAT' saves text pointer on stack and gets "What?" message.
                            	  1052: * 'AWHAT' just gets the "What?" message and jumps to 'ERROR'.
                            	  1053: * 'QSORRY' and 'ASORRY' do the same kind of thing.
                            	  1054: * 'QHOW' and 'AHOW' also do this for "How?".
                            	  1055: *
04:000011F6 6100FECE        	  1056: SETVAL	BSR	TSTV		variable name?
04:000011FA 653A            	  1057: 	BCS	QWHAT		if not, say "What?"
04:000011FC 2F00            	  1058: 	MOVE.L	D0,-(SP)	save the variable's address
04:000011FE 610002B6        	  1059: 	JSR	TSTC		get past the "=" sign
04:00001202 3D              	  1060: 	DC.B	'=',SV1-*
04:00001203 0B
04:00001204 6100FDD8        	  1061: 	BSR	EXPR		evaluate the expression
04:00001208 2C5F            	  1062: 	MOVE.L	(SP)+,A6
04:0000120A 2C80            	  1063: 	MOVE.L	D0,(A6) 	and save its value in the variable
04:0000120C 4E75            	  1064: 	RTS
04:0000120E 6026            	  1065: SV1	BRA	QWHAT		if no "=" sign
                            	  1066: 
04:00001210 610002A4        	  1067: FIN	JSR	TSTC		*** FIN ***
04:00001214 3A              	  1068: 	DC.B	':',FI1-*
04:00001215 07
04:00001216 588F            	  1069: 	ADDQ.L	#4,SP		if ":", discard return address
04:00001218 6000FA22        	  1070: 	BRA	RUNSML		continue on the same line
04:0000121C 61000298        	  1071: FI1	JSR	TSTC		not ":", is it a CR?
04:00001220 0D              	  1072: 	DC.B	CR,FI2-*
04:00001221 07
04:00001222 588F            	  1073: 	ADDQ.L	#4,SP		yes, purge return address
04:00001224 6000F9F6        	  1074: 	BRA	RUNNXL		execute the next line
04:00001228 4E75            	  1075: FI2	RTS			else return to the caller
                            	  1076: 
04:0000122A 610002D8        	  1077: ENDCHK	JSR	IGNBLK
04:0000122E 0C10000D        	  1078: 	CMP.B	#CR,(A0)	does it end with a CR?
04:00001232 6602            	  1079: 	BNE	QWHAT		if not, say "WHAT?"
04:00001234 4E75            	  1080: 	RTS
                            	  1081: 
04:00001236 2F08            	  1082: QWHAT	MOVE.L	A0,-(SP)
04:00001238 4DF900000592    	  1083: AWHAT	LEA	WHTMSG,A6
04:0000123E 61000334        	  1084: ERROR	JSR	PRMESG		display the error message
04:00001242 205F            	  1085: 	MOVE.L	(SP)+,A0	restore the text pointer
04:00001244 203900080AA6    	  1086: 	MOVE.L	CURRNT,D0	get the current line number
04:0000124A 6700F804        	  1087: 	BEQ	WSTART		if zero, do a warm start
04:0000124E B0BCFFFFFFFF    	  1088: 	CMP.L	#-1,D0		is the line no. pointer = -1?
04:00001254 6700FBE4        	  1089: 	BEQ	INPERR		if so, redo input
04:00001258 1F10            	  1090: 	MOVE.B	(A0),-(SP)	save the char. pointed to
04:0000125A 4210            	  1091: 	CLR.B	(A0)		put a zero where the error is
04:0000125C 227900080AA6    	  1092: 	MOVE.L	CURRNT,A1	point to start of current line
04:00001262 61000238        	  1093: 	JSR	PRTLN		display the line in error up to the 0
04:00001266 109F            	  1094: 	MOVE.B	(SP)+,(A0)	restore the character
04:00001268 103C003F        	  1095: 	MOVE.B	#'?',D0         display a "?"
04:0000126C 6100F794        	  1096: 	BSR	GOOUT
04:00001270 4240            	  1097: 	CLR	D0
04:00001272 5389            	  1098: 	SUBQ.L	#1,A1		point back to the error char.
04:00001274 61000158        	  1099: 	JSR	PRTSTG		display the rest of the line
04:00001278 6000F7D6        	  1100: 	BRA	WSTART		and do a warm start
04:0000127C 2F08            	  1101: QSORRY	MOVE.L	A0,-(SP)
04:0000127E 4DF90000059A    	  1102: ASORRY	LEA	SRYMSG,A6
04:00001284 60B8            	  1103: 	BRA	ERROR
04:00001286 2F08            	  1104: QHOW	MOVE.L	A0,-(SP)	Error: "How?"
04:00001288 4DF90000058B    	  1105: AHOW	LEA	HOWMSG,A6
04:0000128E 60AE            	  1106: 	BRA	ERROR
                            	  1107: *
                            	  1108: *******************************************************************
                            	  1109: *
                            	  1110: * *** GETLN *** FNDLN (& friends) ***
                            	  1111: *
                            	  1112: * 'GETLN' reads in input line into 'BUFFER'. It first prompts with
                            	  1113: * the character in D0 (given by the caller), then it fills the
                            	  1114: * buffer and echos. It ignores LF's but still echos
                            	  1115: * them back. Control-H is used to delete the last character
                            	  1116: * entered (if there is one), and control-X is used to delete the
                            	  1117: * whole line and start over again. CR signals the end of a line,
                            	  1118: * and causes 'GETLN' to return.
                            	  1119: *
                            	  1120: * 'FNDLN' finds a line with a given line no. (in D1) in the
                            	  1121: * text save area.  A1 is used as the text pointer. If the line
                            	  1122: * is found, A1 will point to the beginning of that line
                            	  1123: * (i.e. the high byte of the line no.), and flags are NC & Z.
                            	  1124: * If that line is not there and a line with a higher line no.
                            	  1125: * is found, A1 points there and flags are NC & NZ. If we reached
                            	  1126: * the end of the text save area and cannot find the line, flags
                            	  1127: * are C & NZ.
                            	  1128: * 'FNDLN' will initialize A1 to the beginning of the text save
                            	  1129: * area to start the search. Some other entries of this routine
                            	  1130: * will not initialize A1 and do the search.
                            	  1131: * 'FNDLNP' will start with A1 and search for the line no.
                            	  1132: * 'FNDNXT' will bump A1 by 2, find a CR and then start search.
                            	  1133: * 'FNDSKP' uses A1 to find a CR, and then starts the search.
                            	  1134: *
04:00001290 6100F770        	  1135: GETLN	BSR	GOOUT		display the prompt
04:00001294 103C0020        	  1136: 	MOVE.B	#' ',D0         and a space
04:00001298 6100F768        	  1137: 	BSR	GOOUT
04:0000129C 41F900080AD2    	  1138: 	LEA	BUFFER,A0	A0 is the buffer pointer
04:000012A2 610002B8        	  1139: GL1	JSR	CHKIO		check keyboard
04:000012A6 67FA            	  1140: 	BEQ	GL1		wait for a char. to come in
04:000012A8 B03C0008        	  1141: 	CMP.B	#CTRLH,D0	delete last character?
04:000012AC 6726            	  1142: 	BEQ	GL3		if so
04:000012AE B03C0018        	  1143: 	CMP.B	#CTRLX,D0	delete the whole line?
04:000012B2 6744            	  1144: 	BEQ	GL4		if so
04:000012B4 B03C000D        	  1145: 	CMP.B	#CR,D0		accept a CR
04:000012B8 6706            	  1146: 	BEQ	GL2
04:000012BA B03C0020        	  1147: 	CMP.B	#' ',D0         if other control char., discard it
04:000012BE 65E2            	  1148: 	BCS	GL1
04:000012C0 10C0            	  1149: GL2	MOVE.B	D0,(A0)+	save the char.
04:000012C2 6100F73E        	  1150: 	BSR	GOOUT		echo the char back out
04:000012C6 B03C000D        	  1151: 	CMP.B	#CR,D0		if it's a CR, end the line
04:000012CA 675E            	  1152: 	BEQ	GL7
04:000012CC B1FC00080B21    	  1153: 	CMP.L	#(BUFFER+BUFLEN-1),A0	any more room?
04:000012D2 65CE            	  1154: 	BCS	GL1		yes: get some more, else delete last char.
04:000012D4 103C0008        	  1155: GL3	MOVE.B	#CTRLH,D0	delete a char. if possible
04:000012D8 6100F728        	  1156: 	BSR	GOOUT
04:000012DC 103C0020        	  1157: 	MOVE.B	#' ',D0
04:000012E0 6100F720        	  1158: 	BSR	GOOUT
04:000012E4 B1FC00080AD2    	  1159: 	CMP.L	#BUFFER,A0	any char.'s left?
04:000012EA 63B6            	  1160: 	BLS	GL1		if not
04:000012EC 103C0008        	  1161: 	MOVE.B	#CTRLH,D0	if so, finish the BS-space-BS sequence
04:000012F0 6100F710        	  1162: 	BSR	GOOUT
04:000012F4 5388            	  1163: 	SUBQ.L	#1,A0		decrement the text pointer
04:000012F6 60AA            	  1164: 	BRA	GL1		back for more
04:000012F8 2208            	  1165: GL4	MOVE.L	A0,D1		delete the whole line
04:000012FA 92BC00080AD2    	  1166: 	SUB.L	#BUFFER,D1	figure out how many backspaces we need
04:00001300 671E            	  1167: 	BEQ	GL6		if none needed, branch
04:00001302 5341            	  1168: 	SUBQ	#1,D1		adjust for DBRA
04:00001304 103C0008        	  1169: GL5	MOVE.B	#CTRLH,D0	and display BS-space-BS sequences
04:00001308 6100F6F8        	  1170: 	BSR	GOOUT
04:0000130C 103C0020        	  1171: 	MOVE.B	#' ',D0
04:00001310 6100F6F0        	  1172: 	BSR	GOOUT
04:00001314 103C0008        	  1173: 	MOVE.B	#CTRLH,D0
04:00001318 6100F6E8        	  1174: 	BSR	GOOUT
04:0000131C 51C9FFE6        	  1175: 	DBRA	D1,GL5
04:00001320 41F900080AD2    	  1176: GL6	LEA	BUFFER,A0	reinitialize the text pointer
04:00001326 6000FF7A        	  1177: 	BRA	GL1		and go back for more
04:0000132A 103C000A        	  1178: GL7	MOVE.B	#LF,D0		echo a LF for the CR
04:0000132E 6100F6D2        	  1179: 	BSR	GOOUT
04:00001332 4E75            	  1180: 	RTS
                            	  1181: 
04:00001334 B2BC0000FFFF    	  1182: FNDLN	CMP.L	#$FFFF,D1	line no. must be < 65535
04:0000133A 6400FF4A        	  1183: 	BCC	QHOW
04:0000133E 227AF6D6        	  1184: 	MOVE.L	TXTBGN,A1	init. the text save pointer
                            	  1185: 
04:00001342 247900080AC6    	  1186: FNDLNP	MOVE.L	TXTUNF,A2	check if we passed the end
04:00001348 538A            	  1187: 	SUBQ.L	#1,A2
04:0000134A B4C9            	  1188: 	CMP	A1,A2
04:0000134C 650C            	  1189: 	BCS	FNDRET		if so, return with Z=0 & C=1
04:0000134E 1419            	  1190: 	MOVE.B	(A1)+,D2	if not, get a line no.
04:00001350 E14A            	  1191: 	LSL	#8,D2
04:00001352 1411            	  1192: 	MOVE.B	(A1),D2
04:00001354 5389            	  1193: 	SUBQ.L	#1,A1
04:00001356 B441            	  1194: 	CMP	D1,D2		is this the line we want?
04:00001358 6502            	  1195: 	BCS	FNDNXT		no, not there yet
04:0000135A 4E75            	  1196: FNDRET	RTS			return the cond. codes
                            	  1197: 
04:0000135C 5489            	  1198: FNDNXT	ADDQ.L	#2,A1		find the next line
                            	  1199: 
04:0000135E 0C19000D        	  1200: FNDSKP	CMP.B	#CR,(A1)+	try to find a CR
04:00001362 66FA            	  1201: 	BNE	FNDSKP		keep looking
04:00001364 60DC            	  1202: 	BRA	FNDLNP		check if end of text
