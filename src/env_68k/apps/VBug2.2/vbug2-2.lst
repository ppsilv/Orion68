03:000002D8 08290005000B    	    38:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
03:000002DE 67F8            	    39:         beq     .WaitTx
03:000002E0 13400001        	    40:         move.b  D0,THR(A1)      ; transmit byte
03:000002E4 225F            	    41:         MOVE.L (SP)+,A1
03:000002E6 4E75            	    42:         RTS
