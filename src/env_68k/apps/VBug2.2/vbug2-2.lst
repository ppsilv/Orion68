                            	     5:     Align 2
                            	     6: ; -----------------------------------------------------------------------------
                            	     7: ; O SEU CÓDIGO DO PDS317 (Agora rodando na RAM)
                            	     8: ; -----------------------------------------------------------------------------
                            	     9: 
                            	    10: ; --------------------------------
                            	    11: ; TRAP_CCONIN - Ler caractere do console
                            	    12: ; Saída: D0.L - Caractere lido
                            	    13: ; --------------------------------
                            	    14: trap_cconin:
04:000002E4 2F0A            	    15:     MOVE.L A2,-(SP)
04:000002E6 247900080418    	    16:     MOVE.L  (cconin),A2
04:000002EC 4E92            	    17:     JSR     (A2)
04:000002EE 245F            	    18:     MOVE.L (SP)+,A2
                            	    19: 
04:000002F0 0280000000FF    	    20:     ANDI.L  #$FF,D0       ; Mantém apenas o byte inferior
04:000002F6 4E73            	    21:     RTE                   ; Retorna da exceção
                            	    22: 
                            	    23: ; --------------------------------
                            	    24: ; TRAP_CCONOUT - Escrever caractere no console
                            	    25: ; Entrada: D1.L - Caractere a escrever
                            	    26: ; --------------------------------
                            	    27: trap_cconout:
04:000002F8 2F0A            	    28:     MOVE.L A2,-(SP)
04:000002FA 1001            	    29:     MOVE.B  D1,D0
04:000002FC 247900080414    	    30:     MOVE.L  (cconout),A2        ; Busca o endereço da rotina física da UART
04:00000302 4E92            	    31:     JSR     (A2)
04:00000304 245F            	    32:     MOVE.L (SP)+,A2
04:00000306 4E73            	    33:     RTE      
                            	    34:                 
                            	    35: 
                            	    36: trap_strout:
04:00000308 2049            	    37:     MOVE.L  A1,A0
04:0000030A 4EB9000001F0    	    38:     JSR     WriteStringConout
04:00000310 4E73            	    39:     RTE
                            	    40: 
                            	    41: 
                            	    42: ; --------------------------------
                            	    43: ; TRAP_PTERM0 - Terminar programa
                            	    44: ; --------------------------------
                            	    45: trap_pterm0:
04:00000312 303C0000        	    46:     move.w  #0,d0         ; Código de saída 0
04:00000316 6102            	    47:     bsr     hardware_exit ; Chama rotina de término
04:00000318 4E73            	    48:     RTE     
                            	    49: 
                            	    50: ; --------------------------------
                            	    51: ; hardware_exit - Terminar execução
                            	    52: ; Entrada: D0.W - Código de saída
                            	    53: ; --------------------------------
                            	    54: hardware_exit:
                            	    55:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    56:     ; Exemplo: parar o processador
                            	    57:     ; stop    #$2700
                            	    58: 
                            	    59:     ; Exemplo simples: loop infinito
04:0000031A 60FE            	    60:     BRA     hardware_exit
04:0000031C 4E75            	    61:     RTS
                            	    62: 
                            	    63: InitTrap1:
                            	    64:     ; -------------------------------------------------------------------------
                            	    65:     ; COMO INSTALAR NA RAM:
                            	    66:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	    67:     ; -------------------------------------------------------------------------
                            	    68:     ;LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
                            	    69:     ;MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
04:0000031E 4E75            	    70:     RTS
                            	    71:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    72: 

