                            	  1204: *
                            	  1205: *******************************************************************
                            	  1206: *
                            	  1207: * *** MVUP *** MVDOWN *** POPA *** PUSHA ***
                            	  1208: *
                            	  1209: * 'MVUP' moves a block up from where A1 points to where A2 points
                            	  1210: * until A1=A3
                            	  1211: *
                            	  1212: * 'MVDOWN' moves a block down from where A1 points to where A3
                            	  1213: * points until A1=A2
                            	  1214: *
                            	  1215: * 'POPA' restores the 'FOR' loop variable save area from the stack
                            	  1216: *
                            	  1217: * 'PUSHA' stacks for 'FOR' loop variable save area onto the stack
                            	  1218: *
04:00001366 B7C9            	  1219: MVUP	CMP.L	A1,A3		see the above description
04:00001368 6704            	  1220: 	BEQ	MVRET
04:0000136A 14D9            	  1221: 	MOVE.B	(A1)+,(A2)+
04:0000136C 60F8            	  1222: 	BRA	MVUP
04:0000136E 4E75            	  1223: MVRET	RTS
                            	  1224: 
04:00001370 B5C9            	  1225: MVDOWN	CMP.L	A1,A2		see the above description
04:00001372 67FA            	  1226: 	BEQ	MVRET
04:00001374 1721            	  1227: 	MOVE.B	-(A1),-(A3)
04:00001376 60F8            	  1228: 	BRA	MVDOWN
                            	  1229: 
04:00001378 2C5F            	  1230: POPA	MOVE.L	(SP)+,A6	A6 = return address
04:0000137A 23DF00080AB2    	  1231: 	MOVE.L	(SP)+,LOPVAR	restore LOPVAR, but zero means no more
04:00001380 6718            	  1232: 	BEQ	PP1
04:00001382 23DF00080AB6    	  1233: 	MOVE.L	(SP)+,LOPINC	if not zero, restore the rest
04:00001388 23DF00080ABA    	  1234: 	MOVE.L	(SP)+,LOPLMT
04:0000138E 23DF00080ABE    	  1235: 	MOVE.L	(SP)+,LOPLN
04:00001394 23DF00080AC2    	  1236: 	MOVE.L	(SP)+,LOPPT
04:0000139A 4ED6            	  1237: PP1	JMP	(A6)		return
                            	  1238: 
04:0000139C 223900080ACE    	  1239: PUSHA	MOVE.L	STKLMT,D1	Are we running out of stack room?
04:000013A2 928F            	  1240: 	SUB.L	SP,D1
04:000013A4 6400FED6        	  1241: 	BCC	QSORRY		if so, say we're sorry
04:000013A8 2C5F            	  1242: 	MOVE.L	(SP)+,A6	else get the return address
04:000013AA 223900080AB2    	  1243: 	MOVE.L	LOPVAR,D1	save loop variables
04:000013B0 6718            	  1244: 	BEQ	PU1		if LOPVAR is zero, that's all
04:000013B2 2F3900080AC2    	  1245: 	MOVE.L	LOPPT,-(SP)	else save all the others
04:000013B8 2F3900080ABE    	  1246: 	MOVE.L	LOPLN,-(SP)
04:000013BE 2F3900080ABA    	  1247: 	MOVE.L	LOPLMT,-(SP)
04:000013C4 2F3900080AB6    	  1248: 	MOVE.L	LOPINC,-(SP)
04:000013CA 2F01            	  1249: PU1	MOVE.L	D1,-(SP)
04:000013CC 4ED6            	  1250: 	JMP	(A6)		return
