04:00001454 3200            	  1329: 	MOVE	D0,D1		low word into low
04:00001456 82FC000A        	  1330: 	DIVU	#10,D1		divide low word
04:0000145A 2001            	  1331: 	MOVE.L	D1,D0		D0 = remainder
04:0000145C 4841            	  1332: 	SWAP	D1		R/Q becomes Q/R
