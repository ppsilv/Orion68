                            	     1: ;Uart register offsets
                            	     2: UART_BASE   equ     $FF4000
                            	     3: 
                            	     4: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	     5: ; Initialize uart
                            	     6: ; Change A1
                            	     7: ; Parametros: none
                            	     8: ; ----------------------------------------------------------------------
                            	     9: ;;InitUart:
                            	    10: ;;        move.l  currentUart,A1
                            	    11: ;;        move.l  currentBaudRate,D0
                            	    12: ;;        move.b  #%10000011,LCR(A1) ;DLAB=1
                            	    13: ;;        move.b  #$08,DLL(A1)       ; set divisor latch low byte
                            	    14: ;;        move.b  #$00,DLM(A1)       ; set divisor latch high byte
                            	    15: ;;        move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
                            	    16: ;;        move.b  #%00001101,FCR(A1) ; enable FIFO
                            	    17: ;;        clr.b   SCR(A1)            ; clear the scratch register
                            	    18: ;;        RTS
                            	    19: InitUart1:
03:000002A2 227900080410    	    20:         move.l  currentUart,A1
03:000002A8 203900080A58    	    21:         move.l  currentBaudRate,D0
03:000002AE 137C000D0005    	    22:         move.b  #%00001101,FCR(a1)      ; enable FIFO
03:000002B4 137C00830007    	    23:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
03:000002BA 13400001        	    24:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
03:000002BE E088            	    25:         lsr.l   #8,D0                   ; Shift right 8 bits
03:000002C0 13400003        	    26:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
03:000002C4 08A900070007    	    27:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
03:000002CA 4229000F        	    28:         clr.b   SCR(a1)                 ; clear the scratch register
03:000002CE 4E75            	    29:         RTS
