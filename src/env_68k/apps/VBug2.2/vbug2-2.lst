                            	   716: *
                            	   717: *******************************************************************
                            	   718: *
                            	   719: * *** POKE *** & CALL ***
                            	   720: *
                            	   721: * 'POKE expr1,expr2' stores the byte from 'expr2' into the memory
                            	   722: * address specified by 'expr1'.
                            	   723: *
                            	   724: * 'CALL expr' jumps to the machine language subroutine whose
                            	   725: * starting address is specified by 'expr'.  The subroutine can use
                            	   726: * all registers but must leave the stack the way it found it.
                            	   727: * The subroutine returns to the interpreter by executing an RTS.
                            	   728: *
04:00000FB2 612A            	   729: POKE	BSR	EXPR		get the memory address
04:00000FB4 61000500        	   730: 	JSR	TSTC		it must be followed by a comma
04:00000FB8 2C              	   731: 	DC.B	',',PKER-*
04:00000FB9 0D
04:00000FBA 2F00            	   732: 	MOVE.L	D0,-(SP)	save the address
04:00000FBC 6120            	   733: 	BSR	EXPR		get the byte to be POKE'd
04:00000FBE 225F            	   734: 	MOVE.L	(SP)+,A1	get the address back
04:00000FC0 1280            	   735: 	MOVE.B	D0,(A1) 	store the byte in memory
04:00000FC2 6000FD2C        	   736: 	BRA	FINISH
04:00000FC6 6000026E        	   737: PKER	JMP	QWHAT		if no comma, say "What?"
                            	   738: 
04:00000FCA 6112            	   739: CALL	BSR	EXPR		get the subroutine's address
04:00000FCC 4A80            	   740: 	TST.L	D0		make sure we got a valid address
04:00000FCE 670002B6        	   741: 	BEQ.W	QHOW		if not, say "How?"
04:00000FD2 2F08            	   742: 	MOVE.L	A0,-(SP)	save the text pointer
04:00000FD4 2240            	   743: 	MOVE.L	D0,A1
04:00000FD6 4E91            	   744: 	JSR	(A1)		jump to the subroutine
04:00000FD8 205F            	   745: 	MOVE.L	(SP)+,A0	restore the text pointer
04:00000FDA 6000FD14        	   746: 	BRA	FINISH
                            	   747: *
                            	   748: *******************************************************************
                            	   749: *
                            	   750: * *** EXPR ***
                            	   751: *
                            	   752: * 'EXPR' evaluates arithmetical or logical expressions.
                            	   753: * <EXPR>::=<EXPR2>
                            	   754: *	   <EXPR2><rel.op.><EXPR2>
                            	   755: * where <rel.op.> is one of the operators in TAB8 and the result
                            	   756: * of these operations is 1 if true and 0 if false.
                            	   757: * <EXPR2>::=(+ or -)<EXPR3>(+ or -)<EXPR3>(...
                            	   758: * where () are optional and (... are optional repeats.
                            	   759: * <EXPR3>::=<EXPR4>( <* or /><EXPR4> )(...
                            	   760: * <EXPR4>::=<variable>
                            	   761: *	    <function>
                            	   762: *	    (<EXPR>)
                            	   763: * <EXPR> is recursive so that the variable '@' can have an <EXPR>
                            	   764: * as an index, functions can have an <EXPR> as arguments, and
                            	   765: * <EXPR4> can be an <EXPR> in parenthesis.
                            	   766: *
04:00000FDE 6152            	   767: EXPR	BSR	EXPR2
04:00000FE0 2F00            	   768: 	MOVE.L	D0,-(SP)	save <EXPR2> value
04:00000FE2 43FAFB7F        	   769: 	LEA	TAB8,A1 	look up a relational operator
04:00000FE6 45FAFBC0        	   770: 	LEA	TAB8_1,A2
04:00000FEA 6000FBD2        	   771: 	BRA	EXEC		go do it
                            	   772: 
04:00000FEE 6132            	   773: XP11	BSR	XP18		is it ">="?
04:00000FF0 6D24            	   774: 	BLT	XPRT0		no, return D0=0
04:00000FF2 6026            	   775: 	BRA	XPRT1		else return D0=1
                            	   776: 
04:00000FF4 612C            	   777: XP12	BSR	XP18		is it "<>"?
04:00000FF6 671E            	   778: 	BEQ	XPRT0		no, return D0=0
04:00000FF8 6020            	   779: 	BRA	XPRT1		else return D0=1
                            	   780: 
04:00000FFA 6126            	   781: XP13	BSR	XP18		is it ">"?
04:00000FFC 6F18            	   782: 	BLE	XPRT0		no, return D0=0
04:00000FFE 601A            	   783: 	BRA	XPRT1		else return D0=1
                            	   784: 
04:00001000 6120            	   785: XP14	BSR	XP18		is it "<="?
04:00001002 6E12            	   786: 	BGT	XPRT0		no, return D0=0
04:00001004 6014            	   787: 	BRA	XPRT1		else return D0=1
                            	   788: 
04:00001006 611A            	   789: XP15	BSR	XP18		is it "="?
04:00001008 660C            	   790: 	BNE	XPRT0		if not, return D0=0
04:0000100A 600E            	   791: 	BRA	XPRT1		else return D0=1
04:0000100C 4E75            	   792: XP15RT	RTS
                            	   793: 
04:0000100E 6112            	   794: XP16	BSR	XP18		is it "<"?
04:00001010 6C04            	   795: 	BGE	XPRT0		if not, return D0=0
04:00001012 6006            	   796: 	BRA	XPRT1		else return D0=1
04:00001014 4E75            	   797: XP16RT	RTS
                            	   798: 
04:00001016 7000            	   799: XPRT0	CLR.L	D0		return D0=0 (false)
04:00001018 4E75            	   800: 	RTS
                            	   801: 
04:0000101A 7001            	   802: XPRT1	MOVEQ	#1,D0		return D0=1 (true)
04:0000101C 4E75            	   803: 	RTS
                            	   804: 
04:0000101E 201F            	   805: XP17	MOVE.L	(SP)+,D0	it's not a rel. operator
04:00001020 4E75            	   806: 	RTS			return D0=<EXPR2>
                            	   807: 
04:00001022 201F            	   808: XP18	MOVE.L	(SP)+,D0	reverse the top two stack items
04:00001024 221F            	   809: 	MOVE.L	(SP)+,D1
04:00001026 2F00            	   810: 	MOVE.L	D0,-(SP)
04:00001028 2F01            	   811: 	MOVE.L	D1,-(SP)
04:0000102A 6106            	   812: 	BSR	EXPR2		do second <EXPR2>
04:0000102C 221F            	   813: 	MOVE.L	(SP)+,D1
04:0000102E B280            	   814: 	CMP.L	D0,D1		compare with the first result
