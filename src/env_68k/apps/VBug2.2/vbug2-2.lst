                            	     1:         section .code
                            	     2:         even
                            	     3: 
                            	     4: 
                            	     5: SPECIAL_KEY_UP      equ     1
                            	     6: SPECIAL_KEY_DOWN    equ     1
                            	     7: KEY_DOWN            equ     1
                            	     8: 
                            	     9: 
                            	    10: 
                            	    11: ; =============================================================================
                            	    12: ; MACROS DE MANIPULAÇÃO DE FLAGS DIRETAMENTE NA MEMÓRIA (VASM)
                            	    13: ; =============================================================================
                            	    14: 
                            	    15: ; -----------------------------------------------------------------------------
                            	    16: ; MACRO: SET_FLAG
                            	    17: ; Parâmetros: \1 = Máscara do Bit (ex: SPECIAL_KEY_MASK)
                            	    18: ;             \2 = Variável na RAM (ex: flg_system)
                            	    19: ; -----------------------------------------------------------------------------
                            	    20: SET_FLAG    macro
                            	    21:             or.w    #\1,\2
                            	    22:             endm
                            	    23: 
                            	    24: ; -----------------------------------------------------------------------------
                            	    25: ; MACRO: RESET_FLAG
                            	    26: ; Parâmetros: \1 = Máscara do Bit (ex: SPECIAL_KEY_MASK)
                            	    27: ;             \2 = Variável na RAM (ex: flg_system)
                            	    28: ; -----------------------------------------------------------------------------
                            	    29: RESET_FLAG  macro
                            	    30:             and.w   #\1,\2
                            	    31:             endm
                            	    32: 
                            	    33: ; -----------------------------------------------------------------------------
                            	    34: ; MACRO: TEST_FLAG
                            	    35: ; Parâmetros: \1 = Máscara do Bit (ex: SPECIAL_KEY_MASK)
                            	    36: ;             \2 = Variável na RAM (ex: flg_system)
                            	    37: ; Nota: Altera a flag Z (Zero) da CPU para uso com BEQ/BNE logo em seguida.
                            	    38: ; -----------------------------------------------------------------------------
                            	    39: TEST_FLAG   macro
                            	    40:             and.w   #\1,\2
                            	    41:             endm
                            	    42: 

