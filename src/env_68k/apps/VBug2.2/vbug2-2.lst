03:000002D0 08290005000B    	    38:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
03:000002D6 67F8            	    39:         beq     .WaitTx
03:000002D8 13400001        	    40:         move.b  D0,THR(A1)      ; transmit byte
03:000002DC 225F            	    41:         MOVE.L (SP)+,A1
03:000002DE 4E75            	    42:         RTS
