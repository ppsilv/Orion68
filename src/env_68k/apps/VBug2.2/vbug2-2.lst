                            	  1413: 
                            	  1414: *
                            	  1415: * ===== Skip over blanks in the text pointed to by A0.
                            	  1416: *
04:00001504 0C100020        	  1417: IGNBLK	CMP.B	#' ',(A0)       see if it's a space
04:00001508 6604            	  1418: 	BNE	IGBRET		if so, swallow it
04:0000150A 5288            	  1419: IGB1	ADDQ.L	#1,A0		increment the text pointer
04:0000150C 60F6            	  1420: 	BRA	IGNBLK
04:0000150E 4E75            	  1421: IGBRET	RTS
                            	  1422: 
                            	  1423: *
                            	  1424: * ===== Convert the line of text in the input buffer to upper
                            	  1425: *	case (except for stuff between quotes).
                            	  1426: *
04:00001510 41F900080AD2    	  1427: TOUPBUF LEA	BUFFER,A0	set up text pointer
04:00001516 4201            	  1428: 	CLR.B	D1		clear quote flag
04:00001518 1018            	  1429: TOUPB1	MOVE.B	(A0)+,D0	get the next text char.
04:0000151A B03C000D        	  1430: 	CMP.B	#CR,D0		is it end of line?
04:0000151E 6718            	  1431: 	BEQ	TOUPBRT 	if so, return
04:00001520 B03C0022        	  1432: 	CMP.B	#'"',D0         a double quote?
04:00001524 6714            	  1433: 	BEQ	DOQUO
04:00001526 B03C0027        	  1434: 	CMP.B	#'''',D0        or a single quote?
04:0000152A 670E            	  1435: 	BEQ	DOQUO
04:0000152C 4A01            	  1436: 	TST.B	D1		inside quotes?
04:0000152E 66E8            	  1437: 	BNE	TOUPB1		if so, do the next one
04:00001530 6118            	  1438: 	BSR	TOUPPER 	convert to upper case
04:00001532 1100            	  1439: 	MOVE.B	D0,-(A0)	store it
04:00001534 5288            	  1440: 	ADDQ.L	#1,A0
04:00001536 60E0            	  1441: 	BRA	TOUPB1		and go back for more
04:00001538 4E75            	  1442: TOUPBRT RTS
                            	  1443: 
04:0000153A 4A01            	  1444: DOQUO	TST.B	D1		are we inside quotes?
04:0000153C 6604            	  1445: 	BNE	DOQUO1
04:0000153E 1200            	  1446: 	MOVE.B	D0,D1		if not, toggle inside-quotes flag
04:00001540 60D6            	  1447: 	BRA	TOUPB1
04:00001542 B200            	  1448: DOQUO1	CMP.B	D0,D1		make sure we're ending proper quote
04:00001544 66D2            	  1449: 	BNE	TOUPB1		if not, ignore it
04:00001546 4201            	  1450: 	CLR.B	D1		else clear quote flag
04:00001548 60CE            	  1451: 	BRA	TOUPB1
                            	  1452: 
                            	  1453: *
                            	  1454: * ===== Convert the character in D0 to upper case
                            	  1455: *
04:0000154A B03C0061        	  1456: TOUPPER CMP.B	#'a',D0         is it < 'a'?
04:0000154E 650A            	  1457: 	BCS	TOUPRET
04:00001550 B03C007A        	  1458: 	CMP.B	#'z',D0         or > 'z'?
04:00001554 6204            	  1459: 	BHI	TOUPRET
04:00001556 903C0020        	  1460: 	SUB.B	#32,D0		if not, make it upper case
04:0000155A 4E75            	  1461: TOUPRET RTS
                            	  1462: 
                            	  1463: *
                            	  1464: * 'CHKIO' checks the input. If there's no input, it will return
                            	  1465: * to the caller with the Z flag set. If there is input, the Z
                            	  1466: * flag is cleared and the input byte is in D0. However, if a
                            	  1467: * control-C is read, 'CHKIO' will warm-start BASIC and will not
                            	  1468: * return to the caller.
                            	  1469: *
04:0000155C 6100F4A8        	  1470: CHKIO	JSR	GOIN		get input if possible
04:00001560 670A            	  1471: 	BEQ	CHKRET		if Zero, no input
04:00001562 B03C0003        	  1472: 	CMP.B	#CTRLC,D0	is it control-C?
04:00001566 6604            	  1473: 	BNE	CHKRET		if not
04:00001568 6000F4E6        	  1474: 	JMP	WSTART		if so, do a warm start
04:0000156C 4E75            	  1475: CHKRET	RTS
                            	  1476: 
                            	  1477: *
                            	  1478: * ===== Display a CR-LF sequence
                            	  1479: *
04:0000156E 4DF9000005A0    	  1480: CRLF	LEA	CLMSG,A6
                            	  1481: 
                            	  1482: *
                            	  1483: * ===== Display a zero-ended string pointed to by register A6
                            	  1484: *
04:00001574 101E            	  1485: PRMESG	MOVE.B	(A6)+,D0	get the char.
04:00001576 6706            	  1486: 	BEQ	PRMRET		if it's zero, we're done
04:00001578 6100F488        	  1487: 	BSR	GOOUT		else display it
04:0000157C 60F6            	  1488: 	BRA	PRMESG
04:0000157E 4E75            	  1489: PRMRET	RTS
                            	  1490: 
                            	  1491: ******************************************************
                            	  1492: * The following routines are the only ones that need *
                            	  1493: * to be changed for a different I/O environment.     *
                            	  1494: ******************************************************
                            	  1495: 
                            	  1496: *
                            	  1497: * ===== Output character to the console (Port 1) from register D0
                            	  1498: *	(Preserves all registers.)
                            	  1499: *
                            	  1500: OUTC
04:00001580 48E77FFE        	  1501: 	MOVEM.L D1-D7/A0-A6,-(A7)
04:00001584 4EB9000001EE    	  1502: 	jsr		WriteConout
04:0000158A 4CDF7FFE        	  1503: 	MOVEM.L (A7)+,D1-D7/A0-A6
04:0000158E 4E75            	  1504: 	RTS
                            	  1505: 
                            	  1506: *
                            	  1507: * ===== Input a character from the console into register D0 (or
                            	  1508: *	return Zero status if there's no character available).
                            	  1509: * Maybe I need to change this tobe not blocant
                            	  1510: INC	
04:00001590 48E77FFE        	  1511: 	MOVEM.L D1-D7/A0-A6,-(A7)
04:00001594 4EB9000001CE    	  1512: 	jsr		ReadConin
04:0000159A C03C007F        	  1513: 	AND.B	#$7F,D0 	zero out the high bit
04:0000159E 4CDF7FFE        	  1514: 	MOVEM.L (A7)+,D1-D7/A0-A6
04:000015A2 4E75            	  1515: 	RTS
                            	  1516: ;;;BTST	#0,$10040	is character ready?
                            	  1517: ;;;	BEQ	INCRET		if not, return Zero status
                            	  1518: ;;;	MOVE.B	$10042,D0	else get the character
                            	  1519: ;;;	AND.B	#$7F,D0 	zero out the high bit
                            	  1520: ;;;INCRET	RTS
                            	  1521: 
                            	  1522: *
                            	  1523: * ===== Output character to the host (Port 2) from register D0
                            	  1524: *	(Preserves all registers.)
                            	  1525: *
                            	  1526: AUXOUT	
04:000015A4 48E77FFE        	  1527: 	MOVEM.L D1-D7/A0-A6,-(A7)
04:000015A8 4EB9000002D0    	  1528: 	jsr		UartWriteChar
04:000015AE 4CDF7FFE        	  1529: 	MOVEM.L (A7)+,D1-D7/A0-A6
04:000015B2 4E75            	  1530: 	RTS
                            	  1531: 
                            	  1532: 
                            	  1533: *
                            	  1534: * ===== Input a character from the host into register D0 (or
                            	  1535: *	return Zero status if there's no character available).
                            	  1536: *
                            	  1537: AUXIN
04:000015B4 48E77FFE        	  1538: 	MOVEM.L D1-D7/A0-A6,-(A7)
04:000015B8 4EB9000002E8    	  1539: 	jsr		UartReadChar
04:000015BE C03C007F        	  1540: 	AND.B	#$7F,D0 	zero out the high bit
04:000015C2 4CDF7FFE        	  1541: 	MOVEM.L (A7)+,D1-D7/A0-A6
04:000015C6 4E75            	  1542: 	RTS
                            	  1543: 
                            	  1544: 
                            	  1545: *
                            	  1546: * ===== Return to the resident monitor, operating system, etc.
                            	  1547: *
                            	  1548: BYEBYE
04:000015C8 4EF90000008C    	  1549: 	jmp	subLoop
                            	  1550: 	;MOVE.B	#228,D7 	return to Tutor
                            	  1551: 	;TRAP	#14
                            	  1552: 
                            	  1553: ;;INITMSG DC.B	CR,LF,'Gordo''s MC68000 Tiny BASIC, v1.2',CR,LF,LF,0
                            	  1554: ;;OKMSG	DC.B	CR,LF,'OK',CR,LF,0
                            	  1555: ;;HOWMSG	DC.B	'How?',CR,LF,0
                            	  1556: ;;WHTMSG	DC.B	'What?',CR,LF,0
                            	  1557: ;;SRYMSG	DC.B	'Sorry.'
                            	  1558: ;;CLMSG	DC.B	CR,LF,0
04:000015CE 00              	  1559: 	DC.B	0	<- for aligning on a word boundary
                            	  1560: LSTROM	EQU	*		end of possible ROM area
                            	  1561: *
                            	  1562: * Internal variables follow:
                            	  1563: *
                            	  1564: ;;RANPNT	DC.L	START		random number pointer
                            	  1565: ;;CURRNT	DS.L	1		Current line pointer
                            	  1566: ;;STKGOS	DS.L	1		Saves stack pointer in 'GOSUB'
                            	  1567: ;;STKINP	DS.L	1		Saves stack pointer during 'INPUT'
                            	  1568: ;;LOPVAR	DS.L	1		'FOR' loop save area
                            	  1569: ;;LOPINC	DS.L	1		increment
                            	  1570: ;;LOPLMT	DS.L	1		limit
                            	  1571: ;;LOPLN	DS.L	1		line number
                            	  1572: ;;LOPPT	DS.L	1		text pointer
                            	  1573: ;;TXTUNF	DS.L	1		points to unfilled text area
                            	  1574: ;;VARBGN	DS.L	1		points to variable area
                            	  1575: ;;STKLMT	DS.L	1		holds lower limit for stack growth
                            	  1576: ;;BUFFER	DS.B	BUFLEN		Keyboard input buffer
                            	  1577: TXT	EQU	$90000 ;*		Beginning of program area
                            	  1578: 	;;END
                            	  1579: 
