                            	    20: 
                            	    21: * Vers. 1.0  1984/7/17	- Original version by Gordon Brandly
                            	    22: *	1.1  1984/12/9	- Addition of '$' print term by Marvin Lipford
                            	    23: *	1.2  1985/4/9	- Bug fix in multiply routine by Rick Murray
                            	    24: 
                            	    25: 
                            	    26: CR	EQU	$0D		ASCII equates
                            	    27: LF	EQU	$0A
                            	    28: TAB	EQU	$09
                            	    29: CTRLC	EQU	$03
                            	    30: CTRLH	EQU	$08
                            	    31: CTRLS	EQU	$13
                            	    32: CTRLX	EQU	$18
                            	    33: 
                            	    34: BUFLEN	EQU	80		length of keyboard input buffer
                            	    35: 
                            	    36: 	;ORG	$900		first free address using Tutor
                            	    37: *
                            	    38: * Standard jump table. You can change these addresses if you are
                            	    39: * customizing this interpreter for a different environment.
                            	    40: *
04:000009FE 601E            	    41: BASIC_START:	jmp	CSTART		Cold Start entry point
04:00000A00 604E            	    42: GOWARM:			jmp	WSTART		Warm Start entry point
04:00000A02 60000B7C        	    43: GOOUT:			jmp	OUTC		Jump to character-out routine
04:00000A06 60000B88        	    44: GOIN:	   		jmp	INC		Jump to character-in routine
04:00000A0A 60000B98        	    45: GOAUXO:			jmp	AUXOUT		Jump to auxiliary-out routine
04:00000A0E 60000BA4        	    46: GOAUXI:			jmp	AUXIN		Jump to auxiliary-in routine
04:00000A12 60000BB4        	    47: GOBYE:			jmp	BYEBYE		Jump to monitor, DOS, etc.
                            	    48: * 
                            	    49: * Modifiable system constants:
                            	    50: *
04:00000A16 00090000        	    51: TXTBGN	DC.L	TXT		beginning of program memory
04:00000A1A 000A0000        	    52: ENDMEM	DC.L	$A0000		end of available memory
                            	    53: *
                            	    54: * The main interpreter starts here:
                            	    55: *
04:00000A1E 2E7AFFFA        	    56: CSTART	MOVE.L	ENDMEM,SP	initialize stack pointer
04:00000A22 4DF90000055E    	    57: 	LEA	INITMSG,A6	tell who we are
04:00000A28 61000B4A        	    58: 	JSR	PRMESG
04:00000A2C 23FAFFE800080AC6	    59: 	MOVE.L	TXTBGN,TXTUNF	init. end-of-program pointer
04:00000A34 203AFFE4        	    60: 	MOVE.L	ENDMEM,D0	get address of end of memory
04:00000A38 90BC00000800    	    61: 	SUB.L	#2048,D0	reserve 2K for the stack
04:00000A3E 23C000080ACE    	    62: 	MOVE.L	D0,STKLMT
04:00000A44 90BC0000006C    	    63: 	SUB.L	#108,D0 	reserve variable area (27 long words)
04:00000A4A 23C000080ACA    	    64: 	MOVE.L	D0,VARBGN
04:00000A50 7000            	    65: WSTART	CLR.L	D0		initialize internal variables
04:00000A52 23C000080AB2    	    66: 	MOVE.L	D0,LOPVAR
04:00000A58 23C000080AAA    	    67: 	MOVE.L	D0,STKGOS
04:00000A5E 23C000080AA6    	    68: 	MOVE.L	D0,CURRNT	current line number pointer = 0
04:00000A64 2E7AFFB4        	    69: 	MOVE.L	ENDMEM,SP	init S.P. again, just in case
04:00000A68 4DF900000584    	    70: 	LEA	OKMSG,A6	display "OK"
04:00000A6E 61000B04        	    71: 	JSR	PRMESG
04:00000A72 103C003E        	    72: ST3	MOVE.B	#'>',D0         Prompt with a '>' and
04:00000A76 61000818        	    73: 	JSR	GETLN		read a line.
04:00000A7A 61000A94        	    74: 	JSR	TOUPBUF 	convert to upper case
04:00000A7E 2848            	    75: 	MOVE.L	A0,A4		save pointer to end of line
04:00000A80 41F900080AD2    	    76: 	LEA	BUFFER,A0	point to the beginning of line
04:00000A86 61000A46        	    77: 	JSR	TSTNUM		is there a number there?
04:00000A8A 61000A78        	    78: 	JSR	IGNBLK		skip trailing blanks
04:00000A8E 4A41            	    79: 	TST	D1		does line no. exist? (or nonzero?)
04:00000A90 67000124        	    80: 	BEQ.W	DIRECT		if not, it's a direct statement
04:00000A94 B2BC0000FFFF    	    81: 	CMP.L	#$FFFF,D1	see if line no. is <= 16 bits
04:00000A9A 640007EA        	    82: 	BCC.W	QHOW		if not, we've overflowed
04:00000A9E 1101            	    83: 	MOVE.B	D1,-(A0)	store the binary line no.
04:00000AA0 E059            	    84: 	ROR	#8,D1		(Kludge to store a word on a
04:00000AA2 1101            	    85: 	MOVE.B	D1,-(A0)	possible byte boundary)
04:00000AA4 E159            	    86: 	ROL	#8,D1
04:00000AA6 6100088C        	    87: 	JSR	FNDLN		find this line in save area
04:00000AAA 2A49            	    88: 	MOVE.L	A1,A5		save possible line pointer
04:00000AAC 6616            	    89: 	BNE	ST4		if not found, insert
04:00000AAE 610008AC        	    90: 	JSR	FNDNXT		find the next line (into A1)
04:00000AB2 244D            	    91: 	MOVE.L	A5,A2		pointer to line to be deleted
04:00000AB4 267900080AC6    	    92: 	MOVE.L	TXTUNF,A3	points to top of save area
04:00000ABA 610008AA        	    93: 	JSR	MVUP		move up to delete
04:00000ABE 23CA00080AC6    	    94: 	MOVE.L	A2,TXTUNF	update the end pointer
04:00000AC4 200C            	    95: ST4	MOVE.L	A4,D0		calculate the length of new line
04:00000AC6 9088            	    96: 	SUB.L	A0,D0
04:00000AC8 B0BC00000003    	    97: 	CMP.L	#3,D0		is it just a line no. & CR?
04:00000ACE 67A2            	    98: 	BEQ	ST3		if so, it was just a delete
04:00000AD0 267900080AC6    	    99: 	MOVE.L	TXTUNF,A3	compute new end
04:00000AD6 2C4B            	   100: 	MOVE.L	A3,A6
04:00000AD8 D7C0            	   101: 	ADD.L	D0,A3
04:00000ADA 203900080ACA    	   102: 	MOVE.L	VARBGN,D0	see if there's enough room
04:00000AE0 B08B            	   103: 	CMP.L	A3,D0
04:00000AE2 63000798        	   104: 	BLS.W	QSORRY		if not, say so
04:00000AE6 23CB00080AC6    	   105: 	MOVE.L	A3,TXTUNF	if so, store new end position
04:00000AEC 224E            	   106: 	MOVE.L	A6,A1		points to old unfilled area
04:00000AEE 244D            	   107: 	MOVE.L	A5,A2		points to beginning of move area
04:00000AF0 6100087E        	   108: 	JSR	MVDOWN		move things out of the way
04:00000AF4 2248            	   109: 	MOVE.L	A0,A1		set up to do the insertion
04:00000AF6 244D            	   110: 	MOVE.L	A5,A2
04:00000AF8 264C            	   111: 	MOVE.L	A4,A3
04:00000AFA 6100086A        	   112: 	JSR	MVUP		do it
04:00000AFE 6000FF72        	   113: 	BRA	ST3		go back and get another line
                            	   114: 
                            	   115: *
                            	   116: *******************************************************************
                            	   117: *
                            	   118: * *** Tables *** DIRECT *** EXEC ***
                            	   119: *
                            	   120: * This section of the code tests a string against a table. When
                            	   121: * a match is found, control is transferred to the section of
                            	   122: * code according to the table.
                            	   123: *
                            	   124: * At 'EXEC', A0 should point to the string, A1 should point to
                            	   125: * the character table, and A2 should point to the execution
                            	   126: * table. At 'DIRECT', A0 should point to the string, A1 and
                            	   127: * A2 will be set up to point to TAB1 and TAB1_1, which are
                            	   128: * the tables of all direct and statement commands.
                            	   129: *
                            	   130: * A '.' in the string will terminate the test and the partial
                            	   131: * match will be considered as a match, e.g. 'P.', 'PR.','PRI.',
                            	   132: * 'PRIN.', or 'PRINT' will all match 'PRINT'.
                            	   133: *
                            	   134: * There are two tables: the character table and the execution
                            	   135: * table. The character table consists of any number of text items.
                            	   136: * Each item is a string of characters with the last character's
                            	   137: * high bit set to one. The execution table holds a 16-bit
                            	   138: * execution addresses that correspond to each entry in the
                            	   139: * character table.
                            	   140: *
                            	   141: * The end of the character table is a 0 byte which corresponds
                            	   142: * to the default routine in the execution table, which is
                            	   143: * executed if none of the other table items are matched.
                            	   144: *
                            	   145: * Character-matching tables:
04:00000B02 4C4953          	   146: TAB1	DC.B	'LIS',('T'+$80)         Direct commands
04:00000B05 D4
04:00000B06 4C4F41          	   147: 	DC.B	'LOA',('D'+$80)
04:00000B09 C4
04:00000B0A 4E45            	   148: 	DC.B	'NE',('W'+$80)
04:00000B0C D7
04:00000B0D 5255            	   149: 	DC.B	'RU',('N'+$80)
04:00000B0F CE
04:00000B10 534156          	   150: 	DC.B	'SAV',('E'+$80)
04:00000B13 C5
04:00000B14 4E4558          	   151: TAB2	DC.B	'NEX',('T'+$80)         Direct / statement
04:00000B17 D4
04:00000B18 4C45            	   152: 	DC.B	'LE',('T'+$80)
04:00000B1A D4
04:00000B1B 49              	   153: 	DC.B	'I',('F'+$80)
04:00000B1C C6
04:00000B1D 474F54          	   154: 	DC.B	'GOT',('O'+$80)
04:00000B20 CF
04:00000B21 474F5355        	   155: 	DC.B	'GOSU',('B'+$80)
04:00000B25 C2
04:00000B26 5245545552      	   156: 	DC.B	'RETUR',('N'+$80)
04:00000B2B CE
04:00000B2C 5245            	   157: 	DC.B	'RE',('M'+$80)
04:00000B2E CD
04:00000B2F 464F            	   158: 	DC.B	'FO',('R'+$80)
04:00000B31 D2
04:00000B32 494E5055        	   159: 	DC.B	'INPU',('T'+$80)
04:00000B36 D4
04:00000B37 5052494E        	   160: 	DC.B	'PRIN',('T'+$80)
04:00000B3B D4
04:00000B3C 504F4B          	   161: 	DC.B	'POK',('E'+$80)
04:00000B3F C5
04:00000B40 53544F          	   162: 	DC.B	'STO',('P'+$80)
04:00000B43 D0
04:00000B44 4259            	   163: 	DC.B	'BY',('E'+$80)
04:00000B46 C5
04:00000B47 43414C          	   164: 	DC.B	'CAL',('L'+$80)
04:00000B4A CC
