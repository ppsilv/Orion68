                            	    31: ; Write char
                            	    32: ; Change A1
                            	    33: ; Receive char in D0
                            	    34: UartWriteChar:
03:000002D0 2F09            	    35:         MOVE.L A1,-(SP)
03:000002D2 227900080410    	    36:         move.l  currentUart,A1
