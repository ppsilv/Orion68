Source: "cmd/xmodem.asm"
                            	     1: 
                            	     2: ;=== Uart receiver ================= CONSTANTES =================
                            	     3: SOH         EQU     $01        ; Start Of Header
                            	     4: EOT         EQU     $04        ; End Of Transmission
                            	     5: ACK         EQU     $06        ; Acknowledge
                            	     6: NACK        EQU     $15        ; Negative Acknowledge
                            	     7: CAN         EQU     $18        ; Cancel
                            	     8: 
                            	     9: XmodemRec:
04:00000920 08B9000000080A5A	    10:         BCLR    #PROGRAM_LOADED,flg_system
04:00000928 47F900082000    	    11:         LEA     buf_pgm,A3
04:0000092E 7A00            	    12:         clr.l     D5
04:00000930 4EB9000002F8    	    13:         JSR     UartFlush
04:00000936 103C0015        	    14:         MOVE.B  #NACK,D0
04:0000093A 4EB9000002C8    	    15:         JSR     UartWriteChar
                            	    16:         ;MOVE.B  #13,D0
                            	    17:         ;JSR     WriteConout      
                            	    18:         ;MOVE.B  #10,D0
                            	    19:         ;JSR     WriteConout      
                            	    20: .receivePacote:
04:00000940 4EB9000001C6    	    21:         JSR     ReadConin
04:00000946 B03C0004        	    22:         CMP.B   #EOT,D0
04:0000094A 675A            	    23:         BEQ     .Transfer_Complete   ; Fim da transmissão          
                            	    24:         ;JSR     PrintByteHexConout      
04:0000094C 4EB9000001C6    	    25:         JSR     ReadConin
                            	    26:         ;JSR     PrintByteHexConout      
04:00000952 4EB9000001C6    	    27:         JSR     ReadConin
                            	    28:         ;JSR     PrintByteHexConout         
04:00000958 323C007F        	    29:         MOVE.W  #$7F,D1
04:0000095C 43F900080448    	    30:         LEA     buf_xmodem,A1
                            	    31: .centoEvinteOito:
04:00000962 4EB9000001C6    	    32:         JSR     ReadConin
04:00000968 DA40            	    33:         add     D0,D5
04:0000096A 12C0            	    34:         MOVE.B  D0,(A1)+                
                            	    35:         ;JSR     PrintByteHexConout      
04:0000096C 51C9FFF4        	    36:         dbra    d1,.centoEvinteOito
                            	    37:         ;Aguardando check sum
04:00000970 4EB9000001C6    	    38:         JSR     ReadConin
                            	    39: 
                            	    40:         ;MOVE.B  D0,-(SP)   
                            	    41:         ;JSR     PrintByteHexConout              
                            	    42:         ;MOVE.B  D5,D0
                            	    43:         ;JSR     PrintByteHexConout 
                            	    44:         ;MOVE.B  (SP)+,D0 
                            	    45: 
04:00000976 BA00            	    46:         CMP.B   D0,D5
04:00000978 661E            	    47:         BNE     .XMIT_NACK    
04:0000097A 303C001F        	    48:         MOVE.W  #32-1,D0          ; Contador para 32 Longs (128 bytes)Subtraímos 1 porque o DBRA para no -1
04:0000097E 43F900080448    	    49:         LEA     buf_xmodem,A1
                            	    50: .CopyLoop:
04:00000984 26D9            	    51:         MOVE.L  (A1)+,(A3)+       ; Copia 4 bytes de (A1) para (A3) e avança ambos
04:00000986 51C8FFFC        	    52:         DBRA    D0,.CopyLoop      ; Decrementa D0 e pula para .CopyLoop se D0 >= 0
04:0000098A 103C0006        	    53:         MOVE.B  #ACK,D0
04:0000098E 4EB9000002C8    	    54:         JSR     UartWriteChar 
                            	    55:         ;JSR     NewLine  
04:00000994 7A00            	    56:         clr.l     D5
04:00000996 60A8            	    57:         jmp     .receivePacote
                            	    58: .XMIT_NACK
04:00000998 103C0015        	    59:         MOVE.B  #NACK,D0
04:0000099C 4EB9000002C8    	    60:         JSR     UartWriteChar 
                            	    61:         ;JSR     NewLine                
04:000009A2 7A00            	    62:         clr.l     D5
04:000009A4 609A            	    63:         jmp     .receivePacote
                            	    64: .Transfer_Complete:
04:000009A6 08F9000000080A5A	    65:         BSET    #PROGRAM_LOADED,flg_system
04:000009AE 4E75            	    66:         RTS ;
