                            	  1252: *
                            	  1253: *******************************************************************
                            	  1254: *
                            	  1255: * *** PRTSTG *** QTSTG *** PRTNUM *** PRTLN ***
                            	  1256: *
                            	  1257: * 'PRTSTG' prints a string pointed to by A1. It stops printing
                            	  1258: * and returns to the caller when either a CR is printed or when
                            	  1259: * the next byte is the same as what was passed in D0 by the
                            	  1260: * caller.
                            	  1261: *
                            	  1262: * 'QTSTG' looks for an underline (back-arrow on some systems),
                            	  1263: * single-quote, or double-quote.  If none of these are found, returns
                            	  1264: * to the caller.  If underline, outputs a CR without a LF.  If single
                            	  1265: * or double quote, prints the quoted string and demands a matching
                            	  1266: * end quote.  After the printing, the next 2 bytes of the caller are
                            	  1267: * skipped over (usually a short branch instruction).
                            	  1268: *
                            	  1269: * 'PRTNUM' prints the 32 bit number in D1, leading blanks are added if
                            	  1270: * needed to pad the number of spaces to the number in D4.
                            	  1271: * However, if the number of digits is larger than the no. in
                            	  1272: * D4, all digits are printed anyway. Negative sign is also
                            	  1273: * printed and counted in, positive sign is not.
                            	  1274: *
                            	  1275: * 'PRTLN' prints the saved text line pointed to by A1
                            	  1276: * with line no. and all.
                            	  1277: *
04:000013CE 1200            	  1278: PRTSTG	MOVE.B	D0,D1		save the stop character
04:000013D0 1019            	  1279: PS1	MOVE.B	(A1)+,D0	get a text character
04:000013D2 B200            	  1280: 	CMP.B	D0,D1		same as stop character?
04:000013D4 6712            	  1281: 	BEQ	PRTRET		if so, return
04:000013D6 6100F62A        	  1282: 	BSR	GOOUT		display the char.
04:000013DA B03C000D        	  1283: 	CMP.B	#CR,D0		is it a C.R.?
04:000013DE 66F0            	  1284: 	BNE	PS1		no, go back for more
04:000013E0 103C000A        	  1285: 	MOVE.B	#LF,D0		yes, add a L.F.
04:000013E4 6100F61C        	  1286: 	BSR	GOOUT
04:000013E8 4E75            	  1287: PRTRET	RTS			then return
                            	  1288: 
