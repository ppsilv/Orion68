                            	   494:         INCLUDE "cmd/mem_dump.asm"

Source: "cmd/mem_dump.asm"
                            	     1: ; ----------------------------------------------------------------------
                            	     2: ; MemDump - Imprime dump de memória formatado
                            	     3: ; Entrada:
                            	     4: ;   A0 = Endereço inicial (ex: $80000)
                            	     5: ;   D0 = Quantidade de bytes (ex: 256)
                            	     6: ; ----------------------------------------------------------------------
                            	     7: MemDump:
04:00000320 4EB900000550    	     8:         JSR     PicoClearScreen
                            	     9: 
04:00000326 41F900000000    	    10:         LEA     MsgDumpHeader,A0
04:0000032C 4EB9000001F8    	    11:         JSR     WriteStringConout
04:00000332 207C00080000    	    12:         MOVE.L  #$00080000,A0
04:00000338 23C800080424    	    13:         MOVE.L  A0,(addressInHex)
04:0000033E 207900080424    	    14:         MOVE.L  (addressInHex),A0
04:00000344 2008            	    15:         MOVE.L  A0,D0
04:00000346 61000672        	    16:         JSR     Print32bitsHex
04:0000034A 4EB811E4        	    17:         JSR     NewLine
                            	    18: 
04:0000034E 41F900000018    	    19:         LEA     MsgDumpHeader1,A0
04:00000354 4EB9000001F8    	    20:         JSR     WriteStringConout
                            	    21: 
04:0000035A 207900080424    	    22:         MOVE.L  (addressInHex),A0
                            	    23:         ; Calcula endereço final
                            	    24: 
                            	    25: DUMPLOOPMASTER:
04:00000360 303C0000        	    26:         MOVE.W  #$0,D0
04:00000364 4840            	    27:         SWAP    D0
04:00000366 303C0005        	    28:         MOVE.W  #$5,D0
04:0000036A 4EB9000004EC    	    29:         JSR     PicoSetCursor
                            	    30:         
04:00000370 7200            	    31:         CLR.L   D1
04:00000372 2208            	    32:         MOVE.L  A0,D1
04:00000374 0681000000FF    	    33:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    34: 
                            	    35: DumpLoop:
                            	    36:         ; Nova linha a cada 16 bytes
04:0000037A 2008            	    37:         MOVE.L  A0,D0
04:0000037C 02800000000F    	    38:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
04:00000382 661A            	    39:         BNE     NoNewLine
                            	    40: 
                            	    41:         ; Imprime endereço
04:00000384 2008            	    42:         MOVE.L  A0,D0
04:00000386 61000632        	    43:         JSR     Print32bitsHex    ; Imprime 8 dígitos hex
                            	    44: 
04:0000038A 103C003A        	    45:         MOVE.B  #':',D0
04:0000038E 4EB9000001EE    	    46:         JSR     WriteConout
04:00000394 103C0020        	    47:         MOVE.B  #' ',D0
04:00000398 4EB9000001EE    	    48:         JSR     WriteConout
                            	    49: 
                            	    50: NoNewLine:
                            	    51:         ; Imprime byte em hex
04:0000039E 1018            	    52:         MOVE.B  (A0)+,D0
04:000003A0 61000634        	    53:         JSR     PrintByteHex
                            	    54: 
04:000003A4 103C0020        	    55:         MOVE.B  #' ',D0
04:000003A8 4EB9000001EE    	    56:         JSR     WriteConout
                            	    57: 
                            	    58:         ; Verifica fim da linha (16 bytes)
04:000003AE 2008            	    59:         MOVE.L  A0,D0
04:000003B0 02800000000F    	    60:         ANDI.L  #$0000000F,D0
04:000003B6 665C            	    61:         BNE     NoEndLine
                            	    62: 
                            	    63:         ; Imprime caracteres ASCII
04:000003B8 103C0020        	    64:         MOVE.B  #' ',D0
04:000003BC 4EB9000001EE    	    65:         JSR     WriteConout
04:000003C2 103C007C        	    66:         MOVE.B  #'|',D0
04:000003C6 4EB9000001EE    	    67:         JSR     WriteConout
                            	    68: 
04:000003CC 43E8FFF0        	    69:         LEA     -16(A0),A1        ; Volta ao início da linha
04:000003D0 740F            	    70:         MOVEQ   #15,D2            ; 16 caracteres
                            	    71: 
                            	    72: AsciiLoop:
04:000003D2 1019            	    73:         MOVE.B  (A1)+,D0
04:000003D4 B03C0020        	    74:         CMP.B   #32,D0            ; Verifica se é imprimível
04:000003D8 6D0E            	    75:         BLT     NonPrintable
04:000003DA B03C007E        	    76:         CMP.B   #$7E,D0
04:000003DE 6E08            	    77:         BGT     NonPrintable
                            	    78: 
04:000003E0 4EB9000001EE    	    79:         JSR     WriteConout
04:000003E6 600A            	    80:         BRA     NextAscii
                            	    81: 
                            	    82: NonPrintable:
04:000003E8 103C002E        	    83:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
04:000003EC 4EB9000001EE    	    84:         JSR     WriteConout
                            	    85: 
                            	    86: NextAscii:
04:000003F2 51CAFFDE        	    87:         DBRA    D2,AsciiLoop
                            	    88: 
04:000003F6 103C007C        	    89:         MOVE.B  #'|',D0
04:000003FA 4EB9000001EE    	    90:         JSR     WriteConout
04:00000400 103C000D        	    91:         MOVE.B  #13,D0            ; CR
04:00000404 4EB9000001EE    	    92:         JSR     WriteConout
04:0000040A 103C000A        	    93:         MOVE.B  #10,D0            ; LF
04:0000040E 4EB9000001EE    	    94:         JSR     WriteConout
                            	    95: 
                            	    96: NoEndLine:
                            	    97:         ; Verifica fim do dump
04:00000414 B1C1            	    98:         CMP.L   D1,A0
04:00000416 6300FF62        	    99:         BLS     DumpLoop
                            	   100: 
                            	   101:         ;JSR     PrintAx
                            	   102:         ;JSR     PrintDx
                            	   103: 
04:0000041A 2F08            	   104:         MOVE.L  A0,-(SP)          ; Salva endereço atual
04:0000041C 41F900000371    	   105:         LEA     MsgHitAnyKey,A0
04:00000422 4EB9000001F8    	   106:         JSR     WriteStringConout
04:00000428 4EB9000001CE    	   107:         JSR     ReadConin
04:0000042E B03C001B        	   108:         CMP.B   #$1B,D0
04:00000432 6706            	   109:         BEQ     .fim
                            	   110: 
04:00000434 205F            	   111:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
04:00000436 6000FF28        	   112:         BRA     DUMPLOOPMASTER
                            	   113: .fim
04:0000043A 205F            	   114:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
04:0000043C 4E75            	   115:         RTS
