03:0000081E 4A3900080A5E    	   215:         tst.b   mod_caps               ; É zero?
03:00000824 6608            	   216:         bne     .else_if_key_shift     ; Curto-circuito: se não for, pula fora
03:00000826 41F900000000    	   217:         lea     _OE_BASE_KEYMAP,A0     ; A0 aponta para o início da tabela (Endereço Base)     
03:0000082C 6070            	   218:         bra     .busca_caractere   
                            	   219: 
                            	   220: .else_if_key_shift:
                            	   221:         ; --- IF PRINCIPAL: if (special_key_status & KEY_SHIFT) ---
03:0000082E 143900080A5C    	   222:         move.b  special_key_status,D2
03:00000834 C43C0002        	   223:         and.b   #KEY_SHIFT,D2          ; Isola o bit do SHIFT
03:00000838 671A            	   224:         beq     .else_if_key_ctrl          ; Se der zero, o Shift NÃO está apertado. Pula pro 'else' externo.
                            	   225:         ; --- DENTRO DO IF: O Shift está ativo! ---
                            	   226:         ; --- if (mod_caps == 2) ---
03:0000083A 0C39000200080A5E	   227:         cmp.b   #2,mod_caps           ; O Caps Lock está no estado 2?
03:00000842 6608            	   228:         bne     .carrega_shift_map      ; Se NÃO for igual a 2, pula pro 'else' (usa tabela Shift)
                            	   229:         ; --- Caso mod_caps == 2: Usa a tabela BASE (reseta o efeito do Shift) ---
03:00000844 41F900000000    	   230:         lea     _OE_BASE_KEYMAP,A0
03:0000084A 6052            	   231:         bra     .busca_caractere        ; Pula para o bloco comum de busca
                            	   232: .carrega_shift_map:
                            	   233:         ; --- Caso contrário (else): Usa a tabela SHIFT ---
03:0000084C 41F900000080    	   234:         lea     _OE_SHIFT_KEYMAP,A0
03:00000852 604A            	   235:         bra     .busca_caractere   
                            	   236: 
                            	   237: .else_if_key_ctrl:
03:00000854 143900080A5C    	   238:         move.b  special_key_status,D2
03:0000085A C43C0001        	   239:         and.b   #KEY_CTRL,D2          ; Isola o bit do SHIFT
03:0000085E 6708            	   240:         beq     .else_if_key_alt          ; Se der zero, o Shift NÃO está apertado. Pula pro 'else' externo.
03:00000860 41F900000100    	   241:         lea     _OE_CTRL_KEYMAP,A0
03:00000866 6036            	   242:         bra     .busca_caractere   
                            	   243: 
                            	   244: .else_if_key_alt:
03:00000868 143900080A5C    	   245:         move.b  special_key_status,D2
03:0000086E C43C0004        	   246:         and.b   #KEY_ALT,D2          ; Isola o bit do SHIFT
03:00000872 6708            	   247:         beq     .else_if_key_altgr          ; Se der zero, o Shift NÃO está apertado. Pula pro 'else' externo.
03:00000874 41F900000180    	   248:         lea     _OE_ALT_KEYMAP,A0
03:0000087A 6022            	   249:         bra     .busca_caractere   
                            	   250: 
                            	   251: .else_if_key_altgr:
03:0000087C 143900080A5C    	   252:         move.b  special_key_status,D2
03:00000882 C43C0008        	   253:         and.b   #KEY_ALTGR,D2          ; Isola o bit do SHIFT
03:00000886 6708            	   254:         beq     .else_if_mod_caps         ; Se der zero, o Shift NÃO está apertado. Pula pro 'else' externo.
03:00000888 41F900000200    	   255:         lea     _OE_ALTGR_KEYMAP,A0
03:0000088E 600E            	   256:         bra     .busca_caractere   
                            	   257: .else_if_mod_caps:
03:00000890 4A3900080A5E    	   258:         tst.b   mod_caps              ; Testa o byte na RAM (mod_caps == 0?)
03:00000896 6714            	   259:         beq     .fim_get_kbd_key       ; Se for IGUAL a zero (falso), pula o bloco IF        
03:00000898 41F900000080    	   260:         lea     _OE_SHIFT_KEYMAP,A0
                            	   261: .busca_caractere:
                            	   262:         ; --- Executa a indexação: RetKey = TABELA[code] ---
03:0000089E 12300800        	   263:         move.b  (A0,D0.L),D1           ; Busca o caractere na tabela selecionada (A0 + D0)
03:000008A2 13C100080A9C    	   264:         move.b  D1,RetKey             ; Salva em RetKey
                            	   265:         ; --- return RetKey; ---
03:000008A8 1001            	   266:         move.b  D1,D0                  ; Padrão do C: coloca o valor de retorno em D0
03:000008AA 4E75            	   267:         rts                             ; Dá o fora da função (retorna)
                            	   268: .fim_get_kbd_key:
03:000008AC 7000            	   269:         clr.l   D0
03:000008AE 4E75            	   270:         rts
                            	   271: 
                            	   272: get_char:
03:000008B0 6100FE70        	   273:         jsr     get_packet
03:000008B4 4A00            	   274:         tst.b   D0
03:000008B6 67F8            	   275:         beq     get_char
03:000008B8 B03C0010        	   276:         cmp.b   #KEY_CAPS,D0
03:000008BC 660C            	   277:         bne     .getkey
03:000008BE 103900080A5E    	   278:         move.b  mod_caps,D0
03:000008C4 6100FEF8        	   279:         jsr     send_cmd_keyboard
03:000008C8 60E6            	   280:         bra.s   get_char
                            	   281: .getkey:        
                            	   282:         ; --- IF PARTE 1: if (key_flag != KEY_SHIFT) ---
03:000008CA B03C0002        	   283:         cmp.b   #KEY_SHIFT,D0      ; Compara com KEY_SHIFT
03:000008CE 670E            	   284:         beq     .fim_if             ; Se for IGUAL, quebra o "AND" e pula fora
                            	   285: 
                            	   286:         ; --- IF PARTE 2: && (key_flag < VALID_KEY) ---
03:000008D0 B03C00FE        	   287:         cmp.b   #VALID_KEY,D0      ; Compara key_flag com VALID_KEY
03:000008D4 6408            	   288:         bcc     .fim_if             ; BCC = Branch if Carry Clear (Maior ou Igual)
                            	   289:                                     ; Se for maior ou igual, condição falhou, pula fora        
                            	   290:         ; Mas o jeito mais limpo e rápido de jogar um byte na parte alta de uma Word é:
03:000008D6 E148            	   291:         lsl.w   #8,D0              ; Desloca 8 bits para a esquerda. D0 vira = $XX00
03:000008D8 33C000080A9C    	   292:         move.w  d0,RetKey             ; Salva o resultado final na Word 'ch' na RAM
                            	   293: .fim_if:
                            	   294: ; --- IF: if( key_buffer[4] > 0x0 ) ---
03:000008DE 4A3900080A64    	   295:         tst.b   key_buffer+4       ; Testa o byte na posição 4 do buffer (compara com 0)
03:000008E4 6F18            	   296:         ble     .get_char             ; Se for IGUAL a zero ou menor, a condição falhou. Pula fora!
03:000008E6 103900080A64    	   297:         move.b key_buffer+4,D0
03:000008EC 6100FF26        	   298:         jsr     get_kbd_key
03:000008F0 1200            	   299:         move.b  D0,D1
03:000008F2 4240            	   300:         clr.w   D0
03:000008F4 103900080A9C    	   301:         move.b  RetKey,D0
03:000008FA 8041            	   302:         or.w    D1,D0        
03:000008FC 4E75            	   303:         rts
                            	   304: .get_char:
03:000008FE 103900080A9C    	   305:         move.b  RetKey,D0
03:00000904 0040FF00        	   306:         ori.w   #$FF00,D0
03:00000908 4E75            	   307:         rts
                            	   308: 
                            	   309: 
                            	   310: 
                            	   311: 
                            	   312: clear_buffer:
03:0000090A 41F900080A60    	   313:         lea     key_buffer,a0     ; A0 aponta para o início do seu buffer de 48 bytes        
                            	   314:         ; 48 bytes / 4 bytes por instrução = 12 linhas de clr.l
03:00000910 4298            	   315:         clr.l   (a0)+               ; Bytes 0-3
03:00000912 4298            	   316:         clr.l   (a0)+               ; Bytes 4-7
03:00000914 4298            	   317:         clr.l   (a0)+               ; Bytes 8-11
03:00000916 4298            	   318:         clr.l   (a0)+               ; Bytes 12-15
03:00000918 4298            	   319:         clr.l   (a0)+               ; Bytes 16-19
03:0000091A 4298            	   320:         clr.l   (a0)+               ; Bytes 20-23
03:0000091C 4298            	   321:         clr.l   (a0)+               ; Bytes 24-27
03:0000091E 4298            	   322:         clr.l   (a0)+               ; Bytes 28-31
03:00000920 4298            	   323:         clr.l   (a0)+               ; Bytes 32-35
03:00000922 4298            	   324:         clr.l   (a0)+               ; Bytes 36-39
03:00000924 4298            	   325:         clr.l   (a0)+               ; Bytes 40-43
03:00000926 4298            	   326:         clr.l   (a0)+               ; Bytes 44-47                
03:00000928 4E75            	   327:         rts
