                            	   108: ; ----------------------------------------------------------------------
                            	   109: DelUartWriteString:
03:00000350 2F08            	   110:         MOVE.L  A0,-(SP)      ; Preserva D0
03:00000352 2F00            	   111:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   112: .WriteLoop:
03:00000354 1018            	   113:         MOVE.B  (A0)+,D0      ; Pega caractere
03:00000356 6706            	   114:         BEQ     .Done
03:00000358 6100FE8C        	   115:         JSR     WriteConout ; Use sua rotine existente
03:0000035C 60F6            	   116:         BRA     .WriteLoop
                            	   117: .Done:
03:0000035E 201F            	   118:         MOVE.L  (SP)+,D0
03:00000360 205F            	   119:         MOVE.L  (SP)+,A0
03:00000362 4E75            	   120:         RTS
