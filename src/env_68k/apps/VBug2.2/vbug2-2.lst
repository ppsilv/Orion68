                            	   179: ; UartPrintHexAddress - Imprime endereço de 32 bits
                            	   180: ; Entrada: D0 = endereço
                            	   181: ;
                            	   182: DelUartPrintHexAddress:
03:000003E8 4840            	   183:         SWAP    D0                ; Imprime parte alta primeiro
03:000003EA 6102            	   184:         JSR     .PrintWordHex
03:000003EC 4840            	   185:         SWAP    D0                ; Parte baixa
                            	   186: .PrintWordHex:
03:000003EE E158            	   187:         ROL.W   #8,D0             ; Byte mais significativo primeiro
03:000003F0 610001AA        	   188:         JSR     PicoPrintByteHex
03:000003F4 E058            	   189:         ROR.W   #8,D0             ; Byte menos significativo
                            	   190: DelUartPrintByteHex:
03:000003F6 1F00            	   191:         MOVE.B  D0,-(SP)          ; Salva byte original
03:000003F8 E808            	   192:         LSR.B   #4,D0             ; Nibble alto
03:000003FA 6106            	   193:         BSR     .PrintNibble
03:000003FC 101F            	   194:         MOVE.B  (SP)+,D0          ; Recupera byte
03:000003FE 0200000F        	   195:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   196: .PrintNibble:
03:00000402 B03C0009        	   197:         CMP.B   #9,D0
03:00000406 6302            	   198:         BLS     .Decimal
03:00000408 5E00            	   199:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   200: .Decimal:
03:0000040A D03C0030        	   201:         ADD.B   #'0',D0
03:0000040E 6000FDDE        	   202:         JMP     WriteConout    ; Usa JMP para tail call optimization
