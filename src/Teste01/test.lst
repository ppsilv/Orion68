                            	   219: ; ----------------------------------------------------------------------
                            	   220: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   221: ; Entrada: D0 = endereço
                            	   222: ; ----------------------------------------------------------------------
                            	   223: PrintHexAddress:
01:000000EC 4840            	   224:         SWAP    D0                ; Imprime parte alta primeiro
01:000000EE 6102            	   225:         JSR     PrintWordHex
01:000000F0 4840            	   226:         SWAP    D0                ; Parte baixa
                            	   227:         ; Continua para PrintWordHex
                            	   228: 
                            	   229: ; ----------------------------------------------------------------------
                            	   230: ; PrintWordHex - Imprime word em hex (16 bits)
                            	   231: ; Entrada: D0.w = valor
                            	   232: ; ----------------------------------------------------------------------
                            	   233: PrintWordHex:
01:000000F2 E158            	   234:         ROL.W   #8,D0             ; Byte mais significativo primeiro
01:000000F4 6102            	   235:         JSR     PrintByteHex
01:000000F6 E058            	   236:         ROR.W   #8,D0             ; Byte menos significativo
                            	   237:         ; Continua para PrintByteHex
                            	   238: 
                            	   239: ; ----------------------------------------------------------------------
                            	   240: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	   241: ; Entrada: D0.b = valor
                            	   242: ; ----------------------------------------------------------------------
                            	   243: PrintByteHex:
01:000000F8 1F00            	   244:         MOVE.B  D0,-(SP)          ; Salva byte original
01:000000FA E808            	   245:         LSR.B   #4,D0             ; Nibble alto
01:000000FC 6106            	   246:         BSR     PrintNibble
01:000000FE 101F            	   247:         MOVE.B  (SP)+,D0          ; Recupera byte
01:00000100 0200000F        	   248:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   249:         ; Continua para PrintNibble
                            	   250: ; ----------------------------------------------------------------------
                            	   251: ; PrintNibble - Imprime um nibble em hex
                            	   252: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	   253: ; ----------------------------------------------------------------------
                            	   254: PrintNibble:
01:00000104 B03C0009        	   255:         CMP.B   #9,D0
01:00000108 6302            	   256:         BLS     .Decimal
01:0000010A 5E00            	   257:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   258: .Decimal:
01:0000010C D03C0030        	   259:         ADD.B   #'0',D0
01:00000110 60C6            	   260:         JMP     WriteChar    ; Usa JMP para tail call optimization
                            	   261: 
                            	   262: UART_Init:
01:00000112 43F900FF9100    	   263:         lea     UART_BASE,A1
01:00000118 13FC008300FF9107	   264:         move.b  #%10000011,LCR  ;(A1)    ;DLAB=1
01:00000120 4E71            	   265:         NOP
01:00000122 4E71            	   266:         NOP
01:00000124 4E71            	   267:         NOP
01:00000126 4E71            	   268:         NOP
01:00000128 4E71            	   269:         NOP
01:0000012A 4E71            	   270:         NOP
01:0000012C 4E71            	   271:         NOP        
01:0000012E 13FC000800FF9101	   272:         move.b  #$08,DLL  ;(A1)       ; set divisor latch low byte
01:00000136 13FC000000FF9103	   273:         move.b  #$00,DLM  ;(A1)       ; set divisor latch high byte
01:0000013E 13FC000300FF9107	   274:         move.b  #%00000011,LCR  ;(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
01:00000146 13FC000D00FF9105	   275:         move.b  #%00001101,FCR  ;(A1)    ; enable FIFO
01:0000014E 423900FF910F    	   276:         clr.b   SCR  ;(A1)               ; clear the scratch register
01:00000154 4E75            	   277:         RTS
                            	   278: ; Escreve caractere (D0.B)
                            	   279: UART_WriteChar:
01:00000156 2F09            	   280:         move.l  A1,-(SP)        ; Preserva A1
01:00000158 2F00            	   281:         move.l  D0,-(SP)        ; Preserva D0
01:0000015A 2F01            	   282:         move.l  D1,-(SP)        ; Preserva D0
01:0000015C 43F900FF9100    	   283:         lea     UART_BASE,A1
                            	   284: .WaitTx:
01:00000162 123900FF910B    	   285:         move.b  LSR,D1
01:00000168 08010005        	   286:         btst    #5,D1           ; wait until transmit holding register is empty
01:0000016C 67F4            	   287:         beq     .WaitTx
01:0000016E 13C000FF9101    	   288:         move.B  D0,THR  ;(A1)      ; transmit byte
01:00000174 221F            	   289:         move.L  (SP)+,D1        ;Restaura D0
01:00000176 201F            	   290:         move.L  (SP)+,D0        ;Restaura D0
01:00000178 225F            	   291:         move.L  (SP)+,A1        ;Restaura A1
01:0000017A 4E75            	   292:         RTS
