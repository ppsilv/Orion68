                            	   244: ; ----------------------------------------------------------------------
                            	   245: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   246: ; Entrada: D0 = endereço
                            	   247: ; ----------------------------------------------------------------------
                            	   248: PrintHexAddress:
01:00000126 4840            	   249:         SWAP    D0                ; Imprime parte alta primeiro
01:00000128 6102            	   250:         JSR     PrintWordHex
01:0000012A 4840            	   251:         SWAP    D0                ; Parte baixa
                            	   252:         ; Continua para PrintWordHex
                            	   253: 
                            	   254: ; ----------------------------------------------------------------------
                            	   255: ; PrintWordHex - Imprime word em hex (16 bits)
                            	   256: ; Entrada: D0.w = valor
                            	   257: ; ----------------------------------------------------------------------
                            	   258: PrintWordHex:
01:0000012C E158            	   259:         ROL.W   #8,D0             ; Byte mais significativo primeiro
01:0000012E 6102            	   260:         JSR     PrintByteHex
01:00000130 E058            	   261:         ROR.W   #8,D0             ; Byte menos significativo
                            	   262:         ; Continua para PrintByteHex
                            	   263: 
                            	   264: ; ----------------------------------------------------------------------
                            	   265: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	   266: ; Entrada: D0.b = valor
                            	   267: ; ----------------------------------------------------------------------
                            	   268: PrintByteHex:
01:00000132 1F00            	   269:         MOVE.B  D0,-(SP)          ; Salva byte original
01:00000134 E808            	   270:         LSR.B   #4,D0             ; Nibble alto
01:00000136 6106            	   271:         BSR     PrintNibble
01:00000138 101F            	   272:         MOVE.B  (SP)+,D0          ; Recupera byte
01:0000013A 0200000F        	   273:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   274:         ; Continua para PrintNibble
                            	   275: ; ----------------------------------------------------------------------
                            	   276: ; PrintNibble - Imprime um nibble em hex
                            	   277: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	   278: ; ----------------------------------------------------------------------
                            	   279: PrintNibble:
01:0000013E B03C0009        	   280:         CMP.B   #9,D0
01:00000142 6302            	   281:         BLS     .Decimal
01:00000144 5E00            	   282:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   283: .Decimal:
01:00000146 D03C0030        	   284:         ADD.B   #'0',D0
01:0000014A 60C6            	   285:         JMP     WriteChar    ; Usa JMP para tail call optimization
