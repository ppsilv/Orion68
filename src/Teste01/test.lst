01:0000016A 10290001        	   305:         move.B  RHR(A1),D0
01:0000016E 225F            	   306:         move.L  (SP)+,A1        ;Restaura A1
01:00000170 B03C001B        	   307:         CMP.B   #$1b,D0
01:00000174 6702            	   308:         beq     .fim
