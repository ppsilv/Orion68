                            	   287: UART_Init:
01:0000014C 43F900FF9100    	   288:         lea     UART_BASE,A1
01:00000152 13FC008300FF4007	   289:         move.b  #%10000011,LCR  ;(A1)    ;DLAB=1
01:0000015A 4E71            	   290:         NOP
01:0000015C 4E71            	   291:         NOP      
01:0000015E 13FC000800FF4001	   292:         move.b  #$08,DLL  ;(A1)       ; set divisor latch low byte
01:00000166 13FC000000FF4003	   293:         move.b  #$00,DLM  ;(A1)       ; set divisor latch high byte
01:0000016E 13FC000300FF4007	   294:         move.b  #%00000011,LCR  ;(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
01:00000176 13FC000D00FF4005	   295:         move.b  #%00001101,FCR  ;(A1)    ; enable FIFO
01:0000017E 423900FF400F    	   296:         clr.b   SCR  ;(A1)               ; clear the scratch register
01:00000184 4E75            	   297:         RTS
