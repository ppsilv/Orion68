                            	   100: next_addr:
01:00000046 5488            	   101:         addq.l #2,a0            ; Proxima word (16 bits)
01:00000048 B1C2            	   102:         cmp.l d2,a0             ; Fim da memoria?
01:0000004A 66DC            	   103:         bne.s test_loop         ; Se nao, continua
                            	   104:         bra end_test          ; Fim do teste total
                            	   105: 
