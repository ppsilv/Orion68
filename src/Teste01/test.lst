                            	    79: mem_test:
01:0000001A 207C00088000    	    80:         move.l #$88000,a0           ; Inicio da RAM
01:00000020 74104842        	    81:         move.l #$100000,d2      ; Limite de 1MB
01:00000024 303CAA55        	    82:         move.w #$aa55,d0        ; Padrao de teste 1
                            	    83: test_loop:
01:00000028 3080            	    84:         move.w d0,(a0)          ; Grava padrao 1
01:0000002A 3210            	    85:         move.w (a0),d1          ; Le de volta
01:0000002C B240            	    86:         cmp.w d0,d1             ; Verifica
01:0000002E 6634            	    87:         bne.s show_error        ; Se erro, desvia para tratar
                            	    88: 
01:00000030 43F900FB8001    	    89:         lea     $00FB8001,A1
01:00000036 103C0041        	    90:         move.b  #$41,D0     ; Carrega 'A' em D0
01:0000003A 1280            	    91:         move.b  D0,(A1); Escreve no endereço do PicoVGA (LDS ativo)        
                            	    92: 
01:0000003C 223C00000FFF    	    93:             MOVE.L  #$0000FFF,D1 ; Contador para o delay (ajuste se precisar de mais)
                            	    94: .DELAY00:
01:00000042 5381            	    95:             SUBQ.L  #1,D1         ; Subtrai 1 de D1 (4 ciclos)
01:00000044 66FC            	    96:             BNE.S   .DELAY00     ; Pula se não for zero (10 ciclos se pular, 8 se não)
                            	    97:             ;BRA.S   MAIN_ROM    
                            	    98: 
