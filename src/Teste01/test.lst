                            	   294: UART_Init:
01:0000016C 43F900FF9100    	   295:         lea     UART_BASE,A1
01:00000172 13FC008300FF4007	   296:         move.b  #%10000011,LCR  ;(A1)    ;DLAB=1
01:0000017A 4E71            	   297:         NOP
01:0000017C 4E71            	   298:         NOP      
01:0000017E 13FC000800FF4001	   299:         move.b  #$08,DLL  ;(A1)       ; set divisor latch low byte
01:00000186 13FC000000FF4003	   300:         move.b  #$00,DLM  ;(A1)       ; set divisor latch high byte
01:0000018E 13FC000300FF4007	   301:         move.b  #%00000011,LCR  ;(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
01:00000196 13FC000D00FF4005	   302:         move.b  #%00001101,FCR  ;(A1)    ; enable FIFO
01:0000019E 423900FF400F    	   303:         clr.b   SCR  ;(A1)               ; clear the scratch register
01:000001A4 4E75            	   304:         RTS
