                            	   133: ; Recebe Y em D1
                            	   134: SetCursor:
01:0000007C 303C0190        	   135:         MOVE.W  #$0190,D0
01:00000080 303C00A0        	   136:         MOVE.W  #$00A0,D0
01:00000084 13C000FB802F    	   137:         MOVE.B  D0,REG_X_LOW
01:0000008A E048            	   138:         LSR.W   #8,D0             ; Desloca o byte alto para a posição baixa em D0
01:0000008C 13C000FB802D    	   139:         MOVE.B  D0,REG_X_HIGH
01:00000092 13C100FB8033    	   140:         MOVE.B  D1,REG_Y_LOW
01:00000098 E049            	   141:         LSR.W   #8,D1             ; Desloca o byte alto para a posição baixa em D0
01:0000009A 13C100FB8031    	   142:         MOVE.B  D1,REG_Y_HIGH
01:000000A0 43F900FB803D    	   143:         LEA     RUN_CMD,A1    
01:000000A6 103C00A3        	   144:         MOVE.B  #CMD_SET_CUR_POS,D0
01:000000AA 1280            	   145:         MOVE.B  D0,(A1);
01:000000AC 4E75            	   146:         RTS
                            	   147: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   148: ; Limpa a tela 
                            	   149: ; Destroy: A1 = Endereço da string
                            	   150: ; Comando em D0
                            	   151: ClearScreen:
01:000000AE 43F900FB803D    	   152:         LEA     RUN_CMD,A1    
01:000000B4 103C00A4        	   153:         MOVE.B  #CMD_CLEAR_SCREEN,D0
01:000000B8 1280            	   154:         MOVE.B  D0,(A1);
01:000000BA 4E75            	   155:         RTS
                            	   156: 
                            	   157: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   158: ; Imprime string terminada em ZERO
                            	   159: ; Destroy: A0 = Endereço da string
                            	   160: PrintString:
01:000000BC 1018            	   161:         MOVE.B  (A0)+,D0      ; Pega caractere e avança ponteiro
01:000000BE 6704            	   162:         BEQ.S   .Done         ; Se for zero, termina
01:000000C0 6104            	   163:         BSR.S   WriteChar     ; Chama sua função gloriosa!
01:000000C2 60F8            	   164:         BRA.S   PrintString   ; Loop para o próximo
                            	   165: .Done:
01:000000C4 4E75            	   166:         RTS
                            	   167: 
                            	   168: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   169: ; Escreve um caractere no picoVGA
                            	   170: ; Destroy: A1,D1
                            	   171: WriteChar:
01:000000C6 43F900FB8001    	   172:             LEA     WRITE_SCREEN,A1
01:000000CC 1280            	   173:             MOVE.B  D0,(A1); Escreve no endereço do PicoVGA (LDS ativo)
                            	   174: 
01:000000CE 223C000000FF    	   175:             MOVE.L  #$FF,D1 ; Contador para o delay (ajuste se precisar de mais)
                            	   176: .DELAY00:
01:000000D4 5381            	   177:             SUBQ.L  #1,D1         ; Subtrai 1 de D1 (4 ciclos)
01:000000D6 66FC            	   178:             BNE.S   .DELAY00     ; Pula se não for zero (10 ciclos se pular, 8 se não)
01:000000D8 4E75            	   179:             RTS
                            	   180: 
                            	   181: ; ----------------------------------------------------------------------
                            	   182: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   183: ; Entrada: D0 = endereço
                            	   184: ; ----------------------------------------------------------------------
                            	   185: PrintHexAddress:
01:000000DA 4840            	   186:         SWAP    D0                ; Imprime parte alta primeiro
01:000000DC 6102            	   187:         JSR     PrintWordHex
01:000000DE 4840            	   188:         SWAP    D0                ; Parte baixa
                            	   189:         ; Continua para PrintWordHex
                            	   190: 
                            	   191: ; ----------------------------------------------------------------------
                            	   192: ; PrintWordHex - Imprime word em hex (16 bits)
                            	   193: ; Entrada: D0.w = valor
                            	   194: ; ----------------------------------------------------------------------
                            	   195: PrintWordHex:
01:000000E0 E158            	   196:         ROL.W   #8,D0             ; Byte mais significativo primeiro
01:000000E2 6102            	   197:         JSR     PrintByteHex
01:000000E4 E058            	   198:         ROR.W   #8,D0             ; Byte menos significativo
                            	   199:         ; Continua para PrintByteHex
                            	   200: 
                            	   201: ; ----------------------------------------------------------------------
                            	   202: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	   203: ; Entrada: D0.b = valor
                            	   204: ; ----------------------------------------------------------------------
                            	   205: PrintByteHex:
01:000000E6 1F00            	   206:         MOVE.B  D0,-(SP)          ; Salva byte original
01:000000E8 E808            	   207:         LSR.B   #4,D0             ; Nibble alto
01:000000EA 6106            	   208:         BSR     PrintNibble
01:000000EC 101F            	   209:         MOVE.B  (SP)+,D0          ; Recupera byte
01:000000EE 0200000F        	   210:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   211:         ; Continua para PrintNibble
                            	   212: ; ----------------------------------------------------------------------
                            	   213: ; PrintNibble - Imprime um nibble em hex
                            	   214: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	   215: ; ----------------------------------------------------------------------
                            	   216: PrintNibble:
01:000000F2 B03C0009        	   217:         CMP.B   #9,D0
01:000000F6 6302            	   218:         BLS     .Decimal
01:000000F8 5E00            	   219:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   220: .Decimal:
01:000000FA D03C0030        	   221:         ADD.B   #'0',D0
01:000000FE 60C6            	   222:         JMP     WriteChar    ; Usa JMP para tail call optimization
