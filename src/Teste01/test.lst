                            	   231: ; ----------------------------------------------------------------------
                            	   232: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   233: ; Entrada: D0 = endereço
                            	   234: ; ----------------------------------------------------------------------
                            	   235: PrintHexAddress:
01:000000EE 4840            	   236:         SWAP    D0                ; Imprime parte alta primeiro
01:000000F0 6102            	   237:         JSR     PrintWordHex
01:000000F2 4840            	   238:         SWAP    D0                ; Parte baixa
                            	   239:         ; Continua para PrintWordHex
                            	   240: 
                            	   241: ; ----------------------------------------------------------------------
                            	   242: ; PrintWordHex - Imprime word em hex (16 bits)
                            	   243: ; Entrada: D0.w = valor
                            	   244: ; ----------------------------------------------------------------------
                            	   245: PrintWordHex:
01:000000F4 E158            	   246:         ROL.W   #8,D0             ; Byte mais significativo primeiro
01:000000F6 6102            	   247:         JSR     PrintByteHex
01:000000F8 E058            	   248:         ROR.W   #8,D0             ; Byte menos significativo
                            	   249:         ; Continua para PrintByteHex
                            	   250: 
                            	   251: ; ----------------------------------------------------------------------
                            	   252: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	   253: ; Entrada: D0.b = valor
                            	   254: ; ----------------------------------------------------------------------
                            	   255: PrintByteHex:
01:000000FA 1F00            	   256:         MOVE.B  D0,-(SP)          ; Salva byte original
01:000000FC E808            	   257:         LSR.B   #4,D0             ; Nibble alto
01:000000FE 6106            	   258:         BSR     PrintNibble
01:00000100 101F            	   259:         MOVE.B  (SP)+,D0          ; Recupera byte
01:00000102 0200000F        	   260:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   261:         ; Continua para PrintNibble
                            	   262: ; ----------------------------------------------------------------------
                            	   263: ; PrintNibble - Imprime um nibble em hex
                            	   264: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	   265: ; ----------------------------------------------------------------------
                            	   266: PrintNibble:
01:00000106 B03C0009        	   267:         CMP.B   #9,D0
01:0000010A 6302            	   268:         BLS     .Decimal
01:0000010C 5E00            	   269:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   270: .Decimal:
01:0000010E D03C0030        	   271:         ADD.B   #'0',D0
01:00000112 60C6            	   272:         JMP     WriteChar    ; Usa JMP para tail call optimization
