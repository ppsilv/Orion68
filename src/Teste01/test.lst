                            	   294: UART_ReadChar:
01:0000017C 2F09            	   295:         move.L  A1,-(SP)        ; Preserva A1
01:0000017E 43F900FF9100    	   296:         lea     UART_BASE,A1
                            	   297: .WaitRx:
01:00000184 08290000910B    	   298:         BTST    #0,LSR(A1)        ; RX ready?
01:0000018A 67F8            	   299:         beq     .WaitRx
01:0000018C 10299101        	   300:         move.B  RHR(A1),D0
01:00000190 225F            	   301:         move.L  (SP)+,A1        ;Restaura A1
01:00000192 B03C001B        	   302:         CMP.B   #$1b,D0
01:00000196 6702            	   303:         beq     .fim
01:00000198 61BC            	   304:         JSR     UART_WriteChar
                            	   305: .fim
01:0000019A 4E75            	   306:         RTS
