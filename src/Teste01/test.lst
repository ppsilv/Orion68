01:000001A2 43F900FF9100    	   310:         lea     UART_BASE,A1
                            	   311: .WaitRx:
01:000001A8 08290000400B    	   312:         BTST    #0,LSR(A1)        ; RX ready?
01:000001AE 67F8            	   313:         beq     .WaitRx
01:000001B0 10294001        	   314:         move.B  RHR(A1),D0
01:000001B4 225F            	   315:         move.L  (SP)+,A1        ;Restaura A1
01:000001B6 B03C001B        	   316:         CMP.B   #$1b,D0
01:000001BA 6702            	   317:         beq     .fim
01:000001BC 61C8            	   318:         JSR     UART_WriteChar
                            	   319: .fim
01:000001BE 4E75            	   320:         RTS
