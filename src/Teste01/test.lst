01:000001EE 4E71            	   344:         NOP
01:000001F0 4E71            	   345:         NOP      
01:000001F2 13FC000800FF4001	   346:         move.b  #$08,DLL  ;(A1)       ; set divisor latch low byte
01:000001FA 13FC000000FF4003	   347:         move.b  #$00,DLM  ;(A1)       ; set divisor latch high byte
