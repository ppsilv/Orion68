01:000001C2 43F900FF9100    	   317:         lea     UART_BASE,A1
                            	   318: .WaitRx:
01:000001C8 08290000400B    	   319:         BTST    #0,LSR(A1)        ; RX ready?
01:000001CE 67F8            	   320:         beq     .WaitRx
01:000001D0 10294001        	   321:         move.B  RHR(A1),D0
01:000001D4 225F            	   322:         move.L  (SP)+,A1        ;Restaura A1
01:000001D6 B03C001B        	   323:         CMP.B   #$1b,D0
01:000001DA 6702            	   324:         beq     .fim
01:000001DC 61C8            	   325:         JSR     UART_WriteChar
                            	   326: .fim
01:000001DE 4E75            	   327:         RTS
