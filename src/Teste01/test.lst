                            	   298: ; ----------------------------------------------------------------------
                            	   299: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   300: ; Entrada: D0 = endereço
                            	   301: ; ----------------------------------------------------------------------
                            	   302: PrintHexAddress:
01:000001BA 4840            	   303:         SWAP    D0                ; Imprime parte alta primeiro
01:000001BC 6102            	   304:         JSR     PrintWordHex
01:000001BE 4840            	   305:         SWAP    D0                ; Parte baixa
                            	   306:         ; Continua para PrintWordHex
                            	   307: 
                            	   308: ; ----------------------------------------------------------------------
                            	   309: ; PrintWordHex - Imprime word em hex (16 bits)
                            	   310: ; Entrada: D0.w = valor
                            	   311: ; ----------------------------------------------------------------------
                            	   312: PrintWordHex:
01:000001C0 E158            	   313:         ROL.W   #8,D0             ; Byte mais significativo primeiro
01:000001C2 6102            	   314:         JSR     PrintByteHex
01:000001C4 E058            	   315:         ROR.W   #8,D0             ; Byte menos significativo
                            	   316:         ; Continua para PrintByteHex
                            	   317: 
                            	   318: ; ----------------------------------------------------------------------
                            	   319: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	   320: ; Entrada: D0.b = valor
                            	   321: ; ----------------------------------------------------------------------
                            	   322: PrintByteHex:
01:000001C6 1F00            	   323:         MOVE.B  D0,-(SP)          ; Salva byte original
01:000001C8 E808            	   324:         LSR.B   #4,D0             ; Nibble alto
01:000001CA 6106            	   325:         BSR     PrintNibble
01:000001CC 101F            	   326:         MOVE.B  (SP)+,D0          ; Recupera byte
01:000001CE 0200000F        	   327:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   328:         ; Continua para PrintNibble
                            	   329: ; ----------------------------------------------------------------------
                            	   330: ; PrintNibble - Imprime um nibble em hex
                            	   331: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	   332: ; ----------------------------------------------------------------------
                            	   333: PrintNibble:
01:000001D2 B03C0009        	   334:         CMP.B   #9,D0
01:000001D6 6302            	   335:         BLS     .Decimal
01:000001D8 5E00            	   336:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   337: .Decimal:
01:000001DA D03C0030        	   338:         ADD.B   #'0',D0
01:000001DE 60C6            	   339:         JMP     WriteChar    ; Usa JMP para tail call optimization
                            	   340: 
