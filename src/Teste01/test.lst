                            	   251: ; ----------------------------------------------------------------------
                            	   252: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   253: ; Entrada: D0 = endereço
                            	   254: ; ----------------------------------------------------------------------
                            	   255: PrintHexAddress:
01:00000146 4840            	   256:         SWAP    D0                ; Imprime parte alta primeiro
01:00000148 6102            	   257:         JSR     PrintWordHex
01:0000014A 4840            	   258:         SWAP    D0                ; Parte baixa
                            	   259:         ; Continua para PrintWordHex
                            	   260: 
                            	   261: ; ----------------------------------------------------------------------
                            	   262: ; PrintWordHex - Imprime word em hex (16 bits)
                            	   263: ; Entrada: D0.w = valor
                            	   264: ; ----------------------------------------------------------------------
                            	   265: PrintWordHex:
01:0000014C E158            	   266:         ROL.W   #8,D0             ; Byte mais significativo primeiro
01:0000014E 6102            	   267:         JSR     PrintByteHex
01:00000150 E058            	   268:         ROR.W   #8,D0             ; Byte menos significativo
                            	   269:         ; Continua para PrintByteHex
                            	   270: 
                            	   271: ; ----------------------------------------------------------------------
                            	   272: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	   273: ; Entrada: D0.b = valor
                            	   274: ; ----------------------------------------------------------------------
                            	   275: PrintByteHex:
01:00000152 1F00            	   276:         MOVE.B  D0,-(SP)          ; Salva byte original
01:00000154 E808            	   277:         LSR.B   #4,D0             ; Nibble alto
01:00000156 6106            	   278:         BSR     PrintNibble
01:00000158 101F            	   279:         MOVE.B  (SP)+,D0          ; Recupera byte
01:0000015A 0200000F        	   280:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   281:         ; Continua para PrintNibble
                            	   282: ; ----------------------------------------------------------------------
                            	   283: ; PrintNibble - Imprime um nibble em hex
                            	   284: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	   285: ; ----------------------------------------------------------------------
                            	   286: PrintNibble:
01:0000015E B03C0009        	   287:         CMP.B   #9,D0
01:00000162 6302            	   288:         BLS     .Decimal
01:00000164 5E00            	   289:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   290: .Decimal:
01:00000166 D03C0030        	   291:         ADD.B   #'0',D0
01:0000016A 60C6            	   292:         JMP     WriteChar    ; Usa JMP para tail call optimization
