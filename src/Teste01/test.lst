                            	   274: UART_Init:
01:00000114 43F900F00100    	   275:         lea     $F00100,A1
                            	   276:         ;move.b  #%00001101,FCR(A1)    ; enable FIFO
01:0000011A 137C00800007    	   277:         move.b  #%10000000,LCR(A1)    ;DLAB=1
01:00000120 137C00080001    	   278:         move.b  #B115200L,DLL(A1)     ; set divisor latch low byte
01:00000126 137C00000003    	   279:         move.b  #B115200H,DLM(A1)     ; set divisor latch high byte
01:0000012C 137C00030007    	   280:         move.b  #%00000011,LCR(A1)    ; 8 data bits, no parity, 1 stop bit, DLAB=0 
01:00000132 4229000F        	   281:         clr.b   SCR(A1)               ; clear the scratch register
01:00000136 4E75            	   282:         RTS
                            	   283: ; Escreve caractere (D0.B)
                            	   284: UART_WriteChar:
01:00000138 2F09            	   285:         move.l  A1,-(SP)        ; Preserva A1
01:0000013A 2F00            	   286:         move.l  D0,-(SP)        ; Preserva D0
01:0000013C 2F01            	   287:         move.l  D1,-(SP)        ; Preserva D0
01:0000013E 43F900F00100    	   288:         lea     $F00100,A1
                            	   289: .WaitTx:
01:00000144 1229000B        	   290:         move.b  LSR(A1),D1
01:00000148 08010005        	   291:         btst    #5,D1           ; wait until transmit holding register is empty
01:0000014C 67F6            	   292:         beq     .WaitTx
01:0000014E 13400001        	   293:         move.B  D0,THR(A1)      ; transmit byte
01:00000152 221F            	   294:         move.L  (SP)+,D1        ;Restaura D0
01:00000154 201F            	   295:         move.L  (SP)+,D0        ;Restaura D0
01:00000156 225F            	   296:         move.L  (SP)+,A1        ;Restaura A1
01:00000158 4E75            	   297:         RTS
