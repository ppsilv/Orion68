02:00001570 6746            	   125:         BEQ     .Done
                            	   126:         ;Tratando os numeros
02:00001572 B03C0030        	   127:         CMP.B   #'0',D0
02:00001576 6C02            	   128:         BGE     .maiorQueZero
02:00001578 60E6            	   129:         BRA     .Loop
                            	   130: .maiorQueZero:
02:0000157A B03C0039        	   131:         CMP.B   #'9',D0
