                            	    13: REG_07         equ $FF800D        ;;Endereço real 13 0x0d  o pico enxerga 0x06
                            	    14: REG_08         equ $FF800F        ;;Endereço real 15 0x0f  o pico enxerga 0x07
                            	    15: ;Begin Register for reads
                            	    16: REG_09         equ $FF8011        ;;Endereço real 17 0x11  o pico enxerga 0x08
