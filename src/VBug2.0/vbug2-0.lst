                            	    50: ; --------------------------------
                            	    51: ; hardware_exit - Terminar execução
                            	    52: ; Entrada: D0.W - Código de saída
                            	    53: ; --------------------------------
                            	    54: hardware_exit:
                            	    55:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    56:     ; Exemplo: parar o processador
                            	    57:     ; stop    #$2700
                            	    58: 
                            	    59:     ; Exemplo simples: loop infinito
02:00001EC4 60FE            	    60:     BRA     hardware_exit
02:00001EC6 4E75            	    61:     RTS
                            	    62: 
                            	    63: InitTrap1:
                            	    64:     ; -------------------------------------------------------------------------
                            	    65:     ; COMO INSTALAR NA RAM:
                            	    66:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	    67:     ; -------------------------------------------------------------------------
                            	    68:     ;LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
                            	    69:     ;MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
02:00001EC8 4E75            	    70:     RTS
                            	    71:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    72: 

Source: "vbug2-0.asm"
                            	   486:         INCLUDE "rot_print_hex_num.asm"

Source: "rot_print_hex_num.asm"
                            	     1: 
                            	     2: ; ----------------------------------------------------------------------
                            	     3: ; PrintHexAddress - Imprime endereço de 32 bits
                            	     4: ; Entrada: D0 = endereço
                            	     5: ; ----------------------------------------------------------------------
                            	     6: PrintHexAddress:
02:00001ECA 2F01            	     7:         MOVE.L  D1,-(SP)
02:00001ECC 4840            	     8:         SWAP    D0                ; Imprime parte alta primeiro
02:00001ECE 4EB81EDE        	     9:         JSR     PrintWordHex
02:00001ED2 2001            	    10:         MOVE.L  D1,D0
02:00001ED4 4840            	    11:         SWAP    D0                ; Parte baixa
02:00001ED6 4EB81EDE        	    12:         JSR     PrintWordHex
02:00001EDA 221F            	    13:         MOVE.L (SP)+,D1
02:00001EDC 4E75            	    14:         RTS
                            	    15:         
                            	    16: PrintWordHex:
02:00001EDE 2200            	    17:         MOVE.L  D0,D1
02:00001EE0 E058            	    18:         ROR     #8,D0             ; Byte mais significativo primeiro
02:00001EE2 4EB81EEE        	    19:         JSR     PrintByteHex
02:00001EE6 2001            	    20:         MOVE.L  D1,D0             ; Byte menos significativo
02:00001EE8 4EB81EEE        	    21:         JSR     PrintByteHex
02:00001EEC 4E75            	    22:         RTS
                            	    23: 
                            	    24: PrintByteHex:
02:00001EEE 1F00            	    25:         MOVE.B  D0,-(SP)          ; 1. Guarda o byte original na pilha
                            	    26:         ; --- PROCESSA O PRIMEIRO NIBBLE (ALTO) ---
02:00001EF0 E808            	    27:         LSR.B   #4,D0             ; Isola o nibble alto (ex: $A4 -> $0A)
02:00001EF2 610A            	    28:         BSR     .PrintNibble      ; Executa a subrotina para o primeiro dígito
                            	    29:         ; --- PROCESSA O SEGUNDO NIBBLE (BAIXO) ---
02:00001EF4 101F            	    30:         MOVE.B  (SP)+,D0          ; 2. Recupera o byte original da pilha
02:00001EF6 0200000F        	    31:         ANDI.B  #$0F,D0           ; Isola o nibble baixo (ex: $A4 -> $04)
02:00001EFA 6102            	    32:         BSR     .PrintNibble      ; Executa a subrotina para o segundo dígito
02:00001EFC 4E75            	    33:         RTS
                            	    34: 
                            	    35: .PrintNibble:
02:00001EFE 1F00            	    36:         MOVE.B  D0,-(SP)          ; Salva D0 para não destruir o valor na conversão        
02:00001F00 B03C0009        	    37:         CMP.B   #9,D0
02:00001F04 6302            	    38:         BLS     .Decimal          ; Se for menor ou igual a 9, vai direto
02:00001F06 5E00            	    39:         ADD.B   #7,D0             ; Ajuste para letras 'A' até 'F'
                            	    40: .Decimal:
02:00001F08 D03C0030        	    41:         ADD.B   #'0',D0           ; Converte o valor bruto em caractere ASCII
02:00001F0C 4EB813F4        	    42:         JSR     WriteConout       ; Chama a sua rotina de exibição na tela/serial
02:00001F10 101F            	    43:         MOVE.B  (SP)+,D0          ; Restaura o D0 original deste nibble
02:00001F12 4E75            	    44:         RTS
                            	    45: 

