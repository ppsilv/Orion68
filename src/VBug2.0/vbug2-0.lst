                            	   127: ; Write char in picoVGA
                            	   128: ; Destroy: A1,D1
                            	   129: PicoWriteChar:
02:0000176A 2F09            	   130:         MOVE.L  A1,-(SP)
02:0000176C 2F01            	   131:         MOVE.L  D1,-(SP)
02:0000176E 43F900FF8001    	   132:         LEA     WRITE_SCREEN,A1
02:00001774 1280            	   133:         MOVE.B  D0,(A1)     ; Escreve no endereço do PicoVGA (LDS ativo)
02:00001776 723F            	   134:         MOVE.L  #$3F,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	   135: .DELAY00:
02:00001778 5381            	   136:         SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
02:0000177A 66FC            	   137:         BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
02:0000177C 221F            	   138:         MOVE.L (SP)+,D1
02:0000177E 225F            	   139:         MOVE.L (SP)+,A1
02:00001780 4E75            	   140:         RTS
                            	   141: ;last change
                            	   142: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   143: ; Imprime string terminada em ZERO
                            	   144: ; Destroy: A0 = String's address
                            	   145: ;
                            	   146: PicoPrintString:
02:00001782 1018            	   147:         MOVE.B  (A0)+,D0                ; Pega caractere e avança ponteiro
02:00001784 6706            	   148:         BEQ.S   .Done                   ; Se for zero, termina
02:00001786 4EB813B6        	   149:         JSR     WriteConout           ; Chama sua função gloriosa!
02:0000178A 60F6            	   150:         BRA.S   PicoPrintString         ; Loop para o próximo
                            	   151: .Done:
02:0000178C 4E75            	   152:         RTS
                            	   153: 
                            	   154: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   155: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   156: ; Entrada: D0 = endereço
                            	   157: ;
                            	   158: PicoPrintHexAddress:
02:0000178E 4840            	   159:         SWAP    D0                ; Imprime parte alta primeiro
02:00001790 4EB81796        	   160:         JSR     .PrintWordHex
02:00001794 4840            	   161:         SWAP    D0                ; Parte baixa
                            	   162: .PrintWordHex:
02:00001796 E158            	   163:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:00001798 4EB8179E        	   164:         JSR     PicoPrintByteHex
02:0000179C E058            	   165:         ROR.W   #8,D0             ; Byte menos significativo
                            	   166: PicoPrintByteHex:
02:0000179E 1F00            	   167:         MOVE.B  D0,-(SP)          ; Salva byte original
02:000017A0 E808            	   168:         LSR.B   #4,D0             ; Nibble alto
02:000017A2 6106            	   169:         BSR     .PrintNibble
02:000017A4 101F            	   170:         MOVE.B  (SP)+,D0          ; Recupera byte
02:000017A6 0200000F        	   171:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   172: .PrintNibble:
02:000017AA B03C0009        	   173:         CMP.B   #9,D0
02:000017AE 6302            	   174:         BLS     .Decimal
02:000017B0 5E00            	   175:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   176: .Decimal:
02:000017B2 D03C0030        	   177:         ADD.B   #'0',D0
02:000017B6 4EF8176A        	   178:         JMP     PicoWriteChar    ; Usa JMP para tail call optimization
                            	   179: 
                            	   180: 

