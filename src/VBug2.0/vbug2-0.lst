                            	    63: ; Read char block with echo
                            	    64: ; Change A1
                            	    65: ;
                            	    66: ; Return char in D0)
                            	    67: UartbReadCharEcho:
02:00001690 2F09            	    68:         MOVE.L A1,-(SP)
02:00001692 227C00FF4100    	    69:         move.l  #UARTB_BASE,A1
                            	    70: .WaitRx:
02:00001698 08290000000B    	    71:         btst    #0,LSR(A1)        ; RX ready?
02:0000169E 67F8            	    72:         beq     .WaitRx
02:000016A0 10290001        	    73:         move.b  RHR(A1),D0
                            	    74: 
                            	    75: .WaitTx:
02:000016A4 08290005000B    	    76:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:000016AA 67F8            	    77:         beq     .WaitTx
02:000016AC 13400001        	    78:         move.b  D0,THR(A1)      ; transmit byte
02:000016B0 225F            	    79:         MOVE.L (SP)+,A1
02:000016B2 4E75            	    80:         RTS
