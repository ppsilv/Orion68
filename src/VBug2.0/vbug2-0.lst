                            	   465:         INCLUDE "drv_keyboard.asm"

Source: "drv_keyboard.asm"
                            	     1: 
                            	     2: ;Como interpretar o Byte 0 (Modificadores)
                            	     3: ;Como o Shift ou Ctrl não geram uma tecla normal, 
                            	     4: ;eles ligam bits específicos no primeiro byte:
                            	     5: ;
                            	     6: ;Bit 0: Control Esquerdo (Left Ctrl)
                            	     7: ;
                            	     8: ;Bit 1: Shift Esquerdo (Left Shift)
                            	     9: ;
                            	    10: ;Bit 2: Alt Esquerdo (Left Alt)
                            	    11: ;
                            	    12: ;Bit 3: GUI Esquerda (Tecla Windows/Command)
                            	    13: ;
                            	    14: ;Bit 4: Control Direito (Right Ctrl)
                            	    15: ;
                            	    16: ;Bit 5: Shift Direito (Right Shift)
                            	    17: ;
                            	    18: ;Se o usuário pressionar Shift + A, o Byte 0 será 
                            	    19: ;0x02 (bit 1 ligado) e o Byte 2 será 0x04 (código 
                            	    20: ;da letra A).
                            	    21: ;Exemplos de USB Scan Codes (Byte 2)
                            	    22: ;Diferente do PS/2 onde a tecla 'A' costuma ser 0x1C, 
                            	    23: ;no padrão USB HID os códigos começam do zero de 
                            	    24: ;forma mais sequencial:
                            	    25: ;0x00: Nenhuma tecla pressionada
                            	    26: ;0x04 a 0x1D: Letras A a Z (em ordem: A=0x04, B=0x05, C=0x06...)
                            	    27: ;0x1E a 0x27: Números 1 a 0 (1=0x1E, 2=0x1F... 9=0x26, 0=0x27)
                            	    28: ;0x28: Enter
                            	    29: ;0x29: ESC
                            	    30: ;0x2A: Backspace
                            	    31: ;0x2B: Tab
                            	    32: ;0x2C: Espaço
                            	    33: ;0x4F: Seta Direita
                            	    34: ;0x50: Seta Esquerda
                            	    35: 
                            	    36: ; =============================================================================
                            	    37: ; DRIVER DE LEITURA CH9350 PARA MOTOROLA 68000
                            	    38: ; Assembler: vasm68kmot (Sintaxe Motorola)
                            	    39: ; =============================================================================
                            	    40: 
                            	    41: ; --- Constantes do Protocolo CH9350 ---
                            	    42: CH_HEAD1    EQU     $57             ; Primeiro byte de sincronismo
                            	    43: CH_HEAD2    EQU     $AB             ; Segundo byte de sincronismo
                            	    44: 
                            	    45: ; -----------------------------------------------------------------------------
                            	    46: ; Rotina Principal de Captura de Pacote do CH9350
                            	    47: ; Retorno: 
                            	    48: ;   D0.B = Número de bytes úteis de dados lidos (0 se erro/timeout)
                            	    49: ;   A0   = Ponteiro para o buffer contendo os dados puros do relatório HID
                            	    50: ; -----------------------------------------------------------------------------
                            	    51: ReadPacketKbd:
02:000017BA 48E77040        	    52:             movem.l d1-d3/a1,-(sp)    ; Preserva registradores
                            	    53: 
                            	    54: .WaitHead1:
02:000017BE 6100FECA        	    55:             bsr     UartbReadChar     ; Aguarda e lê um byte
02:000017C2 B03C0057        	    56:             cmp.b   #CH_HEAD1,d0      ; É o primeiro byte do cabeçalho?
02:000017C6 66F6            	    57:             bne     .WaitHead1        ; Se não, continua procurando
                            	    58: 
                            	    59: .CheckHead2:
02:000017C8 6100FEC0        	    60:             bsr     UartbReadChar     ; Lê o próximo byte
02:000017CC B03C00AB        	    61:             cmp.b   #CH_HEAD2,d0      ; É o segundo byte de sincronismo?
02:000017D0 66EC            	    62:             bne     .WaitHead1        ; Se falhar, reinicia a busca do cabeçalho
                            	    63: 
                            	    64:             ; Cabeçalho alinhado! Passando para os bytes de controle
02:000017D2 6100FEB6        	    65:             bsr     UartbReadChar     ; Lê Byte 2 (Address/Type)
                            	    66:             
02:000017D6 6100FEB2        	    67:             bsr     UartbReadChar     ; Lê Byte 3 (Command)
02:000017DA 1400            	    68:             move.b  d0,d2             ; Guarda o comando em D2 para validação posterior
                            	    69: 
02:000017DC 6100FEAC        	    70:             bsr     UartbReadChar     ; Lê Byte 4 (Length - Tamanho dos dados)
02:000017E0 1200            	    71:             move.b  d0,d1             ; D1 = Contador de bytes do payload HID
02:000017E2 1600            	    72:             move.b  d0,d3             ; Salva tamanho original para retorno em D0
02:000017E4 6710            	    73:             beq     .PacketDone       ; Se tamanho for 0, encerra
                            	    74: 
                            	    75:             ; Prepara ponteiro para receber os dados úteis
02:000017E6 43F900080A2A    	    76:             lea     chPayloadBuffer,a1
                            	    77: 
                            	    78: .ReadPayload:
02:000017EC 6100FE9C        	    79:             bsr     UartbReadChar     ; Lê byte de dados do teclado/mouse
02:000017F0 12C0            	    80:             move.b  d0,(a1)+          ; Salva no buffer
02:000017F2 51C9FFF8        	    81:             dbra    d1,.ReadPayload   ; Decrementa e repete até ler todo o pacote
                            	    82: 
                            	    83: .PacketDone:
02:000017F6 1003            	    84:             move.b  d3,d0             ; Retorna quantidade de bytes lidos em D0
02:000017F8 41F900080A2A    	    85:             lea     chPayloadBuffer,a0 ; Retorna o endereço do buffer em A0
                            	    86:             
02:000017FE 4CDF020E        	    87:             movem.l (sp)+,d1-d3/a1    ; Restaura registradores
02:00001802 4E75            	    88:             rts
                            	    89: 
                            	    90: ; -----------------------------------------------------------------------------
                            	    91: ; Rotina: DecodeToAscii
                            	    92: ; Entrada:
                            	    93: ;   D0.B = Scan Code puro do USB HID (obtido do Byte 2 do pacote)
                            	    94: ;   D1.B = Byte de Modificadores (obtido do Byte 0 do pacote)
                            	    95: ; Saída:
                            	    96: ;   D0.B = Caractere ASCII correspondente, ou $00 se não for mapeável/solto
                            	    97: ; -----------------------------------------------------------------------------
                            	    98: DecodeToAscii:
02:00001804 2F08            	    99:             move.l  a0,-(sp)          ; Preserva A0
                            	   100: 
                            	   101:             ; 1. Verifica se há tecla pressionada
02:00001806 4A00            	   102:             tst.b   d0                ; Código $00 significa nenhuma tecla
02:00001808 6752            	   103:             beq     .NoChar
                            	   104: 
                            	   105:             ; 2. Verifica se o código está dentro do limite da tabela principal
02:0000180A B03C0004        	   106:             cmp.b   #SCAN_START,d0
02:0000180E 6532            	   107:             blo     .CheckSpecial     ; Menor que $04? Pode ser tecla especial fora da tabela
02:00001810 B03C0038        	   108:             cmp.b   #SCAN_END,d0
02:00001814 622C            	   109:             bhi     .CheckSpecial     ; Maior que $38? Trata separadamente
                            	   110: 
                            	   111:             ; 3. Calcula o deslocamento (Índice = ScanCode - SCAN_START)
02:00001816 5900            	   112:             sub.b   #SCAN_START,d0
02:00001818 C0BC000000FF    	   113:             and.l   #$000000FF,d0     ; Garante extensão limpa para Word/Long
                            	   114: 
                            	   115:             ; 4. Determina qual tabela usar baseado no Shift (Bits 1 e 5 do Modificador)
02:0000181E 08010001        	   116:             btst    #1,d1             ; Verifica Left Shift
02:00001822 6612            	   117:             bne     .UseShiftTable
02:00001824 08010005        	   118:             btst    #5,d1             ; Verifica Right Shift
02:00001828 660C            	   119:             bne     .UseShiftTable
                            	   120: 
                            	   121: .UseNormalTable:
02:0000182A 41F900000000    	   122:             lea     ASCII_Table_Normal,a0
02:00001830 10300800        	   123:             move.b  (a0,d0.l),d0      ; Carrega o caractere correspondente
02:00001834 6028            	   124:             bra     .Done
                            	   125: 
                            	   126: .UseShiftTable:
02:00001836 41F900000038    	   127:             lea     ASCII_Table_Shift,a0
02:0000183C 10300800        	   128:             move.b  (a0,d0.l),d0      ; Carrega o caractere com Shift aplicado
02:00001840 601C            	   129:             bra     .Done
                            	   130: ; -----------------------------------------------------------------------------
                            	   131: ; Tratamento de Teclas fora da faixa contínua alfabética/numérica
                            	   132: ; -----------------------------------------------------------------------------
                            	   133: .CheckSpecial:
                            	   134:             ; O Keypad numérico e teclas como CapsLock e F1-F12 ficam aqui.
                            	   135:             ; Exemplo rápido: Mapear teclas do teclado numérico comum ou setas
02:00001842 B03C004F        	   136:             cmp.b   #$4F,d0           ; Scan code $4F = Seta Direita
02:00001846 6708            	   137:             beq     .IsArrowRight
02:00001848 B03C0050        	   138:             cmp.b   #$50,d0           ; Scan code $50 = Seta Esquerda
02:0000184C 6708            	   139:             beq     .IsArrowLeft
                            	   140:             
                            	   141:             ; Se não mapeado, retorna nulo
02:0000184E 600C            	   142:             bra     .NoChar
                            	   143: 
                            	   144: .IsArrowRight:
02:00001850 103C0006        	   145:             move.b  #$06,d0           ; Retorna código ASCII de controle ACK ou customizado
02:00001854 6008            	   146:             bra     .Done
                            	   147: .IsArrowLeft:
02:00001856 103C0015        	   148:             move.b  #$15,d0           ; Retorna código customizado
02:0000185A 6002            	   149:             bra     .Done
                            	   150: 
                            	   151: .NoChar:
02:0000185C 7000            	   152:             moveq   #0,d0             ; Retorna $00 se não for uma tecla válida de texto
                            	   153: .Done:
02:0000185E 205F            	   154:             move.l  (sp)+,a0          ; Restaura A0
02:00001860 4E75            	   155:             rts
                            	   156: 
                            	   157: ; -----------------------------------------------------------------------------
                            	   158: ; Rotina: DumpPayloadHex
                            	   159: ; Objetivo: Lê sequencialmente os 16 bytes de CH_PayloadBuffer e os imprime
                            	   160: ;           em formato hexadecimal usando a rotina externa PicoPrintByteHex.
                            	   161: ; Passagem: PicoPrintByteHex espera o dado bruto no byte menos significativo de D0.
                            	   162: ; -----------------------------------------------------------------------------
                            	   163: DumpPayloadHex:
02:00001862 48E7C080        	   164:             movem.l d0-d1/a0,-(sp)    ; Preserva registradores que serão usados
                            	   165: 
02:00001866 41F900080A2A    	   166:             lea     chPayloadBuffer,a0 ; Aponta A0 para o início do buffer de 16 bytes
02:0000186C 720F            	   167:             moveq   #16-1,d1          ; D1 = 15 (Contador para a instrução dbra, que para em -1)
                            	   168: 
                            	   169: .LoopDump:
02:0000186E 7000            	   170:             moveq   #0,d0             ; Limpa D0 por segurança
02:00001870 1018            	   171:             move.b  (a0)+,d0          ; Copia o byte atual para D0 e avança o ponteiro A0
                            	   172: 
                            	   173:             ; -----------------------------------------------------------------
                            	   174:             ; Aqui chamamos a sua rotina externa. 
                            	   175:             ; Ela deve ler o byte de D0 e jogá-lo para a tela/serial.
                            	   176:             ; -----------------------------------------------------------------
02:00001872 6100FF2A        	   177:             bsr     PicoPrintByteHex  
                            	   178: 
02:00001876 51C9FFF6        	   179:             dbra    d1,.LoopDump      ; Decrementa D1. Se não for -1, pula para .LoopDump
                            	   180: 
02:0000187A 4CDF0103        	   181:             movem.l (sp)+,d0-d1/a0    ; Restaura os registradores originais
02:0000187E 4EB813AC        	   182:             JSR     ReadConin
02:00001882 4E75            	   183:             rts            

Source: "vbug2-0.asm"
                            	   466:         INCLUDE "cmd_mem_dump.asm"

Source: "cmd_mem_dump.asm"
                            	     1: ; ----------------------------------------------------------------------
                            	     2: ; MemDump - Imprime dump de memória formatado
                            	     3: ; Entrada:
                            	     4: ;   A0 = Endereço inicial (ex: $80000)
                            	     5: ;   D0 = Quantidade de bytes (ex: 256)
                            	     6: ; ----------------------------------------------------------------------
                            	     7: MemDump:
02:00001884 4EB81758        	     8:         JSR     PicoClearScreen
                            	     9: 
02:00001888 41F900000000    	    10:         LEA     MsgDumpHeader,A0
02:0000188E 4EB813C0        	    11:         JSR     WriteStringConout
02:00001892 207900080424    	    12:         MOVE.L  (addressInHex),A0
02:00001898 2008            	    13:         MOVE.L  A0,D0
02:0000189A 4EB81B6E        	    14:         JSR     PrintHexAddress
02:0000189E 4EB811C8        	    15:         JSR     NewLine
                            	    16: 
02:000018A2 41F900000018    	    17:         LEA     MsgDumpHeader1,A0
02:000018A8 4EB813C0        	    18:         JSR     WriteStringConout
                            	    19: 
02:000018AC 207900080424    	    20:         MOVE.L  (addressInHex),A0
                            	    21:         ; Calcula endereço final
                            	    22: 
                            	    23: DUMPLOOPMASTER:
02:000018B2 303C0000        	    24:         MOVE.W  #$0,D0
02:000018B6 4840            	    25:         SWAP    D0
02:000018B8 303C0005        	    26:         MOVE.W  #$5,D0
02:000018BC 4EB816F4        	    27:         JSR     PicoSetCursor
                            	    28:         
02:000018C0 7200            	    29:         CLR.L   D1
02:000018C2 2208            	    30:         MOVE.L  A0,D1
02:000018C4 0681000000FF    	    31:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    32: 
                            	    33: DumpLoop:
                            	    34:         ; Nova linha a cada 16 bytes
02:000018CA 2008            	    35:         MOVE.L  A0,D0
02:000018CC 02800000000F    	    36:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:000018D2 6616            	    37:         BNE     NoNewLine
                            	    38: 
                            	    39:         ; Imprime endereço
02:000018D4 2008            	    40:         MOVE.L  A0,D0
02:000018D6 4EB81B6E        	    41:         JSR     PrintHexAddress    ; Imprime 8 dígitos hex
                            	    42: 
02:000018DA 103C003A        	    43:         MOVE.B  #':',D0
02:000018DE 4EB813B6        	    44:         JSR     WriteConout
02:000018E2 103C0020        	    45:         MOVE.B  #' ',D0
02:000018E6 4EB813B6        	    46:         JSR     WriteConout
                            	    47: 
                            	    48: NoNewLine:
                            	    49:         ; Imprime byte em hex
02:000018EA 1018            	    50:         MOVE.B  (A0)+,D0
02:000018EC 4EB81B92        	    51:         JSR     PrintByteHex
                            	    52: 
02:000018F0 103C0020        	    53:         MOVE.B  #' ',D0
02:000018F4 4EB813B6        	    54:         JSR     WriteConout
                            	    55: 
                            	    56:         ; Verifica fim da linha (16 bytes)
02:000018F8 2008            	    57:         MOVE.L  A0,D0
02:000018FA 02800000000F    	    58:         ANDI.L  #$0000000F,D0
02:00001900 664E            	    59:         BNE     NoEndLine
                            	    60: 
                            	    61:         ; Imprime caracteres ASCII
02:00001902 103C0020        	    62:         MOVE.B  #' ',D0
02:00001906 4EB813B6        	    63:         JSR     WriteConout
02:0000190A 103C007C        	    64:         MOVE.B  #'|',D0
02:0000190E 4EB813B6        	    65:         JSR     WriteConout
                            	    66: 
02:00001912 43E8FFF0        	    67:         LEA     -16(A0),A1        ; Volta ao início da linha
02:00001916 740F            	    68:         MOVEQ   #15,D2            ; 16 caracteres
                            	    69: 
                            	    70: AsciiLoop:
02:00001918 1019            	    71:         MOVE.B  (A1)+,D0
02:0000191A B03C0020        	    72:         CMP.B   #32,D0            ; Verifica se é imprimível
02:0000191E 6D0C            	    73:         BLT     NonPrintable
02:00001920 B03C007E        	    74:         CMP.B   #$7E,D0
02:00001924 6E06            	    75:         BGT     NonPrintable
                            	    76: 
02:00001926 4EB813B6        	    77:         JSR     WriteConout
02:0000192A 6008            	    78:         BRA     NextAscii
                            	    79: 
                            	    80: NonPrintable:
02:0000192C 103C002E        	    81:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
02:00001930 4EB813B6        	    82:         JSR     WriteConout
                            	    83: 
                            	    84: NextAscii:
02:00001934 51CAFFE2        	    85:         DBRA    D2,AsciiLoop
                            	    86: 
02:00001938 103C007C        	    87:         MOVE.B  #'|',D0
02:0000193C 4EB813B6        	    88:         JSR     WriteConout
02:00001940 103C000D        	    89:         MOVE.B  #13,D0            ; CR
02:00001944 4EB813B6        	    90:         JSR     WriteConout
02:00001948 103C000A        	    91:         MOVE.B  #10,D0            ; LF
02:0000194C 4EB813B6        	    92:         JSR     WriteConout
                            	    93: 
                            	    94: NoEndLine:
                            	    95:         ; Verifica fim do dump
02:00001950 B1C1            	    96:         CMP.L   D1,A0
02:00001952 6300FF76        	    97:         BLS     DumpLoop
                            	    98: 
02:00001956 4EB8197E        	    99:         JSR     PrintAx
02:0000195A 4EB819E2        	   100:         JSR     PrintDx
                            	   101: 
02:0000195E 2F08            	   102:         MOVE.L  A0,-(SP)          ; Salva endereço atual
02:00001960 41F90000037F    	   103:         LEA     MsgHitAnyKey,A0
02:00001966 4EB813C0        	   104:         JSR     WriteStringConout
02:0000196A 4EB813AC        	   105:         JSR     ReadConin
02:0000196E B03C001B        	   106:         CMP.B   #$1B,D0
02:00001972 6706            	   107:         BEQ     .fim
                            	   108: 
02:00001974 205F            	   109:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:00001976 6000FF3A        	   110:         BRA     DUMPLOOPMASTER
                            	   111: .fim
02:0000197A 205F            	   112:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:0000197C 4E75            	   113:         RTS
                            	   114: 
                            	   115: 
                            	   116: PrintAx:
02:0000197E 2F08            	   117:         MOVE.L  A0,-(SP)          ; Salva endereço atual
                            	   118: 
02:00001980 41F900000453    	   119:         LEA     MsgA0,A0
02:00001986 4EB813C0        	   120:         JSR     WriteStringConout
02:0000198A 205F            	   121:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:0000198C 2F08            	   122:         MOVE.L  A0,-(SP)          ; Salva endereço atual
                            	   123: 
02:0000198E 2008            	   124:         MOVE.L  A0,D0
02:00001990 4EB81B6E        	   125:         JSR     PrintHexAddress    ; Imprime 8 dígitos hex
                            	   126: 
                            	   127: 
02:00001994 41F90000045A    	   128:         LEA     MsgA1,A0
02:0000199A 4EB813C0        	   129:         JSR     WriteStringConout
02:0000199E 2009            	   130:         MOVE.L  A1,D0
02:000019A0 4EB81B6E        	   131:         JSR     PrintHexAddress    ; Imprime 8 dígitos hex
                            	   132: 
02:000019A4 41F900000462    	   133:         LEA     MsgA2,A0
02:000019AA 4EB813C0        	   134:         JSR     WriteStringConout
02:000019AE 200A            	   135:         MOVE.L  A2,D0
