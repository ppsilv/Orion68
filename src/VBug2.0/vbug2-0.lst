                            	   104: ; ----------------------------------------------------------------------
                            	   105: ; UART_WriteString - Envia string terminada em null para UART
                            	   106: ; Entrada:
                            	   107: ;   A0 = Ponteiro para a string (endereço da string)
                            	   108: ; ----------------------------------------------------------------------
                            	   109: DelUartWriteString:
02:00001590 2F08            	   110:         MOVE.L  A0,-(SP)      ; Preserva D0
02:00001592 2F00            	   111:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   112: .WriteLoop:
02:00001594 1018            	   113:         MOVE.B  (A0)+,D0      ; Pega caractere
02:00001596 6706            	   114:         BEQ     .Done
02:00001598 4EB813EE        	   115:         JSR     WriteConout ; Use sua rotine existente
02:0000159C 60F6            	   116:         BRA     .WriteLoop
                            	   117: .Done:
02:0000159E 201F            	   118:         MOVE.L  (SP)+,D0
02:000015A0 205F            	   119:         MOVE.L  (SP)+,A0
02:000015A2 4E75            	   120:         RTS
