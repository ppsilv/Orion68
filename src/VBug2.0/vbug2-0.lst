                            	     1: 
                            	     2: ; ----------------------------------------------------------------------
                            	     3: ; PrintHexAddress - Imprime endereço de 32 bits
                            	     4: ; Entrada: D0 = endereço
                            	     5: ; ----------------------------------------------------------------------
                            	     6: PrintHexAddress:
02:00001B6E 2F01            	     7:         MOVE.L  D1,-(SP)
02:00001B70 4840            	     8:         SWAP    D0                ; Imprime parte alta primeiro
02:00001B72 4EB81B82        	     9:         JSR     PrintWordHex
02:00001B76 2001            	    10:         MOVE.L  D1,D0
02:00001B78 4840            	    11:         SWAP    D0                ; Parte baixa
02:00001B7A 4EB81B82        	    12:         JSR     PrintWordHex
02:00001B7E 221F            	    13:         MOVE.L (SP)+,D1
02:00001B80 4E75            	    14:         RTS
                            	    15:         
                            	    16: PrintWordHex:
02:00001B82 2200            	    17:         MOVE.L  D0,D1
02:00001B84 E058            	    18:         ROR     #8,D0             ; Byte mais significativo primeiro
02:00001B86 4EB81B92        	    19:         JSR     PrintByteHex
02:00001B8A 2001            	    20:         MOVE.L  D1,D0             ; Byte menos significativo
02:00001B8C 4EB81B92        	    21:         JSR     PrintByteHex
02:00001B90 4E75            	    22:         RTS
                            	    23: 
                            	    24: PrintByteHex:
02:00001B92 1F00            	    25:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001B94 E808            	    26:         LSR.B   #4,D0             ; Nibble alto
02:00001B96 6106            	    27:         BSR     .PrintNibble
02:00001B98 101F            	    28:         MOVE.B  (SP)+,D0          ; Recupera byte
02:00001B9A 0200000F        	    29:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	    30: .PrintNibble:
02:00001B9E B03C0009        	    31:         CMP.B   #9,D0
02:00001BA2 6302            	    32:         BLS     .Decimal
02:00001BA4 5E00            	    33:         ADD.B   #7,D0             ; Ajuste para A-F
                            	    34: .Decimal:
02:00001BA6 D03C0030        	    35:         ADD.B   #'0',D0
02:00001BAA 4EB813B6        	    36:         JSR     WriteConout    ; Usa JMP para tail call optimization
02:00001BAE 4E75            	    37:         RTS
                            	    38: 

