02:00001512 08290005000B    	    38:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:00001518 67F8            	    39:         beq     .WaitTx
02:0000151A 13400001        	    40:         move.b  D0,THR(A1)      ; transmit byte
02:0000151E 225F            	    41:         MOVE.L (SP)+,A1
02:00001520 4E75            	    42:         RTS
