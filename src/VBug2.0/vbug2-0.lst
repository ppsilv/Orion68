02:000016A2 08290005000B    	    39:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:000016A8 67F8            	    40:         beq     .WaitTx
02:000016AA 13400001        	    41:         move.b  D0,THR(A1)      ; transmit byte
02:000016AE 225F            	    42:         MOVE.L (SP)+,A1
