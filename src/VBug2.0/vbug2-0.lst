Source: "cmd_xmodem.asm"
                            	     1: 
                            	     2: ;=== Uart receiver ================= CONSTANTES =================
                            	     3: SOH         EQU     $01        ; Start Of Header
                            	     4: EOT         EQU     $04        ; End Of Transmission
                            	     5: ACK         EQU     $06        ; Acknowledge
                            	     6: NACK         EQU     $15        ; Negative Acknowledge
                            	     7: CAN         EQU     $18        ; Cancel
                            	     8: 
                            	     9: XmodemRec:
02:00001A40 7A00            	    10:         clr.l     D5
02:00001A42 4EB81502        	    11:         JSR     UartFlush
02:00001A46 103C0015        	    12:         MOVE.B  #NACK,D0
02:00001A4A 4EB814D2        	    13:         JSR     UartWriteChar
02:00001A4E 103C000D        	    14:         MOVE.B  #13,D0
02:00001A52 4EB813B6        	    15:         JSR     WriteConout      
02:00001A56 103C000A        	    16:         MOVE.B  #10,D0
02:00001A5A 4EB813B6        	    17:         JSR     WriteConout      
                            	    18: .receivePacote:
02:00001A5E 4EB813AC        	    19:         JSR     ReadConin
02:00001A62 B03C0004        	    20:         CMP.B   #EOT,D0
02:00001A66 6744            	    21:         BEQ     .Transfer_Complete   ; Fim da transmissão          
02:00001A68 4EB81458        	    22:         JSR     PrintByteHexConout      
02:00001A6C 4EB813AC        	    23:         JSR     ReadConin
02:00001A70 4EB81458        	    24:         JSR     PrintByteHexConout      
02:00001A74 4EB813AC        	    25:         JSR     ReadConin
02:00001A78 4EB81458        	    26:         JSR     PrintByteHexConout         
02:00001A7C 323C007F        	    27:         MOVE.W  #$7F,D1
                            	    28: .centoEvinteOito:
02:00001A80 4EB813AC        	    29:         JSR     ReadConin
02:00001A84 DA40            	    30:         add     D0,D5
02:00001A86 4EB81458        	    31:         JSR     PrintByteHexConout      
02:00001A8A 51C9FFF4        	    32:         dbra    d1,.centoEvinteOito
                            	    33:         ;Aguardando check sum
02:00001A8E 4EB813AC        	    34:         JSR     ReadConin
02:00001A92 4EB81458        	    35:         JSR     PrintByteHexConout      
02:00001A96 1005            	    36:         MOVE.B  D5,D0
02:00001A98 4EB81458        	    37:         JSR     PrintByteHexConout      
02:00001A9C 103C0006        	    38:         MOVE.B  #ACK,D0
02:00001AA0 4EB814D2        	    39:         JSR     UartWriteChar 
02:00001AA4 4EB811C8        	    40:         JSR     NewLine                
02:00001AA8 4EF81A5E        	    41:         jmp     .receivePacote
                            	    42: .Transfer_Complete:
                            	    43: 
02:00001AAC 4EB813AC        	    44:         JSR     ReadConin
                            	    45: 
02:00001AB0 4E75            	    46:         RTS ;

