                            	   179: ; UartPrintHexAddress - Imprime endereço de 32 bits
                            	   180: ; Entrada: D0 = endereço
                            	   181: ;
                            	   182: DelUartPrintHexAddress:
02:00001610 4840            	   183:         SWAP    D0                ; Imprime parte alta primeiro
02:00001612 4EB81618        	   184:         JSR     .PrintWordHex
02:00001616 4840            	   185:         SWAP    D0                ; Parte baixa
                            	   186: .PrintWordHex:
02:00001618 E158            	   187:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:0000161A 4EB817C6        	   188:         JSR     PicoPrintByteHex
02:0000161E E058            	   189:         ROR.W   #8,D0             ; Byte menos significativo
                            	   190: DelUartPrintByteHex:
02:00001620 1F00            	   191:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001622 E808            	   192:         LSR.B   #4,D0             ; Nibble alto
02:00001624 6106            	   193:         BSR     .PrintNibble
02:00001626 101F            	   194:         MOVE.B  (SP)+,D0          ; Recupera byte
02:00001628 0200000F        	   195:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   196: .PrintNibble:
02:0000162C B03C0009        	   197:         CMP.B   #9,D0
02:00001630 6302            	   198:         BLS     .Decimal
02:00001632 5E00            	   199:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   200: .Decimal:
02:00001634 D03C0030        	   201:         ADD.B   #'0',D0
02:00001638 4EF813DE        	   202:         JMP     WriteConout    ; Usa JMP para tail call optimization
