                            	    11: ; TRAP_CCONIN - Ler caractere do console
                            	    12: ; Saída: D0.L - Caractere lido
                            	    13: ; --------------------------------
                            	    14: trap_cconin:
02:00001E90 2F0A            	    15:     MOVE.L A2,-(SP)
02:00001E92 247900080418    	    16:     MOVE.L  (cconin),A2
02:00001E98 4E92            	    17:     JSR     (A2)
02:00001E9A 245F            	    18:     MOVE.L (SP)+,A2
                            	    19: 
02:00001E9C 0280000000FF    	    20:     ANDI.L  #$FF,D0       ; Mantém apenas o byte inferior
02:00001EA2 4E73            	    21:     RTE                   ; Retorna da exceção
                            	    22: 
                            	    23: ; --------------------------------
                            	    24: ; TRAP_CCONOUT - Escrever caractere no console
                            	    25: ; Entrada: D1.L - Caractere a escrever
                            	    26: ; --------------------------------
                            	    27: trap_cconout:
02:00001EA4 2F0A            	    28:     MOVE.L A2,-(SP)
02:00001EA6 1001            	    29:     MOVE.B  D1,D0
02:00001EA8 247900080414    	    30:     MOVE.L  (cconout),A2        ; Busca o endereço da rotina física da UART
02:00001EAE 4E92            	    31:     JSR     (A2)
02:00001EB0 245F            	    32:     MOVE.L (SP)+,A2
02:00001EB2 4E73            	    33:     RTE      
