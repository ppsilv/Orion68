                            	   104: ; ----------------------------------------------------------------------
                            	   105: ; UART_WriteString - Envia string terminada em null para UART
                            	   106: ; Entrada:
                            	   107: ;   A0 = Ponteiro para a string (endereço da string)
                            	   108: ; ----------------------------------------------------------------------
                            	   109: DelUartWriteString:
02:00001558 2F08            	   110:         MOVE.L  A0,-(SP)      ; Preserva D0
02:0000155A 2F00            	   111:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   112: .WriteLoop:
02:0000155C 1018            	   113:         MOVE.B  (A0)+,D0      ; Pega caractere
02:0000155E 6706            	   114:         BEQ     .Done
02:00001560 4EB813B6        	   115:         JSR     WriteConout ; Use sua rotine existente
02:00001564 60F6            	   116:         BRA     .WriteLoop
                            	   117: .Done:
02:00001566 201F            	   118:         MOVE.L  (SP)+,D0
02:00001568 205F            	   119:         MOVE.L  (SP)+,A0
02:0000156A 4E75            	   120:         RTS
                            	   121: 
                            	   122: ; Lê número hexadecimal (retorna em D0)
                            	   123: DelUartReadHex:
02:0000156C 2F01            	   124:         MOVE.L  D1,-(SP)
02:0000156E 2F02            	   125:         MOVE.L  D2,-(SP)
                            	   126: 
02:00001570 7000            	   127:         MOVEQ   #0,D0
02:00001572 721C            	   128:         MOVEQ   #28,D1            ; Máximo 8 dígitos
02:00001574 7400            	   129:         MOVEQ   #0,D2            ; Resultado em D2
                            	   130: .Loop:
02:00001576 7000            	   131:         CLR.L   D0
02:00001578 4EB813AC        	   132:         JSR     ReadConin
02:0000157C B03C000D        	   133:         CMP.B   #13,D0
02:00001580 674C            	   134:         BEQ     .Done
02:00001582 B03C000A        	   135:         CMP.B   #10,D0
02:00001586 6746            	   136:         BEQ     .Done
                            	   137:         ;Tratando os numeros
02:00001588 B03C0030        	   138:         CMP.B   #'0',D0
02:0000158C 6C02            	   139:         BGE     .maiorQueZero
02:0000158E 60E6            	   140:         BRA     .Loop
                            	   141: .maiorQueZero:
02:00001590 B03C0039        	   142:         CMP.B   #'9',D0
02:00001594 6F10            	   143:         BLE     .isdigit
                            	   144:         ;Tratando as letras
02:00001596 B03C0041        	   145:         CMP.B   #'A',D0
02:0000159A 6C02            	   146:         BGE     .maiorQueA
02:0000159C 60D8            	   147:         BRA     .Loop
                            	   148: .maiorQueA:
02:0000159E B03C0046        	   149:         CMP.B   #'F',D0
02:000015A2 6F16            	   150:         BLE     .isletter
02:000015A4 60D0            	   151:         BRA     .Loop
                            	   152: .isdigit:
02:000015A6 903C0030        	   153:         SUB.B   #'0',D0
02:000015AA E3A8            	   154:         LSL.L   D1,D0
02:000015AC 5901            	   155:         SUB.B   #4,D1
02:000015AE 8480            	   156:         OR.L    D0,D2
02:000015B0 41F900080424    	   157:         LEA     addressInHex,A0
02:000015B6 2082            	   158:         MOVE.L  D2,(A0)
02:000015B8 60BC            	   159:         BRA     .Loop
                            	   160: .isletter:
02:000015BA 903C0037        	   161:         SUB.B   #$37,D0
02:000015BE E3A8            	   162:         LSL.L   D1,D0
02:000015C0 5901            	   163:         SUB.B   #4,D1
02:000015C2 8480            	   164:         OR.L    D0,D2
02:000015C4 41F900080424    	   165:         LEA     addressInHex,A0
02:000015CA 2082            	   166:         MOVE.L  D2,(A0)
02:000015CC 60A8            	   167:         BRA     .Loop
                            	   168: .Done:
02:000015CE 4EB811C8        	   169:         JSR     NewLine
02:000015D2 41F900080424    	   170:         LEA     addressInHex,A0
02:000015D8 2010            	   171:         MOVE.L  (A0),D0
02:000015DA 4EB8178E        	   172:         JSR     PicoPrintHexAddress
02:000015DE 4EB811C8        	   173:         JSR     NewLine
02:000015E2 241F            	   174:         MOVE.L  (SP)+,D2
02:000015E4 221F            	   175:         MOVE.L  (SP)+,D1
02:000015E6 4E75            	   176:         RTS
