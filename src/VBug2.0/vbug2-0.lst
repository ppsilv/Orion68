                            	   167: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   168: ; UartPrintHexAddress - Imprime endereço de 32 bits
                            	   169: ; Entrada: D0 = endereço
                            	   170: ;
                            	   171: DelUartPrintHexAddress:
02:000015D2 4840            	   172:         SWAP    D0                ; Imprime parte alta primeiro
02:000015D4 4EB815DA        	   173:         JSR     .PrintWordHex
02:000015D8 4840            	   174:         SWAP    D0                ; Parte baixa
                            	   175: .PrintWordHex:
02:000015DA E158            	   176:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:000015DC 4EB81788        	   177:         JSR     PicoPrintByteHex
02:000015E0 E058            	   178:         ROR.W   #8,D0             ; Byte menos significativo
                            	   179: DelUartPrintByteHex:
02:000015E2 1F00            	   180:         MOVE.B  D0,-(SP)          ; Salva byte original
02:000015E4 E808            	   181:         LSR.B   #4,D0             ; Nibble alto
02:000015E6 6106            	   182:         BSR     .PrintNibble
02:000015E8 101F            	   183:         MOVE.B  (SP)+,D0          ; Recupera byte
02:000015EA 0200000F        	   184:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   185: .PrintNibble:
02:000015EE B03C0009        	   186:         CMP.B   #9,D0
02:000015F2 6302            	   187:         BLS     .Decimal
02:000015F4 5E00            	   188:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   189: .Decimal:
02:000015F6 D03C0030        	   190:         ADD.B   #'0',D0
02:000015FA 4EF813B6        	   191:         JMP     WriteConout    ; Usa JMP para tail call optimization
                            	   192: 
