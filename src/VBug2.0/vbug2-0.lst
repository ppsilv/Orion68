02:0000151E 67F8            	    39:         beq     .WaitTx
02:00001520 13400001        	    40:         move.b  D0,THR(A1)      ; transmit byte
02:00001524 225F            	    41:         MOVE.L (SP)+,A1
02:00001526 4E75            	    42:         RTS
