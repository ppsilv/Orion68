                            	   126: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   127: ; Write char in picoVGA
                            	   128: ; Destroy: A1,D1
                            	   129: PicoWriteChar:
02:000017A8 2F09            	   130:         MOVE.L  A1,-(SP)
02:000017AA 2F01            	   131:         MOVE.L  D1,-(SP)
02:000017AC 43F900FF8001    	   132:         LEA     WRITE_SCREEN,A1
02:000017B2 1280            	   133:         MOVE.B  D0,(A1)     ; Escreve no endereço do PicoVGA (LDS ativo)
02:000017B4 723F            	   134:         MOVE.L  #$3F,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	   135: .DELAY00:
02:000017B6 5381            	   136:         SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
02:000017B8 66FC            	   137:         BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
02:000017BA 221F            	   138:         MOVE.L (SP)+,D1
02:000017BC 225F            	   139:         MOVE.L (SP)+,A1
02:000017BE 4E75            	   140:         RTS
                            	   141: ;last change
                            	   142: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   143: ; Imprime string terminada em ZERO
                            	   144: ; Destroy: A0 = String's address
                            	   145: ;
                            	   146: PicoPrintString:
02:000017C0 1018            	   147:         MOVE.B  (A0)+,D0                ; Pega caractere e avança ponteiro
02:000017C2 6706            	   148:         BEQ.S   .Done                   ; Se for zero, termina
02:000017C4 4EB813F4        	   149:         JSR     WriteConout           ; Chama sua função gloriosa!
02:000017C8 60F6            	   150:         BRA.S   PicoPrintString         ; Loop para o próximo
                            	   151: .Done:
02:000017CA 4E75            	   152:         RTS
                            	   153: 
                            	   154: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   155: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   156: ; Entrada: D0 = endereço
                            	   157: ;
                            	   158: PicoPrintHexAddress:
02:000017CC 4840            	   159:         SWAP    D0                ; Imprime parte alta primeiro
02:000017CE 4EB817D4        	   160:         JSR     .PrintWordHex
02:000017D2 4840            	   161:         SWAP    D0                ; Parte baixa
                            	   162: .PrintWordHex:
02:000017D4 E158            	   163:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:000017D6 4EB817DE        	   164:         JSR     PicoPrintByteHex
02:000017DA E058            	   165:         ROR.W   #8,D0             ; Byte menos significativo
02:000017DC 4E75            	   166:         RTS
                            	   167: 
                            	   168: PicoPrintByteHex:
02:000017DE 1F00            	   169:         MOVE.B  D0,-(SP)          ; Salva byte original
02:000017E0 E808            	   170:         LSR.B   #4,D0             ; Nibble alto
02:000017E2 6118            	   171:         BSR     .PrintNibble1
                            	   172: .PrintNibble2
02:000017E4 101F            	   173:         MOVE.B  (SP)+,D0          ; Recupera byte
02:000017E6 0200000F        	   174:         ANDI.B  #$0F,D0           ; Nibble baixo
02:000017EA B03C0009        	   175:         CMP.B   #9,D0
02:000017EE 6302            	   176:         BLS     .Decimal2
02:000017F0 5E00            	   177:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   178: .Decimal2:
02:000017F2 D03C0030        	   179:         ADD.B   #'0',D0
02:000017F6 4EB817A8        	   180:         JSR     PicoWriteChar    ; Usa JMP para tail call optimization
02:000017FA 4E75            	   181:         RTS
                            	   182: .PrintNibble1:
02:000017FC B03C0009        	   183:         CMP.B   #9,D0
02:00001800 6302            	   184:         BLS     .Decimal
02:00001802 5E00            	   185:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   186: .Decimal:
02:00001804 D03C0030        	   187:         ADD.B   #'0',D0
02:00001808 4EB817A8        	   188:         JSR     PicoWriteChar    ; Usa JMP para tail call optimization
02:0000180C 60D6            	   189:         BRA.S   .PrintNibble2
