02:0000187C 2008            	    35:         MOVE.L  A0,D0
02:0000187E 02800000000F    	    36:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:00001884 6616            	    37:         BNE     NoNewLine
                            	    38: 
