                            	     1: ; ----------------------------------------------------------------------
                            	     2: ; MemDump - Imprime dump de memória formatado
                            	     3: ; Entrada:
                            	     4: ;   A0 = Endereço inicial (ex: $80000)
                            	     5: ;   D0 = Quantidade de bytes (ex: 256)
                            	     6: ; ----------------------------------------------------------------------
                            	     7: MemDump:
02:00001836 4EB81796        	     8:         JSR     PicoClearScreen
                            	     9: 
02:0000183A 41F900000000    	    10:         LEA     MsgDumpHeader,A0
