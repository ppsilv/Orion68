02:000018B4 103C0020        	    62:         MOVE.B  #' ',D0
02:000018B8 4EB813F4        	    63:         JSR     WriteConout
02:000018BC 103C007C        	    64:         MOVE.B  #'|',D0
02:000018C0 4EB813F4        	    65:         JSR     WriteConout
                            	    66: 
02:000018C4 43E8FFF0        	    67:         LEA     -16(A0),A1        ; Volta ao início da linha
