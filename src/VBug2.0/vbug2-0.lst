02:000014B6 137C00830007    	    23:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:000014BC 13400001        	    24:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:000014C0 E088            	    25:         lsr.l   #8,D0                   ; Shift right 8 bits
02:000014C2 13400003        	    26:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:000014C6 08A900070007    	    27:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:000014CC 4229000F        	    28:         clr.b   SCR(a1)                 ; clear the scratch register
