Source: "cmd_xmodem.asm"
                            	     1: 
                            	     2: ;=== Uart receiver ================= CONSTANTES =================
                            	     3: SOH         EQU     $01        ; Start Of Header
                            	     4: EOT         EQU     $04        ; End Of Transmission
                            	     5: ACK         EQU     $06        ; Acknowledge
                            	     6: NACK        EQU     $15        ; Negative Acknowledge
                            	     7: CAN         EQU     $18        ; Cancel
                            	     8: 
                            	     9: XmodemRec:
02:00001A64 08B9000000080A3A	    10:         BCLR    #PROGRAM_LOADED,flg_system
02:00001A6C 47F900082000    	    11:         LEA     buf_pgm,A3
02:00001A72 7A00            	    12:         clr.l     D5
02:00001A74 4EB8153A        	    13:         JSR     UartFlush
02:00001A78 103C0015        	    14:         MOVE.B  #NACK,D0
02:00001A7C 4EB8150A        	    15:         JSR     UartWriteChar
                            	    16:         ;MOVE.B  #13,D0
                            	    17:         ;JSR     WriteConout      
                            	    18:         ;MOVE.B  #10,D0
                            	    19:         ;JSR     WriteConout      
                            	    20: .receivePacote:
02:00001A80 4EB813CC        	    21:         JSR     ReadConin
02:00001A84 B03C0004        	    22:         CMP.B   #EOT,D0
02:00001A88 6752            	    23:         BEQ     .Transfer_Complete   ; Fim da transmissão          
                            	    24:         ;JSR     PrintByteHexConout      
02:00001A8A 4EB813CC        	    25:         JSR     ReadConin
                            	    26:         ;JSR     PrintByteHexConout      
02:00001A8E 4EB813CC        	    27:         JSR     ReadConin
                            	    28:         ;JSR     PrintByteHexConout         
02:00001A92 323C007F        	    29:         MOVE.W  #$7F,D1
02:00001A96 43F900080428    	    30:         LEA     buf_xmodem,A1
                            	    31: .centoEvinteOito:
02:00001A9C 4EB813CC        	    32:         JSR     ReadConin
02:00001AA0 DA40            	    33:         add     D0,D5
02:00001AA2 12C0            	    34:         MOVE.B  D0,(A1)+                
                            	    35:         ;JSR     PrintByteHexConout      
02:00001AA4 51C9FFF6        	    36:         dbra    d1,.centoEvinteOito
                            	    37:         ;Aguardando check sum
02:00001AA8 4EB813CC        	    38:         JSR     ReadConin
                            	    39: 
                            	    40:         ;MOVE.B  D0,-(SP)   
                            	    41:         ;JSR     PrintByteHexConout              
                            	    42:         ;MOVE.B  D5,D0
                            	    43:         ;JSR     PrintByteHexConout 
                            	    44:         ;MOVE.B  (SP)+,D0 
                            	    45: 
02:00001AAC BA00            	    46:         CMP.B   D0,D5
02:00001AAE 661E            	    47:         BNE     .XMIT_NACK    
02:00001AB0 303C001F        	    48:         MOVE.W  #32-1,D0          ; Contador para 32 Longs (128 bytes)Subtraímos 1 porque o DBRA para no -1
02:00001AB4 43F900080428    	    49:         LEA     buf_xmodem,A1
                            	    50: .CopyLoop:
02:00001ABA 26D9            	    51:         MOVE.L  (A1)+,(A3)+       ; Copia 4 bytes de (A1) para (A3) e avança ambos
02:00001ABC 51C8FFFC        	    52:         DBRA    D0,.CopyLoop      ; Decrementa D0 e pula para .CopyLoop se D0 >= 0
02:00001AC0 103C0006        	    53:         MOVE.B  #ACK,D0
02:00001AC4 4EB8150A        	    54:         JSR     UartWriteChar 
                            	    55:         ;JSR     NewLine  
02:00001AC8 7A00            	    56:         clr.l     D5
02:00001ACA 4EF81A80        	    57:         jmp     .receivePacote
                            	    58: .XMIT_NACK
02:00001ACE 103C0015        	    59:         MOVE.B  #NACK,D0
02:00001AD2 4EB8150A        	    60:         JSR     UartWriteChar 
                            	    61:         ;JSR     NewLine                
02:00001AD6 7A00            	    62:         clr.l     D5
02:00001AD8 4EF81A80        	    63:         jmp     .receivePacote
                            	    64: .Transfer_Complete:
02:00001ADC 08F9000000080A3A	    65:         BSET    #PROGRAM_LOADED,flg_system
02:00001AE4 4E75            	    66:         RTS ;
