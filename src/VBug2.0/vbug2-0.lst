02:00001596 5901            	   144:         SUB.B   #4,D1
02:00001598 8480            	   145:         OR.L    D0,D2
02:0000159A 41F900080424    	   146:         LEA     addressInHex,A0
02:000015A0 2082            	   147:         MOVE.L  D2,(A0)
02:000015A2 60BC            	   148:         BRA     .Loop
                            	   149: .isletter:
02:000015A4 903C0037        	   150:         SUB.B   #$37,D0
02:000015A8 E3A8            	   151:         LSL.L   D1,D0
02:000015AA 5901            	   152:         SUB.B   #4,D1
02:000015AC 8480            	   153:         OR.L    D0,D2
02:000015AE 41F900080424    	   154:         LEA     addressInHex,A0
02:000015B4 2082            	   155:         MOVE.L  D2,(A0)
02:000015B6 60A8            	   156:         BRA     .Loop
                            	   157: .Done:
02:000015B8 4EB811C8        	   158:         JSR     NewLine
02:000015BC 41F900080424    	   159:         LEA     addressInHex,A0
02:000015C2 2010            	   160:         MOVE.L  (A0),D0
02:000015C4 4EB81778        	   161:         JSR     PicoPrintHexAddress
02:000015C8 4EB811C8        	   162:         JSR     NewLine
02:000015CC 241F            	   163:         MOVE.L  (SP)+,D2
