                            	   127: ; Write char in picoVGA
                            	   128: ; Destroy: A1,D1
                            	   129: PicoWriteChar:
02:00001754 2F09            	   130:         MOVE.L  A1,-(SP)
02:00001756 2F01            	   131:         MOVE.L  D1,-(SP)
02:00001758 43F900FF8001    	   132:         LEA     WRITE_SCREEN,A1
02:0000175E 1280            	   133:         MOVE.B  D0,(A1)     ; Escreve no endereço do PicoVGA (LDS ativo)
02:00001760 723F            	   134:         MOVE.L  #$3F,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	   135: .DELAY00:
02:00001762 5381            	   136:         SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
02:00001764 66FC            	   137:         BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
02:00001766 221F            	   138:         MOVE.L (SP)+,D1
02:00001768 225F            	   139:         MOVE.L (SP)+,A1
02:0000176A 4E75            	   140:         RTS
                            	   141: ;last change
                            	   142: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   143: ; Imprime string terminada em ZERO
                            	   144: ; Destroy: A0 = String's address
                            	   145: ;
                            	   146: PicoPrintString:
02:0000176C 1018            	   147:         MOVE.B  (A0)+,D0                ; Pega caractere e avança ponteiro
02:0000176E 6706            	   148:         BEQ.S   .Done                   ; Se for zero, termina
02:00001770 4EB813B6        	   149:         JSR     WriteConout           ; Chama sua função gloriosa!
02:00001774 60F6            	   150:         BRA.S   PicoPrintString         ; Loop para o próximo
                            	   151: .Done:
02:00001776 4E75            	   152:         RTS
