                            	    69: 
                            	    70: AsciiLoop:
02:000018CA 1019            	    71:         MOVE.B  (A1)+,D0
02:000018CC B03C0020        	    72:         CMP.B   #32,D0            ; Verifica se é imprimível
02:000018D0 6D0C            	    73:         BLT     NonPrintable
02:000018D2 B03C007E        	    74:         CMP.B   #$7E,D0
02:000018D6 6E06            	    75:         BGT     NonPrintable
