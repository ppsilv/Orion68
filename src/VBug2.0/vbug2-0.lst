02:000016B2 08290005000B    	    39:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:000016B8 67F8            	    40:         beq     .WaitTx
02:000016BA 13400001        	    41:         move.b  D0,THR(A1)      ; transmit byte
02:000016BE 225F            	    42:         MOVE.L (SP)+,A1
02:000016C0 4E75            	    43:         RTS
