                            	   115: ; Clear screen
                            	   116: ; Destroy: A1 
                            	   117: ; Command in D0
                            	   118: PicoClearScreen:
02:00001758 2F09            	   119:         MOVE.L A1,-(SP)
02:0000175A 43F900FF803D    	   120:         LEA     RUN_CMD,A1    
