                            	   115: 
02:0000155A 7000            	   116:         MOVEQ   #0,D0
02:0000155C 721C            	   117:         MOVEQ   #28,D1            ; Máximo 8 dígitos
02:0000155E 7400            	   118:         MOVEQ   #0,D2            ; Resultado em D2
                            	   119: .Loop:
02:00001560 7000            	   120:         CLR.L   D0
02:00001562 4EB8139E        	   121:         JSR     ReadConin
02:00001566 B03C000D        	   122:         CMP.B   #13,D0
