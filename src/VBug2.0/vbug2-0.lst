02:00001596 2F02            	   125:         MOVE.L  D2,-(SP)
                            	   126: 
02:00001598 7000            	   127:         MOVEQ   #0,D0
02:0000159A 721C            	   128:         MOVEQ   #28,D1            ; Máximo 8 dígitos
02:0000159C 7400            	   129:         MOVEQ   #0,D2            ; Resultado em D2
                            	   130: .Loop:
02:0000159E 7000            	   131:         CLR.L   D0
02:000015A0 4EB813BC        	   132:         JSR     ReadConin
02:000015A4 B03C000D        	   133:         CMP.B   #13,D0
02:000015A8 674C            	   134:         BEQ     .Done
02:000015AA B03C000A        	   135:         CMP.B   #10,D0
02:000015AE 6746            	   136:         BEQ     .Done
                            	   137:         ;Tratando os numeros
02:000015B0 B03C0030        	   138:         CMP.B   #'0',D0
02:000015B4 6C02            	   139:         BGE     .maiorQueZero
02:000015B6 60E6            	   140:         BRA     .Loop
                            	   141: .maiorQueZero:
02:000015B8 B03C0039        	   142:         CMP.B   #'9',D0
02:000015BC 6F10            	   143:         BLE     .isdigit
                            	   144:         ;Tratando as letras
02:000015BE B03C0041        	   145:         CMP.B   #'A',D0
02:000015C2 6C02            	   146:         BGE     .maiorQueA
02:000015C4 60D8            	   147:         BRA     .Loop
                            	   148: .maiorQueA:
02:000015C6 B03C0046        	   149:         CMP.B   #'F',D0
02:000015CA 6F16            	   150:         BLE     .isletter
02:000015CC 60D0            	   151:         BRA     .Loop
                            	   152: .isdigit:
02:000015CE 903C0030        	   153:         SUB.B   #'0',D0
02:000015D2 E3A8            	   154:         LSL.L   D1,D0
02:000015D4 5901            	   155:         SUB.B   #4,D1
02:000015D6 8480            	   156:         OR.L    D0,D2
02:000015D8 41F900080424    	   157:         LEA     addressInHex,A0
02:000015DE 2082            	   158:         MOVE.L  D2,(A0)
02:000015E0 60BC            	   159:         BRA     .Loop
                            	   160: .isletter:
02:000015E2 903C0037        	   161:         SUB.B   #$37,D0
02:000015E6 E3A8            	   162:         LSL.L   D1,D0
02:000015E8 5901            	   163:         SUB.B   #4,D1
02:000015EA 8480            	   164:         OR.L    D0,D2
02:000015EC 41F900080424    	   165:         LEA     addressInHex,A0
02:000015F2 2082            	   166:         MOVE.L  D2,(A0)
02:000015F4 60A8            	   167:         BRA     .Loop
                            	   168: .Done:
02:000015F6 4EB811E8        	   169:         JSR     NewLine
02:000015FA 41F900080424    	   170:         LEA     addressInHex,A0
02:00001600 2010            	   171:         MOVE.L  (A0),D0
02:00001602 4EB817B6        	   172:         JSR     PicoPrintHexAddress
02:00001606 4EB811E8        	   173:         JSR     NewLine
02:0000160A 241F            	   174:         MOVE.L  (SP)+,D2
