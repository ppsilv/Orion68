                            	     4: RHR         equ     $01   ; receive holding register (read)
                            	     5: THR         equ     $01   ; transmit holding register (write)
                            	     6: IER         equ     $03   ; interrupt enable register
                            	     7: ISR         equ     $05   ; interrupt status register (read)
                            	     8: FCR         equ     $05   ; FIFO control register (write)
                            	     9: LCR         equ     $07   ; line control register
                            	    10: MCR         equ     $09   ; modem control register
                            	    11: LSR         equ     $0B   ; line status register
                            	    12: MSR         equ     $0D   ; modem status register
                            	    13: SPR         equ     $0F   ; scratchpad register (reserved for system use)
                            	    14: DLL         equ     $01   ; divisor latch LSB
                            	    15: DLM         equ     $03   ; divisor latch MSB
                            	    16: ; aliases for register names (used by different manufacturers)cd ..
                            	    17: RBR         equ     RHR ; receive buffer register
                            	    18: IIR         equ     ISR ; interrupt identification register
                            	    19: SCR         equ     SPR ; scratch register
