                            	     5: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	     6: ; Initialize uart
                            	     7: ; Change A1
                            	     8: ; Parametros: none
