02:00001714 4E71            	    95:         NOP
02:00001716 E049            	    96:         LSR.W   #8,D1             ; Desloca o byte alto para a posição baixa em D0
02:00001718 13C100FF8031    	    97:         MOVE.B  D1,REG_Y_HIGH
02:0000171E 4E71            	    98:         NOP
