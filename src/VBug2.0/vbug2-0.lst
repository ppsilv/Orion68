                            	   108: ; ----------------------------------------------------------------------
                            	   109: DelUartWriteString:
02:00001580 2F08            	   110:         MOVE.L  A0,-(SP)      ; Preserva D0
02:00001582 2F00            	   111:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   112: .WriteLoop:
02:00001584 1018            	   113:         MOVE.B  (A0)+,D0      ; Pega caractere
02:00001586 6706            	   114:         BEQ     .Done
02:00001588 4EB813DE        	   115:         JSR     WriteConout ; Use sua rotine existente
02:0000158C 60F6            	   116:         BRA     .WriteLoop
                            	   117: .Done:
02:0000158E 201F            	   118:         MOVE.L  (SP)+,D0
02:00001590 205F            	   119:         MOVE.L  (SP)+,A0
02:00001592 4E75            	   120:         RTS
