                            	    19: 
02:0000185E 207900080424    	    20:         MOVE.L  (addressInHex),A0
                            	    21:         ; Calcula endereço final
                            	    22: 
                            	    23: DUMPLOOPMASTER:
02:00001864 303C0000        	    24:         MOVE.W  #$0,D0
02:00001868 4840            	    25:         SWAP    D0
