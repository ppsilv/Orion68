02:0000172A 4E71            	    95:         NOP
02:0000172C E049            	    96:         LSR.W   #8,D1             ; Desloca o byte alto para a posição baixa em D0
02:0000172E 13C100FF8031    	    97:         MOVE.B  D1,REG_Y_HIGH
02:00001734 4E71            	    98:         NOP
02:00001736 4E71            	    99:         NOP
