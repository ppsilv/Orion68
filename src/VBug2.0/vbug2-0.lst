                            	    31: ; Write char
                            	    32: ; Change A1
                            	    33: ; Receive char in D0
                            	    34: UartWriteChar:
02:000014FA 2F09            	    35:         MOVE.L A1,-(SP)
02:000014FC 227900080410    	    36:         move.l  currentUart,A1
