                            	     1: ;Uart register offsets
                            	     2: UARTB_BASE   equ     $FF4100
                            	     3: 
                            	     4: 
                            	     5: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	     6: ; Initialize uart
                            	     7: ; Change A1
                            	     8: ; Parametros: none
                            	     9: ; ----------------------------------------------------------------------
                            	    10: InitUartb:
02:00001614 227C00FF4100    	    11:         move.l  #UARTB_BASE,A1
02:0000161A 203900080A28    	    12:         move.l  currentBaudRate,D0
02:00001620 137C00830007    	    13:         move.b  #%10000011,LCR(A1) ;DLAB=1
02:00001626 137C00080001    	    14:         move.b  #$08,DLL(A1)       ; set divisor latch low byte
02:0000162C 137C00000003    	    15:         move.b  #$00,DLM(A1)       ; set divisor latch high byte
02:00001632 137C00030007    	    16:         move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:00001638 137C000D0005    	    17:         move.b  #%00001101,FCR(A1) ; enable FIFO
02:0000163E 4229000F        	    18:         clr.b   SCR(A1)            ; clear the scratch register
02:00001642 4E75            	    19:         RTS
                            	    20: InitUartb1:
02:00001644 227C00FF4100    	    21:         move.l  #UARTB_BASE,A1
02:0000164A 203900080A28    	    22:         move.l  currentBaudRate,D0
02:00001650 137C000D0005    	    23:         move.b  #%00001101,FCR(a1)      ; enable FIFO
02:00001656 137C00830007    	    24:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:0000165C 13400001        	    25:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:00001660 E088            	    26:         lsr.l   #8,D0                   ; Shift right 8 bits
02:00001662 13400003        	    27:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:00001666 08A900070007    	    28:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:0000166C 4229000F        	    29:         clr.b   SCR(a1)                 ; clear the scratch register
02:00001670 4E75            	    30:         RTS
                            	    31: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    32: ; Write char
                            	    33: ; Change A1
                            	    34: ; Receive char in D0
                            	    35: UartbWriteChar:
02:00001672 2F09            	    36:         MOVE.L A1,-(SP)
02:00001674 227C00FF4100    	    37:         move.l  #UARTB_BASE,A1
                            	    38: .WaitTx:
02:0000167A 08290005000B    	    39:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:00001680 67F8            	    40:         beq     .WaitTx
02:00001682 13400001        	    41:         move.b  D0,THR(A1)      ; transmit byte
02:00001686 225F            	    42:         MOVE.L (SP)+,A1
02:00001688 4E75            	    43:         RTS
                            	    44:         
                            	    45: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    46: ; Read char block
