Source: "rot_print_hex_num.asm"
                            	     1: 
                            	     2: ; ----------------------------------------------------------------------
                            	     3: ; PrintHexAddress - Imprime endereço de 32 bits
                            	     4: ; Entrada: D0 = endereço
                            	     5: ; ----------------------------------------------------------------------
                            	     6: PrintHexAddress:
02:00001AE6 2F01            	     7:         MOVE.L  D1,-(SP)
02:00001AE8 4840            	     8:         SWAP    D0                ; Imprime parte alta primeiro
02:00001AEA 4EB81AFA        	     9:         JSR     PrintWordHex
02:00001AEE 2001            	    10:         MOVE.L  D1,D0
02:00001AF0 4840            	    11:         SWAP    D0                ; Parte baixa
02:00001AF2 4EB81AFA        	    12:         JSR     PrintWordHex
02:00001AF6 221F            	    13:         MOVE.L (SP)+,D1
02:00001AF8 4E75            	    14:         RTS
                            	    15:         
                            	    16: PrintWordHex:
02:00001AFA 2200            	    17:         MOVE.L  D0,D1
02:00001AFC E058            	    18:         ROR     #8,D0             ; Byte mais significativo primeiro
02:00001AFE 4EB81B0A        	    19:         JSR     PrintByteHex
02:00001B02 2001            	    20:         MOVE.L  D1,D0             ; Byte menos significativo
02:00001B04 4EB81B0A        	    21:         JSR     PrintByteHex
02:00001B08 4E75            	    22:         RTS
                            	    23: 
                            	    24: PrintByteHex:
02:00001B0A 1F00            	    25:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001B0C E808            	    26:         LSR.B   #4,D0             ; Nibble alto
02:00001B0E 6106            	    27:         BSR     .PrintNibble
02:00001B10 101F            	    28:         MOVE.B  (SP)+,D0          ; Recupera byte
02:00001B12 0200000F        	    29:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	    30: .PrintNibble:
02:00001B16 B03C0009        	    31:         CMP.B   #9,D0
02:00001B1A 6302            	    32:         BLS     .Decimal
02:00001B1C 5E00            	    33:         ADD.B   #7,D0             ; Ajuste para A-F
                            	    34: .Decimal:
02:00001B1E D03C0030        	    35:         ADD.B   #'0',D0
02:00001B22 4EB813B6        	    36:         JSR     WriteConout    ; Usa JMP para tail call optimization
02:00001B26 4E75            	    37:         RTS
                            	    38: 

