                            	   108: ; ----------------------------------------------------------------------
                            	   109: DelUartWriteString:
02:00001596 2F08            	   110:         MOVE.L  A0,-(SP)      ; Preserva D0
02:00001598 2F00            	   111:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   112: .WriteLoop:
02:0000159A 1018            	   113:         MOVE.B  (A0)+,D0      ; Pega caractere
02:0000159C 6706            	   114:         BEQ     .Done
02:0000159E 4EB813F4        	   115:         JSR     WriteConout ; Use sua rotine existente
02:000015A2 60F6            	   116:         BRA     .WriteLoop
                            	   117: .Done:
02:000015A4 201F            	   118:         MOVE.L  (SP)+,D0
02:000015A6 205F            	   119:         MOVE.L  (SP)+,A0
02:000015A8 4E75            	   120:         RTS
