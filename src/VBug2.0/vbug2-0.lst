                            	     9: InitUart:
02:000014B2 227900080410    	    10:         move.l  currentUart,A1
02:000014B8 203900080A48    	    11:         move.l  currentBaudRate,D0
02:000014BE 137C00830007    	    12:         move.b  #%10000011,LCR(A1) ;DLAB=1
02:000014C4 137C00080001    	    13:         move.b  #$08,DLL(A1)       ; set divisor latch low byte
02:000014CA 137C00000003    	    14:         move.b  #$00,DLM(A1)       ; set divisor latch high byte
02:000014D0 137C00030007    	    15:         move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:000014D6 137C000D0005    	    16:         move.b  #%00001101,FCR(A1) ; enable FIFO
02:000014DC 4229000F        	    17:         clr.b   SCR(A1)            ; clear the scratch register
02:000014E0 4E75            	    18:         RTS
                            	    19: InitUart1:
02:000014E2 227900080410    	    20:         move.l  currentUart,A1
02:000014E8 203900080A48    	    21:         move.l  currentBaudRate,D0
02:000014EE 137C000D0005    	    22:         move.b  #%00001101,FCR(a1)      ; enable FIFO
02:000014F4 137C00830007    	    23:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:000014FA 13400001        	    24:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:000014FE E088            	    25:         lsr.l   #8,D0                   ; Shift right 8 bits
02:00001500 13400003        	    26:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:00001504 08A900070007    	    27:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:0000150A 4229000F        	    28:         clr.b   SCR(a1)                 ; clear the scratch register
02:0000150E 4E75            	    29:         RTS
