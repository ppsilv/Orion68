                            	     4: 
                            	     5:     Align 2
                            	     6: ; -----------------------------------------------------------------------------
                            	     7: ; O SEU CÓDIGO DO TCPBOX68K (Agora rodando na RAM)
                            	     8: ; -----------------------------------------------------------------------------
                            	     9: vbug2_trap1:
02:00001B18 B03C0001        	    10:     CMP.B   #CMD_CCONIN,D0      ; Compara com CCONIN (ler caractere)
02:00001B1C 6714            	    11:     BEQ     trap_cconin         ; Se for 1, vai para leitura
02:00001B1E B03C0002        	    12:     CMP.B   #CMD_CCONOUT,D0     ; Compara com CCONOUT (escrever caractere)
02:00001B22 671E            	    13:     BEQ     trap_cconout        ; Se for 2, vai para escrita
02:00001B24 B03C0003        	    14:     CMP.B   #CMD_CCONOUTSTR,D0  ; Compara com CCONOUT (escrever string)
02:00001B28 6724            	    15:     BEQ     trap_strout         ; Se for 3, vai para escrita
02:00001B2A 4A00            	    16:     CMP.B   #CMD_PTERM0,D0      ; Compara com PTERM0 (terminar)
02:00001B2C 6728            	    17:     BEQ     trap_pterm0         ; Se for 0, vai para terminar
02:00001B2E 70FF            	    18:     MOVE.L  #-1,D0              ; Retorna erro se função não reconhecida
02:00001B30 4E73            	    19:     RTE
                            	    20: 
                            	    21: ; --------------------------------
                            	    22: ; TRAP_CCONIN - Ler caractere do console
                            	    23: ; Saída: D0.L - Caractere lido
                            	    24: ; --------------------------------
                            	    25: trap_cconin:
02:00001B32 247900080418    	    26:     MOVE.L  (cconin),A2
02:00001B38 4E92            	    27:     JSR     (A2)
02:00001B3A 0280000000FF    	    28:     ANDI.L  #$FF,D0       ; Mantém apenas o byte inferior
02:00001B40 4E73            	    29:     RTE                   ; Retorna da exceção
                            	    30: 
                            	    31: ; --------------------------------
                            	    32: ; TRAP_CCONOUT - Escrever caractere no console
                            	    33: ; Entrada: D1.L - Caractere a escrever
                            	    34: ; --------------------------------
                            	    35: trap_cconout:
02:00001B42 1001            	    36:     MOVE.B  D1,D0
02:00001B44 247900080414    	    37:     MOVE.L  (cconout),A2        ; Busca o endereço da rotina física da UART
02:00001B4A 4E92            	    38:     JSR     (A2)
02:00001B4C 4E73            	    39:     RTE      
                            	    40:                 
                            	    41: 
                            	    42: trap_strout:
02:00001B4E 2049            	    43:     MOVE.L  A1,A0
02:00001B50 4EB813C0        	    44:     JSR     WriteStringConout
02:00001B54 4E73            	    45:     RTE
                            	    46: 
                            	    47: 
                            	    48: ; --------------------------------
                            	    49: ; TRAP_PTERM0 - Terminar programa
                            	    50: ; --------------------------------
                            	    51: trap_pterm0:
02:00001B56 303C0000        	    52:     move.w  #0,d0         ; Código de saída 0
02:00001B5A 6102            	    53:     bsr     hardware_exit ; Chama rotina de término
02:00001B5C 4E73            	    54:     RTE     
                            	    55: 
                            	    56: ; --------------------------------
                            	    57: ; hardware_exit - Terminar execução
                            	    58: ; Entrada: D0.W - Código de saída
                            	    59: ; --------------------------------
                            	    60: hardware_exit:
                            	    61:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    62:     ; Exemplo: parar o processador
                            	    63:     ; stop    #$2700
                            	    64: 
                            	    65:     ; Exemplo simples: loop infinito
02:00001B5E 60FE            	    66:     BRA     hardware_exit
02:00001B60 4E75            	    67:     RTS
                            	    68: 
                            	    69: InitTrap1:
                            	    70:     ; -------------------------------------------------------------------------
                            	    71:     ; COMO INSTALAR NA RAM:
                            	    72:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	    73:     ; -------------------------------------------------------------------------
02:00001B62 41F81B18        	    74:     LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
02:00001B66 23C800080004    	    75:     MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
02:00001B6C 4E75            	    76:     RTS
                            	    77:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    78: 

