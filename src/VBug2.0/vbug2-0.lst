02:0000168C 227C00FF4100    	    52:         move.l  #UARTB_BASE,A1
                            	    53: .WaitRx:
02:00001692 08290000000B    	    54:         btst    #0,LSR(A1)        ; RX ready?
02:00001698 67F8            	    55:         beq     .WaitRx
                            	    56: 
02:0000169A 10290001        	    57:         move.b  RHR(A1),D0
02:0000169E 225F            	    58:         MOVE.L (SP)+,A1
