                            	    41: 
                            	    42: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    43: ; Initialize uart
                            	    44: ; Change A1
                            	    45: ; Parametros: D0 = baudrate number to write in DLM e DLL.
                            	    46: ; ----------------------------------------------------------------------
                            	    47: UartInit:
02:0000126A 227900080410    	    48:         move.l  currentUart,A1
02:00001270 137C000D0005    	    49:         move.b  #%00001101,FCR(A1)      ; enable FIFO
02:00001276 137C00830007    	    50:         move.b  #%10000011,LCR(A1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:0000127C 13400001        	    51:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:00001280 E088            	    52:         lsr.l   #8,D0                   ; Shift right 8 bits
02:00001282 13400003        	    53:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:00001286 08A900070007    	    54:         bclr.b  #7,LCR(A1)              ; disable divisor latch
02:0000128C 4229000F        	    55:         clr.b   SCR(A1)                 ; clear the scratch register
02:00001290 4E75            	    56:         RTS
                            	    57: 
                            	    58: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    59: ; Write char
                            	    60: ; Change A1
                            	    61: ; Receive char in D0
                            	    62: UartWriteChar:
02:00001292 43F900080410    	    63:         lea     currentUart,A1
                            	    64: .WaitTx:
02:00001298 08290005000B    	    65:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:0000129E 67F8            	    66:         beq     .WaitTx
02:000012A0 13400001        	    67:         move.b  D0,THR(A1)      ; transmit byte
02:000012A4 4E75            	    68:         RTS
                            	    69: 
                            	    70: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    71: ; Write char
                            	    72: ; Change A1
                            	    73: ;
                            	    74: ; Return char in D0)
                            	    75: UartReadChar:
02:000012A6 43F900080410    	    76:         lea     currentUart,A1
                            	    77: .WaitRx:
02:000012AC 08290000000B    	    78:         btst    #0,LSR(A1)        ; RX ready?
02:000012B2 67F8            	    79:         beq     .WaitRx
02:000012B4 10290001        	    80:         move.b  RHR(A1),D0
02:000012B8 4E75            	    81:         RTS
                            	    82: 

