                            	     5: ;Uart register offsets
                            	     6: UART_BASE   equ         $FF9100
                            	     7: RHR         equ         $1   ; receive holding register (read)
                            	     8: THR         equ         $1   ; transmit holding register (write)
                            	     9: IER         equ         $3   ; interrupt enable register
                            	    10: ISR         equ         $5   ; interrupt status register (read)
                            	    11: FCR         equ         $5   ; FIFO control register (write)
                            	    12: LCR         equ         $7   ; line control register
                            	    13: MCR         equ         $9   ; modem control register
                            	    14: LSR         equ         $B   ; line status register
                            	    15: MSR         equ         $D   ; modem status register
                            	    16: SPR         equ         $F   ; scratchpad register (reserved for system use)
                            	    17: DLL         equ         $1   ; divisor latch LSB
                            	    18: DLM         equ         $3   ; divisor latch MSB
                            	    19: ; aliases for register names (used by different manufacturers)cd ..
                            	    20: RBR         equ         RHR ; receive buffer register
                            	    21: IIR         equ         ISR ; interrupt identification register
                            	    22: SCR         equ         SPR ; scratch register
                            	    23: 
                            	    24: B009600     equ         $0060
                            	    25: B019200     equ         $0030
                            	    26: B038400     equ         $0018
                            	    27: B057600     equ         $0010
                            	    28: B115200     equ         $0008
                            	    29: B230400     equ         $0004
                            	    30: B460800     equ         $0002
                            	    31: B921600     equ         $0001
                            	    32: 
                            	    33: 
                            	    34: B009600L    equ         $60
                            	    35: B019200L    equ         $30
                            	    36: B038400L    equ         $18
                            	    37: B057600L    equ         $10
                            	    38: B115200L    equ         $08
                            	    39: B230400L    equ         $04
                            	    40: B460800L    equ         $02
                            	    41: B921600L    equ         $01
                            	    42: B009600H    equ         $00
                            	    43: B019200H    equ         $00     
                            	    44: B038400H    equ         $00     
                            	    45: B057600H    equ         $00     
                            	    46: B115200H    equ         $00     
                            	    47: B230400H    equ         $00
                            	    48: B460800H    equ         $00
                            	    49: B921600H    equ         $00
                            	    50: 
                            	    51: 
                            	    52: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    53: ; Initialize uart
                            	    54: ; Change A1
                            	    55: ; Parametros: none
                            	    56: ; ----------------------------------------------------------------------
                            	    57: InitUart:
02:000012A0 227900080410    	    58:         move.l  currentUart,A1
02:000012A6 203900080414    	    59:         move.l  currentBaudRate,D0
02:000012AC 137C000D0005    	    60:         move.b  #%00001101,FCR(A1)      ; enable FIFO
02:000012B2 137C00830007    	    61:         move.b  #%10000011,LCR(A1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:000012B8 13400001        	    62:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:000012BC E088            	    63:         lsr.l   #8,D0                   ; Shift right 8 bits
02:000012BE 13400003        	    64:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:000012C2 08A900070007    	    65:         bclr.b  #7,LCR(A1)              ; disable divisor latch
02:000012C8 4229000F        	    66:         clr.b   SCR(A1)                 ; clear the scratch register
02:000012CC 4E75            	    67:         RTS
                            	    68: 
                            	    69: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    70: ; Write char
                            	    71: ; Change A1
                            	    72: ; Receive char in D0
                            	    73: UartWriteChar:
02:000012CE 43F900080410    	    74:         lea     currentUart,A1
                            	    75: .WaitTx:
02:000012D4 08290005000B    	    76:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:000012DA 67F8            	    77:         beq     .WaitTx
02:000012DC 13400001        	    78:         move.b  D0,THR(A1)      ; transmit byte
02:000012E0 4E75            	    79:         RTS
                            	    80: 
                            	    81: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    82: ; Write char
                            	    83: ; Change A1
                            	    84: ;
                            	    85: ; Return char in D0)
                            	    86: UartReadChar:
02:000012E2 43F900080410    	    87:         lea     currentUart,A1
                            	    88: .WaitRx:
02:000012E8 08290000000B    	    89:         btst    #0,LSR(A1)        ; RX ready?
02:000012EE 67F8            	    90:         beq     .WaitRx
02:000012F0 10290001        	    91:         move.b  RHR(A1),D0
02:000012F4 4E75            	    92:         RTS
                            	    93: 

