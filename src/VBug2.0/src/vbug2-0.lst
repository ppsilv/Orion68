Source: "trap1.asm"
                            	     1:     ORG     $00008000
                            	     2: 
                            	     3: ; -----------------------------------------------------------------------------
                            	     4: ; O SEU CÓDIGO DO TCPBOX68K (Agora rodando na RAM)
                            	     5: ; -----------------------------------------------------------------------------
                            	     6: vbug2_trap1:
02:00008000 B07C0001        	     7:     CMP.W   #CMD_CCONIN,D0      ; Compara com CCONIN (ler caractere)
02:00008004 6714            	     8:     BEQ     trap_cconin         ; Se for 1, vai para leitura
02:00008006 B07C0002        	     9:     CMP.W   #CMD_CCONOUT,D0     ; Compara com CCONOUT (escrever caractere)
02:0000800A 671E            	    10:     BEQ     trap_cconout        ; Se for 2, vai para escrita
02:0000800C B07C0003        	    11:     CMP.W   #CMD_CCONOUTSTR,D0  ; Compara com CCONOUT (escrever string)
02:00008010 6722            	    12:     BEQ     trap_strout         ; Se for 3, vai para escrita
02:00008012 4A40            	    13:     CMP.W   #CMD_PTERM0,D0      ; Compara com PTERM0 (terminar)
02:00008014 6730            	    14:     BEQ     trap_pterm0         ; Se for 0, vai para terminar
02:00008016 70FF            	    15:     MOVE.L  #-1,D0              ; Retorna erro se função não reconhecida
02:00008018 4E73            	    16:     RTE
                            	    17: 
                            	    18: ; --------------------------------
                            	    19: ; TRAP_CCONIN - Ler caractere do console
                            	    20: ; Saída: D0.L - Caractere lido
                            	    21: ; --------------------------------
                            	    22: trap_cconin:
02:0000801A 20790008041A    	    23:     MOVE.L  (cconin),A0
02:00008020 4E90            	    24:     JSR     (A0)
02:00008022 0280000000FF    	    25:     ANDI.L      #$FF,D0       ; Mantém apenas o byte inferior
02:00008028 4E73            	    26:     RTE                   ; Retorna da exceção
                            	    27: 
                            	    28: ; --------------------------------
                            	    29: ; TRAP_CCONOUT - Escrever caractere no console
                            	    30: ; Entrada: D1.L - Caractere a escrever
                            	    31: ; --------------------------------
                            	    32: trap_cconout:
02:0000802A 207900080416    	    33:     MOVE.L  (cconout),A0
02:00008030 4E90            	    34:     JSR     (A0)
02:00008032 4E73            	    35:     RTE                   ; Retorna da exceção
                            	    36: 
                            	    37: trap_strout:
02:00008034 227900080416    	    38:     MOVE.L  (cconout),A1
                            	    39: .strout:
02:0000803A 1018            	    40:     MOVE.B  (A0)+,D0
02:0000803C 4A00            	    41:     CMP.B   #0,D0
02:0000803E 6704            	    42:     BEQ     .fim
02:00008040 4E91            	    43:     JSR     (A1)
02:00008042 60F6            	    44:     BRA     .strout
                            	    45: .fim:
02:00008044 4E73            	    46:     RTE
                            	    47: 
                            	    48: ; --------------------------------
                            	    49: ; TRAP_PTERM0 - Terminar programa
                            	    50: ; --------------------------------
                            	    51: trap_pterm0:
02:00008046 303C0000        	    52:     move.w  #0,d0         ; Código de saída 0
02:0000804A 6102            	    53:     bsr     hardware_exit ; Chama rotina de término
02:0000804C 4E73            	    54:     RTE     
                            	    55: 
                            	    56: ; --------------------------------
                            	    57: ; hardware_exit - Terminar execução
                            	    58: ; Entrada: D0.W - Código de saída
                            	    59: ; --------------------------------
                            	    60: hardware_exit:
                            	    61:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    62:     ; Exemplo: parar o processador
                            	    63:     ; stop    #$2700
                            	    64: 
                            	    65:     ; Exemplo simples: loop infinito
02:0000804E 60FE            	    66:     BRA     hardware_exit
02:00008050 4E75            	    67:     RTS
                            	    68: 
                            	    69: InitTrap1:
                            	    70:     ; -------------------------------------------------------------------------
                            	    71:     ; COMO INSTALAR NA RAM:
                            	    72:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	    73:     ; -------------------------------------------------------------------------
02:00008052 41FAFFAC        	    74:     LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
02:00008056 23C800080004    	    75:     MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
02:0000805C 4E75            	    76:     RTS
                            	    77:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    78: 

