                            	     5: ;Uart register offsets
                            	     6: UART_BASE   equ         $FF4000
                            	     7: RHR         equ         $1   ; receive holding register (read)
                            	     8: THR         equ         $1   ; transmit holding register (write)
                            	     9: IER         equ         $3   ; interrupt enable register
                            	    10: ISR         equ         $5   ; interrupt status register (read)
                            	    11: FCR         equ         $5   ; FIFO control register (write)
                            	    12: LCR         equ         $7   ; line control register
                            	    13: MCR         equ         $9   ; modem control register
                            	    14: LSR         equ         $B   ; line status register
                            	    15: MSR         equ         $D   ; modem status register
                            	    16: SPR         equ         $F   ; scratchpad register (reserved for system use)
                            	    17: DLL         equ         $1   ; divisor latch LSB
                            	    18: DLM         equ         $3   ; divisor latch MSB
                            	    19: ; aliases for register names (used by different manufacturers)cd ..
                            	    20: RBR         equ         RHR ; receive buffer register
                            	    21: IIR         equ         ISR ; interrupt identification register
                            	    22: SCR         equ         SPR ; scratch register
                            	    23: 
                            	    24: B009600     equ         $0060
                            	    25: B019200     equ         $0030
                            	    26: B038400     equ         $0018
                            	    27: B057600     equ         $0010
                            	    28: B115200     equ         $0008
                            	    29: B230400     equ         $0004
                            	    30: B460800     equ         $0002
                            	    31: B921600     equ         $0001
                            	    32: 
                            	    33: 
                            	    34: B009600L    equ         $60
                            	    35: B019200L    equ         $30
                            	    36: B038400L    equ         $18
                            	    37: B057600L    equ         $10
                            	    38: B115200L    equ         $08
                            	    39: B230400L    equ         $04
                            	    40: B460800L    equ         $02
                            	    41: B921600L    equ         $01
                            	    42: B009600H    equ         $00
                            	    43: B019200H    equ         $00     
                            	    44: B038400H    equ         $00     
                            	    45: B057600H    equ         $00     
                            	    46: B115200H    equ         $00     
                            	    47: B230400H    equ         $00
                            	    48: B460800H    equ         $00
                            	    49: B921600H    equ         $00
