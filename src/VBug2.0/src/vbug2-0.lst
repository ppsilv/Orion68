Source: "cmd_mem_dump.asm"
                            	     1: 
                            	     2: 
                            	     3: 
                            	     4: 
                            	     5: ; ----------------------------------------------------------------------
                            	     6: ; MemDump - Imprime dump de memória formatado
                            	     7: ; Entrada:
                            	     8: ;   A0 = Endereço inicial (ex: $80000)
                            	     9: ;   D0 = Quantidade de bytes (ex: 256)
                            	    10: ; ----------------------------------------------------------------------
                            	    11: MEMDUMP:
02:000013BA 41F900000000    	    12:         LEA     MsgDumpHeader,A0
02:000013C0 4EB811F4        	    13:         JSR     WriteString
02:000013C4 207900080634    	    14:         MOVE.L  (addressInHex),A0
02:000013CA 2008            	    15:         MOVE.L  A0,D0
02:000013CC 4EB8138E        	    16:         JSR     PicoPrintHexAddress
02:000013D0 4EB81206        	    17:         JSR     NewLine
                            	    18: 
02:000013D4 41F900000013    	    19:         LEA     MsgDumpHeader1,A0
02:000013DA 4EB811F4        	    20:         JSR     WriteString
                            	    21: 
02:000013DE 207900080634    	    22:         MOVE.L  (addressInHex),A0
                            	    23:         ; Calcula endereço final
                            	    24: 
                            	    25: DUMPLOOPMASTER:
02:000013E4 7200            	    26:         CLR.L   D1
02:000013E6 2208            	    27:         MOVE.L  A0,D1
02:000013E8 0681000000FF    	    28:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    29:         ;MOVE.L  D1,D0
                            	    30:         ;JSR     PicoPrintHexAddress
                            	    31:         ;JSR     new_line
                            	    32: 
                            	    33:         ;aguarda um caractere ser digitado mas nao usa é somente para parar a execução aqui
                            	    34:         ;JSR     ReadChar
                            	    35: 
                            	    36: 
                            	    37: DumpLoop:
                            	    38:         ; Nova linha a cada 16 bytes
02:000013EE 2008            	    39:         MOVE.L  A0,D0
02:000013F0 02800000000F    	    40:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:000013F6 6616            	    41:         BNE     NoNewLine
                            	    42: 
                            	    43:         ; Imprime endereço
02:000013F8 2008            	    44:         MOVE.L  A0,D0
02:000013FA 4EB8138E        	    45:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    46: 
02:000013FE 103C003A        	    47:         MOVE.B  #':',D0
02:00001402 4EB811EA        	    48:         JSR     WriteChar
02:00001406 103C0020        	    49:         MOVE.B  #' ',D0
02:0000140A 4EB811EA        	    50:         JSR     WriteChar
                            	    51: 
                            	    52: NoNewLine:
                            	    53:         ; Imprime byte em hex
02:0000140E 1018            	    54:         MOVE.B  (A0)+,D0
02:00001410 4EB8139E        	    55:         JSR     PicoPrintByteHex
                            	    56: 
02:00001414 103C0020        	    57:         MOVE.B  #' ',D0
02:00001418 4EB811EA        	    58:         JSR     WriteChar
                            	    59: 
                            	    60:         ; Verifica fim da linha (16 bytes)
02:0000141C 2008            	    61:         MOVE.L  A0,D0
02:0000141E 02800000000F    	    62:         ANDI.L  #$0000000F,D0
02:00001424 664E            	    63:         BNE     NoEndLine
                            	    64: 
                            	    65:         ; Imprime caracteres ASCII
02:00001426 103C0020        	    66:         MOVE.B  #' ',D0
02:0000142A 4EB811EA        	    67:         JSR     WriteChar
02:0000142E 103C007C        	    68:         MOVE.B  #'|',D0
02:00001432 4EB811EA        	    69:         JSR     WriteChar
                            	    70: 
02:00001436 43E8FFF0        	    71:         LEA     -16(A0),A1        ; Volta ao início da linha
02:0000143A 740F            	    72:         MOVEQ   #15,D2            ; 16 caracteres
                            	    73: 
                            	    74: AsciiLoop:
02:0000143C 1019            	    75:         MOVE.B  (A1)+,D0
02:0000143E B03C0020        	    76:         CMP.B   #32,D0            ; Verifica se é imprimível
02:00001442 6D0C            	    77:         BLT     NonPrintable
02:00001444 B03C007E        	    78:         CMP.B   #126,D0
02:00001448 6E06            	    79:         BGT     NonPrintable
                            	    80: 
02:0000144A 4EB811EA        	    81:         JSR     WriteChar
02:0000144E 6008            	    82:         BRA     NextAscii
                            	    83: 
                            	    84: NonPrintable:
02:00001450 103C002E        	    85:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
02:00001454 4EB811EA        	    86:         JSR     WriteChar
                            	    87: 
                            	    88: NextAscii:
02:00001458 51CAFFE2        	    89:         DBRA    D2,AsciiLoop
                            	    90: 
02:0000145C 103C007C        	    91:         MOVE.B  #'|',D0
02:00001460 4EB811EA        	    92:         JSR     WriteChar
02:00001464 103C000D        	    93:         MOVE.B  #13,D0            ; CR
02:00001468 4EB811EA        	    94:         JSR     WriteChar
02:0000146C 103C000A        	    95:         MOVE.B  #10,D0            ; LF
02:00001470 4EB811EA        	    96:         JSR     WriteChar
                            	    97: 
                            	    98: NoEndLine:
                            	    99:         ; Verifica fim do dump
02:00001474 B1C1            	   100:         CMP.L   D1,A0
02:00001476 6300FF76        	   101:         BLS     DumpLoop
                            	   102: 
02:0000147A 2F08            	   103:         MOVE.L  A0,-(SP)          ; Salva endereço atual
02:0000147C 41F900000310    	   104:         LEA     MsgHitAnyKey,A0
02:00001482 4EB811F4        	   105:         JSR     WriteString
02:00001486 4EB811FC        	   106:         JSR     ReadChar
02:0000148A B03C001B        	   107:         CMP.B   #$1B,D0
02:0000148E 6706            	   108:         BEQ     .fim
                            	   109: 
02:00001490 205F            	   110:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:00001492 6000FF50        	   111:         BRA     DUMPLOOPMASTER
                            	   112: .fim
02:00001496 4E75            	   113:         RTS

