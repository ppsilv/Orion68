                            	     4: 
                            	     5: ; ----------------------------------------------------------------------
                            	     6: ; MemDump - Imprime dump de memória formatado
                            	     7: ; Entrada:
                            	     8: ;   A0 = Endereço inicial (ex: $80000)
                            	     9: ;   D0 = Quantidade de bytes (ex: 256)
                            	    10: ; ----------------------------------------------------------------------
                            	    11: MEMDUMP:
02:00001350 41F900000000    	    12:         LEA     MsgDumpHeader,A0
02:00001356 4EB900000000    	    13:         JSR     UART_WriteString
02:0000135C 207900080422    	    14:         MOVE.L  (addressInHex),A0
02:00001362 2008            	    15:         MOVE.L  A0,D0
02:00001364 4EB81324        	    16:         JSR     PicoPrintHexAddress
02:00001368 4EB811F0        	    17:         JSR     NewLine
                            	    18: 
02:0000136C 41F900000013    	    19:         LEA     MsgDumpHeader1,A0
02:00001372 4EB900000000    	    20:         JSR     UART_WriteString
                            	    21: 
02:00001378 207900080422    	    22:         MOVE.L  (addressInHex),A0
                            	    23:         ; Calcula endereço final
                            	    24: 
                            	    25: DUMPLOOPMASTER:
02:0000137E 7200            	    26:         CLR.L   D1
02:00001380 2208            	    27:         MOVE.L  A0,D1
02:00001382 0681000000FF    	    28:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    29:         ;MOVE.L  D1,D0
                            	    30:         ;JSR     PicoPrintHexAddress
                            	    31:         ;JSR     new_line
                            	    32: 
                            	    33:         ;aguarda um caractere ser digitado mas nao usa é somente para parar a execução aqui
                            	    34:         ;JSR     UART_ReadChar
                            	    35: 
                            	    36: 
                            	    37: DumpLoop:
                            	    38:         ; Nova linha a cada 16 bytes
02:00001388 2008            	    39:         MOVE.L  A0,D0
02:0000138A 02800000000F    	    40:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:00001390 661A            	    41:         BNE     NoNewLine
                            	    42: 
                            	    43:         ; Imprime endereço
02:00001392 2008            	    44:         MOVE.L  A0,D0
02:00001394 4EB81324        	    45:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    46: 
02:00001398 103C003A        	    47:         MOVE.B  #':',D0
02:0000139C 4EB900000000    	    48:         JSR     UART_WriteChar
02:000013A2 103C0020        	    49:         MOVE.B  #' ',D0
02:000013A6 4EB900000000    	    50:         JSR     UART_WriteChar
                            	    51: 
                            	    52: NoNewLine:
                            	    53:         ; Imprime byte em hex
02:000013AC 1018            	    54:         MOVE.B  (A0)+,D0
02:000013AE 4EB81334        	    55:         JSR     PicoPrintByteHex
                            	    56: 
02:000013B2 103C0020        	    57:         MOVE.B  #' ',D0
02:000013B6 4EB900000000    	    58:         JSR     UART_WriteChar
                            	    59: 
                            	    60:         ; Verifica fim da linha (16 bytes)
02:000013BC 2008            	    61:         MOVE.L  A0,D0
02:000013BE 02800000000F    	    62:         ANDI.L  #$0000000F,D0
02:000013C4 665C            	    63:         BNE     NoEndLine
                            	    64: 
                            	    65:         ; Imprime caracteres ASCII
02:000013C6 103C0020        	    66:         MOVE.B  #' ',D0
02:000013CA 4EB900000000    	    67:         JSR     UART_WriteChar
02:000013D0 103C007C        	    68:         MOVE.B  #'|',D0
02:000013D4 4EB900000000    	    69:         JSR     UART_WriteChar
                            	    70: 
02:000013DA 43E8FFF0        	    71:         LEA     -16(A0),A1        ; Volta ao início da linha
02:000013DE 740F            	    72:         MOVEQ   #15,D2            ; 16 caracteres
                            	    73: 
                            	    74: AsciiLoop:
02:000013E0 1019            	    75:         MOVE.B  (A1)+,D0
02:000013E2 B03C0020        	    76:         CMP.B   #32,D0            ; Verifica se é imprimível
02:000013E6 6D0E            	    77:         BLT     NonPrintable
02:000013E8 B03C007E        	    78:         CMP.B   #126,D0
02:000013EC 6E08            	    79:         BGT     NonPrintable
                            	    80: 
02:000013EE 4EB900000000    	    81:         JSR     UART_WriteChar
02:000013F4 600A            	    82:         BRA     NextAscii
                            	    83: 
                            	    84: NonPrintable:
02:000013F6 103C002E        	    85:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
02:000013FA 4EB900000000    	    86:         JSR     UART_WriteChar
                            	    87: 
                            	    88: NextAscii:
02:00001400 51CAFFDE        	    89:         DBRA    D2,AsciiLoop
                            	    90: 
02:00001404 103C007C        	    91:         MOVE.B  #'|',D0
02:00001408 4EB900000000    	    92:         JSR     UART_WriteChar
02:0000140E 103C000D        	    93:         MOVE.B  #13,D0            ; CR
02:00001412 4EB900000000    	    94:         JSR     UART_WriteChar
02:00001418 103C000A        	    95:         MOVE.B  #10,D0            ; LF
02:0000141C 4EB900000000    	    96:         JSR     UART_WriteChar
                            	    97: 
                            	    98: NoEndLine:
                            	    99:         ; Verifica fim do dump
02:00001422 B1C1            	   100:         CMP.L   D1,A0
02:00001424 6300FF62        	   101:         BLS     DumpLoop
                            	   102: 
02:00001428 2F08            	   103:         MOVE.L  A0,-(SP)          ; Salva endereço atual
02:0000142A 41F900000456    	   104:         LEA     MsgHitAnyKey,A0
02:00001430 4EB900000000    	   105:         JSR     UART_WriteString
02:00001436 4EB900000000    	   106:         JSR     UART_ReadChar
02:0000143C B03C001B        	   107:         CMP.B   #$1B,D0
02:00001440 6706            	   108:         BEQ     .fim
                            	   109: 
02:00001442 205F            	   110:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:00001444 6000FF38        	   111:         BRA     DUMPLOOPMASTER
                            	   112: .fim
02:00001448 4E75            	   113:         RTS

