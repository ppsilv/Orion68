                            	     5: ;;picoVGA Register address
                            	     6: WRITE_SCREEN   equ $FF8001        ;;Endereço real  3 0x03  o pico enxerga 0x00
                            	     7: REG_02         equ $FF8003        ;;Endereço real  3 0x03  o pico enxerga 0x01
                            	     8: REG_03         equ $FF8005        ;;Endereço real  5 0x05  o pico enxerga 0x02
                            	     9: REG_04         equ $FF8007        ;;Endereço real  7 0x07  o pico enxerga 0x03
                            	    10: CONFIG_REG     equ $FF8009        ;;Endereço real  9 0x09  o pico enxerga 0x04
                            	    11: REG_06         equ $FF800B        ;;Endereço real 11 0x0b  o pico enxerga 0x05
                            	    12: REG_07         equ $FF800D        ;;Endereço real 13 0x0d  o pico enxerga 0x06
                            	    13: REG_08         equ $FF800F        ;;Endereço real 15 0x0f  o pico enxerga 0x07
                            	    14: REG_09         equ $FF8011        ;;Endereço real 17 0x11  o pico enxerga 0x08
                            	    15: REG_0A         equ $FF8013        ;;Endereço real 19 0x13  o pico enxerga 0x09
                            	    16: REG_0B         equ $FF8015        ;;Endereço real 21 0x15  o pico enxerga 0x0A
                            	    17: REG_0C         equ $FF8017        ;;Endereço real 23 0x17  o pico enxerga 0x0B
                            	    18: REG_0D         equ $FF8019        ;;Endereço real 25 0x19  o pico enxerga 0x0C
                            	    19: REG_0E         equ $FF801B        ;;Endereço real 27 0x1b  o pico enxerga 0x0D
                            	    20: REG_0F         equ $FF801D        ;;Endereço real 29 0x1d  o pico enxerga 0x0E
                            	    21: REG_10         equ $FF801F        ;;Endereço real 31 0x1f  o pico enxerga 0x0F
                            	    22: REG_11         equ $FF8021        ;;Endereço real 33 0x21  o pico enxerga 0x10
                            	    23: REG_12         equ $FF8023        ;;Endereço real 35 0x23  o pico enxerga 0x11
                            	    24: REG_13         equ $FF8025        ;;Endereço real 37 0x25  o pico enxerga 0x12
                            	    25: SET_MODE       equ $FF8027        ;;Endereço real 39 0x27  o pico enxerga 0x13 (0=Texto+Scroll, 1=Texto Fixo, 2=320x20
                            	    26: SET_TXT_COLOR  equ $FF8029        ;;Endereço real 41 0x29  o pico enxerga 0x14
                            	    27: CHANGE_CUR_POS equ $FF802B        ;;Endereço real 43 0x2b  o pico enxerga 0x15
                            	    28: REG_X_HIGH     equ $FF802D        ;;Endereço real 45 0x2d  o pico enxerga 0x16
                            	    29: REG_X_LOW      equ $FF802F        ;;Endereço real 47 0x2f  o pico enxerga 0x17
                            	    30: REG_Y_HIGH     equ $FF8031        ;;Endereço real 49 0x31  o pico enxerga 0x18
                            	    31: REG_Y_LOW      equ $FF8033        ;;Endereço real 51 0x33  o pico enxerga 0x19
                            	    32: CHANGE_BUFFER  equ $FF8035        ;;Endereço real 53 0x35  o pico enxerga 0x1A
                            	    33: SELECT_SCREEN  equ $FF8037        ;;Endereço real 55 0x37  o pico enxerga 0x1B
                            	    34: SET_HORIZONTAL equ $FF8039        ;;Endereço real 57 0x39  o pico enxerga 0x1C
                            	    35: SET_VERTICAL   equ $FF803B        ;;Endereço real 59 0x3b  o pico enxerga 0x1D
                            	    36: RUN_CMD        equ $FF803D        ;;Endereço real 61 0x3d  o pico enxerga 0x1E
                            	    37: CORINGA        equ $FF803F        ;;Endereço real 63 0x3f  o pico enxerga 0x1F    
                            	    38: 
                            	    39: ;Commands
                            	    40: CMD_SYSTEM_ENABLE equ  $A5
                            	    41: CMD_CLEAR_SCREEN  equ  $A4
                            	    42: CMD_SET_CUR_POS   equ  $A3
                            	    43: CMD_SET_TXT_COLOR equ  $A2
                            	    44: CMD_GO_HOME       equ  $A1
                            	    45: 
                            	    46: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    47: ; Cursor go home
                            	    48: ; Receive cmd in D0
                            	    49: ;
                            	    50: PicoRunCmd:
02:000012BA 13C000FF803D    	    51:         MOVE.B  D0,RUN_CMD
02:000012C0 4E75            	    52:         RTS
                            	    53: 
                            	    54: 
                            	    55: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    56: ; Cursor go home
                            	    57: ; 
                            	    58: PicoGoHome:
02:000012C2 103C00A1        	    59:         MOVE.B  #CMD_GO_HOME,D0
02:000012C6 13C000FF803D    	    60:         MOVE.B  D0,RUN_CMD
02:000012CC 4E75            	    61:         RTS
                            	    62: 
                            	    63: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    64: ; Set cursor position
                            	    65: ; Detroy: A1
                            	    66: ; Receive X in D0
                            	    67: ; Receive Y in D1
                            	    68: PicoSetCursor:
02:000012CE 13C000FF802F    	    69:         MOVE.B  D0,REG_X_LOW
02:000012D4 E048            	    70:         LSR.W   #8,D0             ; Desloca o byte alto para a posição baixa em D0
02:000012D6 13C000FF802D    	    71:         MOVE.B  D0,REG_X_HIGH
02:000012DC 13C100FF8033    	    72:         MOVE.B  D1,REG_Y_LOW
02:000012E2 E049            	    73:         LSR.W   #8,D1             ; Desloca o byte alto para a posição baixa em D0
02:000012E4 13C100FF8031    	    74:         MOVE.B  D1,REG_Y_HIGH
02:000012EA 43F900FF803D    	    75:         LEA     RUN_CMD,A1    
02:000012F0 103C00A3        	    76:         MOVE.B  #CMD_SET_CUR_POS,D0
02:000012F4 1280            	    77:         MOVE.B  D0,(A1);
02:000012F6 4E75            	    78:         RTS
                            	    79: 
                            	    80: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    81: ; Clear screen
                            	    82: ; Destroy: A1 
                            	    83: ; Command in D0
                            	    84: PicoClearScreen:
02:000012F8 43F900FF803D    	    85:         LEA     RUN_CMD,A1    
02:000012FE 103C00A4        	    86:         MOVE.B  #CMD_CLEAR_SCREEN,D0
02:00001302 1280            	    87:         MOVE.B  D0,(A1);
02:00001304 4E75            	    88:         RTS
                            	    89: 
                            	    90: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    91: ; Write char in picoVGA
                            	    92: ; Destroy: A1,D1
                            	    93: PicoWriteChar:
02:00001306 43F900FF8001    	    94:             LEA     WRITE_SCREEN,A1
02:0000130C 1280            	    95:             MOVE.B  D0,(A1)     ; Escreve no endereço do PicoVGA (LDS ativo)
02:0000130E 223C00000FFF    	    96:             MOVE.L  #$FFF,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	    97: .DELAY00:
02:00001314 5381            	    98:             SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
02:00001316 66FC            	    99:             BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
02:00001318 4E75            	   100:             RTS
                            	   101: 
                            	   102: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   103: ; Imprime string terminada em ZERO
                            	   104: ; Destroy: A0 = String's address
                            	   105: ;
                            	   106: PicoPrintString:
02:0000131A 1018            	   107:         MOVE.B  (A0)+,D0      ; Pega caractere e avança ponteiro
02:0000131C 6704            	   108:         BEQ.S   .Done         ; Se for zero, termina
02:0000131E 61E6            	   109:         BSR.S   PicoWriteChar ; Chama sua função gloriosa!
02:00001320 60F8            	   110:         BRA.S   PicoPrintString   ; Loop para o próximo
                            	   111: .Done:
02:00001322 4E75            	   112:         RTS
                            	   113: 
                            	   114: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   115: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   116: ; Entrada: D0 = endereço
                            	   117: ;
                            	   118: PicoPrintHexAddress:
02:00001324 4840            	   119:         SWAP    D0                ; Imprime parte alta primeiro
02:00001326 4EB8132C        	   120:         JSR     .PrintWordHex
02:0000132A 4840            	   121:         SWAP    D0                ; Parte baixa
                            	   122: .PrintWordHex:
02:0000132C E158            	   123:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:0000132E 4EB81334        	   124:         JSR     PicoPrintByteHex
02:00001332 E058            	   125:         ROR.W   #8,D0             ; Byte menos significativo
                            	   126: PicoPrintByteHex:
02:00001334 1F00            	   127:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001336 E808            	   128:         LSR.B   #4,D0             ; Nibble alto
02:00001338 6106            	   129:         BSR     .PrintNibble
02:0000133A 101F            	   130:         MOVE.B  (SP)+,D0          ; Recupera byte
02:0000133C 0200000F        	   131:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   132: .PrintNibble:
02:00001340 B03C0009        	   133:         CMP.B   #9,D0
02:00001344 6302            	   134:         BLS     .Decimal
02:00001346 5E00            	   135:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   136: .Decimal:
02:00001348 D03C0030        	   137:         ADD.B   #'0',D0
02:0000134C 4EF81306        	   138:         JMP     PicoWriteChar    ; Usa JMP para tail call optimization
                            	   139: 

