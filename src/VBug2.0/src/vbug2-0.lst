                            	     5: ;;picoVGA Register address
                            	     6: PICO_BASE_ADDR equ $FF8000
                            	     7: WRITE_SCREEN   equ $FF8001        ;;Endereço real  3 0x03  o pico enxerga 0x00
                            	     8: REG_02         equ $FF8003        ;;Endereço real  3 0x03  o pico enxerga 0x01
                            	     9: REG_03         equ $FF8005        ;;Endereço real  5 0x05  o pico enxerga 0x02
                            	    10: REG_04         equ $FF8007        ;;Endereço real  7 0x07  o pico enxerga 0x03
                            	    11: CONFIG_REG     equ $FF8009        ;;Endereço real  9 0x09  o pico enxerga 0x04
                            	    12: REG_06         equ $FF800B        ;;Endereço real 11 0x0b  o pico enxerga 0x05
                            	    13: REG_07         equ $FF800D        ;;Endereço real 13 0x0d  o pico enxerga 0x06
                            	    14: REG_08         equ $FF800F        ;;Endereço real 15 0x0f  o pico enxerga 0x07
                            	    15: ;Begin Register for reads
                            	    16: REG_09         equ $FF8011        ;;Endereço real 17 0x11  o pico enxerga 0x08
                            	    17: REG_0A         equ $FF8013        ;;Endereço real 19 0x13  o pico enxerga 0x09
                            	    18: REG_0B         equ $FF8015        ;;Endereço real 21 0x15  o pico enxerga 0x0A
                            	    19: REG_0C         equ $FF8017        ;;Endereço real 23 0x17  o pico enxerga 0x0B
                            	    20: REG_0D         equ $FF8019        ;;Endereço real 25 0x19  o pico enxerga 0x0C
                            	    21: REG_0E         equ $FF801B        ;;Endereço real 27 0x1b  o pico enxerga 0x0D
                            	    22: REG_0F         equ $FF801D        ;;Endereço real 29 0x1d  o pico enxerga 0x0E
                            	    23: REG_10         equ $FF801F        ;;Endereço real 31 0x1f  o pico enxerga 0x0F
                            	    24: ;End
                            	    25: REG_11         equ $FF8021        ;;Endereço real 33 0x21  o pico enxerga 0x10
                            	    26: REG_12         equ $FF8023        ;;Endereço real 35 0x23  o pico enxerga 0x11
                            	    27: REG_13         equ $FF8025        ;;Endereço real 37 0x25  o pico enxerga 0x12
                            	    28: SET_MODE       equ $FF8027        ;;Endereço real 39 0x27  o pico enxerga 0x13 (0=Texto+Scroll, 1=Texto Fixo, 2=320x20
                            	    29: SET_TXT_COLOR  equ $FF8029        ;;Endereço real 41 0x29  o pico enxerga 0x14
                            	    30: CHANGE_CUR_POS equ $FF802B        ;;Endereço real 43 0x2b  o pico enxerga 0x15
                            	    31: REG_X_HIGH     equ $FF802D        ;;Endereço real 45 0x2d  o pico enxerga 0x16
                            	    32: REG_X_LOW      equ $FF802F        ;;Endereço real 47 0x2f  o pico enxerga 0x17
                            	    33: REG_Y_HIGH     equ $FF8031        ;;Endereço real 49 0x31  o pico enxerga 0x18
                            	    34: REG_Y_LOW      equ $FF8033        ;;Endereço real 51 0x33  o pico enxerga 0x19
                            	    35: CHANGE_BUFFER  equ $FF8035        ;;Endereço real 53 0x35  o pico enxerga 0x1A
                            	    36: SELECT_SCREEN  equ $FF8037        ;;Endereço real 55 0x37  o pico enxerga 0x1B
                            	    37: SET_HORIZONTAL equ $FF8039        ;;Endereço real 57 0x39  o pico enxerga 0x1C
                            	    38: SET_VERTICAL   equ $FF803B        ;;Endereço real 59 0x3b  o pico enxerga 0x1D
                            	    39: RUN_CMD        equ $FF803D        ;;Endereço real 61 0x3d  o pico enxerga 0x1E
                            	    40: CORINGA        equ $FF803F        ;;Endereço real 63 0x3f  o pico enxerga 0x1F    
                            	    41: 
                            	    42: ;Commands
                            	    43: CMD_SYSTEM_ENABLE equ  $A5
                            	    44: CMD_CLEAR_SCREEN  equ  $A4
                            	    45: CMD_SET_CUR_POS   equ  $A3
                            	    46: CMD_SET_TXT_COLOR equ  $A2
                            	    47: CMD_GO_HOME       equ  $A1
                            	    48: 
                            	    49: InitPicoVga:
02:000012F6 4E75            	    50:         RTS
                            	    51: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    52: ; Cursor go home
                            	    53: ; Receive cmd in D0
                            	    54: ;
                            	    55: PicoRunCmd:
02:000012F8 13C000FF803D    	    56:         MOVE.B  D0,RUN_CMD
02:000012FE 4E75            	    57:         RTS
                            	    58: 
                            	    59: 
                            	    60: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    61: ; Cursor go home
                            	    62: ; 
                            	    63: PicoGoHome:
02:00001300 103C00A1        	    64:         MOVE.B  #CMD_GO_HOME,D0
02:00001304 13C000FF803D    	    65:         MOVE.B  D0,RUN_CMD
02:0000130A 4E75            	    66:         RTS
                            	    67: 
                            	    68: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    69: ; Set cursor position
                            	    70: ; Detroy: A1
                            	    71: ; Receive X in D0
                            	    72: ; Receive Y in D1
                            	    73: PicoSetCursor:
02:0000130C 13C000FF802F    	    74:         MOVE.B  D0,REG_X_LOW
02:00001312 E048            	    75:         LSR.W   #8,D0             ; Desloca o byte alto para a posição baixa em D0
02:00001314 13C000FF802D    	    76:         MOVE.B  D0,REG_X_HIGH
02:0000131A 13C100FF8033    	    77:         MOVE.B  D1,REG_Y_LOW
02:00001320 E049            	    78:         LSR.W   #8,D1             ; Desloca o byte alto para a posição baixa em D0
02:00001322 13C100FF8031    	    79:         MOVE.B  D1,REG_Y_HIGH
02:00001328 43F900FF803D    	    80:         LEA     RUN_CMD,A1    
02:0000132E 103C00A3        	    81:         MOVE.B  #CMD_SET_CUR_POS,D0
02:00001332 1280            	    82:         MOVE.B  D0,(A1);
02:00001334 4E75            	    83:         RTS
                            	    84: 
                            	    85: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    86: ; Clear screen
                            	    87: ; Destroy: A1 
                            	    88: ; Command in D0
                            	    89: PicoClearScreen:
02:00001336 43F900FF803D    	    90:         LEA     RUN_CMD,A1    
02:0000133C 103C00A4        	    91:         MOVE.B  #CMD_CLEAR_SCREEN,D0
02:00001340 1280            	    92:         MOVE.B  D0,(A1);
02:00001342 4E75            	    93:         RTS
                            	    94: 
                            	    95: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    96: ; Write char in picoVGA
                            	    97: ; Destroy: A1,D1
                            	    98: PicoWriteChar:
02:00001344 43F900FF8001    	    99:             LEA     WRITE_SCREEN,A1
02:0000134A 1280            	   100:             MOVE.B  D0,(A1)     ; Escreve no endereço do PicoVGA (LDS ativo)
02:0000134C 223C00000FFF    	   101:             MOVE.L  #$FFF,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	   102: .DELAY00:
02:00001352 5381            	   103:             SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
02:00001354 66FC            	   104:             BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
02:00001356 4E75            	   105:             RTS
                            	   106: 
                            	   107: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   108: ; Imprime string terminada em ZERO
                            	   109: ; Destroy: A0 = String's address
                            	   110: ;
                            	   111: PicoPrintString:
02:00001358 1018            	   112:         MOVE.B  (A0)+,D0      ; Pega caractere e avança ponteiro
02:0000135A 6704            	   113:         BEQ.S   .Done         ; Se for zero, termina
02:0000135C 61E6            	   114:         BSR.S   PicoWriteChar ; Chama sua função gloriosa!
02:0000135E 60F8            	   115:         BRA.S   PicoPrintString   ; Loop para o próximo
                            	   116: .Done:
02:00001360 4E75            	   117:         RTS
                            	   118: 
                            	   119: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   120: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   121: ; Entrada: D0 = endereço
                            	   122: ;
                            	   123: PicoPrintHexAddress:
02:00001362 4840            	   124:         SWAP    D0                ; Imprime parte alta primeiro
02:00001364 4EB8136A        	   125:         JSR     .PrintWordHex
02:00001368 4840            	   126:         SWAP    D0                ; Parte baixa
                            	   127: .PrintWordHex:
02:0000136A E158            	   128:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:0000136C 4EB81372        	   129:         JSR     PicoPrintByteHex
02:00001370 E058            	   130:         ROR.W   #8,D0             ; Byte menos significativo
                            	   131: PicoPrintByteHex:
02:00001372 1F00            	   132:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001374 E808            	   133:         LSR.B   #4,D0             ; Nibble alto
02:00001376 6106            	   134:         BSR     .PrintNibble
02:00001378 101F            	   135:         MOVE.B  (SP)+,D0          ; Recupera byte
02:0000137A 0200000F        	   136:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   137: .PrintNibble:
02:0000137E B03C0009        	   138:         CMP.B   #9,D0
02:00001382 6302            	   139:         BLS     .Decimal
02:00001384 5E00            	   140:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   141: .Decimal:
02:00001386 D03C0030        	   142:         ADD.B   #'0',D0
02:0000138A 4EF81344        	   143:         JMP     PicoWriteChar    ; Usa JMP para tail call optimization
                            	   144: 

