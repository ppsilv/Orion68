                            	   356:         INCLUDE "trap1.asm"

Source: "trap1.asm"
                            	     1:     ORG     $00008000
                            	     2: 
                            	     3: InitTrap1:
                            	     4:     ; -------------------------------------------------------------------------
                            	     5:     ; COMO INSTALAR NA RAM:
                            	     6:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	     7:     ; -------------------------------------------------------------------------
02:00008000 41FA000A        	     8:     LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
02:00008004 23C800080004    	     9:     MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
02:0000800A 4E75            	    10:     RTS
                            	    11:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    12:     
                            	    13: ; -----------------------------------------------------------------------------
                            	    14: ; O SEU CÓDIGO DO TCPBOX68K (Agora rodando na RAM)
                            	    15: ; -----------------------------------------------------------------------------
                            	    16: vbug2_trap1:
02:0000800C B07C0001        	    17:     CMP.W   #1,D0          ; Compara com CCONIN (ler caractere)
02:00008010 6714            	    18:     BEQ     trap_cconin    ; Se for 1, vai para leitura
02:00008012 B07C0002        	    19:     CMP.W   #2,D0          ; Compara com CCONOUT (escrever caractere)
02:00008016 671E            	    20:     BEQ     trap_cconout   ; Se for 2, vai para escrita
02:00008018 B07C0003        	    21:     CMP.W   #3,D0          ; Compara com CCONOUT (escrever string)
02:0000801C 6722            	    22:     BEQ     trap_strout    ; Se for 3, vai para escrita
02:0000801E 4A40            	    23:     CMP.W   #0,D0          ; Compara com PTERM0 (terminar)
02:00008020 6730            	    24:     BEQ     trap_pterm0    ; Se for 0, vai para terminar
02:00008022 70FF            	    25:     MOVE.L  #-1,D0         ; Retorna erro se função não reconhecida
02:00008024 4E73            	    26:     RTE
                            	    27: 
                            	    28: ; --------------------------------
                            	    29: ; TRAP_CCONIN - Ler caractere do console
                            	    30: ; Saída: D0.L - Caractere lido
                            	    31: ; --------------------------------
                            	    32: trap_cconin:
02:00008026 20790008041A    	    33:     MOVE.L  (cconin),A0
02:0000802C 4E90            	    34:     JSR     (A0)
02:0000802E 0280000000FF    	    35:     ANDI.L      #$FF,D0       ; Mantém apenas o byte inferior
02:00008034 4E73            	    36:     RTE                   ; Retorna da exceção
                            	    37: 
                            	    38: ; --------------------------------
                            	    39: ; TRAP_CCONOUT - Escrever caractere no console
                            	    40: ; Entrada: D1.L - Caractere a escrever
                            	    41: ; --------------------------------
                            	    42: trap_cconout:
02:00008036 207900080416    	    43:     MOVE.L  (cconout),A0
02:0000803C 4E90            	    44:     JSR     (A0)
02:0000803E 4E73            	    45:     RTE                   ; Retorna da exceção
                            	    46: 
                            	    47: trap_strout:
02:00008040 227900080416    	    48:     MOVE.L  (cconout),A1
                            	    49: .strout:
02:00008046 1018            	    50:     MOVE.B  (A0)+,D0
02:00008048 4A00            	    51:     CMP.B   #0,D0
02:0000804A 6704            	    52:     BEQ     .fim
02:0000804C 4E91            	    53:     JSR     (A1)
02:0000804E 60F6            	    54:     BRA     .strout
                            	    55: .fim:
02:00008050 4E73            	    56:     RTE
                            	    57: 
                            	    58: ; --------------------------------
                            	    59: ; TRAP_PTERM0 - Terminar programa
                            	    60: ; --------------------------------
                            	    61: trap_pterm0:
02:00008052 303C0000        	    62:     move.w  #0,d0         ; Código de saída 0
02:00008056 6102            	    63:     bsr     hardware_exit ; Chama rotina de término
02:00008058 4E73            	    64:     RTE     
                            	    65: 
                            	    66: ; --------------------------------
                            	    67: ; hardware_exit - Terminar execução
                            	    68: ; Entrada: D0.W - Código de saída
                            	    69: ; --------------------------------
                            	    70: hardware_exit:
                            	    71:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    72:     ; Exemplo: parar o processador
                            	    73:     ; stop    #$2700
                            	    74: 
                            	    75:     ; Exemplo simples: loop infinito
02:0000805A 60FE            	    76:     BRA     hardware_exit
02:0000805C 4E75            	    77:     RTS

