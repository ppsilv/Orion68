                            	   353:         INCLUDE "cmd_mem_dump.asm"

Source: "cmd_mem_dump.asm"
                            	     1: 
                            	     2: 
                            	     3: 
                            	     4: 
                            	     5: ; ----------------------------------------------------------------------
                            	     6: ; MemDump - Imprime dump de memória formatado
                            	     7: ; Entrada:
                            	     8: ;   A0 = Endereço inicial (ex: $80000)
                            	     9: ;   D0 = Quantidade de bytes (ex: 256)
                            	    10: ; ----------------------------------------------------------------------
                            	    11: MEMDUMP:
02:0000138E 41F900000000    	    12:         LEA     MsgDumpHeader,A0
02:00001394 4EB811EE        	    13:         JSR     WriteString
02:00001398 207900080422    	    14:         MOVE.L  (addressInHex),A0
02:0000139E 2008            	    15:         MOVE.L  A0,D0
02:000013A0 4EB81362        	    16:         JSR     PicoPrintHexAddress
02:000013A4 4EB811F2        	    17:         JSR     NewLine
                            	    18: 
02:000013A8 41F900000013    	    19:         LEA     MsgDumpHeader1,A0
02:000013AE 4EB811EE        	    20:         JSR     WriteString
                            	    21: 
02:000013B2 207900080422    	    22:         MOVE.L  (addressInHex),A0
                            	    23:         ; Calcula endereço final
                            	    24: 
                            	    25: DUMPLOOPMASTER:
02:000013B8 7200            	    26:         CLR.L   D1
02:000013BA 2208            	    27:         MOVE.L  A0,D1
02:000013BC 0681000000FF    	    28:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    29:         ;MOVE.L  D1,D0
                            	    30:         ;JSR     PicoPrintHexAddress
                            	    31:         ;JSR     new_line
                            	    32: 
                            	    33:         ;aguarda um caractere ser digitado mas nao usa é somente para parar a execução aqui
                            	    34:         ;JSR     ReadChar
                            	    35: 
                            	    36: 
                            	    37: DumpLoop:
                            	    38:         ; Nova linha a cada 16 bytes
02:000013C2 2008            	    39:         MOVE.L  A0,D0
02:000013C4 02800000000F    	    40:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:000013CA 6616            	    41:         BNE     NoNewLine
                            	    42: 
                            	    43:         ; Imprime endereço
02:000013CC 2008            	    44:         MOVE.L  A0,D0
02:000013CE 4EB81362        	    45:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    46: 
02:000013D2 103C003A        	    47:         MOVE.B  #':',D0
02:000013D6 4EB811EA        	    48:         JSR     WriteChar
02:000013DA 103C0020        	    49:         MOVE.B  #' ',D0
02:000013DE 4EB811EA        	    50:         JSR     WriteChar
                            	    51: 
                            	    52: NoNewLine:
                            	    53:         ; Imprime byte em hex
02:000013E2 1018            	    54:         MOVE.B  (A0)+,D0
02:000013E4 4EB81372        	    55:         JSR     PicoPrintByteHex
                            	    56: 
02:000013E8 103C0020        	    57:         MOVE.B  #' ',D0
02:000013EC 4EB811EA        	    58:         JSR     WriteChar
                            	    59: 
                            	    60:         ; Verifica fim da linha (16 bytes)
02:000013F0 2008            	    61:         MOVE.L  A0,D0
02:000013F2 02800000000F    	    62:         ANDI.L  #$0000000F,D0
02:000013F8 664E            	    63:         BNE     NoEndLine
                            	    64: 
                            	    65:         ; Imprime caracteres ASCII
02:000013FA 103C0020        	    66:         MOVE.B  #' ',D0
02:000013FE 4EB811EA        	    67:         JSR     WriteChar
02:00001402 103C007C        	    68:         MOVE.B  #'|',D0
02:00001406 4EB811EA        	    69:         JSR     WriteChar
                            	    70: 
02:0000140A 43E8FFF0        	    71:         LEA     -16(A0),A1        ; Volta ao início da linha
02:0000140E 740F            	    72:         MOVEQ   #15,D2            ; 16 caracteres
                            	    73: 
                            	    74: AsciiLoop:
02:00001410 1019            	    75:         MOVE.B  (A1)+,D0
02:00001412 B03C0020        	    76:         CMP.B   #32,D0            ; Verifica se é imprimível
02:00001416 6D0C            	    77:         BLT     NonPrintable
02:00001418 B03C007E        	    78:         CMP.B   #126,D0
02:0000141C 6E06            	    79:         BGT     NonPrintable
                            	    80: 
02:0000141E 4EB811EA        	    81:         JSR     WriteChar
02:00001422 6008            	    82:         BRA     NextAscii
                            	    83: 
                            	    84: NonPrintable:
02:00001424 103C002E        	    85:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
02:00001428 4EB811EA        	    86:         JSR     WriteChar
                            	    87: 
                            	    88: NextAscii:
02:0000142C 51CAFFE2        	    89:         DBRA    D2,AsciiLoop
                            	    90: 
02:00001430 103C007C        	    91:         MOVE.B  #'|',D0
02:00001434 4EB811EA        	    92:         JSR     WriteChar
02:00001438 103C000D        	    93:         MOVE.B  #13,D0            ; CR
02:0000143C 4EB811EA        	    94:         JSR     WriteChar
02:00001440 103C000A        	    95:         MOVE.B  #10,D0            ; LF
02:00001444 4EB811EA        	    96:         JSR     WriteChar
                            	    97: 
                            	    98: NoEndLine:
                            	    99:         ; Verifica fim do dump
02:00001448 B1C1            	   100:         CMP.L   D1,A0
02:0000144A 6300FF76        	   101:         BLS     DumpLoop
                            	   102: 
02:0000144E 2F08            	   103:         MOVE.L  A0,-(SP)          ; Salva endereço atual
02:00001450 41F900000456    	   104:         LEA     MsgHitAnyKey,A0
02:00001456 4EB811EE        	   105:         JSR     WriteString
02:0000145A 4EB811EC        	   106:         JSR     ReadChar
02:0000145E B03C001B        	   107:         CMP.B   #$1B,D0
02:00001462 6706            	   108:         BEQ     .fim
                            	   109: 
02:00001464 205F            	   110:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:00001466 6000FF50        	   111:         BRA     DUMPLOOPMASTER
                            	   112: .fim
02:0000146A 4E75            	   113:         RTS

Source: "vbug2-0.asm"
                            	   354: 
