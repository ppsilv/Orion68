                            	    49: InitPicoVga:
02:000014CE 4E75            	    50:         RTS
                            	    51: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    52: ; Cursor go home
                            	    53: ; Receive cmd in D0
                            	    54: ;
                            	    55: PicoRunCmd:
02:000014D0 13C000FF803D    	    56:         MOVE.B  D0,RUN_CMD
02:000014D6 4E75            	    57:         RTS
                            	    58: 
                            	    59: 
                            	    60: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    61: ; Cursor go home
                            	    62: ; 
                            	    63: PicoGoHome:
02:000014D8 103C00A1        	    64:         MOVE.B  #CMD_GO_HOME,D0
02:000014DC 13C000FF803D    	    65:         MOVE.B  D0,RUN_CMD
02:000014E2 4E75            	    66:         RTS
                            	    67: 
                            	    68: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    69: ; Set cursor position
                            	    70: ; Detroy:
                            	    71: ; Receive X in D0
                            	    72: ; Receive Y in D1
                            	    73: PicoSetCursor:
02:000014E4 2F09            	    74:         MOVE.L A1,-(SP)
02:000014E6 13C000FF802F    	    75:         MOVE.B  D0,REG_X_LOW
02:000014EC 4E71            	    76:         NOP
02:000014EE 4E71            	    77:         NOP
02:000014F0 4E71            	    78:         NOP
02:000014F2 4E71            	    79:         NOP
02:000014F4 4E71            	    80:         NOP
02:000014F6 E048            	    81:         LSR.W   #8,D0             ; Desloca o byte alto para a posição baixa em D0
02:000014F8 13C000FF802D    	    82:         MOVE.B  D0,REG_X_HIGH
02:000014FE 4E71            	    83:         NOP
02:00001500 4E71            	    84:         NOP
02:00001502 4E71            	    85:         NOP
02:00001504 4E71            	    86:         NOP
02:00001506 4E71            	    87:         NOP
02:00001508 13C100FF8033    	    88:         MOVE.B  D1,REG_Y_LOW
02:0000150E 4E71            	    89:         NOP
02:00001510 4E71            	    90:         NOP
02:00001512 4E71            	    91:         NOP
02:00001514 4E71            	    92:         NOP
02:00001516 4E71            	    93:         NOP
02:00001518 E049            	    94:         LSR.W   #8,D1             ; Desloca o byte alto para a posição baixa em D0
02:0000151A 13C100FF8031    	    95:         MOVE.B  D1,REG_Y_HIGH
02:00001520 4E71            	    96:         NOP
02:00001522 4E71            	    97:         NOP
02:00001524 4E71            	    98:         NOP
02:00001526 4E71            	    99:         NOP
02:00001528 4E71            	   100:         NOP
02:0000152A 43F900FF803D    	   101:         LEA     RUN_CMD,A1    
02:00001530 103C00A3        	   102:         MOVE.B  #CMD_SET_CUR_POS,D0
02:00001534 1280            	   103:         MOVE.B  D0,(A1);
02:00001536 4E71            	   104:         NOP
02:00001538 4E71            	   105:         NOP
02:0000153A 4E71            	   106:         NOP
02:0000153C 4E71            	   107:         NOP
02:0000153E 4E71            	   108:         NOP
02:00001540 225F            	   109:         MOVE.L (SP)+,A1
02:00001542 4E75            	   110:         RTS
                            	   111: 
                            	   112: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   113: ; Clear screen
                            	   114: ; Destroy: A1 
                            	   115: ; Command in D0
                            	   116: PicoClearScreen:
02:00001544 2F09            	   117:         MOVE.L A1,-(SP)
02:00001546 43F900FF803D    	   118:         LEA     RUN_CMD,A1    
02:0000154C 103C00A4        	   119:         MOVE.B  #CMD_CLEAR_SCREEN,D0
02:00001550 1280            	   120:         MOVE.B  D0,(A1);
02:00001552 225F            	   121:         MOVE.L (SP)+,A1
02:00001554 4E75            	   122:         RTS
                            	   123: 
                            	   124: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   125: ; Write char in picoVGA
                            	   126: ; Destroy: A1,D1
                            	   127: PicoWriteChar:
02:00001556 2F09            	   128:         MOVE.L A1,-(SP)
02:00001558 43F900FF8001    	   129:             LEA     WRITE_SCREEN,A1
02:0000155E 1280            	   130:             MOVE.B  D0,(A1)     ; Escreve no endereço do PicoVGA (LDS ativo)
02:00001560 723F            	   131:             MOVE.L  #$3F,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	   132: .DELAY00:
02:00001562 5381            	   133:             SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
02:00001564 66FC            	   134:             BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
02:00001566 225F            	   135:         MOVE.L (SP)+,A1
02:00001568 4E75            	   136:             RTS
                            	   137: ;last change
                            	   138: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   139: ; Imprime string terminada em ZERO
                            	   140: ; Destroy: A0 = String's address
                            	   141: ;
                            	   142: PicoPrintString:
02:0000156A 1018            	   143:         MOVE.B  (A0)+,D0      ; Pega caractere e avança ponteiro
02:0000156C 6704            	   144:         BEQ.S   .Done         ; Se for zero, termina
02:0000156E 61E6            	   145:         BSR.S   PicoWriteChar ; Chama sua função gloriosa!
02:00001570 60F8            	   146:         BRA.S   PicoPrintString   ; Loop para o próximo
                            	   147: .Done:
02:00001572 4E75            	   148:         RTS
                            	   149: 
                            	   150: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   151: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   152: ; Entrada: D0 = endereço
                            	   153: ;
                            	   154: PicoPrintHexAddress:
02:00001574 4840            	   155:         SWAP    D0                ; Imprime parte alta primeiro
02:00001576 4EB8157C        	   156:         JSR     .PrintWordHex
02:0000157A 4840            	   157:         SWAP    D0                ; Parte baixa
                            	   158: .PrintWordHex:
02:0000157C E158            	   159:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:0000157E 4EB81584        	   160:         JSR     PicoPrintByteHex
02:00001582 E058            	   161:         ROR.W   #8,D0             ; Byte menos significativo
                            	   162: PicoPrintByteHex:
02:00001584 1F00            	   163:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001586 E808            	   164:         LSR.B   #4,D0             ; Nibble alto
02:00001588 6106            	   165:         BSR     .PrintNibble
02:0000158A 101F            	   166:         MOVE.B  (SP)+,D0          ; Recupera byte
02:0000158C 0200000F        	   167:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   168: .PrintNibble:
02:00001590 B03C0009        	   169:         CMP.B   #9,D0
02:00001594 6302            	   170:         BLS     .Decimal
02:00001596 5E00            	   171:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   172: .Decimal:
02:00001598 D03C0030        	   173:         ADD.B   #'0',D0
02:0000159C 4EF81556        	   174:         JMP     PicoWriteChar    ; Usa JMP para tail call optimization
                            	   175: 

