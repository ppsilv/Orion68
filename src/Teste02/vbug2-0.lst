02:00001258 2278130E        	   341:         MOVE.L  UartReadChar,A1         ; Initialize cconin console char in
02:0000125C 23C90008001A    	   342:         MOVE.L  A1,cconin
02:00001262 227C00FF4000    	   343:         MOVE.L  #UART_BASE,A1    ; Initialize uart output,INPUT and baud
02:00001268 23C900080010    	   344:         MOVE.L  A1,currentUart
02:0000126E 23FC000000080008	   345:         MOVE.L  #B115200,currentBaudRate
02:00001276 0014
02:00001278 41F900080000    	   346:         LEA     RAM_VECTOR_BASE,A0
                            	   347: 
                            	   348:         ;Initializations
                            	   349: 
                            	   350:         ;Initialize picoVga
02:0000127E 4EB8133A        	   351:         JSR  InitPicoVga
                            	   352:         ;Initialize UART
02:00001282 4EB812C6        	   353:         JSR  InitUart   
                            	   354:         ;Initialize TRAP1
                            	   355:         ;JSR  InitTrap1
02:00001286 41F9000004D6    	   356:     LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
02:0000128C 23C800080004    	   357:     MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
                            	   358: 
                            	   359: mainLoop:
02:00001292 4EB8137A        	   360:         JSR     PicoClearScreen
02:00001296 41F9000000A3    	   361:         LEA     MsgMSGINIT,A0
02:0000129C 4EB8139C        	   362:         JSR     PicoPrintString
02:000012A0 103C0043        	   363:         MOVE.B  #$43,D0
02:000012A4 4EB811C2        	   364:         JSR     WriteChar
                            	   365: subLoop:        
02:000012A8 103C0041        	   366:         move.b  #$41,D0
02:000012AC 4EB812FA        	   367:         JSR     UartWriteChar
