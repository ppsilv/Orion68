02:0000146E 7400            	   153:         MOVEQ   #0,D2            ; Resultado em D2
                            	   154: .Loop:
02:00001470 7000            	   155:         CLR.L   D0
02:00001472 4EB81416        	   156:         JSR     UartReadChar
02:00001476 B03C000D        	   157:         CMP.B   #13,D0
02:0000147A 674C            	   158:         BEQ     .Done
02:0000147C B03C000A        	   159:         CMP.B   #10,D0
02:00001480 6746            	   160:         BEQ     .Done
                            	   161:         ;Tratando os numeros
