                            	   154: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   155: ; UartPrintHexAddress - Imprime endereço de 32 bits
                            	   156: ; Entrada: D0 = endereço
                            	   157: ;
                            	   158: UartPrintHexAddress:
02:00001506 4840            	   159:         SWAP    D0                ; Imprime parte alta primeiro
02:00001508 4EB8150E        	   160:         JSR     .PrintWordHex
02:0000150C 4840            	   161:         SWAP    D0                ; Parte baixa
                            	   162: .PrintWordHex:
02:0000150E E158            	   163:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:00001510 4EB816B2        	   164:         JSR     PicoPrintByteHex
02:00001514 E058            	   165:         ROR.W   #8,D0             ; Byte menos significativo
                            	   166: UartPrintByteHex:
02:00001516 1F00            	   167:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001518 E808            	   168:         LSR.B   #4,D0             ; Nibble alto
02:0000151A 6106            	   169:         BSR     .PrintNibble
02:0000151C 101F            	   170:         MOVE.B  (SP)+,D0          ; Recupera byte
02:0000151E 0200000F        	   171:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   172: .PrintNibble:
02:00001522 B03C0009        	   173:         CMP.B   #9,D0
02:00001526 6302            	   174:         BLS     .Decimal
02:00001528 5E00            	   175:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   176: .Decimal:
02:0000152A D03C0030        	   177:         ADD.B   #'0',D0
02:0000152E 4EF81422        	   178:         JMP     UartWriteChar    ; Usa JMP para tail call optimization
                            	   179: 

