                            	     4: .DentroDaFaixa:
                            	     5:         ; Se o código chegar aqui, significa que:
                            	     6:         ; $80000 <= A0 <= $FFFFF (O endereço é válido!)
                            	     7:         ; ... seu código para endereço válido aqui ...
                            	     8:         BRA     .Fim
                            	     9: 
                            	    10: .OutOfRange:
                            	    11:         ; Se desviou para cá, o endereço é inválido (Menor que $80000 OU Maior que $FFFFF)
                            	    12:         ; ... seu tratamento de erro aqui ...
                            	    13: 
                            	    14: 
                            	    15: 
                            	    16: .Fim:
02:000015B4 4E75            	    17:         RTS
                            	    18: 
                            	    19: 
                            	    20: ; ----------------------------------------------------------------------
                            	    21: ; MemDump - Imprime dump de memória formatado
                            	    22: ; Entrada:
                            	    23: ;   A0 = Endereço inicial (ex: $80000)
                            	    24: ;   D0 = Quantidade de bytes (ex: 256)
                            	    25: ; ----------------------------------------------------------------------
                            	    26: MemDump:
02:000015B6 41F900000000    	    27:         LEA     MsgDumpHeader,A0
02:000015BC 4EB811D2        	    28:         JSR     WriteString
02:000015C0 207900080424    	    29:         MOVE.L  (addressInHex),A0
02:000015C6 B1FC000FFFFF    	    30:         CMPA.L  #$FFFFF,A0        ; Compara A0 com o limite superior
02:000015CC 620000EE        	    31:         BHI     OutOfRange       ; BHI (Branch if Higher): Desvia se A0 > $FFFFF
                            	    32: 
02:000015D0 2008            	    33:         MOVE.L  A0,D0
02:000015D2 4EB81588        	    34:         JSR     PicoPrintHexAddress
02:000015D6 4EB811EA        	    35:         JSR     NewLine
                            	    36: 
02:000015DA 41F900000016    	    37:         LEA     MsgDumpHeader1,A0
02:000015E0 4EB811D2        	    38:         JSR     WriteString
                            	    39: 
02:000015E4 207900080424    	    40:         MOVE.L  (addressInHex),A0
                            	    41:         ; Calcula endereço final
                            	    42: DumpLoopMaster:
02:000015EA 303C0000        	    43:         MOVE.W  #$0000,D0
02:000015EE 323C0008        	    44:         MOVE.W  #$0008,D1
02:000015F2 4EB814F8        	    45:         JSR     PicoSetCursor
02:000015F6 7600            	    46:         CLR.L   D3
02:000015F8 2608            	    47:         MOVE.L  A0,D3
02:000015FA 0683000000FF    	    48:         ADDI.L  #$000000FF,D3             ; D3 = endereço final    
                            	    49: DumpLoop:
                            	    50:         ; Nova linha a cada 16 bytes
02:00001600 2008            	    51:         MOVE.L  A0,D0
02:00001602 02800000000F    	    52:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:00001608 6616            	    53:         BNE     NoNewLine
                            	    54: 
                            	    55:         ; Imprime endereço
02:0000160A 2008            	    56:         MOVE.L  A0,D0
02:0000160C 4EB81588        	    57:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    58: 
02:00001610 103C003A        	    59:         MOVE.B  #':',D0
02:00001614 4EB811C2        	    60:         JSR     WriteChar
02:00001618 103C0020        	    61:         MOVE.B  #' ',D0
02:0000161C 4EB811C2        	    62:         JSR     WriteChar
                            	    63: 
                            	    64: NoNewLine:
                            	    65:         ; Imprime byte em hex
02:00001620 1018            	    66:         MOVE.B  (A0)+,D0
02:00001622 4EB81598        	    67:         JSR     PicoPrintByteHex
                            	    68: 
02:00001626 103C0020        	    69:         MOVE.B  #' ',D0
02:0000162A 4EB811C2        	    70:         JSR     WriteChar
                            	    71: 
                            	    72:         ; Verifica fim da linha (16 bytes)
02:0000162E 2008            	    73:         MOVE.L  A0,D0
02:00001630 02800000000F    	    74:         ANDI.L  #$0000000F,D0
02:00001636 66E8            	    75:         BNE     NoNewLine
                            	    76: 
                            	    77:         ; Imprime caracteres ASCII
02:00001638 103C0020        	    78:         MOVE.B  #' ',D0
02:0000163C 4EB811C2        	    79:         JSR     WriteChar
02:00001640 103C007C        	    80:         MOVE.B  #'|',D0
02:00001644 4EB811C2        	    81:         JSR     WriteChar
                            	    82: 
02:00001648 43E8FFF0        	    83:         LEA     -16(A0),A1        ; Volta ao início da linha
02:0000164C 740F            	    84:         MOVEQ   #15,D2            ; 16 caracteres
                            	    85: 
                            	    86: AsciiLoop:
02:0000164E 1019            	    87:         MOVE.B  (A1)+,D0
02:00001650 B03C0020        	    88:         CMP.B   #$20,D0            ; Verifica se é imprimível
02:00001654 650C            	    89:         BLO     NonPrintable
02:00001656 B03C007E        	    90:         CMP.B   #$7E,D0
02:0000165A 6206            	    91:         BHI     NonPrintable
                            	    92: 
02:0000165C 4EB811C2        	    93:         JSR     WriteChar
02:00001660 6008            	    94:         BRA     NextAscii
                            	    95: 
                            	    96: NonPrintable:
02:00001662 103C002E        	    97:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
02:00001666 4EB811C2        	    98:         JSR     WriteChar
                            	    99: 
                            	   100: NextAscii:
02:0000166A 51CAFFE2        	   101:         DBRA    D2,AsciiLoop
                            	   102: 
02:0000166E 103C007C        	   103:         MOVE.B  #'|',D0
02:00001672 4EB811C2        	   104:         JSR     WriteChar
02:00001676 103C000D        	   105:         MOVE.B  #13,D0            ; CR
02:0000167A 4EB811C2        	   106:         JSR     WriteChar
02:0000167E 103C000A        	   107:         MOVE.B  #10,D0            ; LF
02:00001682 4EB811C2        	   108:         JSR     WriteChar
                            	   109: 
                            	   110: NoEndLine:
                            	   111:         ; Verifica fim do dump
02:00001686 B1C3            	   112:         CMP.L   D3,A0
02:00001688 6300FF76        	   113:         BLS     DumpLoop
                            	   114: 
02:0000168C 2F08            	   115:         MOVE.L  A0,-(SP)          ; Salva endereço atual
02:0000168E 41F90000035B    	   116:         LEA     MsgHitAnyKey,A0
02:00001694 4EB811D2        	   117:         JSR     WriteString
02:00001698 4EB81416        	   118:         JSR     UartReadChar
02:0000169C B03C001B        	   119:         CMP.B   #$1B,D0
02:000016A0 6716            	   120:         BEQ     .fim
                            	   121: 
02:000016A2 103C000D        	   122:         MOVE.B  #13,D0            ; CR
02:000016A6 4EB811C2        	   123:         JSR     WriteChar
02:000016AA 103C000A        	   124:         MOVE.B  #10,D0            ; LF
02:000016AE 4EB811C2        	   125:         JSR     WriteChar
                            	   126: 
02:000016B2 205F            	   127:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:000016B4 6000FF34        	   128:         BRA     DumpLoopMaster
                            	   129: .fim
02:000016B8 4EF812AE        	   130:         JMP     subLoop
