02:000012B8 223C0001FFFF    	   371:         MOVE.L  #$001FFFF,D1 ; Contador para o delay (ajuste se precisar de mais)
                            	   372: .DELAY01:
02:000012BE 5381            	   373:         SUBQ.L  #1,D1         ; Subtrai 1 de D1 (4 ciclos)
02:000012C0 66FC            	   374:         BNE.S   .DELAY01     ; Pula se não for zero (10 ciclos se pular, 8 se não)
