                            	    49: InitPicoVga:
02:000015FC 4E75            	    50:         RTS
                            	    51: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    52: ; Cursor go home
                            	    53: ; Receive cmd in D0
                            	    54: ;
                            	    55: PicoRunCmd:
02:000015FE 13C000FF803D    	    56:         MOVE.B  D0,RUN_CMD
02:00001604 4E75            	    57:         RTS
                            	    58: 
                            	    59: 
                            	    60: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    61: ; Cursor go home
                            	    62: ; 
                            	    63: PicoGoHome:
02:00001606 103C00A1        	    64:         MOVE.B  #CMD_GO_HOME,D0
02:0000160A 13C000FF803D    	    65:         MOVE.B  D0,RUN_CMD
02:00001610 4E75            	    66:         RTS
                            	    67: 
                            	    68: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    69: ; Set cursor position
                            	    70: ; Detroy:
                            	    71: ; Receive X in D0
                            	    72: ; Receive Y in D1
                            	    73: PicoSetCursor:
02:00001612 2F09            	    74:         MOVE.L A1,-(SP)
02:00001614 13C000FF802F    	    75:         MOVE.B  D0,REG_X_LOW
02:0000161A 4E71            	    76:         NOP
02:0000161C 4E71            	    77:         NOP
02:0000161E 4E71            	    78:         NOP
02:00001620 4E71            	    79:         NOP
02:00001622 4E71            	    80:         NOP
02:00001624 E048            	    81:         LSR.W   #8,D0             ; Desloca o byte alto para a posição baixa em D0
02:00001626 13C000FF802D    	    82:         MOVE.B  D0,REG_X_HIGH
02:0000162C 4E71            	    83:         NOP
02:0000162E 4E71            	    84:         NOP
02:00001630 4E71            	    85:         NOP
02:00001632 4E71            	    86:         NOP
02:00001634 4E71            	    87:         NOP
02:00001636 13C100FF8033    	    88:         MOVE.B  D1,REG_Y_LOW
02:0000163C 4E71            	    89:         NOP
02:0000163E 4E71            	    90:         NOP
02:00001640 4E71            	    91:         NOP
02:00001642 4E71            	    92:         NOP
02:00001644 4E71            	    93:         NOP
02:00001646 E049            	    94:         LSR.W   #8,D1             ; Desloca o byte alto para a posição baixa em D0
02:00001648 13C100FF8031    	    95:         MOVE.B  D1,REG_Y_HIGH
02:0000164E 4E71            	    96:         NOP
02:00001650 4E71            	    97:         NOP
02:00001652 4E71            	    98:         NOP
02:00001654 4E71            	    99:         NOP
02:00001656 4E71            	   100:         NOP
02:00001658 43F900FF803D    	   101:         LEA     RUN_CMD,A1    
02:0000165E 103C00A3        	   102:         MOVE.B  #CMD_SET_CUR_POS,D0
02:00001662 1280            	   103:         MOVE.B  D0,(A1);
02:00001664 4E71            	   104:         NOP
02:00001666 4E71            	   105:         NOP
02:00001668 4E71            	   106:         NOP
02:0000166A 4E71            	   107:         NOP
02:0000166C 4E71            	   108:         NOP
02:0000166E 225F            	   109:         MOVE.L (SP)+,A1
02:00001670 4E75            	   110:         RTS
                            	   111: 
                            	   112: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   113: ; Clear screen
                            	   114: ; Destroy: A1 
                            	   115: ; Command in D0
                            	   116: PicoClearScreen:
02:00001672 2F09            	   117:         MOVE.L A1,-(SP)
02:00001674 43F900FF803D    	   118:         LEA     RUN_CMD,A1    
02:0000167A 103C00A4        	   119:         MOVE.B  #CMD_CLEAR_SCREEN,D0
02:0000167E 1280            	   120:         MOVE.B  D0,(A1);
02:00001680 225F            	   121:         MOVE.L (SP)+,A1
02:00001682 4E75            	   122:         RTS
                            	   123: 
                            	   124: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   125: ; Write char in picoVGA
                            	   126: ; Destroy: A1,D1
                            	   127: PicoWriteChar:
02:00001684 2F09            	   128:         MOVE.L A1,-(SP)
02:00001686 43F900FF8001    	   129:             LEA     WRITE_SCREEN,A1
02:0000168C 1280            	   130:             MOVE.B  D0,(A1)     ; Escreve no endereço do PicoVGA (LDS ativo)
02:0000168E 723F            	   131:             MOVE.L  #$3F,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	   132: .DELAY00:
02:00001690 5381            	   133:             SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
02:00001692 66FC            	   134:             BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
02:00001694 225F            	   135:         MOVE.L (SP)+,A1
02:00001696 4E75            	   136:             RTS
                            	   137: ;last change
                            	   138: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   139: ; Imprime string terminada em ZERO
                            	   140: ; Destroy: A0 = String's address
                            	   141: ;
                            	   142: PicoPrintString:
02:00001698 1018            	   143:         MOVE.B  (A0)+,D0      ; Pega caractere e avança ponteiro
02:0000169A 6704            	   144:         BEQ.S   .Done         ; Se for zero, termina
02:0000169C 61E6            	   145:         BSR.S   PicoWriteChar ; Chama sua função gloriosa!
02:0000169E 60F8            	   146:         BRA.S   PicoPrintString   ; Loop para o próximo
                            	   147: .Done:
02:000016A0 4E75            	   148:         RTS
                            	   149: 
                            	   150: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   151: ; PrintHexAddress - Imprime endereço de 32 bits
                            	   152: ; Entrada: D0 = endereço
                            	   153: ;
                            	   154: PicoPrintHexAddress:
02:000016A2 4840            	   155:         SWAP    D0                ; Imprime parte alta primeiro
02:000016A4 4EB816AA        	   156:         JSR     .PrintWordHex
02:000016A8 4840            	   157:         SWAP    D0                ; Parte baixa
                            	   158: .PrintWordHex:
02:000016AA E158            	   159:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:000016AC 4EB816B2        	   160:         JSR     PicoPrintByteHex
02:000016B0 E058            	   161:         ROR.W   #8,D0             ; Byte menos significativo
                            	   162: PicoPrintByteHex:
02:000016B2 1F00            	   163:         MOVE.B  D0,-(SP)          ; Salva byte original
02:000016B4 E808            	   164:         LSR.B   #4,D0             ; Nibble alto
02:000016B6 6106            	   165:         BSR     .PrintNibble
02:000016B8 101F            	   166:         MOVE.B  (SP)+,D0          ; Recupera byte
02:000016BA 0200000F        	   167:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	   168: .PrintNibble:
02:000016BE B03C0009        	   169:         CMP.B   #9,D0
02:000016C2 6302            	   170:         BLS     .Decimal
02:000016C4 5E00            	   171:         ADD.B   #7,D0             ; Ajuste para A-F
                            	   172: .Decimal:
02:000016C6 D03C0030        	   173:         ADD.B   #'0',D0
02:000016CA 4EF81684        	   174:         JMP     PicoWriteChar    ; Usa JMP para tail call optimization
                            	   175: 

