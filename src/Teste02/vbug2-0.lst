                            	     5: ;Uart register offsets
                            	     6: UART_BASE   equ     $FF4000
                            	     7: RHR         equ     $01   ; receive holding register (read)
                            	     8: THR         equ     $01   ; transmit holding register (write)
                            	     9: IER         equ     $03   ; interrupt enable register
                            	    10: ISR         equ     $05   ; interrupt status register (read)
                            	    11: FCR         equ     $05   ; FIFO control register (write)
                            	    12: LCR         equ     $07   ; line control register
                            	    13: MCR         equ     $09   ; modem control register
                            	    14: LSR         equ     $0B   ; line status register
                            	    15: MSR         equ     $0D   ; modem status register
                            	    16: SPR         equ     $0F   ; scratchpad register (reserved for system use)
                            	    17: DLL         equ     $01   ; divisor latch LSB
                            	    18: DLM         equ     $03   ; divisor latch MSB
                            	    19: ; aliases for register names (used by different manufacturers)cd ..
                            	    20: RBR         equ     RHR ; receive buffer register
                            	    21: IIR         equ     ISR ; interrupt identification register
                            	    22: SCR         equ     SPR ; scratch register
                            	    23: 
                            	    24: B009600     equ         $0060
                            	    25: B019200     equ         $0030
                            	    26: B038400     equ         $0018
                            	    27: B057600     equ         $0010
                            	    28: B115200     equ         $0008
                            	    29: B230400     equ         $0004
                            	    30: B460800     equ         $0002
                            	    31: B921600     equ         $0001
                            	    32: 
                            	    33: 
                            	    34: B009600L    equ         $60
                            	    35: B019200L    equ         $30
                            	    36: B038400L    equ         $18
                            	    37: B057600L    equ         $10
                            	    38: B115200L    equ         $08
                            	    39: B230400L    equ         $04
                            	    40: B460800L    equ         $02
                            	    41: B921600L    equ         $01
                            	    42: B009600H    equ         $00
                            	    43: B019200H    equ         $00     
                            	    44: B038400H    equ         $00     
                            	    45: B057600H    equ         $00     
                            	    46: B115200H    equ         $00     
                            	    47: B230400H    equ         $00
                            	    48: B460800H    equ         $00
                            	    49: B921600H    equ         $00
                            	    50: 
                            	    51: 
                            	    52: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    53: ; Initialize uart
                            	    54: ; Change A1
                            	    55: ; Parametros: none
                            	    56: ; ----------------------------------------------------------------------
                            	    57: InitUart:
02:000012C6 227900080010    	    58:         move.l  currentUart,A1
02:000012CC 203C00080014    	    59:         move.l  #currentBaudRate,D0
02:000012D2 137C00830007    	    60:         move.b  #%10000011,LCR(A1) ;DLAB=1
02:000012D8 4E71            	    61:         NOP
02:000012DA 4E71            	    62:         NOP      
02:000012DC 137C00080001    	    63:         move.b  #$08,DLL(A1)       ; set divisor latch low byte
02:000012E2 137C00000003    	    64:         move.b  #$00,DLM(A1)       ; set divisor latch high byte
02:000012E8 137C00030007    	    65:         move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:000012EE 137C000D0005    	    66:         move.b  #%00001101,FCR(A1) ; enable FIFO
02:000012F4 4229000F        	    67:         clr.b   SCR(A1)            ; clear the scratch register
02:000012F8 4E75            	    68:         RTS
                            	    69: 
                            	    70: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    71: ; Write char
                            	    72: ; Change A1
                            	    73: ; Receive char in D0
                            	    74: UartWriteChar:
02:000012FA 227900080010    	    75:         move.l  currentUart,A1
                            	    76: .WaitTx:
02:00001300 08290005000B    	    77:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:00001306 67F8            	    78:         beq     .WaitTx
02:00001308 13400001        	    79:         move.b  D0,THR(A1)      ; transmit byte
02:0000130C 4E75            	    80:         RTS
                            	    81: 
                            	    82: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    83: ; Read char block
                            	    84: ; Change A1
                            	    85: ;
                            	    86: ; Return char in D0)
                            	    87: UartReadChar:
02:0000130E 227900080010    	    88:         move.l  currentUart,A1
                            	    89: .WaitRx:
02:00001314 08290000000B    	    90:         btst    #0,LSR(A1)        ; RX ready?
02:0000131A 67F8            	    91:         beq     .WaitRx
02:0000131C 10380001        	    92:         move.b  RHR,D0
02:00001320 4E75            	    93:         RTS
                            	    94: 
                            	    95: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    96: ; Read char block with echo
                            	    97: ; Change A1
                            	    98: ;
                            	    99: ; Return char in D0)
                            	   100: UartReadCharEcho:
02:00001322 227900080010    	   101:         move.l  currentUart,A1
                            	   102: .WaitRx:
02:00001328 08290000000B    	   103:         btst    #0,LSR(A1)        ; RX ready?
02:0000132E 67F8            	   104:         beq     .WaitRx
02:00001330 10380001        	   105:         move.b  RHR,D0
02:00001334 4EB812FA        	   106:         JSR     UartWriteChar
02:00001338 4E75            	   107:         RTS
                            	   108: 

