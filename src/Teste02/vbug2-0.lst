                            	     9: ; ----------------------------------------------------------------------
                            	    10: InitUartb:
02:00001532 227C00FF4100    	    11:         move.l  #UARTB_BASE,A1
02:00001538 203900080A28    	    12:         move.l  currentBaudRate,D0
02:0000153E 137C00830007    	    13:         move.b  #%10000011,LCR(A1) ;DLAB=1
02:00001544 137C00080001    	    14:         move.b  #$08,DLL(A1)       ; set divisor latch low byte
02:0000154A 137C00000003    	    15:         move.b  #$00,DLM(A1)       ; set divisor latch high byte
02:00001550 137C00030007    	    16:         move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:00001556 137C000D0005    	    17:         move.b  #%00001101,FCR(A1) ; enable FIFO
02:0000155C 4229000F        	    18:         clr.b   SCR(A1)            ; clear the scratch register
02:00001560 4E75            	    19:         RTS
                            	    20: InitUartb1:
02:00001562 227C00FF4100    	    21:         move.l  #UARTB_BASE,A1
02:00001568 203900080A28    	    22:         move.l  currentBaudRate,D0
02:0000156E 137C000D0005    	    23:         move.b  #%00001101,FCR(a1)      ; enable FIFO
02:00001574 137C00830007    	    24:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:0000157A 13400001        	    25:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:0000157E E088            	    26:         lsr.l   #8,D0                   ; Shift right 8 bits
02:00001580 13400003        	    27:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:00001584 08A900070007    	    28:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:0000158A 4229000F        	    29:         clr.b   SCR(a1)                 ; clear the scratch register
02:0000158E 4E75            	    30:         RTS
                            	    31: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    32: ; Write char
                            	    33: ; Change A1
                            	    34: ; Receive char in D0
                            	    35: UartbWriteChar:
02:00001590 2F09            	    36:         MOVE.L A1,-(SP)
02:00001592 227C00FF4100    	    37:         move.l  #UARTB_BASE,A1
                            	    38: .WaitTx:
02:00001598 08290005000B    	    39:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:0000159E 67F8            	    40:         beq     .WaitTx
02:000015A0 13400001        	    41:         move.b  D0,THR(A1)      ; transmit byte
02:000015A4 225F            	    42:         MOVE.L (SP)+,A1
02:000015A6 4E75            	    43:         RTS
                            	    44:         
                            	    45: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    46: ; Read char block
                            	    47: ; Change A1
                            	    48: ;
                            	    49: ; Return char in D0)
                            	    50: UartbReadChar:
02:000015A8 2F09            	    51:         MOVE.L A1,-(SP)
02:000015AA 227C00FF4100    	    52:         move.l  #UARTB_BASE,A1
                            	    53: .WaitRx:
02:000015B0 08290000000B    	    54:         btst    #0,LSR(A1)        ; RX ready?
02:000015B6 67F8            	    55:         beq     .WaitRx
                            	    56: 
02:000015B8 10290001        	    57:         move.b  RHR(A1),D0
02:000015BC 225F            	    58:         MOVE.L (SP)+,A1
02:000015BE 4EB81516        	    59:         JSR     UartPrintByteHex
02:000015C2 4E75            	    60:         RTS
                            	    61: 
                            	    62: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    63: ; Read char block with echo
                            	    64: ; Change A1
                            	    65: ;
                            	    66: ; Return char in D0)
                            	    67: UartbReadCharEcho:
02:000015C4 2F09            	    68:         MOVE.L A1,-(SP)
02:000015C6 227C00FF4100    	    69:         move.l  #UARTB_BASE,A1
                            	    70: .WaitRx:
02:000015CC 08290000000B    	    71:         btst    #0,LSR(A1)        ; RX ready?
02:000015D2 67F8            	    72:         beq     .WaitRx
02:000015D4 10290001        	    73:         move.b  RHR(A1),D0
                            	    74: 
                            	    75: .WaitTx:
02:000015D8 08290005000B    	    76:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:000015DE 67F8            	    77:         beq     .WaitTx
02:000015E0 13400001        	    78:         move.b  D0,THR(A1)      ; transmit byte
02:000015E4 225F            	    79:         MOVE.L (SP)+,A1
02:000015E6 4E75            	    80:         RTS
