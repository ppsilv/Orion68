                            	     7: ; O SEU CÓDIGO DO TCPBOX68K (Agora rodando na RAM)
                            	     8: ; -----------------------------------------------------------------------------
                            	     9: vbug2_trap1:
02:0000171C B07C0001        	    10:     CMP.W   #CMD_CCONIN,D0      ; Compara com CCONIN (ler caractere)
02:00001720 6714            	    11:     BEQ     trap_cconin         ; Se for 1, vai para leitura
02:00001722 B07C0002        	    12:     CMP.W   #CMD_CCONOUT,D0     ; Compara com CCONOUT (escrever caractere)
02:00001726 671E            	    13:     BEQ     trap_cconout        ; Se for 2, vai para escrita
02:00001728 B07C0003        	    14:     CMP.W   #CMD_CCONOUTSTR,D0  ; Compara com CCONOUT (escrever string)
02:0000172C 6724            	    15:     BEQ     trap_strout         ; Se for 3, vai para escrita
02:0000172E 4A40            	    16:     CMP.W   #CMD_PTERM0,D0      ; Compara com PTERM0 (terminar)
02:00001730 6732            	    17:     BEQ     trap_pterm0         ; Se for 0, vai para terminar
02:00001732 70FF            	    18:     MOVE.L  #-1,D0              ; Retorna erro se função não reconhecida
02:00001734 4E73            	    19:     RTE
                            	    20: 
                            	    21: ; --------------------------------
                            	    22: ; TRAP_CCONIN - Ler caractere do console
                            	    23: ; Saída: D0.L - Caractere lido
                            	    24: ; --------------------------------
                            	    25: trap_cconin:
02:00001736 207900080418    	    26:     MOVE.L  (cconin),A0
02:0000173C 4E90            	    27:     JSR     (A0)
02:0000173E 0280000000FF    	    28:     ANDI.L      #$FF,D0       ; Mantém apenas o byte inferior
02:00001744 4E73            	    29:     RTE                   ; Retorna da exceção
                            	    30: 
                            	    31: ; --------------------------------
                            	    32: ; TRAP_CCONOUT - Escrever caractere no console
                            	    33: ; Entrada: D1.L - Caractere a escrever
                            	    34: ; --------------------------------
                            	    35: trap_cconout:
02:00001746 1001            	    36:     MOVE.B  D1,D0
02:00001748 207900080414    	    37:     MOVE.L  (cconout),A0        ; Busca o endereço da rotina física da UART
02:0000174E 4E90            	    38:     JSR     (A0)
02:00001750 4E73            	    39:     RTE      
                            	    40:                 
                            	    41: 
                            	    42: trap_strout:
02:00001752 227900080414    	    43:     MOVE.L  (cconout),A1
                            	    44: .strout:
02:00001758 1018            	    45:     MOVE.B  (A0)+,D0
02:0000175A 4A00            	    46:     CMP.B   #0,D0
02:0000175C 6704            	    47:     BEQ     .fim
02:0000175E 4E91            	    48:     JSR     (A1)
02:00001760 60F6            	    49:     BRA     .strout
                            	    50: .fim:
02:00001762 4E73            	    51:     RTE
                            	    52: 
                            	    53: ; --------------------------------
                            	    54: ; TRAP_PTERM0 - Terminar programa
                            	    55: ; --------------------------------
                            	    56: trap_pterm0:
02:00001764 303C0000        	    57:     move.w  #0,d0         ; Código de saída 0
02:00001768 6102            	    58:     bsr     hardware_exit ; Chama rotina de término
02:0000176A 4E73            	    59:     RTE     
                            	    60: 
                            	    61: ; --------------------------------
                            	    62: ; hardware_exit - Terminar execução
                            	    63: ; Entrada: D0.W - Código de saída
                            	    64: ; --------------------------------
                            	    65: hardware_exit:
                            	    66:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    67:     ; Exemplo: parar o processador
                            	    68:     ; stop    #$2700
                            	    69: 
                            	    70:     ; Exemplo simples: loop infinito
02:0000176C 60FE            	    71:     BRA     hardware_exit
02:0000176E 4E75            	    72:     RTS
                            	    73: 
                            	    74: InitTrap1:
                            	    75:     ; -------------------------------------------------------------------------
                            	    76:     ; COMO INSTALAR NA RAM:
                            	    77:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	    78:     ; -------------------------------------------------------------------------
02:00001770 41F8171C        	    79:     LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
02:00001774 23C800080004    	    80:     MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
02:0000177A 4E75            	    81:     RTS
                            	    82:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    83: 

