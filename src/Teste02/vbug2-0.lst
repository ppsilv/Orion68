                            	   481:         INCLUDE "cmd_mem_dump.asm"

Source: "cmd_mem_dump.asm"
                            	     1: 
                            	     2: 
                            	     3: 
                            	     4: 
                            	     5: ; ----------------------------------------------------------------------
                            	     6: ; MemDump - Imprime dump de memória formatado
                            	     7: ; Entrada:
                            	     8: ;   A0 = Endereço inicial (ex: $80000)
                            	     9: ;   D0 = Quantidade de bytes (ex: 256)
                            	    10: ; ----------------------------------------------------------------------
                            	    11: MemDump:
02:00001798 41F900000000    	    12:         LEA     MsgDumpHeader,A0
02:0000179E 4EB811D4        	    13:         JSR     WriteString
02:000017A2 207900080424    	    14:         MOVE.L  (addressInHex),A0
02:000017A8 B1FC000FFFFF    	    15:         CMPA.L  #$FFFFF,A0        ; Compara A0 com o limite superior
02:000017AE 620000F0        	    16:         BHI     OutOfRange       ; BHI (Branch if Higher): Desvia se A0 > $FFFFF
                            	    17: 
02:000017B2 2008            	    18:         MOVE.L  A0,D0
02:000017B4 4EB816A2        	    19:         JSR     PicoPrintHexAddress
02:000017B8 4EB811EC        	    20:         JSR     NewLine
                            	    21: 
02:000017BC 41F900000016    	    22:         LEA     MsgDumpHeader1,A0
02:000017C2 4EB811D4        	    23:         JSR     WriteString
                            	    24: 
02:000017C6 207900080424    	    25:         MOVE.L  (addressInHex),A0
                            	    26:         ; Calcula endereço final
                            	    27: DumpLoopMaster:
02:000017CC 303C0000        	    28:         MOVE.W  #$0000,D0
02:000017D0 323C0008        	    29:         MOVE.W  #$0008,D1
02:000017D4 4EB81612        	    30:         JSR     PicoSetCursor
02:000017D8 7600            	    31:         CLR.L   D3
02:000017DA 2608            	    32:         MOVE.L  A0,D3
02:000017DC 0683000000FF    	    33:         ADDI.L  #$000000FF,D3             ; D3 = endereço final    
                            	    34: DumpLoop:
                            	    35:         ; Nova linha a cada 16 bytes
02:000017E2 2008            	    36:         MOVE.L  A0,D0
02:000017E4 02800000000F    	    37:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:000017EA 6616            	    38:         BNE     NoNewLine
                            	    39: 
                            	    40:         ; Imprime endereço
02:000017EC 2008            	    41:         MOVE.L  A0,D0
02:000017EE 4EB816A2        	    42:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    43: 
02:000017F2 103C003A        	    44:         MOVE.B  #':',D0
02:000017F6 4EB811C4        	    45:         JSR     WriteChar
02:000017FA 103C0020        	    46:         MOVE.B  #' ',D0
02:000017FE 4EB811C4        	    47:         JSR     WriteChar
                            	    48: 
                            	    49: NoNewLine:
                            	    50:         ; Imprime byte em hex
02:00001802 1018            	    51:         MOVE.B  (A0)+,D0
02:00001804 4EB816B2        	    52:         JSR     PicoPrintByteHex
                            	    53: 
02:00001808 103C0020        	    54:         MOVE.B  #' ',D0
02:0000180C 4EB811C4        	    55:         JSR     WriteChar
                            	    56: 
                            	    57:         ; Verifica fim da linha (16 bytes)
02:00001810 2008            	    58:         MOVE.L  A0,D0
02:00001812 02800000000F    	    59:         ANDI.L  #$0000000F,D0
02:00001818 66E8            	    60:         BNE     NoNewLine
                            	    61: 
                            	    62:         ; Imprime caracteres ASCII
02:0000181A 103C0020        	    63:         MOVE.B  #' ',D0
02:0000181E 4EB811C4        	    64:         JSR     WriteChar
02:00001822 103C007C        	    65:         MOVE.B  #'|',D0
02:00001826 4EB811C4        	    66:         JSR     WriteChar
                            	    67: 
02:0000182A 43E8FFF0        	    68:         LEA     -16(A0),A1        ; Volta ao início da linha
02:0000182E 740F            	    69:         MOVEQ   #15,D2            ; 16 caracteres
                            	    70: 
                            	    71: AsciiLoop:
02:00001830 1019            	    72:         MOVE.B  (A1)+,D0
02:00001832 B03C0020        	    73:         CMP.B   #$20,D0            ; Verifica se é imprimível
02:00001836 650C            	    74:         BLO     NonPrintable
02:00001838 B03C007E        	    75:         CMP.B   #$7E,D0
02:0000183C 6206            	    76:         BHI     NonPrintable
                            	    77: 
02:0000183E 4EB811C4        	    78:         JSR     WriteChar
02:00001842 6008            	    79:         BRA     NextAscii
                            	    80: 
                            	    81: NonPrintable:
02:00001844 103C002E        	    82:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
02:00001848 4EB811C4        	    83:         JSR     WriteChar
                            	    84: 
                            	    85: NextAscii:
02:0000184C 51CAFFE2        	    86:         DBRA    D2,AsciiLoop
                            	    87: 
02:00001850 103C007C        	    88:         MOVE.B  #'|',D0
02:00001854 4EB811C4        	    89:         JSR     WriteChar
02:00001858 103C000D        	    90:         MOVE.B  #13,D0            ; CR
02:0000185C 4EB811C4        	    91:         JSR     WriteChar
02:00001860 103C000A        	    92:         MOVE.B  #10,D0            ; LF
02:00001864 4EB811C4        	    93:         JSR     WriteChar
                            	    94: 
                            	    95: NoEndLine:
                            	    96:         ; Verifica fim do dump
02:00001868 B1C3            	    97:         CMP.L   D3,A0
02:0000186A 6300FF76        	    98:         BLS     DumpLoop
                            	    99: 
02:0000186E 2F08            	   100:         MOVE.L  A0,-(SP)          ; Salva endereço atual
02:00001870 41F900000370    	   101:         LEA     MsgHitAnyKey,A0
02:00001876 4EB811D4        	   102:         JSR     WriteString
02:0000187A 4EB8143A        	   103:         JSR     UartReadChar
02:0000187E B03C001B        	   104:         CMP.B   #$1B,D0
02:00001882 6716            	   105:         BEQ     .fim
                            	   106: 
02:00001884 103C000D        	   107:         MOVE.B  #13,D0            ; CR
02:00001888 4EB811C4        	   108:         JSR     WriteChar
02:0000188C 103C000A        	   109:         MOVE.B  #10,D0            ; LF
02:00001890 4EB811C4        	   110:         JSR     WriteChar
                            	   111: 
02:00001894 205F            	   112:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:00001896 6000FF34        	   113:         BRA     DumpLoopMaster
                            	   114: .fim
02:0000189A 205F            	   115:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:0000189C 4EF812B4        	   116:         JMP     subLoop
                            	   117: OutOfRange:
02:000018A0 41F900000247    	   118:         LEA     MsgOutOfRange,A0
02:000018A6 4EB811D4        	   119:         JSR     WriteString        
02:000018AA 4EF812B4        	   120:         JMP     subLoop
                            	   121:      

