                            	   380:         INCLUDE "cmd_mem_dump.asm"

Source: "cmd_mem_dump.asm"
                            	     1: 
                            	     2: 
                            	     3: 
                            	     4: 
                            	     5: ; ----------------------------------------------------------------------
                            	     6: ; MemDump - Imprime dump de memória formatado
                            	     7: ; Entrada:
                            	     8: ;   A0 = Endereço inicial (ex: $80000)
                            	     9: ;   D0 = Quantidade de bytes (ex: 256)
                            	    10: ; ----------------------------------------------------------------------
                            	    11: MEMDUMP:
02:000013D2 41F900000000    	    12:         LEA     MsgDumpHeader,A0
02:000013D8 4EB811CC        	    13:         JSR     WriteString
02:000013DC 207900080234    	    14:         MOVE.L  (addressInHex),A0
02:000013E2 2008            	    15:         MOVE.L  A0,D0
02:000013E4 4EB813A6        	    16:         JSR     PicoPrintHexAddress
02:000013E8 4EB811DE        	    17:         JSR     NewLine
                            	    18: 
02:000013EC 41F900000013    	    19:         LEA     MsgDumpHeader1,A0
02:000013F2 4EB811CC        	    20:         JSR     WriteString
                            	    21: 
02:000013F6 207900080234    	    22:         MOVE.L  (addressInHex),A0
                            	    23:         ; Calcula endereço final
                            	    24: 
                            	    25: DUMPLOOPMASTER:
02:000013FC 7200            	    26:         CLR.L   D1
02:000013FE 2208            	    27:         MOVE.L  A0,D1
02:00001400 0681000000FF    	    28:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    29:         ;MOVE.L  D1,D0
                            	    30:         ;JSR     PicoPrintHexAddress
                            	    31:         ;JSR     new_line
                            	    32: 
                            	    33:         ;aguarda um caractere ser digitado mas nao usa é somente para parar a execução aqui
                            	    34:         ;JSR     ReadChar
                            	    35: 
                            	    36: 
                            	    37: DumpLoop:
                            	    38:         ; Nova linha a cada 16 bytes
02:00001406 2008            	    39:         MOVE.L  A0,D0
02:00001408 02800000000F    	    40:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:0000140E 6616            	    41:         BNE     NoNewLine
                            	    42: 
                            	    43:         ; Imprime endereço
02:00001410 2008            	    44:         MOVE.L  A0,D0
02:00001412 4EB813A6        	    45:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    46: 
02:00001416 103C003A        	    47:         MOVE.B  #':',D0
02:0000141A 4EB811C2        	    48:         JSR     WriteChar
02:0000141E 103C0020        	    49:         MOVE.B  #' ',D0
02:00001422 4EB811C2        	    50:         JSR     WriteChar
                            	    51: 
                            	    52: NoNewLine:
                            	    53:         ; Imprime byte em hex
02:00001426 1018            	    54:         MOVE.B  (A0)+,D0
02:00001428 4EB813B6        	    55:         JSR     PicoPrintByteHex
                            	    56: 
02:0000142C 103C0020        	    57:         MOVE.B  #' ',D0
02:00001430 4EB811C2        	    58:         JSR     WriteChar
                            	    59: 
                            	    60:         ; Verifica fim da linha (16 bytes)
02:00001434 2008            	    61:         MOVE.L  A0,D0
02:00001436 02800000000F    	    62:         ANDI.L  #$0000000F,D0
02:0000143C 664E            	    63:         BNE     NoEndLine
                            	    64: 
                            	    65:         ; Imprime caracteres ASCII
02:0000143E 103C0020        	    66:         MOVE.B  #' ',D0
02:00001442 4EB811C2        	    67:         JSR     WriteChar
02:00001446 103C007C        	    68:         MOVE.B  #'|',D0
02:0000144A 4EB811C2        	    69:         JSR     WriteChar
                            	    70: 
