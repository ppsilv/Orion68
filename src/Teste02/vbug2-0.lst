                            	    53: ; Initialize uart
                            	    54: ; Change A1
                            	    55: ; Parametros: none
                            	    56: ; ----------------------------------------------------------------------
                            	    57: InitUart:
02:000013A0 227900080410    	    58:         move.l  currentUart,A1
02:000013A6 203900080A28    	    59:         move.l  currentBaudRate,D0
02:000013AC 137C00830007    	    60:         move.b  #%10000011,LCR(A1) ;DLAB=1
02:000013B2 137C00080001    	    61:         move.b  #$08,DLL(A1)       ; set divisor latch low byte
02:000013B8 137C00000003    	    62:         move.b  #$00,DLM(A1)       ; set divisor latch high byte
02:000013BE 137C00030007    	    63:         move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:000013C4 137C000D0005    	    64:         move.b  #%00001101,FCR(A1) ; enable FIFO
02:000013CA 4229000F        	    65:         clr.b   SCR(A1)            ; clear the scratch register
02:000013CE 4E75            	    66:         RTS
                            	    67: InitUart1:
02:000013D0 227900080410    	    68:         move.l  currentUart,A1
02:000013D6 203900080A28    	    69:         move.l  currentBaudRate,D0
02:000013DC 137C000D0005    	    70:         move.b  #%00001101,FCR(a1)      ; enable FIFO
02:000013E2 137C00830007    	    71:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:000013E8 13400001        	    72:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:000013EC E088            	    73:         lsr.l   #8,D0                   ; Shift right 8 bits
02:000013EE 13400003        	    74:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:000013F2 08A900070007    	    75:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:000013F8 4229000F        	    76:         clr.b   SCR(a1)                 ; clear the scratch register
02:000013FC 4E75            	    77:         RTS
                            	    78: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    79: ; Write char
                            	    80: ; Change A1
                            	    81: ; Receive char in D0
                            	    82: UartWriteChar:
02:000013FE 2F09            	    83:         MOVE.L A1,-(SP)
02:00001400 227900080410    	    84:         move.l  currentUart,A1
                            	    85: .WaitTx:
02:00001406 08290005000B    	    86:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:0000140C 67F8            	    87:         beq     .WaitTx
02:0000140E 13400001        	    88:         move.b  D0,THR(A1)      ; transmit byte
02:00001412 225F            	    89:         MOVE.L (SP)+,A1
02:00001414 4E75            	    90:         RTS
                            	    91: 
                            	    92: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    93: ; Read char block
                            	    94: ; Change A1
                            	    95: ;
                            	    96: ; Return char in D0)
                            	    97: UartReadChar:
02:00001416 2F09            	    98:         MOVE.L A1,-(SP)
02:00001418 227900080410    	    99:         move.l  currentUart,A1
                            	   100: .WaitRx:
02:0000141E 08290000000B    	   101:         btst    #0,LSR(A1)        ; RX ready?
02:00001424 67F8            	   102:         beq     .WaitRx
                            	   103: 
02:00001426 10290001        	   104:         move.b  RHR(A1),D0
02:0000142A 225F            	   105:         MOVE.L (SP)+,A1
02:0000142C 4E75            	   106:         RTS
                            	   107: 
                            	   108: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	   109: ; Read char block with echo
                            	   110: ; Change A1
                            	   111: ;
                            	   112: ; Return char in D0)
                            	   113: UartReadCharEcho:
02:0000142E 2F09            	   114:         MOVE.L A1,-(SP)
02:00001430 227900080410    	   115:         move.l  currentUart,A1
                            	   116: .WaitRx:
02:00001436 08290000000B    	   117:         btst    #0,LSR(A1)        ; RX ready?
02:0000143C 67F8            	   118:         beq     .WaitRx
02:0000143E 10290001        	   119:         move.b  RHR(A1),D0
                            	   120: 
                            	   121: .WaitTx:
02:00001442 08290005000B    	   122:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:00001448 67F8            	   123:         beq     .WaitTx
02:0000144A 13400001        	   124:         move.b  D0,THR(A1)      ; transmit byte
02:0000144E 225F            	   125:         MOVE.L (SP)+,A1
02:00001450 4E75            	   126:         RTS
