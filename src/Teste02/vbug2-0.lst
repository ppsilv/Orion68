                            	     1: ;Uart register offsets
                            	     2: UART_BASE   equ     $FF4000
                            	     3: 
                            	     4: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	     5: ; Initialize uart
                            	     6: ; Change A1
                            	     7: ; Parametros: none
                            	     8: ; ----------------------------------------------------------------------
                            	     9: InitUart:
02:000013C4 227900080410    	    10:         move.l  currentUart,A1
02:000013CA 203900080A28    	    11:         move.l  currentBaudRate,D0
02:000013D0 137C00830007    	    12:         move.b  #%10000011,LCR(A1) ;DLAB=1
02:000013D6 137C00080001    	    13:         move.b  #$08,DLL(A1)       ; set divisor latch low byte
02:000013DC 137C00000003    	    14:         move.b  #$00,DLM(A1)       ; set divisor latch high byte
02:000013E2 137C00030007    	    15:         move.b  #%00000011,LCR(A1) ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:000013E8 137C000D0005    	    16:         move.b  #%00001101,FCR(A1) ; enable FIFO
02:000013EE 4229000F        	    17:         clr.b   SCR(A1)            ; clear the scratch register
02:000013F2 4E75            	    18:         RTS
                            	    19: InitUart1:
02:000013F4 227900080410    	    20:         move.l  currentUart,A1
02:000013FA 203900080A28    	    21:         move.l  currentBaudRate,D0
02:00001400 137C000D0005    	    22:         move.b  #%00001101,FCR(a1)      ; enable FIFO
02:00001406 137C00830007    	    23:         move.b  #%10000011,LCR(a1)      ; 8 data bits, no parity, 1 stop bit, DLAB=1
02:0000140C 13400001        	    24:         move.b  D0,DLL(A1)              ; Byte 0 (LSB) -> DLL
02:00001410 E088            	    25:         lsr.l   #8,D0                   ; Shift right 8 bits
02:00001412 13400003        	    26:         move.b  D0,DLM(A1)              ; Byte 1 (agora no LSB) -> DLM
02:00001416 08A900070007    	    27:         bclr.b  #7,LCR(a1)              ; 8 data bits, no parity, 1 stop bit, DLAB=0
02:0000141C 4229000F        	    28:         clr.b   SCR(a1)                 ; clear the scratch register
02:00001420 4E75            	    29:         RTS
                            	    30: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    31: ; Write char
                            	    32: ; Change A1
                            	    33: ; Receive char in D0
                            	    34: UartWriteChar:
02:00001422 2F09            	    35:         MOVE.L A1,-(SP)
02:00001424 227900080410    	    36:         move.l  currentUart,A1
                            	    37: .WaitTx:
02:0000142A 08290005000B    	    38:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:00001430 67F8            	    39:         beq     .WaitTx
02:00001432 13400001        	    40:         move.b  D0,THR(A1)      ; transmit byte
02:00001436 225F            	    41:         MOVE.L (SP)+,A1
02:00001438 4E75            	    42:         RTS
                            	    43: 
                            	    44: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    45: ; Read char block
                            	    46: ; Change A1
                            	    47: ;
                            	    48: ; Return char in D0)
                            	    49: UartReadChar:
02:0000143A 2F09            	    50:         MOVE.L A1,-(SP)
02:0000143C 227900080410    	    51:         move.l  currentUart,A1
                            	    52: .WaitRx:
02:00001442 08290000000B    	    53:         btst    #0,LSR(A1)        ; RX ready?
02:00001448 67F8            	    54:         beq     .WaitRx
                            	    55: 
02:0000144A 10290001        	    56:         move.b  RHR(A1),D0
02:0000144E 225F            	    57:         MOVE.L (SP)+,A1
02:00001450 4E75            	    58:         RTS
                            	    59: 
                            	    60: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    61: ; Read char block with echo
                            	    62: ; Change A1
                            	    63: ;
                            	    64: ; Return char in D0)
                            	    65: UartReadCharEcho:
02:00001452 2F09            	    66:         MOVE.L A1,-(SP)
02:00001454 227900080410    	    67:         move.l  currentUart,A1
                            	    68: .WaitRx:
02:0000145A 08290000000B    	    69:         btst    #0,LSR(A1)        ; RX ready?
02:00001460 67F8            	    70:         beq     .WaitRx
02:00001462 10290001        	    71:         move.b  RHR(A1),D0
                            	    72: 
                            	    73: .WaitTx:
02:00001466 08290005000B    	    74:         btst    #5,LSR(A1)      ; wait until transmit holding register is empty
02:0000146C 67F8            	    75:         beq     .WaitTx
02:0000146E 13400001        	    76:         move.b  D0,THR(A1)      ; transmit byte
02:00001472 225F            	    77:         MOVE.L (SP)+,A1
02:00001474 4E75            	    78:         RTS
