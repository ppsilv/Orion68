                            	    82: ; ----------------------------------------------------------------------
                            	    83: ; UART_WriteString - Envia string terminada em null para UART
                            	    84: ; Entrada:
                            	    85: ;   A0 = Ponteiro para a string (endereço da string)
                            	    86: ; ----------------------------------------------------------------------
                            	    87: UartbWriteString:
02:000015E8 2F08            	    88:         MOVE.L  A0,-(SP)      ; Preserva D0
02:000015EA 2F00            	    89:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	    90: .WriteLoop:
02:000015EC 1018            	    91:         MOVE.B  (A0)+,D0      ; Pega caractere
02:000015EE 6706            	    92:         BEQ     .Done
02:000015F0 4EB81590        	    93:         JSR     UartbWriteChar ; Use sua rotine existente
02:000015F4 60F6            	    94:         BRA     .WriteLoop
                            	    95: .Done:
02:000015F6 201F            	    96:         MOVE.L  (SP)+,D0
02:000015F8 205F            	    97:         MOVE.L  (SP)+,A0
02:000015FA 4E75            	    98:         RTS
