                            	     4: ; -----------------------------------------------------------------------------
                            	     5: ; O SEU CÓDIGO DO TCPBOX68K (Agora rodando na RAM)
                            	     6: ; -----------------------------------------------------------------------------
                            	     7: vbug2_trap1:
04:000004D6 B07C0001        	     8:     CMP.W   #CMD_CCONIN,D0      ; Compara com CCONIN (ler caractere)
04:000004DA 6714            	     9:     BEQ     trap_cconin         ; Se for 1, vai para leitura
04:000004DC B07C0002        	    10:     CMP.W   #CMD_CCONOUT,D0     ; Compara com CCONOUT (escrever caractere)
04:000004E0 671E            	    11:     BEQ     trap_cconout        ; Se for 2, vai para escrita
04:000004E2 B07C0003        	    12:     CMP.W   #CMD_CCONOUTSTR,D0  ; Compara com CCONOUT (escrever string)
04:000004E6 6722            	    13:     BEQ     trap_strout         ; Se for 3, vai para escrita
04:000004E8 4A40            	    14:     CMP.W   #CMD_PTERM0,D0      ; Compara com PTERM0 (terminar)
04:000004EA 6730            	    15:     BEQ     trap_pterm0         ; Se for 0, vai para terminar
04:000004EC 70FF            	    16:     MOVE.L  #-1,D0              ; Retorna erro se função não reconhecida
04:000004EE 4E73            	    17:     RTE
                            	    18: 
                            	    19: ; --------------------------------
                            	    20: ; TRAP_CCONIN - Ler caractere do console
                            	    21: ; Saída: D0.L - Caractere lido
                            	    22: ; --------------------------------
                            	    23: trap_cconin:
04:000004F0 20790008001A    	    24:     MOVE.L  (cconin),A0
04:000004F6 4E90            	    25:     JSR     (A0)
04:000004F8 0280000000FF    	    26:     ANDI.L      #$FF,D0       ; Mantém apenas o byte inferior
04:000004FE 4E73            	    27:     RTE                   ; Retorna da exceção
                            	    28: 
                            	    29: ; --------------------------------
                            	    30: ; TRAP_CCONOUT - Escrever caractere no console
                            	    31: ; Entrada: D1.L - Caractere a escrever
                            	    32: ; --------------------------------
                            	    33: trap_cconout:
04:00000500 1001            	    34:     MOVE.B  D1,D0
04:00000502 207900080016    	    35:     MOVE.L  (cconout),A0        ; Busca o endereço da rotina física da UART
04:00000508 4E73            	    36:     RTE      
                            	    37:                 
                            	    38: 
                            	    39: trap_strout:
04:0000050A 227900080016    	    40:     MOVE.L  (cconout),A1
                            	    41: .strout:
04:00000510 1018            	    42:     MOVE.B  (A0)+,D0
04:00000512 4A00            	    43:     CMP.B   #0,D0
04:00000514 6704            	    44:     BEQ     .fim
04:00000516 4E91            	    45:     JSR     (A1)
04:00000518 60F6            	    46:     BRA     .strout
                            	    47: .fim:
04:0000051A 4E73            	    48:     RTE
                            	    49: 
                            	    50: ; --------------------------------
                            	    51: ; TRAP_PTERM0 - Terminar programa
                            	    52: ; --------------------------------
                            	    53: trap_pterm0:
04:0000051C 303C0000        	    54:     move.w  #0,d0         ; Código de saída 0
04:00000520 6102            	    55:     bsr     hardware_exit ; Chama rotina de término
04:00000522 4E73            	    56:     RTE     
                            	    57: 
                            	    58: ; --------------------------------
                            	    59: ; hardware_exit - Terminar execução
                            	    60: ; Entrada: D0.W - Código de saída
                            	    61: ; --------------------------------
                            	    62: hardware_exit:
                            	    63:     ; >>> ADAPTE PARA SUA PLACA <<<
                            	    64:     ; Exemplo: parar o processador
                            	    65:     ; stop    #$2700
                            	    66: 
                            	    67:     ; Exemplo simples: loop infinito
04:00000524 60FE            	    68:     BRA     hardware_exit
04:00000526 4E75            	    69:     RTS
                            	    70: 
                            	    71: InitTrap1:
                            	    72:     ; -------------------------------------------------------------------------
                            	    73:     ; COMO INSTALAR NA RAM:
                            	    74:     ; Copiamos o endereço do nosso handler real para a posição $404 da RAM
                            	    75:     ; -------------------------------------------------------------------------
04:00000528 41FAFFAC        	    76:     LEA     vbug2_trap1,A0             ; Pega o endereço da nossa rotina na RAM
04:0000052C 23C800080004    	    77:     MOVE.L  A0,($00080004)              ; Grava na posição da TRAP 1 na RAM!
04:00000532 4E75            	    78:     RTS
                            	    79:     ; A partir deste momento, qualquer instrução "TRAP #1" vai cair aqui!
                            	    80: 

