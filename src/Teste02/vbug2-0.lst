                            	   480:         INCLUDE "drv_keyboard.asm"

Source: "drv_keyboard.asm"
                            	     1: 
                            	     2: ;Como interpretar o Byte 0 (Modificadores)
                            	     3: ;Como o Shift ou Ctrl não geram uma tecla normal, 
                            	     4: ;eles ligam bits específicos no primeiro byte:
                            	     5: ;
                            	     6: ;Bit 0: Control Esquerdo (Left Ctrl)
                            	     7: ;
                            	     8: ;Bit 1: Shift Esquerdo (Left Shift)
                            	     9: ;
                            	    10: ;Bit 2: Alt Esquerdo (Left Alt)
                            	    11: ;
                            	    12: ;Bit 3: GUI Esquerda (Tecla Windows/Command)
                            	    13: ;
                            	    14: ;Bit 4: Control Direito (Right Ctrl)
                            	    15: ;
                            	    16: ;Bit 5: Shift Direito (Right Shift)
                            	    17: ;
                            	    18: ;Se o usuário pressionar Shift + A, o Byte 0 será 
                            	    19: ;0x02 (bit 1 ligado) e o Byte 2 será 0x04 (código 
                            	    20: ;da letra A).
                            	    21: ;Exemplos de USB Scan Codes (Byte 2)
                            	    22: ;Diferente do PS/2 onde a tecla 'A' costuma ser 0x1C, 
                            	    23: ;no padrão USB HID os códigos começam do zero de 
                            	    24: ;forma mais sequencial:
                            	    25: ;0x00: Nenhuma tecla pressionada
                            	    26: ;0x04 a 0x1D: Letras A a Z (em ordem: A=0x04, B=0x05, C=0x06...)
                            	    27: ;0x1E a 0x27: Números 1 a 0 (1=0x1E, 2=0x1F... 9=0x26, 0=0x27)
                            	    28: ;0x28: Enter
                            	    29: ;0x29: ESC
                            	    30: ;0x2A: Backspace
                            	    31: ;0x2B: Tab
                            	    32: ;0x2C: Espaço
                            	    33: ;0x4F: Seta Direita
                            	    34: ;0x50: Seta Esquerda
                            	    35: 
                            	    36: ; =============================================================================
                            	    37: ; DRIVER DE LEITURA CH9350 PARA MOTOROLA 68000
                            	    38: ; Assembler: vasm68kmot (Sintaxe Motorola)
                            	    39: ; =============================================================================
                            	    40: 
                            	    41: ; --- Constantes do Protocolo CH9350 ---
                            	    42: CH_HEAD1    EQU     $57             ; Primeiro byte de sincronismo
                            	    43: CH_HEAD2    EQU     $AB             ; Segundo byte de sincronismo
                            	    44: 
                            	    45: ; -----------------------------------------------------------------------------
                            	    46: ; Rotina Principal de Captura de Pacote do CH9350
                            	    47: ; Retorno: 
                            	    48: ;   D0.B = Número de bytes úteis de dados lidos (0 se erro/timeout)
                            	    49: ;   A0   = Ponteiro para o buffer contendo os dados puros do relatório HID
                            	    50: ; -----------------------------------------------------------------------------
                            	    51: ReadPacketKbd:
02:000016CE 48E77040        	    52:             movem.l d1-d3/a1,-(sp)    ; Preserva registradores
                            	    53: 
                            	    54: .WaitHead1:
02:000016D2 6100FED4        	    55:             bsr     UartbReadChar     ; Aguarda e lê um byte
02:000016D6 B03C0057        	    56:             cmp.b   #CH_HEAD1,d0      ; É o primeiro byte do cabeçalho?
02:000016DA 66F6            	    57:             bne     .WaitHead1        ; Se não, continua procurando
                            	    58: 
                            	    59: .CheckHead2:
02:000016DC 6100FECA        	    60:             bsr     UartbReadChar     ; Lê o próximo byte
02:000016E0 B03C00AB        	    61:             cmp.b   #CH_HEAD2,d0      ; É o segundo byte de sincronismo?
02:000016E4 66EC            	    62:             bne     .WaitHead1        ; Se falhar, reinicia a busca do cabeçalho
                            	    63: 
                            	    64:             ; Cabeçalho alinhado! Passando para os bytes de controle
02:000016E6 6100FEC0        	    65:             bsr     UartbReadChar     ; Lê Byte 2 (Address/Type)
                            	    66:             
02:000016EA 6100FEBC        	    67:             bsr     UartbReadChar     ; Lê Byte 3 (Command)
02:000016EE 1400            	    68:             move.b  d0,d2             ; Guarda o comando em D2 para validação posterior
                            	    69: 
02:000016F0 6100FEB6        	    70:             bsr     UartbReadChar     ; Lê Byte 4 (Length - Tamanho dos dados)
02:000016F4 1200            	    71:             move.b  d0,d1             ; D1 = Contador de bytes do payload HID
02:000016F6 1600            	    72:             move.b  d0,d3             ; Salva tamanho original para retorno em D0
02:000016F8 6710            	    73:             beq     .PacketDone       ; Se tamanho for 0, encerra
                            	    74: 
                            	    75:             ; Prepara ponteiro para receber os dados úteis
02:000016FA 43F900080A2A    	    76:             lea     chPayloadBuffer,a1
                            	    77: 
                            	    78: .ReadPayload:
02:00001700 6100FEA6        	    79:             bsr     UartbReadChar     ; Lê byte de dados do teclado/mouse
02:00001704 12C0            	    80:             move.b  d0,(a1)+          ; Salva no buffer
02:00001706 51C9FFF8        	    81:             dbra    d1,.ReadPayload   ; Decrementa e repete até ler todo o pacote
                            	    82: 
                            	    83: .PacketDone:
02:0000170A 1003            	    84:             move.b  d3,d0             ; Retorna quantidade de bytes lidos em D0
02:0000170C 41F900080A2A    	    85:             lea     chPayloadBuffer,a0 ; Retorna o endereço do buffer em A0
                            	    86:             
02:00001712 4CDF020E        	    87:             movem.l (sp)+,d1-d3/a1    ; Restaura registradores
02:00001716 4E75            	    88:             rts
                            	    89: 
                            	    90: ; -----------------------------------------------------------------------------
                            	    91: ; Rotina: DecodeToAscii
                            	    92: ; Entrada:
                            	    93: ;   D0.B = Scan Code puro do USB HID (obtido do Byte 2 do pacote)
                            	    94: ;   D1.B = Byte de Modificadores (obtido do Byte 0 do pacote)
                            	    95: ; Saída:
                            	    96: ;   D0.B = Caractere ASCII correspondente, ou $00 se não for mapeável/solto
                            	    97: ; -----------------------------------------------------------------------------
                            	    98: DecodeToAscii:
02:00001718 2F08            	    99:             move.l  a0,-(sp)          ; Preserva A0
                            	   100: 
                            	   101:             ; 1. Verifica se há tecla pressionada
02:0000171A 4A00            	   102:             tst.b   d0                ; Código $00 significa nenhuma tecla
02:0000171C 6752            	   103:             beq     .NoChar
                            	   104: 
                            	   105:             ; 2. Verifica se o código está dentro do limite da tabela principal
02:0000171E B03C0004        	   106:             cmp.b   #SCAN_START,d0
02:00001722 6532            	   107:             blo     .CheckSpecial     ; Menor que $04? Pode ser tecla especial fora da tabela
02:00001724 B03C0038        	   108:             cmp.b   #SCAN_END,d0
02:00001728 622C            	   109:             bhi     .CheckSpecial     ; Maior que $38? Trata separadamente
                            	   110: 
                            	   111:             ; 3. Calcula o deslocamento (Índice = ScanCode - SCAN_START)
02:0000172A 5900            	   112:             sub.b   #SCAN_START,d0
02:0000172C C0BC000000FF    	   113:             and.l   #$000000FF,d0     ; Garante extensão limpa para Word/Long
                            	   114: 
                            	   115:             ; 4. Determina qual tabela usar baseado no Shift (Bits 1 e 5 do Modificador)
02:00001732 08010001        	   116:             btst    #1,d1             ; Verifica Left Shift
02:00001736 6612            	   117:             bne     .UseShiftTable
02:00001738 08010005        	   118:             btst    #5,d1             ; Verifica Right Shift
02:0000173C 660C            	   119:             bne     .UseShiftTable
                            	   120: 
                            	   121: .UseNormalTable:
02:0000173E 41F900000000    	   122:             lea     ASCII_Table_Normal,a0
02:00001744 10300800        	   123:             move.b  (a0,d0.l),d0      ; Carrega o caractere correspondente
02:00001748 6028            	   124:             bra     .Done
                            	   125: 
                            	   126: .UseShiftTable:
02:0000174A 41F900000038    	   127:             lea     ASCII_Table_Shift,a0
02:00001750 10300800        	   128:             move.b  (a0,d0.l),d0      ; Carrega o caractere com Shift aplicado
02:00001754 601C            	   129:             bra     .Done
                            	   130: ; -----------------------------------------------------------------------------
                            	   131: ; Tratamento de Teclas fora da faixa contínua alfabética/numérica
                            	   132: ; -----------------------------------------------------------------------------
                            	   133: .CheckSpecial:
                            	   134:             ; O Keypad numérico e teclas como CapsLock e F1-F12 ficam aqui.
                            	   135:             ; Exemplo rápido: Mapear teclas do teclado numérico comum ou setas
02:00001756 B03C004F        	   136:             cmp.b   #$4F,d0           ; Scan code $4F = Seta Direita
02:0000175A 6708            	   137:             beq     .IsArrowRight
02:0000175C B03C0050        	   138:             cmp.b   #$50,d0           ; Scan code $50 = Seta Esquerda
02:00001760 6708            	   139:             beq     .IsArrowLeft
                            	   140:             
                            	   141:             ; Se não mapeado, retorna nulo
02:00001762 600C            	   142:             bra     .NoChar
                            	   143: 
                            	   144: .IsArrowRight:
02:00001764 103C0006        	   145:             move.b  #$06,d0           ; Retorna código ASCII de controle ACK ou customizado
02:00001768 6008            	   146:             bra     .Done
                            	   147: .IsArrowLeft:
02:0000176A 103C0015        	   148:             move.b  #$15,d0           ; Retorna código customizado
02:0000176E 6002            	   149:             bra     .Done
                            	   150: 
                            	   151: .NoChar:
02:00001770 7000            	   152:             moveq   #0,d0             ; Retorna $00 se não for uma tecla válida de texto
                            	   153: .Done:
02:00001772 205F            	   154:             move.l  (sp)+,a0          ; Restaura A0
02:00001774 4E75            	   155:             rts
                            	   156: 
                            	   157: ; -----------------------------------------------------------------------------
                            	   158: ; Rotina: DumpPayloadHex
                            	   159: ; Objetivo: Lê sequencialmente os 16 bytes de CH_PayloadBuffer e os imprime
                            	   160: ;           em formato hexadecimal usando a rotina externa PicoPrintByteHex.
                            	   161: ; Passagem: PicoPrintByteHex espera o dado bruto no byte menos significativo de D0.
                            	   162: ; -----------------------------------------------------------------------------
                            	   163: DumpPayloadHex:
02:00001776 48E7C080        	   164:             movem.l d0-d1/a0,-(sp)    ; Preserva registradores que serão usados
                            	   165: 
02:0000177A 41F900080A2A    	   166:             lea     chPayloadBuffer,a0 ; Aponta A0 para o início do buffer de 16 bytes
02:00001780 720F            	   167:             moveq   #16-1,d1          ; D1 = 15 (Contador para a instrução dbra, que para em -1)
                            	   168: 
                            	   169: .LoopDump:
02:00001782 7000            	   170:             moveq   #0,d0             ; Limpa D0 por segurança
02:00001784 1018            	   171:             move.b  (a0)+,d0          ; Copia o byte atual para D0 e avança o ponteiro A0
                            	   172: 
                            	   173:             ; -----------------------------------------------------------------
                            	   174:             ; Aqui chamamos a sua rotina externa. 
                            	   175:             ; Ela deve ler o byte de D0 e jogá-lo para a tela/serial.
                            	   176:             ; -----------------------------------------------------------------
02:00001786 6100FF2A        	   177:             bsr     PicoPrintByteHex  
                            	   178: 
02:0000178A 51C9FFF6        	   179:             dbra    d1,.LoopDump      ; Decrementa D1. Se não for -1, pula para .LoopDump
                            	   180: 
02:0000178E 4CDF0103        	   181:             movem.l (sp)+,d0-d1/a0    ; Restaura os registradores originais
02:00001792 4EB8143A        	   182:             JSR     UartReadChar
02:00001796 4E75            	   183:             rts            

