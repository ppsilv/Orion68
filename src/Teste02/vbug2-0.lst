02:000018AE 4D45524441204D45	     3:     DC.B    "MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA MERDA ",13,10,0
02:000018B6 524441204D455244
02:000018BE 41204D4552444120
02:000018C6 4D45524441204D45
02:000018CE 524441204D455244
02:000018D6 41204D4552444120
02:000018DE 4D45524441204D45
02:000018E6 524441204D455244
02:000018EE 41204D4552444120
02:000018F6 4D45524441204D45
