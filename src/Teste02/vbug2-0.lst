                            	     2: ; PrintHexAddress - Imprime endereço de 32 bits
                            	     3: ; Entrada: D0 = endereço
                            	     4: ; ----------------------------------------------------------------------
                            	     5: PrintHexAddress:
02:00001790 4840            	     6:         SWAP    D0                ; Imprime parte alta primeiro
02:00001792 4EB81798        	     7:         JSR     PrintWordHex
02:00001796 4840            	     8:         SWAP    D0                ; Parte baixa
                            	     9:         ; Continua para PrintWordHex
                            	    10: 
                            	    11: ; ----------------------------------------------------------------------
                            	    12: ; PrintWordHex - Imprime word em hex (16 bits)
                            	    13: ; Entrada: D0.w = valor
                            	    14: ; ----------------------------------------------------------------------
                            	    15: PrintWordHex:
02:00001798 E158            	    16:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:0000179A 4EB817A0        	    17:         JSR     PrintByteHex
02:0000179E E058            	    18:         ROR.W   #8,D0             ; Byte menos significativo
                            	    19:         ; Continua para PrintByteHex
                            	    20: 
                            	    21: ; ----------------------------------------------------------------------
                            	    22: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	    23: ; Entrada: D0.b = valor
                            	    24: ; ----------------------------------------------------------------------
                            	    25: PrintByteHex:
02:000017A0 1F00            	    26:         MOVE.B  D0,-(SP)          ; Salva byte original
02:000017A2 E808            	    27:         LSR.B   #4,D0             ; Nibble alto
02:000017A4 6106            	    28:         BSR     PrintNibble
02:000017A6 101F            	    29:         MOVE.B  (SP)+,D0          ; Recupera byte
02:000017A8 0200000F        	    30:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	    31:         ; Continua para PrintNibble
                            	    32: ; ----------------------------------------------------------------------
                            	    33: ; PrintNibble - Imprime um nibble em hex
                            	    34: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	    35: ; ----------------------------------------------------------------------
                            	    36: PrintNibble:
02:000017AC B03C0009        	    37:         CMP.B   #9,D0
02:000017B0 6302            	    38:         BLS     .Decimal
02:000017B2 5E00            	    39:         ADD.B   #7,D0             ; Ajuste para A-F
                            	    40: .Decimal:
02:000017B4 D03C0030        	    41:         ADD.B   #'0',D0
02:000017B8 4EF813FE        	    42:         JMP     UartWriteChar    ; Usa JMP para tail call optimization
                            	    43: 

