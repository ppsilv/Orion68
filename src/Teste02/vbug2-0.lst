                            	   483:         INCLUDE "rot_print_hex_num.asm"

Source: "rot_print_hex_num.asm"
                            	     1: ; ----------------------------------------------------------------------
                            	     2: ; PrintHexAddress - Imprime endereço de 32 bits
                            	     3: ; Entrada: D0 = endereço
                            	     4: ; ----------------------------------------------------------------------
                            	     5: PrintHexAddress:
02:00001974 4840            	     6:         SWAP    D0                ; Imprime parte alta primeiro
02:00001976 4EB8197C        	     7:         JSR     PrintWordHex
02:0000197A 4840            	     8:         SWAP    D0                ; Parte baixa
                            	     9:         ; Continua para PrintWordHex
                            	    10: 
                            	    11: ; ----------------------------------------------------------------------
                            	    12: ; PrintWordHex - Imprime word em hex (16 bits)
                            	    13: ; Entrada: D0.w = valor
                            	    14: ; ----------------------------------------------------------------------
                            	    15: PrintWordHex:
02:0000197C E158            	    16:         ROL.W   #8,D0             ; Byte mais significativo primeiro
02:0000197E 4EB81984        	    17:         JSR     PrintByteHex
02:00001982 E058            	    18:         ROR.W   #8,D0             ; Byte menos significativo
                            	    19:         ; Continua para PrintByteHex
                            	    20: 
                            	    21: ; ----------------------------------------------------------------------
                            	    22: ; PrintByteHex - Imprime byte em hex (8 bits)
                            	    23: ; Entrada: D0.b = valor
                            	    24: ; ----------------------------------------------------------------------
                            	    25: PrintByteHex:
02:00001984 1F00            	    26:         MOVE.B  D0,-(SP)          ; Salva byte original
02:00001986 E808            	    27:         LSR.B   #4,D0             ; Nibble alto
02:00001988 6106            	    28:         BSR     PrintNibble
02:0000198A 101F            	    29:         MOVE.B  (SP)+,D0          ; Recupera byte
02:0000198C 0200000F        	    30:         ANDI.B  #$0F,D0           ; Nibble baixo
                            	    31:         ; Continua para PrintNibble
                            	    32: ; ----------------------------------------------------------------------
                            	    33: ; PrintNibble - Imprime um nibble em hex
                            	    34: ; Entrada: D0.b bits 3-0 = nibble (0-15)
                            	    35: ; ----------------------------------------------------------------------
                            	    36: PrintNibble:
02:00001990 B03C0009        	    37:         CMP.B   #9,D0
02:00001994 6302            	    38:         BLS     .Decimal
02:00001996 5E00            	    39:         ADD.B   #7,D0             ; Ajuste para A-F
                            	    40: .Decimal:
02:00001998 D03C0030        	    41:         ADD.B   #'0',D0
02:0000199C 4EF81422        	    42:         JMP     UartWriteChar    ; Usa JMP para tail call optimization
                            	    43: 

