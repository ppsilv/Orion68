02:00001440 2F00            	   135:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   136: .WriteLoop:
02:00001442 1018            	   137:         MOVE.B  (A0)+,D0      ; Pega caractere
02:00001444 6706            	   138:         BEQ     .Done
02:00001446 4EB813EA        	   139:         JSR     UartWriteChar ; Use sua rotine existente
02:0000144A 60F6            	   140:         BRA     .WriteLoop
                            	   141: .Done:
02:0000144C 201F            	   142:         MOVE.L  (SP)+,D0
02:0000144E 205F            	   143:         MOVE.L  (SP)+,A0
02:00001450 4E75            	   144:         RTS
