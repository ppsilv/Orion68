                            	     4: .DentroDaFaixa:
                            	     5:         ; Se o código chegar aqui, significa que:
                            	     6:         ; $80000 <= A0 <= $FFFFF (O endereço é válido!)
                            	     7:         ; ... seu código para endereço válido aqui ...
                            	     8:         BRA     .Fim
                            	     9: 
                            	    10: .OutOfRange:
                            	    11:         ; Se desviou para cá, o endereço é inválido (Menor que $80000 OU Maior que $FFFFF)
                            	    12:         ; ... seu tratamento de erro aqui ...
                            	    13: 
                            	    14: 
                            	    15: 
                            	    16: .Fim:
02:000015A0 4E75            	    17:         RTS
                            	    18: 
                            	    19: 
                            	    20: ; ----------------------------------------------------------------------
                            	    21: ; MemDump - Imprime dump de memória formatado
                            	    22: ; Entrada:
                            	    23: ;   A0 = Endereço inicial (ex: $80000)
                            	    24: ;   D0 = Quantidade de bytes (ex: 256)
                            	    25: ; ----------------------------------------------------------------------
                            	    26: MemDump:
02:000015A2 41F900000000    	    27:         LEA     MsgDumpHeader,A0
02:000015A8 4EB811D2        	    28:         JSR     WriteString
02:000015AC 207900080424    	    29:         MOVE.L  (addressInHex),A0
02:000015B2 B1FC000FFFFF    	    30:         CMPA.L  #$FFFFF,A0        ; Compara A0 com o limite superior
02:000015B8 620000EE        	    31:         BHI     OutOfRange       ; BHI (Branch if Higher): Desvia se A0 > $FFFFF
                            	    32: 
02:000015BC 2008            	    33:         MOVE.L  A0,D0
02:000015BE 4EB81574        	    34:         JSR     PicoPrintHexAddress
02:000015C2 4EB811EA        	    35:         JSR     NewLine
                            	    36: 
02:000015C6 41F900000016    	    37:         LEA     MsgDumpHeader1,A0
02:000015CC 4EB811D2        	    38:         JSR     WriteString
                            	    39: 
02:000015D0 207900080424    	    40:         MOVE.L  (addressInHex),A0
                            	    41:         ; Calcula endereço final
                            	    42: DumpLoopMaster:
02:000015D6 303C0000        	    43:         MOVE.W  #$0000,D0
02:000015DA 323C0008        	    44:         MOVE.W  #$0008,D1
02:000015DE 4EB814E4        	    45:         JSR     PicoSetCursor
02:000015E2 7600            	    46:         CLR.L   D3
02:000015E4 2608            	    47:         MOVE.L  A0,D3
02:000015E6 0683000000FF    	    48:         ADDI.L  #$000000FF,D3             ; D3 = endereço final    
                            	    49: DumpLoop:
                            	    50:         ; Nova linha a cada 16 bytes
02:000015EC 2008            	    51:         MOVE.L  A0,D0
02:000015EE 02800000000F    	    52:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
02:000015F4 6616            	    53:         BNE     NoNewLine
                            	    54: 
                            	    55:         ; Imprime endereço
02:000015F6 2008            	    56:         MOVE.L  A0,D0
02:000015F8 4EB81574        	    57:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    58: 
02:000015FC 103C003A        	    59:         MOVE.B  #':',D0
02:00001600 4EB811C2        	    60:         JSR     WriteChar
02:00001604 103C0020        	    61:         MOVE.B  #' ',D0
02:00001608 4EB811C2        	    62:         JSR     WriteChar
                            	    63: 
                            	    64: NoNewLine:
                            	    65:         ; Imprime byte em hex
02:0000160C 1018            	    66:         MOVE.B  (A0)+,D0
02:0000160E 4EB81584        	    67:         JSR     PicoPrintByteHex
                            	    68: 
02:00001612 103C0020        	    69:         MOVE.B  #' ',D0
02:00001616 4EB811C2        	    70:         JSR     WriteChar
                            	    71: 
                            	    72:         ; Verifica fim da linha (16 bytes)
02:0000161A 2008            	    73:         MOVE.L  A0,D0
02:0000161C 02800000000F    	    74:         ANDI.L  #$0000000F,D0
02:00001622 66E8            	    75:         BNE     NoNewLine
                            	    76: 
                            	    77:         ; Imprime caracteres ASCII
02:00001624 103C0020        	    78:         MOVE.B  #' ',D0
02:00001628 4EB811C2        	    79:         JSR     WriteChar
02:0000162C 103C007C        	    80:         MOVE.B  #'|',D0
02:00001630 4EB811C2        	    81:         JSR     WriteChar
                            	    82: 
02:00001634 43E8FFF0        	    83:         LEA     -16(A0),A1        ; Volta ao início da linha
02:00001638 740F            	    84:         MOVEQ   #15,D2            ; 16 caracteres
                            	    85: 
                            	    86: AsciiLoop:
02:0000163A 1019            	    87:         MOVE.B  (A1)+,D0
02:0000163C B03C0020        	    88:         CMP.B   #$20,D0            ; Verifica se é imprimível
02:00001640 650C            	    89:         BLO     NonPrintable
02:00001642 B03C007E        	    90:         CMP.B   #$7E,D0
02:00001646 6206            	    91:         BHI     NonPrintable
                            	    92: 
02:00001648 4EB811C2        	    93:         JSR     WriteChar
02:0000164C 6008            	    94:         BRA     NextAscii
                            	    95: 
                            	    96: NonPrintable:
02:0000164E 103C002E        	    97:         MOVE.B  #'.',D0           ; Substitui não imprimíveis
02:00001652 4EB811C2        	    98:         JSR     WriteChar
                            	    99: 
                            	   100: NextAscii:
02:00001656 51CAFFE2        	   101:         DBRA    D2,AsciiLoop
                            	   102: 
02:0000165A 103C007C        	   103:         MOVE.B  #'|',D0
02:0000165E 4EB811C2        	   104:         JSR     WriteChar
02:00001662 103C000D        	   105:         MOVE.B  #13,D0            ; CR
02:00001666 4EB811C2        	   106:         JSR     WriteChar
02:0000166A 103C000A        	   107:         MOVE.B  #10,D0            ; LF
02:0000166E 4EB811C2        	   108:         JSR     WriteChar
                            	   109: 
                            	   110: NoEndLine:
                            	   111:         ; Verifica fim do dump
02:00001672 B1C3            	   112:         CMP.L   D3,A0
02:00001674 6300FF76        	   113:         BLS     DumpLoop
                            	   114: 
02:00001678 2F08            	   115:         MOVE.L  A0,-(SP)          ; Salva endereço atual
02:0000167A 41F90000035B    	   116:         LEA     MsgHitAnyKey,A0
02:00001680 4EB811D2        	   117:         JSR     WriteString
02:00001684 4EB81402        	   118:         JSR     UartReadChar
02:00001688 B03C001B        	   119:         CMP.B   #$1B,D0
02:0000168C 6716            	   120:         BEQ     .fim
                            	   121: 
02:0000168E 103C000D        	   122:         MOVE.B  #13,D0            ; CR
02:00001692 4EB811C2        	   123:         JSR     WriteChar
02:00001696 103C000A        	   124:         MOVE.B  #10,D0            ; LF
02:0000169A 4EB811C2        	   125:         JSR     WriteChar
                            	   126: 
02:0000169E 205F            	   127:         MOVE.L  (SP)+,A0          ; Recupera endereço atual
02:000016A0 6000FF34        	   128:         BRA     DumpLoopMaster
                            	   129: .fim
02:000016A4 4EF8129A        	   130:         JMP     subLoop
