                            	   128: ; ----------------------------------------------------------------------
                            	   129: ; UART_WriteString - Envia string terminada em null para UART
                            	   130: ; Entrada:
                            	   131: ;   A0 = Ponteiro para a string (endereço da string)
                            	   132: ; ----------------------------------------------------------------------
                            	   133: UartWriteString:
