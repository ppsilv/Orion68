                            	   147: UartReadHex:
02:00001452 2F01            	   148:         MOVE.L  D1,-(SP)
02:00001454 2F02            	   149:         MOVE.L  D2,-(SP)
                            	   150: 
02:00001456 7000            	   151:         MOVEQ   #0,D0
02:00001458 721C            	   152:         MOVEQ   #28,D1            ; Máximo 8 dígitos
02:0000145A 7400            	   153:         MOVEQ   #0,D2            ; Resultado em D2
                            	   154: .Loop:
02:0000145C 7000            	   155:         CLR.L   D0
02:0000145E 4EB81402        	   156:         JSR     UartReadChar
02:00001462 B03C000D        	   157:         CMP.B   #13,D0
02:00001466 674C            	   158:         BEQ     .Done
02:00001468 B03C000A        	   159:         CMP.B   #10,D0
02:0000146C 6746            	   160:         BEQ     .Done
                            	   161:         ;Tratando os numeros
02:0000146E B03C0030        	   162:         CMP.B   #'0',D0
02:00001472 6C02            	   163:         BGE     .maiorQueZero
02:00001474 60E6            	   164:         BRA     .Loop
                            	   165: .maiorQueZero:
02:00001476 B03C0039        	   166:         CMP.B   #'9',D0
02:0000147A 6F10            	   167:         BLE     .isdigit
                            	   168:         ;Tratando as letras
02:0000147C B03C0041        	   169:         CMP.B   #'A',D0
