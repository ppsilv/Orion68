02:00001454 2F00            	   135:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	   136: .WriteLoop:
02:00001456 1018            	   137:         MOVE.B  (A0)+,D0      ; Pega caractere
02:00001458 6706            	   138:         BEQ     .Done
02:0000145A 4EB813FE        	   139:         JSR     UartWriteChar ; Use sua rotine existente
02:0000145E 60F6            	   140:         BRA     .WriteLoop
                            	   141: .Done:
02:00001460 201F            	   142:         MOVE.L  (SP)+,D0
02:00001462 205F            	   143:         MOVE.L  (SP)+,A0
02:00001464 4E75            	   144:         RTS
