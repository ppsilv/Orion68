                            	    80: ; ----------------------------------------------------------------------
                            	    81: ; UART_WriteString - Envia string terminada em null para UART
                            	    82: ; Entrada:
                            	    83: ;   A0 = Ponteiro para a string (endereço da string)
                            	    84: ; ----------------------------------------------------------------------
                            	    85: UartWriteString:
02:00001476 2F08            	    86:         MOVE.L  A0,-(SP)      ; Preserva D0
02:00001478 2F00            	    87:         MOVE.L  D0,-(SP)      ; Preserva D0
                            	    88: .WriteLoop:
02:0000147A 1018            	    89:         MOVE.B  (A0)+,D0      ; Pega caractere
02:0000147C 6706            	    90:         BEQ     .Done
02:0000147E 4EB81422        	    91:         JSR     UartWriteChar ; Use sua rotine existente
02:00001482 60F6            	    92:         BRA     .WriteLoop
                            	    93: .Done:
02:00001484 201F            	    94:         MOVE.L  (SP)+,D0
02:00001486 205F            	    95:         MOVE.L  (SP)+,A0
02:00001488 4E75            	    96:         RTS
                            	    97: 
                            	    98: ; Lê número hexadecimal (retorna em D0)
                            	    99: UartReadHex:
02:0000148A 2F01            	   100:         MOVE.L  D1,-(SP)
02:0000148C 2F02            	   101:         MOVE.L  D2,-(SP)
                            	   102: 
02:0000148E 7000            	   103:         MOVEQ   #0,D0
02:00001490 721C            	   104:         MOVEQ   #28,D1            ; Máximo 8 dígitos
02:00001492 7400            	   105:         MOVEQ   #0,D2            ; Resultado em D2
                            	   106: .Loop:
02:00001494 7000            	   107:         CLR.L   D0
02:00001496 4EB8143A        	   108:         JSR     UartReadChar
02:0000149A B03C000D        	   109:         CMP.B   #13,D0
02:0000149E 674C            	   110:         BEQ     .Done
02:000014A0 B03C000A        	   111:         CMP.B   #10,D0
02:000014A4 6746            	   112:         BEQ     .Done
                            	   113:         ;Tratando os numeros
02:000014A6 B03C0030        	   114:         CMP.B   #'0',D0
02:000014AA 6C02            	   115:         BGE     .maiorQueZero
02:000014AC 60E6            	   116:         BRA     .Loop
                            	   117: .maiorQueZero:
02:000014AE B03C0039        	   118:         CMP.B   #'9',D0
02:000014B2 6F10            	   119:         BLE     .isdigit
                            	   120:         ;Tratando as letras
02:000014B4 B03C0041        	   121:         CMP.B   #'A',D0
02:000014B8 6C02            	   122:         BGE     .maiorQueA
02:000014BA 60D8            	   123:         BRA     .Loop
                            	   124: .maiorQueA:
02:000014BC B03C0046        	   125:         CMP.B   #'F',D0
02:000014C0 6F16            	   126:         BLE     .isletter
02:000014C2 60D0            	   127:         BRA     .Loop
                            	   128: .isdigit:
02:000014C4 903C0030        	   129:         SUB.B   #'0',D0
02:000014C8 E3A8            	   130:         LSL.L   D1,D0
02:000014CA 5901            	   131:         SUB.B   #4,D1
02:000014CC 8480            	   132:         OR.L    D0,D2
02:000014CE 41F900080424    	   133:         LEA     addressInHex,A0
02:000014D4 2082            	   134:         MOVE.L  D2,(A0)
02:000014D6 60BC            	   135:         BRA     .Loop
                            	   136: .isletter:
02:000014D8 903C0037        	   137:         SUB.B   #$37,D0
02:000014DC E3A8            	   138:         LSL.L   D1,D0
02:000014DE 5901            	   139:         SUB.B   #4,D1
02:000014E0 8480            	   140:         OR.L    D0,D2
02:000014E2 41F900080424    	   141:         LEA     addressInHex,A0
02:000014E8 2082            	   142:         MOVE.L  D2,(A0)
02:000014EA 60A8            	   143:         BRA     .Loop
                            	   144: .Done:
02:000014EC 4EB811EC        	   145:         JSR     NewLine
02:000014F0 41F900080424    	   146:         LEA     addressInHex,A0
02:000014F6 2010            	   147:         MOVE.L  (A0),D0
02:000014F8 4EB81974        	   148:         JSR     PrintHexAddress
02:000014FC 4EB811EC        	   149:         JSR     NewLine
02:00001500 241F            	   150:         MOVE.L  (SP)+,D2
02:00001502 221F            	   151:         MOVE.L  (SP)+,D1
02:00001504 4E75            	   152:         RTS
