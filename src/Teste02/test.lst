01:00000016 223C000001FF    	    23:         MOVE.L  #$1FF,D1    ; Contador para o delay (ajuste se precisar de mais)
                            	    24: .DELAY00:
01:0000001C 5381            	    25:         SUBQ.L  #1,D1       ; Subtrai 1 de D1 (4 ciclos)
01:0000001E 66FC            	    26:         BNE.S   .DELAY00    ; Pula se não for zero (10 ciclos se pular, 8 se não)
