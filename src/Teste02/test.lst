                            	     5: 
                            	     6:             ORG     $00000400
                            	     7: ; Exemplo rápido de teste de RAM (Base em $00004000)
                            	     8: RAM_START      equ $080000
                            	     9: RAM_END        equ $0FFFFF 
                            	    10: 
