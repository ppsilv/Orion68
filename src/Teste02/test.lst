                            	     5: ;Uart register offsets
                            	     6: UART_BASE   equ     $FF4000
                            	     7: RHR         equ     $FF4001   ; receive holding register (read)
                            	     8: THR         equ     $FF4001   ; transmit holding register (write)
                            	     9: IER         equ     $FF4003   ; interrupt enable register
                            	    10: ISR         equ     $FF4005   ; interrupt status register (read)
                            	    11: FCR         equ     $FF4005   ; FIFO control register (write)
                            	    12: LCR         equ     $FF4007   ; line control register
                            	    13: MCR         equ     $FF4009   ; modem control register
                            	    14: LSR         equ     $FF400B   ; line status register
                            	    15: MSR         equ     $FF400D   ; modem status register
                            	    16: SPR         equ     $FF400F   ; scratchpad register (reserved for system use)
                            	    17: DLL         equ     $FF4001   ; divisor latch LSB
                            	    18: DLM         equ     $FF4003   ; divisor latch MSB
                            	    19: ; aliases for register names (used by different manufacturers)cd ..
                            	    20: RBR         equ     RHR ; receive buffer register
                            	    21: IIR         equ     ISR ; interrupt identification register
                            	    22: SCR         equ     SPR ; scratch register
                            	    23: 
                            	    24: B009600     equ         $0060
                            	    25: B019200     equ         $0030
                            	    26: B038400     equ         $0018
                            	    27: B057600     equ         $0010
                            	    28: B115200     equ         $0008
                            	    29: B230400     equ         $0004
                            	    30: B460800     equ         $0002
                            	    31: B921600     equ         $0001
                            	    32: 
                            	    33: 
                            	    34: B009600L    equ         $60
                            	    35: B019200L    equ         $30
                            	    36: B038400L    equ         $18
                            	    37: B057600L    equ         $10
                            	    38: B115200L    equ         $08
                            	    39: B230400L    equ         $04
                            	    40: B460800L    equ         $02
                            	    41: B921600L    equ         $01
                            	    42: B009600H    equ         $00
                            	    43: B019200H    equ         $00     
                            	    44: B038400H    equ         $00     
                            	    45: B057600H    equ         $00     
                            	    46: B115200H    equ         $00     
                            	    47: B230400H    equ         $00
                            	    48: B460800H    equ         $00
                            	    49: B921600H    equ         $00
                            	    50: 
                            	    51: 
                            	    52: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    53: ; Initialize uart
                            	    54: ; Change A1
                            	    55: ; Parametros: none
                            	    56: ; ----------------------------------------------------------------------
                            	    57: InitUart:
01:0000004E 43F900080010    	    58:         lea     currentUart,A1
01:00000054 203900080014    	    59:         move.l  currentBaudRate,D0
01:0000005A 13FC008300FF4007	    60:         move.b  #%10000011,LCR   ;(A1)    ;DLAB=1
01:00000062 4E71            	    61:         NOP
01:00000064 4E71            	    62:         NOP      
01:00000066 13FC000800FF4001	    63:         move.b  #$08,DLL     ;(A1)       ; set divisor latch low byte
01:0000006E 13FC000000FF4003	    64:         move.b  #$00,DLM     ;(A1)       ; set divisor latch high byte
01:00000076 13FC000300FF4007	    65:         move.b  #%00000011,LCR  ;(A1)      ; 8 data bits, no parity, 1 stop bit, DLAB=0
01:0000007E 13FC000D00FF4005	    66:         move.b  #%00001101,FCR ;(A1)     ; enable FIFO
01:00000086 423900FF400F    	    67:         clr.b   SCR    ;(A1)                 ; clear the scratch register
01:0000008C 4E75            	    68:         RTS
                            	    69: 
                            	    70: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    71: ; Write char
                            	    72: ; Change A1
                            	    73: ; Receive char in D0
                            	    74: UartWriteChar:
01:0000008E 43F900080010    	    75:         lea     currentUart,A1
                            	    76: .WaitTx:
01:00000094 0839000500FF400B	    77:         btst    #5,LSR  ;(A1)      ; wait until transmit holding register is empty
01:0000009C 67F6            	    78:         beq     .WaitTx
01:0000009E 13C000FF4001    	    79:         move.b  D0,THR  ;(A1)      ; transmit byte
01:000000A4 4E75            	    80:         RTS
                            	    81: 
                            	    82: ;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;
                            	    83: ; Write char
                            	    84: ; Change A1
                            	    85: ;
                            	    86: ; Return char in D0)
                            	    87: UartReadChar:
01:000000A6 43F900080010    	    88:         lea     currentUart,A1
                            	    89: .WaitRx:
01:000000AC 0839000000FF400B	    90:         btst    #0,LSR ;(A1)        ; RX ready?
01:000000B4 67F6            	    91:         beq     .WaitRx
01:000000B6 103900FF4001    	    92:         move.b  RHR,D0
01:000000BC 4E75            	    93:         RTS
                            	    94: 

