01:00000000 007C0700        	    14:         ori.w   #$0700,SR    ; Desabilita as interrupções (Nível 7)
01:00000004 4FF9000FFFF0    	    15:         LEA     $FFFF0,SP ; Garante o Stack Pointer (se o hardware não carregou)
                            	    16: 
01:0000000A 223C0003FFFF    	    17:         MOVE.L  #$003FFFF,D1 ; Contador para o delay (ajuste se precisar de mais)
