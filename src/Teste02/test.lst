Source: "cmd_mem_dump.asm"
                            	     1: 
                            	     2: 
                            	     3: 
                            	     4: 
                            	     5: ; ----------------------------------------------------------------------
                            	     6: ; MemDump - Imprime dump de memória formatado
                            	     7: ; Entrada:
                            	     8: ;   A0 = Endereço inicial (ex: $80000)
                            	     9: ;   D0 = Quantidade de bytes (ex: 256)
                            	    10: ; ----------------------------------------------------------------------
                            	    11: MEMDUMP:
01:00000150 41F900000000    	    12:         LEA     MsgDumpHeader,A0
01:00000156 6100FEF4        	    13:         JSR     WriteString
01:0000015A 207900080234    	    14:         MOVE.L  (addressInHex),A0
01:00000160 2008            	    15:         MOVE.L  A0,D0
01:00000162 61C6            	    16:         JSR     PicoPrintHexAddress
01:00000164 610000C2        	    17:         JSR     NewLine
                            	    18: 
01:00000168 41F900000013    	    19:         LEA     MsgDumpHeader1,A0
01:0000016E 6100FEDC        	    20:         JSR     WriteString
                            	    21: 
01:00000172 207900080234    	    22:         MOVE.L  (addressInHex),A0
                            	    23:         ; Calcula endereço final
                            	    24: 
                            	    25: DUMPLOOPMASTER:
01:00000178 7200            	    26:         CLR.L   D1
01:0000017A 2208            	    27:         MOVE.L  A0,D1
01:0000017C 0681000000FF    	    28:         ADDI.L  #$000000FF,D1             ; D1 = endereço final
                            	    29:         ;MOVE.L  D1,D0
                            	    30:         ;JSR     PicoPrintHexAddress
                            	    31:         ;JSR     new_line
                            	    32: 
                            	    33:         ;aguarda um caractere ser digitado mas nao usa é somente para parar a execução aqui
                            	    34:         ;JSR     ReadChar
                            	    35: 
                            	    36: 
                            	    37: DumpLoop:
                            	    38:         ; Nova linha a cada 16 bytes
01:00000182 2008            	    39:         MOVE.L  A0,D0
01:00000184 02800000000F    	    40:         ANDI.L  #$0000000F,D0     ; Verifica se é início de linha
01:0000018A 6614            	    41:         BNE     NoNewLine
                            	    42: 
                            	    43:         ; Imprime endereço
01:0000018C 2008            	    44:         MOVE.L  A0,D0
01:0000018E 619A            	    45:         JSR     PicoPrintHexAddress    ; Imprime 8 dígitos hex
                            	    46: 
01:00000190 103C003A        	    47:         MOVE.B  #':',D0
01:00000194 6100FEB2        	    48:         JSR     WriteChar
01:00000198 103C0020        	    49:         MOVE.B  #' ',D0
01:0000019C 6100FEAA        	    50:         JSR     WriteChar
                            	    51: 
                            	    52: NoNewLine:
                            	    53:         ; Imprime byte em hex
01:000001A0 1018            	    54:         MOVE.B  (A0)+,D0
01:000001A2 6192            	    55:         JSR     PicoPrintByteHex
                            	    56: 
01:000001A4 103C0020        	    57:         MOVE.B  #' ',D0
01:000001A8 6100FE9E        	    58:         JSR     WriteChar
                            	    59: 
                            	    60:         ; Verifica fim da linha (16 bytes)
01:000001AC 2008            	    61:         MOVE.L  A0,D0
01:000001AE 02800000000F    	    62:         ANDI.L  #$0000000F,D0
01:000001B4 664E            	    63:         BNE     NoEndLine
                            	    64: 
                            	    65:         ; Imprime caracteres ASCII
01:000001B6 103C0020        	    66:         MOVE.B  #' ',D0
01:000001BA 6100FE8C        	    67:         JSR     WriteChar
01:000001BE 103C007C        	    68:         MOVE.B  #'|',D0
01:000001C2 6100FE84        	    69:         JSR     WriteChar
                            	    70: 
01:000001C6 43E8FFF0        	    71:         LEA     -16(A0),A1        ; Volta ao início da linha
01:000001CA 740F            	    72:         MOVEQ   #15,D2            ; 16 caracteres
                            	    73: 
                            	    74: AsciiLoop:
